@model Medical_Affiliation.Models.ApplicationStatusReportVM
@{
    ViewData["Title"] = "Application Completion Report";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Application Completion Report</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        :root {
            --navy: #0c1f3f;
            --navy2: #1a3461;
            --gold: #c9903a;
            --gold2: #e8b45a;
            --cream: #f7f4ef;
            --white: #fff;
            --border: #e2ddd5;
            --green: #1a7a4a;
            --amber: #d97706;
            --red: #c0392b;
            --darkred: #8B0000;
            --text: #1a1a2e;
            --muted: #6b6880;
            --radius: 10px;
            --shadow: 0 4px 24px rgba(12,31,63,.10);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans',sans-serif;
            background: var(--cream);
            color: var(--text);
            min-height: 100vh;
        }

        .rpt-header {
            background: linear-gradient(135deg,var(--navy) 0%,var(--navy2) 100%);
            padding: 28px 40px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 3px solid var(--gold);
        }

        .rpt-header-left {
            display: flex;
            align-items: center;
            gap: 18px;
        }

        .rpt-header-icon {
            width: 52px;
            height: 52px;
            border: 2px solid var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .rpt-header-icon svg {
                width: 26px;
                height: 26px;
                fill: var(--gold);
            }

        .rpt-header h1 {
            font-family: 'Syne',sans-serif;
            font-size: 1.5rem;
            color: #fff;
            font-weight: 700;
        }

        .rpt-header p {
            font-size: .75rem;
            color: rgba(255,255,255,.5);
            margin-top: 3px;
            text-transform: uppercase;
            letter-spacing: .08em;
        }

        .rpt-body {
            max-width: 1400px;
            margin: 32px auto;
            padding: 0 28px 60px;
        }

        .summary-row {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 18px;
            margin-bottom: 32px;
        }

        .sum-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px 24px;
            box-shadow: var(--shadow);
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .sum-icon {
            width: 46px;
            height: 46px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
        }

            .sum-icon.total {
                background: #e8f0fe;
            }

            .sum-icon.done {
                background: #e6f4ee;
            }

            .sum-icon.prog {
                background: #fff7e6;
            }

            .sum-icon.none {
                background: #fde8e8;
            }

        .sum-val {
            font-family: 'Syne',sans-serif;
            font-size: 1.9rem;
            font-weight: 800;
            line-height: 1;
        }

        .sum-lbl {
            font-size: .75rem;
            color: var(--muted);
            margin-top: 3px;
            font-weight: 500;
        }

        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 32px;
        }

        .chart-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            box-shadow: var(--shadow);
        }

            .chart-card h3 {
                font-family: 'Syne',sans-serif;
                font-size: 1rem;
                font-weight: 700;
                margin-bottom: 18px;
                color: var(--navy);
                border-bottom: 2px solid var(--gold);
                padding-bottom: 8px;
                display: inline-block;
            }

        .chart-wrap {
            position: relative;
            height: 260px;
            display: flex;
            justify-content: center;
        }

        .filter-bar {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px 20px;
            margin-bottom: 24px;
            box-shadow: var(--shadow);
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .search-box {
            display: flex;
            gap: 8px;
            flex: 1;
            min-width: 300px;
        }

        .filter-bar input[type=text] {
            flex: 1;
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 8px 12px;
            font-size: .85rem;
            font-family: 'DM Sans',sans-serif;
            background: #fafaf8;
            color: var(--text);
        }

        .btn-search {
            background: var(--navy);
            color: white;
            border: none;
            border-radius: 7px;
            padding: 8px 16px;
            cursor: pointer;
            font-weight: 600;
            font-family: 'DM Sans',sans-serif;
        }

        .filter-btn {
            border: 1px solid var(--border);
            background: var(--white);
            color: var(--muted);
            border-radius: 7px;
            padding: 8px 16px;
            font-size: .8rem;
            font-weight: 600;
            cursor: pointer;
            font-family: 'DM Sans',sans-serif;
            transition: all .15s;
        }

            .filter-btn:hover, .filter-btn.active {
                background: var(--navy);
                color: #fff;
                border-color: var(--navy);
            }

            .filter-btn.done-btn.active {
                background: var(--green);
                border-color: var(--green);
            }

            .filter-btn.prog-btn.active {
                background: var(--amber);
                border-color: var(--amber);
            }

            .filter-btn.none-btn.active {
                background: var(--red);
                border-color: var(--red);
            }

        .export-group {
            display: flex;
            gap: 10px;
            margin-left: auto;
        }

        .btn-export {
            padding: 8px 14px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            border-radius: 7px;
            border: 1px solid var(--border);
            background: #fff;
            font-family: 'DM Sans', sans-serif;
            transition: all 0.2s;
        }

            .btn-export:hover {
                background: #f0f0f0;
            }

        .sort-select {
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 8px 12px;
            font-size: .8rem;
            font-family: 'DM Sans',sans-serif;
            background: #fafaf8;
            color: var(--text);
        }

        .college-table-wrap {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

            .college-table-wrap h3 {
                font-family: 'Syne',sans-serif;
                font-size: 1rem;
                font-weight: 700;
                padding: 18px 22px 14px;
                color: var(--navy);
                border-bottom: 1px solid var(--border);
            }

        table.ct {
            width: 100%;
            border-collapse: collapse;
        }

            table.ct thead th {
                background: linear-gradient(180deg,#f5f2ec,#ede8df);
                padding: 11px 14px;
                font-size: .68rem;
                font-weight: 700;
                letter-spacing: .1em;
                text-transform: uppercase;
                color: var(--navy);
                border-bottom: 2px solid var(--border);
                text-align: left;
                white-space: nowrap;
            }

            table.ct tbody tr {
                border-bottom: 1px solid #f0ede6;
                transition: background .12s;
            }

                table.ct tbody tr:hover {
                    background: #f8f5ee;
                }

            table.ct td {
                padding: 13px 14px;
                vertical-align: middle;
                font-size: .85rem;
            }

        .ct-name {
            font-weight: 600;
            color: var(--navy);
        }

        .ct-code {
            font-size: .72rem;
            color: var(--muted);
        }

        .prog-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .prog-track {
            flex: 1;
            height: 8px;
            background: #ede8df;
            border-radius: 99px;
            overflow: hidden;
            min-width: 80px;
        }

        .prog-fill {
            height: 100%;
            border-radius: 99px;
            transition: width .3s;
        }

            .prog-fill.done {
                background: linear-gradient(90deg,#1a7a4a,#27ae60);
            }

            .prog-fill.high {
                background: linear-gradient(90deg,#1a7a4a,#27ae60);
            }

            .prog-fill.mid {
                background: linear-gradient(90deg,#d97706,#f59e0b);
            }

            .prog-fill.low {
                background: linear-gradient(90deg,#c0392b,#e74c3c);
            }

        .prog-txt {
            font-size: .78rem;
            font-weight: 700;
            min-width: 36px;
            text-align: right;
        }

        .lvl-badge {
            display: inline-block;
            background: rgba(12,31,63,.08);
            border: 1px solid rgba(12,31,63,.15);
            border-radius: 4px;
            padding: 2px 7px;
            font-size: .62rem;
            font-weight: 700;
            color: var(--navy);
            margin-right: 3px;
            letter-spacing: .06em;
        }

        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 99px;
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .04em;
        }

            .status-badge.done {
                background: #e6f4ee;
                color: var(--green);
            }

            .status-badge.prog {
                background: #fff7e6;
                color: var(--amber);
            }

            .status-badge.none {
                background: #fde8e8;
                color: var(--red);
            }

        .detail-btn {
            border: 1px solid var(--border);
            background: transparent;
            border-radius: 6px;
            padding: 5px 12px;
            font-size: .72rem;
            font-weight: 600;
            cursor: pointer;
            color: var(--navy2);
            font-family: 'DM Sans',sans-serif;
            transition: all .15s;
        }

            .detail-btn:hover {
                background: var(--navy);
                color: #fff;
                border-color: var(--navy);
            }

        .detail-row td {
            padding: 0 !important;
            background: #fafaf9;
        }

        .detail-panel {
            display: none;
            padding: 18px 24px 18px 48px;
        }

            .detail-panel.open {
                display: block;
            }

        .step-group-title {
            font-size: .65rem;
            font-weight: 700;
            letter-spacing: .14em;
            text-transform: uppercase;
            color: var(--muted);
            margin: 14px 0 6px;
        }

        .step-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .step-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 6px;
            padding: 5px 11px;
            font-size: .72rem;
            font-weight: 500;
        }

            .step-pill.done {
                background: #e6f4ee;
                color: #1a7a4a;
                border: 1px solid #a8d5b5;
            }

            .step-pill.pend {
                background: #fde8e8;
                color: #c0392b;
                border: 1px solid #f0b8b8;
            }

            .step-pill .dot {
                width: 6px;
                height: 6px;
                border-radius: 50%;
                flex-shrink: 0;
            }

            .step-pill.done .dot {
                background: #1a7a4a;
            }

            .step-pill.pend .dot {
                background: #c0392b;
            }

        .empty-state {
            text-align: center;
            padding: 48px 24px;
            color: var(--muted);
        }

        @@media print {
            .filter-bar, .detail-btn, .charts-row, .rpt-header-left svg {
                display: none !important;
            }

            body {
                background: white;
            }

            .rpt-body {
                margin: 0;
                padding: 0;
            }

            .college-table-wrap {
                box-shadow: none;
                border: 1px solid #000;
            }
        }

        @@media(max-width:900px) {
            .summary-row {
                grid-template-columns: 1fr 1fr;
            }

            .charts-row {
                grid-template-columns: 1fr;
            }
        }

        rpt-header {
            justify-content: space-between; /* Ensures left and right alignment */
        }

        .btn-logout {
            background: rgba(255,255,255,0.1);
            color: white;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            border: 1px solid rgba(255,255,255,0.3);
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .btn-logout:hover {
                background: #c0392b;
                border-color: #c0392b;
            }

        /* Center the chart layout */
        .charts-row {
            display: flex;
            justify-content: center;
            margin-bottom: 32px;
        }

        .chart-card-centered {
            width: 100%;
            max-width: 600px; /* Keeps it from becoming too wide */
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            box-shadow: var(--shadow);
        }
    </style>
</head>
<body>

    <!-- Header -->
    <div class="rpt-header">
        <div class="rpt-header-left">
            <div class="rpt-header-icon">
                <svg viewBox="0 0 24 24"><path d="M9 11H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm2-7h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V9h14v11z" /></svg>
            </div>
            <div style="display: inline-block;">
                <h1 style="margin:0;">Application Completion Report</h1>
                <p>Continuous Affiliation · Admin Dashboard · @DateTime.Now.ToString("dd MMM yyyy")</p>
            </div>
        </div>

        <!-- FIX 5: Logout Button -->
        <div class="rpt-header-right">
            <a href="@Url.Action("AdminDashboard", "Admin")" class="btn-logout">
                <span>Logout</span> ⏻
            </a>
        </div>
    </div>

    <div class="rpt-body">

        <!-- Summary Cards -->
        <div class="summary-row">
            <div class="sum-card">
                <div class="sum-icon total">🏫</div>
                <div class="sum-info">
                    <div class="sum-val">@Model.TotalColleges</div>
                    <div class="sum-lbl">Total Colleges</div>
                </div>
            </div>
            <div class="sum-card">
                <div class="sum-icon done">✅</div>
                <div class="sum-info">
                    <div class="sum-val" style="color:var(--green);">@Model.FullyCompleted</div>
                    <div class="sum-lbl">Fully Completed</div>
                </div>
            </div>
            <div class="sum-card">
                <div class="sum-icon prog">⏳</div>
                <div class="sum-info">
                    <div class="sum-val" style="color:var(--amber);">@Model.InProgress</div>
                    <div class="sum-lbl">In Progress</div>
                </div>
            </div>
            <div class="sum-card">
                <div class="sum-icon none">❌</div>
                <div class="sum-info">
                    <div class="sum-val" style="color:var(--red);">@Model.NotStarted</div>
                    <div class="sum-lbl">Not Started</div>
                </div>
            </div>
        </div>

        <div class="charts-row">
            <div class="chart-card-centered">
                <h3>Overall College Completion</h3>
                <div class="chart-wrap">
                    <canvas id="overallChart"></canvas>
                </div>
            </div>

            @* 
        <div class="chart-card">
            <h3>Steps Completion Graph</h3>
            <div class="chart-wrap">
                <canvas id="stepsChart"></canvas>
            </div>
        </div> 
        *@
        </div>

        <!-- Filter bar -->
        <form method="get" asp-action="ApplicationStatusReport" id="filterForm">
            <div class="filter-bar">
                <div class="search-box">
                    <input type="text" name="search" placeholder="🔍 Search by College Name or College Code" value="@Model.Search" />
                    <button type="submit" class="btn-search">Search</button>
                </div>

                <button type="submit" name="filterStatus" value=""
                        class="filter-btn @(string.IsNullOrEmpty(Model.FilterStatus) ? "active" : "")">
                    All
                </button>
                <button type="submit" name="filterStatus" value="complete"
                        class="filter-btn done-btn @(Model.FilterStatus == "complete" ? "active" : "")">
                    ✅ Complete
                </button>
                <button type="submit" name="filterStatus" value="inprogress"
                        class="filter-btn prog-btn @(Model.FilterStatus == "inprogress" ? "active" : "")">
                    ⏳ In Progress
                </button>
                <button type="submit" name="filterStatus" value="notstarted"
                        class="filter-btn none-btn @(Model.FilterStatus == "notstarted" ? "active" : "")">
                    ❌ Not Started
                </button>

                <select name="sortBy" class="sort-select" onchange="this.form.submit()">
                    <option value="pct_desc" @(Model.SortBy == "pct_desc" || Model.SortBy == null ? "selected" : "")>Sort: Most Complete First</option>
                    <option value="pct_asc" @(Model.SortBy == "pct_asc" ? "selected" : "")>Sort: Least Complete First</option>
                    <option value="name" @(Model.SortBy == "name" ? "selected" : "")>Sort: College Name A–Z</option>
                </select>

                <div class="export-group">
                    <button type="button" class="btn-export" onclick="exportPDF()">📄 PDF</button>
                   @*  <button type="button" class="btn-export" onclick="exportWord()">📝 Word</button> *@
                </div>
            </div>
        </form>

        <!-- College Table -->
        <div class="college-table-wrap" id="printableArea">
            <h3>College-wise Status — @Model.Colleges.Count college(s) shown</h3>

            @if (!Model.Colleges.Any())
            {
                <div class="empty-state">
                    <p>No colleges match the current filters.</p>
                </div>
            }
            else
            {
                <table class="ct" id="mainTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>College</th>
                            @*   <th>Levels</th> *@
                            <th>Pages Filled</th>
                            <th>Progress</th>
                            <th>Status</th>
                            <th class="no-print">Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Colleges.Count; i++)
                        {
                            var col = Model.Colleges[i];
                            var pct = col.Percentage;
                            var fillCls = pct == 100 ? "done" : pct >= 50 ? "high" : pct > 0 ? "mid" : "low";
                            var statusLbl = pct == 100 ? "Complete" : pct > 0 ? "In Progress" : "Not Started";
                            var statusCls = pct == 100 ? "done" : pct > 0 ? "prog" : "none";
                            var rowId = $"detail-{i}";

                            <tr>
                                <td style="color:var(--muted);font-size:.8rem;">@(i + 1)</td>
                                <td>
                                    <div class="ct-name">@col.CollegeName</div>
                                    <div class="ct-code">@col.CollegeCode</div>
                                </td>
                                @*  <td>
                                    @foreach (var lv in col.Levels)
                                    {
                                        <span class="lvl-badge">@lv</span>
                                    }
                                </td> *@
                                <td><strong>@col.DoneSteps</strong> <span style="color:var(--muted);"> / @col.TotalSteps</span></td>
                                <td style="min-width:160px;">
                                    <div class="prog-wrap">
                                        <div class="prog-track"><div class="prog-fill @fillCls" style="width:@pct%"></div></div>
                                        <span class="prog-txt">@pct%</span>
                                    </div>
                                </td>
                                <td><span class="status-badge @statusCls">@statusLbl</span></td>
                                <td class="no-print">
                                    <button class="detail-btn" onclick="toggleDetail('@rowId')">▼ View</button>
                                </td>
                            </tr>
                            <tr class="detail-row">
                                <td colspan="7">
                                    <div class="detail-panel" id="@rowId">
                                        @foreach (var grp in col.StepGroups)
                                        {
                                            <div class="step-group-title">@grp.GroupName</div>
                                            <div class="step-list">
                                                @foreach (var step in grp.Steps)
                                                {
                                                    var cls = step.Completed ? "done" : "pend";
                                                    <span class="step-pill @cls"><span class="dot"></span> @(step.Completed ? "✓" : "○") @step.Label</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <script>
        // 1. Overall Donut (Logic Corrected by Controller)
               new Chart(document.getElementById('overallChart'), {
            type: 'doughnut',
            data: {
                labels: ['Fully Complete', 'In Progress', 'Not Started'],
                datasets: [{
                    data: [@Model.FullyCompleted, @Model.InProgress, @Model.NotStarted],
                    backgroundColor: ['#1a7a4a', '#d97706', '#c0392b'],
                    borderWidth: 3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: { legend: { position: 'bottom' } }
            }
        });

        // 2. Steps Distribution Chart (Updated Colors: Orange, Red, Dark Red)
        var colleges = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Colleges.Select(c => c.Percentage).ToList()));
        var buckets = [0, 0, 0, 0, 0, 0];
        colleges.forEach(function(p) {
            if (p === 0) buckets[0]++;
            else if (p <= 25) buckets[1]++;
            else if (p <= 50) buckets[2]++;
            else if (p <= 75) buckets[3]++;
            else if (p < 100) buckets[4]++;
            else buckets[5]++;
        });

        new Chart(document.getElementById('stepsChart'), {
            type: 'doughnut',
            data: {
                labels: ['Not Started', '1-25%', '26-50%', '51-75%', '76-99%', 'Completed'],
                datasets: [{
                    data: buckets,
                    // Order: Not Started (Dark Red), In Progress (Red/Shades), Completed (Orange)
                    backgroundColor: ['#8B0000', '#B22222', '#FF0000', '#FF4500', '#FF8C00', '#FFA500'],
                    borderWidth: 3
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, cutout: '65%', plugins: { legend: { position: 'bottom' } } }
        });

        function toggleDetail(id) {
            const panel = document.getElementById(id);
            const btn = event.currentTarget;
            const isOpen = panel.classList.contains('open');
            panel.classList.toggle('open', !isOpen);
            btn.textContent = isOpen ? '▼ View' : '▲ Hide';
        }

        // Export Functions
        function exportPDF() {
            window.print(); // Best native way to generate PDF from layout
        }

        function exportWord() {
            var html = document.getElementById('printableArea').outerHTML;
            var blob = new Blob(['\ufeff', html], {
                type: 'application/msword'
            });
            var url = URL.createObjectURL(blob);
            var link = document.createElement('a');
            link.href = url;
            link.download = 'Application_Status_Report.doc';
            link.click();
        }
    </script>
</body>
</html>
