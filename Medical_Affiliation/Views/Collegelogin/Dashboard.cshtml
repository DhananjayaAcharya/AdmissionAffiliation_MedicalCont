@using Microsoft.AspNetCore.Http
@model DashboardViewModel
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Dashboard";
    var repositoryRows = ViewBag.RepositoryRows as List<UgandPgrepository> ?? new List<UgandPgrepository>();
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    var facultyName = HttpContextAccessor.HttpContext.Session.GetString("FacultyName");
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
    var collegeName = ViewBag.CollegeName as string ?? "College";
    var collegeCode = ViewBag.CollegeCode as string ?? "";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RGUHS Academic Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root {
            --navy: #0f1f3d;
            --navy-mid: #1a3360;
            --navy-soft: #253f78;
            --gold: #c8972e;
            --gold-lt: #e0b84a;
            --gold-pale: #fdf6e3;
            --gold-ring: rgba(200,151,46,.20);
            --surface: #ffffff;
            --bg: #f4f6fa;
            --bg-2: #eef1f7;
            --border: #dde2ee;
            --border-2: #c8cedf;
            --text-1: #0d1b35;
            --text-2: #4a5568;
            --text-3: #8896b0;
            --green: #1a7a4a;
            --green-bg: rgba(26,122,74,.10);
            --red: #c0392b;
            --red-bg: rgba(192,57,43,.09);
            --sidebar-w: 270px;
            --topbar-h: 68px;
            --radius: 12px;
            --radius-lg: 18px;
            --radius-xl: 24px;
            --shadow-xs: 0 1px 3px rgba(15,31,61,.07);
            --shadow-sm: 0 2px 10px rgba(15,31,61,.09);
            --shadow-md: 0 6px 24px rgba(15,31,61,.12);
            --shadow-lg: 0 16px 48px rgba(15,31,61,.16);
            --ease: cubic-bezier(.4,0,.2,1);
            --dur: .22s;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
            font-size: 15px;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text-1);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* ── TOPBAR ─────────────────────────────────────── */
        .topbar {
            position: fixed;
            inset: 0 0 auto 0;
            height: var(--topbar-h);
            background: var(--navy);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            z-index: 1000;
            box-shadow: 0 1px 0 rgba(255,255,255,.06), var(--shadow-md);
        }

            .topbar::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg, var(--gold) 0%, var(--gold-lt) 40%, transparent 100%);
            }

        /* Brand */
        .tb-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            flex-shrink: 0;
        }

        .tb-logo {
            width: 46px;
            height: 46px;
            border-radius: 10px;
            overflow: hidden;
            flex-shrink: 0;
            display: grid;
            place-items: center;
            background: #fff;
        }

            .tb-logo img {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }

        .tb-brand-text {
            line-height: 1.2;
        }

        .tb-brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 17px;
            font-weight: 700;
            color: #fff;
            letter-spacing: .2px;
        }

        .tb-brand-sub {
            font-size: 10px;
            color: rgba(255,255,255,.38);
            text-transform: uppercase;
            letter-spacing: 1.3px;
        }

        /* Centre pill */
        .tb-centre {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            align-items: center;
            gap: 9px;
            background: rgba(255,255,255,.07);
            border: 1px solid rgba(255,255,255,.11);
            border-radius: 40px;
            padding: 6px 16px 6px 10px;
            max-width: 480px;
            min-width: 0;
        }

        .tb-centre-ico {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: var(--gold-ring);
            border: 1px solid rgba(200,151,46,.30);
            display: grid;
            place-items: center;
            color: var(--gold-lt);
            font-size: 12px;
            flex-shrink: 0;
        }

        .tb-centre-inner {
            min-width: 0;
        }

        .tb-centre-label {
            font-size: 9px;
            color: rgba(255,255,255,.32);
            text-transform: uppercase;
            letter-spacing: 1.1px;
            line-height: 1;
            margin-bottom: 1px;
        }

        .tb-centre-name {
            font-size: 13px;
            font-weight: 600;
            color: rgba(255,255,255,.88);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        /* Right side */
        .tb-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .tb-code {
            background: var(--gold-ring);
            border: 1px solid rgba(200,151,46,.30);
            color: var(--gold-lt);
            padding: 5px 13px;
            border-radius: 40px;
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: .8px;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            gap: 6px;
            background: rgba(220,38,38,.09);
            border: 1px solid rgba(220,38,38,.25);
            color: #fca5a5;
            border-radius: 40px;
            padding: 6px 16px 6px 11px;
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background var(--dur) var(--ease), border-color var(--dur) var(--ease), transform var(--dur) var(--ease);
        }

            .btn-logout i {
                font-size: 14px;
            }

            .btn-logout:hover {
                background: rgba(220,38,38,.20);
                border-color: rgba(220,38,38,.45);
                color: #fff;
                transform: translateY(-1px);
            }

        /* ── LAYOUT ──────────────────────────────────────── */
        .layout {
            display: flex;
            padding-top: var(--topbar-h);
            min-height: 100vh;
        }

        .sidebar-wrap {
            width: var(--sidebar-w);
            flex-shrink: 0;
        }

        .main {
            flex: 1;
            min-width: 0;
            padding: 36px 44px 60px;
        }

        /* ── PAGE HEADER ─────────────────────────────────── */
        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }

        .page-eyebrow {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            font-weight: 600;
            color: var(--text-3);
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 8px;
        }

            .page-eyebrow i {
                font-size: 13px;
            }

        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 28px;
            font-weight: 700;
            color: var(--text-1);
            line-height: 1.15;
            letter-spacing: -.3px;
        }

        .page-sub {
            font-size: 13.5px;
            color: var(--text-2);
            margin-top: 5px;
            line-height: 1.6;
        }

        .status-pill {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 40px;
            padding: 8px 18px;
            font-size: 12.5px;
            font-weight: 600;
            color: var(--green);
            box-shadow: var(--shadow-xs);
            white-space: nowrap;
        }

        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #2ecc71;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0% {
                box-shadow: 0 0 0 0 rgba(46,204,113,.5);
            }

            70% {
                box-shadow: 0 0 0 7px rgba(46,204,113,0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(46,204,113,0);
            }
        }

        /* ── BANNER CARD ─────────────────────────────────── */
        .banner {
            background: var(--navy);
            border-radius: var(--radius-xl);
            padding: 32px 36px;
            margin-bottom: 28px;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow-lg);
        }

            .banner::before {
                content: '';
                position: absolute;
                top: -80px;
                right: -80px;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(200,151,46,.18) 0%, transparent 70%);
                pointer-events: none;
            }

            .banner::after {
                content: '';
                position: absolute;
                bottom: -50px;
                left: 30%;
                width: 200px;
                height: 200px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(26,51,96,.8) 0%, transparent 70%);
                pointer-events: none;
            }

        .banner-inner {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            flex-wrap: wrap;
        }

        .banner-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(200,151,46,.15);
            border: 1px solid rgba(200,151,46,.28);
            color: var(--gold-lt);
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 10.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 12px;
        }

        .banner-title {
            font-family: 'Playfair Display', serif;
            font-size: 26px;
            font-weight: 700;
            color: #fff;
            line-height: 1.2;
            margin-bottom: 8px;
        }

        .banner-desc {
            font-size: 13.5px;
            color: rgba(255,255,255,.50);
            line-height: 1.7;
            max-width: 540px;
        }

        .banner-meta {
            display: flex;
            flex-direction: column;
            gap: 10px;
            align-items: flex-end;
            flex-shrink: 0;
        }

        .banner-step-label {
            font-size: 10px;
            color: rgba(255,255,255,.30);
            text-transform: uppercase;
            letter-spacing: 1px;
            text-align: right;
            margin-bottom: 2px;
        }

        .step-dots {
            display: flex;
            gap: 5px;
        }

        .step-dot {
            width: 28px;
            height: 4px;
            border-radius: 99px;
            background: rgba(255,255,255,.12);
        }

            .step-dot.done {
                background: var(--gold);
            }

            .step-dot.active {
                background: var(--gold-lt);
            }

        /* ── STAT ROW ────────────────────────────────────── */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 22px 24px;
            display: flex;
            align-items: flex-start;
            gap: 16px;
            transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
            box-shadow: var(--shadow-xs);
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: var(--shadow-md);
            }

        .stat-icon-wrap {
            width: 46px;
            height: 46px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .si-blue {
            background: #ebf3ff;
        }

        .si-amber {
            background: #fef8ec;
        }

        .si-teal {
            background: #edfaf5;
        }

        .stat-label {
            font-size: 10.5px;
            font-weight: 700;
            color: var(--text-3);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }

        .stat-val {
            font-size: 17px;
            font-weight: 700;
            color: var(--text-1);
            line-height: 1.2;
        }

        .stat-hint {
            font-size: 11.5px;
            color: var(--text-3);
            margin-top: 2px;
        }

        /* ── CONTENT GRID ────────────────────────────────── */
        .content-grid {
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 20px;
        }

        /* ── PANELS ──────────────────────────────────────── */
        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-xs);
        }

        .panel-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 24px;
            border-bottom: 1px solid var(--border);
        }

        .panel-head-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .panel-head-ico {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: var(--bg-2);
            display: grid;
            place-items: center;
            font-size: 15px;
            color: var(--navy-mid);
        }

        .panel-title {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-1);
            letter-spacing: .1px;
        }

        .panel-count {
            font-size: 10.5px;
            background: var(--bg-2);
            color: var(--text-2);
            border-radius: 40px;
            padding: 3px 10px;
            font-weight: 700;
            border: 1px solid var(--border);
        }

        /* Action list */
        .action-list {
            padding: 8px 12px;
        }

        .action-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 13px 12px;
            border-radius: var(--radius);
            text-decoration: none;
            color: var(--text-1);
            transition: background var(--dur) var(--ease), transform var(--dur) var(--ease);
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }

            .action-item:hover {
                background: var(--bg);
                transform: translateX(3px);
                color: var(--text-1);
                text-decoration: none;
            }

            .action-item + .action-item {
                border-top: 1px solid var(--border);
                border-radius: 0;
            }

                .action-item + .action-item:hover {
                    border-radius: var(--radius);
                }

        .action-ico {
            width: 44px;
            height: 44px;
            border-radius: 11px;
            display: grid;
            place-items: center;
            font-size: 19px;
            flex-shrink: 0;
        }

        .ai-navy {
            background: var(--navy);
        }

        .ai-gold {
            background: #7a5c00;
        }

        .ai-teal {
            background: #0b5e47;
        }

        .ai-slate {
            background: #374151;
        }

        .action-text {
            flex: 1;
            min-width: 0;
        }

        .action-name {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-1);
            margin-bottom: 1px;
        }

        .action-desc {
            font-size: 12px;
            color: var(--text-3);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .action-arr {
            color: var(--border-2);
            font-size: 15px;
            transition: color var(--dur) var(--ease), transform var(--dur) var(--ease);
        }

        .action-item:hover .action-arr {
            color: var(--navy-mid);
            transform: translateX(3px);
        }

        /* ── SIDE PANELS ─────────────────────────────────── */
        .side-stack {
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .info-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-xs);
        }

        .info-head {
            padding: 15px 20px 14px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .info-head-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--gold);
        }

        .info-head-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.1px;
            color: var(--text-3);
        }

        .info-body {
            padding: 6px 20px 12px;
        }

        .detail-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 0;
        }

            .detail-row + .detail-row {
                border-top: 1px solid var(--border);
            }

        .detail-key {
            font-size: 12.5px;
            color: var(--text-3);
            display: flex;
            align-items: center;
            gap: 7px;
        }

            .detail-key i {
                font-size: 14px;
            }

        .detail-val {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-1);
            text-align: right;
            max-width: 160px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* Progress panel */
        .progress-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 20px;
            box-shadow: var(--shadow-xs);
        }

        .prog-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 14px;
        }

        .prog-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.1px;
            color: var(--text-3);
        }

        .prog-pct {
            font-size: 13px;
            font-weight: 700;
            color: var(--gold);
        }

        .prog-track {
            height: 6px;
            background: var(--bg-2);
            border-radius: 99px;
            overflow: hidden;
            margin-bottom: 16px;
        }

        .prog-fill {
            height: 100%;
            width: 40%;
            background: linear-gradient(90deg, var(--navy), var(--navy-soft));
            border-radius: 99px;
            animation: fillBar .9s .3s var(--ease) both;
        }

        @@keyframes fillBar {
            from {
                width: 0;
            }

            to {
                width: 40%;
            }
        }

        .notice-box {
            display: flex;
            gap: 11px;
            background: #fffbec;
            border: 1px solid #f0d97a;
            border-radius: var(--radius);
            padding: 13px 15px;
            font-size: 12.5px;
            color: #6b4c00;
            line-height: 1.65;
        }

            .notice-box i {
                font-size: 16px;
                color: #c49b0a;
                flex-shrink: 0;
                margin-top: 1px;
            }

        /* Quick links in side */
        .quick-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 12px;
            border-radius: var(--radius);
            background: var(--bg);
            border: 1px solid var(--border);
            text-decoration: none;
            color: var(--text-1);
            font-size: 13px;
            font-weight: 600;
            transition: background var(--dur), border-color var(--dur), transform var(--dur);
            cursor: pointer;
        }

            .quick-link:hover {
                background: var(--bg-2);
                border-color: var(--border-2);
                transform: translateY(-1px);
                color: var(--text-1);
                text-decoration: none;
            }

            .quick-link i {
                font-size: 16px;
                color: var(--navy-mid);
            }

        /* ── MODALS ──────────────────────────────────────── */
        .modal-content {
            border: none;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow-lg);
        }

        .modal-header {
            background: var(--navy);
            padding: 24px 28px;
            border: none;
            position: relative;
        }

            .modal-header::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(90deg, var(--gold), transparent);
            }

        .modal-header-inner {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .modal-ico {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: var(--gold-ring);
            border: 1px solid rgba(200,151,46,.30);
            display: grid;
            place-items: center;
            font-size: 20px;
        }

        .modal-title {
            font-family: 'Playfair Display', serif;
            font-size: 20px;
            font-weight: 700;
            color: #fff;
            margin: 0;
            line-height: 1.2;
        }

        .modal-sub {
            font-size: 11.5px;
            color: rgba(255,255,255,.40);
            margin-top: 2px;
        }

        .btn-close {
            filter: invert(1) brightness(2);
            opacity: .55;
        }

            .btn-close:hover {
                opacity: 1;
            }

        .modal-body {
            padding: 28px 32px 20px;
        }

            .modal-body p {
                color: var(--text-2);
                font-size: 14px;
                line-height: 1.75;
            }

                .modal-body p + p {
                    margin-top: 8px;
                }

            .modal-body strong {
                color: var(--text-1);
            }

        .modal-footer {
            padding: 16px 32px 28px;
            border: none;
            gap: 10px;
        }

        .btn-primary-modal {
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 12px 26px;
            font-size: 13.5px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: background var(--dur), transform var(--dur), box-shadow var(--dur);
            font-family: 'Inter', sans-serif;
        }

            .btn-primary-modal:hover {
                background: var(--navy-mid);
                transform: translateY(-1px);
                box-shadow: 0 6px 16px rgba(15,31,61,.22);
            }

        .btn-dismiss {
            background: transparent;
            color: var(--text-2);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 11px 20px;
            font-size: 13.5px;
            font-weight: 500;
            transition: background var(--dur);
            font-family: 'Inter', sans-serif;
        }

            .btn-dismiss:hover {
                background: var(--bg);
            }

        /* Password modal form fields */
        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-2);
            margin-bottom: 6px;
        }

        .form-control, .form-select {
            font-size: 14px;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 10px 14px;
            transition: border-color var(--dur), box-shadow var(--dur);
            font-family: 'Inter', sans-serif;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--navy-mid);
                box-shadow: 0 0 0 3px rgba(26,51,96,.12);
                outline: none;
            }

        /* ── RESPONSIVE ──────────────────────────────────── */
        @@media (max-width: 1100px) {
            .content-grid {
                grid-template-columns: 1fr;
            }

            .side-stack {
                flex-direction: row;
                flex-wrap: wrap;
            }

            .info-panel, .progress-panel {
                flex: 1;
                min-width: 220px;
            }
        }

        @@media (max-width: 900px) {
            .stat-grid {
                grid-template-columns: 1fr 1fr;
            }

            .main {
                padding: 24px 20px 48px;
            }
        }

        @@media (max-width: 640px) {
            .stat-grid {
                grid-template-columns: 1fr;
            }

            .tb-centre {
                display: none;
            }

            .tb-code {
                display: none;
            }

            .topbar {
                padding: 0 16px;
            }

            .banner {
                padding: 24px 20px;
            }

            .banner-title {
                font-size: 20px;
            }
        }

        /* Fade-up entrance */
        .fade-up {
            animation: fadeUp .45s var(--ease) both;
        }

        .fade-up-1 {
            animation-delay: .06s;
        }

        .fade-up-2 {
            animation-delay: .12s;
        }

        .fade-up-3 {
            animation-delay: .18s;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(14px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Alert variants */
        .alert-warning {
            background: #fffbec;
            border-color: #f0d97a;
            color: #6b4c00;
            border-radius: var(--radius);
            font-size: 13.5px;
        }

        .alert-info {
            background: #eef4ff;
            border-color: #b0c8f8;
            color: #1a3360;
            border-radius: var(--radius);
            font-size: 13.5px;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <!-- ── TOPBAR ──────────────────────────────────────────── -->
    <header class="topbar">
        <a class="tb-brand" href="#">
            <div class="tb-logo">
                <img src="~/images/newlogo.jpeg" alt="RGUHS Logo" />
            </div>
            <div class="tb-brand-text">
                <div class="tb-brand-name">RGUHS Portal</div>
                <div class="tb-brand-sub">Affiliation Management</div>
            </div>
        </a>

        <div class="tb-centre">
            <div class="tb-centre-ico"><i class="bi bi-buildings-fill"></i></div>
            <div class="tb-centre-inner">
                <div class="tb-centre-label">Institution</div>
                <div class="tb-centre-name" title="@collegeName">@collegeName</div>
            </div>
        </div>

        <div class="tb-right">
            @if (!string.IsNullOrEmpty(collegeCode))
            {
                <span class="tb-code">@collegeCode</span>
            }
            <form asp-action="Logout" asp-controller="Login" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i>
                    Sign Out
                </button>
            </form>
        </div>
    </header>

    <!-- ── LAYOUT ──────────────────────────────────────────── -->
    <div class="layout">

        @if (!string.IsNullOrEmpty(facultyCode))
        {
            <div class="sidebar-wrap">
                @await Component.InvokeAsync("Sidebar")
            </div>
        }

        <main class="main">

            <!-- Page Header -->
            <div class="page-header fade-up">
                <div>
                    <div class="page-eyebrow">
                        <i class="bi bi-house-door"></i> Home
                        <i class="bi bi-chevron-right"></i>
                        Dashboard
                    </div>
                    <h1 class="page-title">Welcome back</h1>
                </div>
                <div class="status-pill">
                    <div class="status-dot"></div>
                    Portal Active
                </div>
            </div>

            <!-- Banner -->
            <div class="banner fade-up fade-up-1">
                <div class="banner-inner">
                    <div>
                        <div class="banner-badge">
                            <i class="bi bi-mortarboard-fill"></i>
                            Academic Portal
                        </div>
                        <h2 class="banner-title">@collegeName</h2>
                        <p class="banner-desc">
                            Submit course intake requirements, update institutional data, and monitor
                            your affiliation progress from this unified portal.
                        </p>
                    </div>
                    <div class="banner-meta">
                        <div>
                            <div class="banner-step-label">Application Progress</div>
                            <div class="step-dots">
                                <div class="step-dot done"></div>
                                <div class="step-dot active"></div>
                                <div class="step-dot"></div>
                                <div class="step-dot"></div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(collegeCode))
                        {
                            <div style="background: rgba(200,151,46,.14); border: 1px solid rgba(200,151,46,.28); border-radius: 40px; padding: 6px 16px; font-size: 12px; font-weight: 700; color: var(--gold-lt); letter-spacing: .5px; text-align: right;">
                                Code: @collegeCode
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Stat Cards -->
            <div class="stat-grid fade-up fade-up-2">
                <div class="stat-card">
                    <div class="stat-icon-wrap si-blue">🏛️</div>
                    <div>
                        <div class="stat-label">Institution</div>
                        <div class="stat-val">@collegeName</div>
                        <div class="stat-hint">Registered college</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon-wrap si-amber">🔖</div>
                    <div>
                        <div class="stat-label">College Code</div>
                        <div class="stat-val">@(string.IsNullOrEmpty(collegeCode) ? "—" : collegeCode)</div>
                        <div class="stat-hint">Unique identifier</div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(facultyName))
                {
                    <div class="stat-card">
                        <div class="stat-icon-wrap si-teal">🎓</div>
                        <div>
                            <div class="stat-label">Faculty Stream</div>
                            <div class="stat-val">@facultyName</div>
                            <div class="stat-hint">Active stream</div>
                        </div>
                    </div>
                }
            </div>

            <!-- Content Grid -->
            <div class="content-grid fade-up fade-up-3">

                <!-- Quick Actions -->
                <div class="panel">
                    <div class="panel-head">
                        <div class="panel-head-left">
                            <div class="panel-head-ico"><i class="bi bi-grid-1x2-fill"></i></div>
                            <div class="panel-title">Quick Actions</div>
                        </div>
                        <span class="panel-count">4 tasks</span>
                    </div>
                    <div class="action-list">
                        <a href="@Url.Action("IncreaseIntake", "ContinuousAffiliationIncreaseintake")" class="action-item">
                            <div class="action-ico ai-navy">📝</div>
                            <div class="action-text">
                                <div class="action-name">Course Intake Form</div>
                                <div class="action-desc">Submit or update annual intake requirements</div>
                            </div>
                            <i class="bi bi-chevron-right action-arr"></i>
                        </a>
                        <a href="@Url.Action("Dashboard", "Collegelogin")" class="action-item">
                            <div class="action-ico ai-gold">🏫</div>
                            <div class="action-text">
                                <div class="action-name">Institution Profile</div>
                                <div class="action-desc">View and manage college information</div>
                            </div>
                            <i class="bi bi-chevron-right action-arr"></i>
                        </a>
                        <a href="@Url.Action("Dashboard", "Collegelogin")" class="action-item">
                            <div class="action-ico ai-teal">📊</div>
                            <div class="action-text">
                                <div class="action-name">Applications</div>
                                <div class="action-desc">Monitor and track submitted applications</div>
                            </div>
                            <i class="bi bi-chevron-right action-arr"></i>
                        </a>
                        <button class="action-item" onclick="goToChangePassword(event)">
                            <div class="action-ico ai-slate">🔑</div>
                            <div class="action-text">
                                <div class="action-name">Security Settings</div>
                                <div class="action-desc">Update your account password</div>
                            </div>
                            <i class="bi bi-chevron-right action-arr"></i>
                        </button>
                    </div>
                </div>

                <!-- Side Stack -->
                <div class="side-stack">

                    <!-- Account Details -->
                    <div class="info-panel">
                        <div class="info-head">
                            <div class="info-head-dot"></div>
                            <div class="info-head-title">Account Details</div>
                        </div>
                        <div class="info-body">
                            <div class="detail-row">
                                <span class="detail-key"><i class="bi bi-building"></i> College</span>
                                <span class="detail-val" title="@collegeName">@collegeName</span>
                            </div>
                            @if (!string.IsNullOrEmpty(collegeCode))
                            {
                                <div class="detail-row">
                                    <span class="detail-key"><i class="bi bi-upc-scan"></i> Code</span>
                                    <span class="detail-val">@collegeCode</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(facultyName))
                            {
                                <div class="detail-row">
                                    <span class="detail-key"><i class="bi bi-person-badge"></i> Stream</span>
                                    <span class="detail-val">@facultyName</span>
                                </div>
                            }
                            <div class="detail-row">
                                <span class="detail-key"><i class="bi bi-shield-check"></i> Status</span>
                                <span class="detail-val" style="color: var(--green);">Active</span>
                            </div>
                        </div>
                    </div>

                    <!-- Progress -->
                    <div class="progress-panel">
                        <div class="prog-header">
                            <div class="prog-title">Intake Completion</div>
                            <div class="prog-pct">40%</div>
                        </div>
                        <div class="prog-track">
                            <div class="prog-fill"></div>
                        </div>
                        <div class="notice-box">
                            <i class="bi bi-info-circle-fill"></i>
                            <div>Ensure all intake details are submitted before the deadline. Contact the admissions office for any discrepancies.</div>
                        </div>
                    </div>

                    <!-- Help links -->
                    <div style="display: flex; flex-direction: column; gap: 8px;">
                        <a href="#" class="quick-link">
                            <i class="bi bi-file-earmark-text"></i>
                            Application Guidelines
                        </a>
                        <a href="#" class="quick-link">
                            <i class="bi bi-headset"></i>
                            Contact Support
                        </a>
                    </div>

                </div>
            </div>

        </main>
    </div>

    <!-- ── WELCOME MODAL ─────────────────────────────────────── -->
    @if (TempData["ShowWelcomePopup"] != null && (bool)TempData["ShowWelcomePopup"])
    {
        var popupCollegeName = TempData["CollegeName"]?.ToString() ?? "College";
        <div class="modal fade" id="welcomeModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <div class="modal-header-inner">
                            <div class="modal-ico">🎓</div>
                            <div>
                                <div class="modal-title">Welcome Aboard</div>
                                <div class="modal-sub">First-time login detected</div>
                            </div>
                        </div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-center">
                        <p>Welcome to the RGUHS Academic Portal, <strong>@popupCollegeName</strong>.</p>
                        <p>Your account has been created successfully. For your security, please set a new password before proceeding.</p>
                    </div>
                    <div class="modal-footer justify-content-center">
                        <button type="button" class="btn-dismiss" data-bs-dismiss="modal">Later</button>
                        <button type="button" class="btn-primary-modal" id="btnChangePassword">
                            <i class="bi bi-shield-lock-fill"></i> Set New Password
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ── CHANGE PASSWORD MODAL ─────────────────────────────── -->
    <div class="modal fade" id="updatePasswordModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="UpdatePassword" asp-controller="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <div class="modal-header-inner">
                            <div class="modal-ico">🔑</div>
                            <div>
                                <div class="modal-title">Change Password</div>
                                <div class="modal-sub">Update your account credentials</div>
                            </div>
                        </div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="CollegeCode" value="@collegeCode" />
                        <div class="mb-3 position-relative">
                            <label for="NewPassword" class="form-label">New Password</label>
                            <input type="password"
                                   class="form-control"
                                   id="NewPassword"
                                   name="UpdatedPassword"
                                   required
                                   minlength="8"
                                   maxlength="20"
                                   pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!%*?&@@$])[A-Za-z\d!%*?&@@$]{8,20}$"
                                   title="Password must be 8–20 characters and include uppercase, lowercase, number, and special character."
                                   autocomplete="new-password" />
                            <span class="position-absolute end-0 pe-3 toggle-password"
                                  style="cursor:pointer; top: 38px;">
                                <i class="bi bi-eye" id="toggleIcon" style="font-size:16px; color: var(--text-3);"></i>
                            </span>
                            <div class="mt-2" style="font-size:12px; color: var(--text-3); line-height: 1.6;">
                                Must contain: uppercase · lowercase · number · special character · min. 8 characters
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn-dismiss" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn-primary-modal">
                            <i class="bi bi-check2-circle"></i> Update Password
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ── LOCATION MODAL ────────────────────────────────────── -->
    <div class="modal fade" id="locationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <form id="locationForm" asp-action="UpdateLocation" asp-controller="Collegelogin" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <div class="modal-header-inner">
                            <div class="modal-ico">📍</div>
                            <div>
                                <div class="modal-title">Update Location</div>
                                <div class="modal-sub">District & Taluk details required</div>
                            </div>
                        </div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" name="CollegeCode" value="@Model.CollegeCode" />

                        <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            Please select your District and Taluk before proceeding.
                        </div>
                        <div class="alert alert-info text-center mb-4">
                            <strong>@Model.CollegeName</strong>
                        </div>

                        <div class="mb-3">
                            <label for="DistrictId" class="form-label">District <span class="text-danger">*</span></label>
                            <select id="DistrictId" name="DistrictId" class="form-select">
                                <option value="">— Select District —</option>
                                @foreach (var district in Model.Districts)
                                {
                                    if (Model.DistrictId == district.DistrictId)
                                    {
                                        <option value="@district.DistrictId" selected>@district.DistrictName</option>
                                    }
                                    else
                                    {
                                        <option value="@district.DistrictId">@district.DistrictName</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="TalukId" class="form-label">Taluk <span class="text-danger">*</span></label>
                            <select id="TalukId" name="TalukId" class="form-select">
                                <option value="">— Select Taluk —</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn-primary-modal">
                            <i class="bi bi-check2-circle"></i> Save & Continue
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Password toggle
        (function () {
            const toggle = document.querySelector('.toggle-password');
            const input  = document.getElementById('NewPassword');
            const icon   = document.getElementById('toggleIcon');
            if (toggle && input) {
                toggle.addEventListener('click', function () {
                    const show = input.type === 'password';
                    input.type = show ? 'text' : 'password';
                    icon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
                });
            }
        })();

        // Change password shortcut
        function goToChangePassword(e) {
            if (e) e.preventDefault();
            new bootstrap.Modal(document.getElementById('updatePasswordModal')).show();
        }

        // Welcome → Change Password chained flow
        @if (TempData["ShowWelcomePopup"] != null && (bool)TempData["ShowWelcomePopup"])
        {
                <text>
                (function () {
                    var welcomeModal = new bootstrap.Modal(document.getElementById('welcomeModal'));
                    welcomeModal.show();
                    document.getElementById('btnChangePassword').addEventListener('click', function () {
                        welcomeModal.hide();
                        setTimeout(function () {
                            new bootstrap.Modal(document.getElementById('updatePasswordModal')).show();
                        }, 400);
                    });
                })();
                </text>
        }

        // Location modal auto-show
        @if (TempData["ShowLocationPopup"] != null && (bool)TempData["ShowLocationPopup"])
        {
                <text>
                document.addEventListener('DOMContentLoaded', function () {
                    new bootstrap.Modal(document.getElementById('locationModal')).show();
                });
                </text>
        }

        // District → Taluk cascade
        document.addEventListener('DOMContentLoaded', function () {
            var districtDd  = document.getElementById('DistrictId');
            var talukDd     = document.getElementById('TalukId');
            if (!districtDd || !talukDd) return;

            var getTaluksUrl    = '@Url.Action("GetTaluks", "Collegelogin")';
            var selectedTalukId = '@Model.TalukId';

            function loadTaluks(districtId, selectedTaluk) {
                talukDd.innerHTML = '<option value="">— Select Taluk —</option>';
                if (!districtId) return;
                fetch(getTaluksUrl + '?districtId=' + encodeURIComponent(districtId))
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        data.forEach(function (t) {
                            var o = document.createElement('option');
                            o.value = t.talukId;
                            o.textContent = t.talukName;
                            if (selectedTaluk && selectedTaluk === t.talukId) o.selected = true;
                            talukDd.appendChild(o);
                        });
                    })
                    .catch(function (err) { console.error('Taluk load error:', err); });
            }

            districtDd.addEventListener('change', function () { loadTaluks(this.value); });
            if (districtDd.value) loadTaluks(districtDd.value, selectedTalukId);

            document.getElementById('locationForm').addEventListener('submit', function (e) {
                if (!districtDd.value || !talukDd.value) {
                    e.preventDefault();
                    alert('Please select both District and Taluk.');
                }
            });
        });
    </script>
</body>
</html>
