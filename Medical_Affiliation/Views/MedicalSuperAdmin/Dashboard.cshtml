@model Medical_Affiliation.Models.MedicalDashboardViewModel
@{
    ViewBag.Title = "Medical Colleges — Super Admin Dashboard";
   
    Layout = null;

}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
    :root {
        --navy-950: #03060f;
        --navy-900: #060d1f;
        --navy-800: #0a1630;
        --navy-700: #0f2248;
        --blue-400: #2d62c8;
        --blue-300: #4a7dd8;
        --blue-200: #8ab0eb;
        --blue-100: #d4e4f9;
        --gold-600: #8a6200;
        --gold-500: #b07d00;
        --gold-400: #c99210;
        --gold-300: #e0ac2a;
        --gold-200: #f0cc6b;
        --gold-100: #fdf0c0;
        --neutral-50: #f8f9fc;
        --neutral-100: #f0f2f8;
        --neutral-200: #e2e6f0;
        --neutral-300: #c8cedf;
        --neutral-400: #8f9ab5;
        --neutral-500: #5e6b88;
        --neutral-700: #2a3450;
        --neutral-900: #0f1624;
        --white: #ffffff;
        --surface: #f4f6fc;
        --fd: 'Playfair Display', serif;
        --fb: 'DM Sans', sans-serif;
        --fm: 'DM Mono', monospace;
        --r: 10px;
        --r-lg: 16px;
        --r-xl: 24px;
        --shadow-xs: 0 1px 3px rgba(6,13,31,.06);
        --shadow-sm: 0 2px 8px rgba(6,13,31,.08), 0 1px 3px rgba(6,13,31,.05);
        --shadow-md: 0 4px 20px rgba(6,13,31,.10);
        --shadow-lg: 0 12px 40px rgba(6,13,31,.14);
    }

    /* MAIN TABLE ZEBRA STRIPING */
    .data-table tbody tr:nth-child(even) {
        background-color: var(--neutral-50);
    }

    .data-table tbody tr:nth-child(odd) {
        background-color: var(--white);
    }

    /* PAGE SIZE SELECT STYLE */
    .pg-size-select {
        padding: 4px 8px;
        border: 1px solid var(--neutral-200);
        border-radius: 6px;
        font-size: 12px;
        font-family: var(--fb);
        background: var(--white);
        cursor: pointer;
    }

    /* RESTORE CARD LOOK (Image 4/5) */
    .filter-panel, .table-section {
        background: var(--white) !important;
        border: 1px solid var(--neutral-200) !important;
        box-shadow: var(--shadow-sm) !important;
    }

    /* MODAL DESIGN FIXES (Image 1) */
    .modal-close {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
    }

    /* THE COURSE GROUP WRAPPER (Rounded, Colored backgrounds) */
    .course-group {
        background: #fcfcfd;
        border: 1px solid var(--neutral-200);
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 25px;
        box-shadow: var(--shadow-xs);
    }

        .course-group.ug-group {
            background: #f8fbff;
            border-color: #bfdbfe;
        }

        .course-group.pg-group {
            background: #fdfaff;
            border-color: #e9d5ff;
        }

    .course-sec-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 15px;
        padding: 0 5px;
    }

    .course-tbl {
        width: 100%;
        border-collapse: collapse;
        border: none !important;
        background: transparent !important;
    }

        .course-tbl thead tr {
            background: var(--navy-800);
            border-radius: 8px 8px 0 0;
        }

        .course-tbl th {
            padding: 12px;
            color: rgba(255,255,255,.6);
            font-size: 10px;
            text-transform: uppercase;
        }

        .course-tbl td {
            padding: 12px;
            border-bottom: 1px solid var(--neutral-200);
        }

        /* Zebra striping for Modal Table */
        .course-tbl tbody tr:nth-child(even) {
            background: rgba(0,0,0,0.02);
        }

    /* FOOTER BUTTONS (Reference style) */
    .btn-modal-pdf {
        background: linear-gradient(135deg, var(--navy-700), var(--navy-800));
        color: #fff;
        border: none;
        padding: 10px 20px;
        border-radius: var(--r);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(15,34,72,0.2);
    }

    .btn-modal-close2 {
        background: var(--white);
        color: var(--neutral-500);
        border: 1.5px solid var(--neutral-200);
        padding: 10px 20px;
        border-radius: var(--r);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

    body {
        font-family: var(--fb);
        background: var(--neutral-50);
        margin: 0;
        overflow-x: hidden;
    }

    /* ══════════════ PAGE CONTAINERS (Restoring Image 4/5 look) ══════════════ */
    .stats-strip {
        background: var(--navy-700);
        border-bottom: 1px solid rgba(255,255,255,.06);
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        z-index: 10;
    }

    .stats-inner {
        display: flex;
        padding: 0 40px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .stat-item {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px 24px;
        border-right: 1px solid rgba(255,255,255,.07);
    }

        .stat-item:last-child {
            border-right: none;
        }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background: rgba(224,172,42,.1);
        border: 1px solid rgba(224,172,42,.2);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .stat-icon i {
            color: var(--gold-300);
            font-size: 17px;
        }

        .stat-icon.blue {
            background: rgba(45,98,200,.12);
            border-color: rgba(45,98,200,.25);
        }

            .stat-icon.blue i {
                color: #93c5fd;
            }

        .stat-icon.purple {
            background: rgba(124,58,237,.12);
            border-color: rgba(124,58,237,.25);
        }

            .stat-icon.purple i {
                color: #a78bfa;
            }

        .stat-icon.green {
            background: rgba(26,122,74,.12);
            border-color: rgba(26,122,74,.3);
        }

            .stat-icon.green i {
                color: #6ee7b7;
            }

    .stat-num {
        font-family: var(--fd);
        font-size: 28px;
        color: #fff;
        font-weight: 600;
    }

    .stat-lbl {
        font-size: 9.5px;
        color: rgba(255,255,255,.34);
        text-transform: uppercase;
    }

    .page-body {
        padding: 28px 40px 60px;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* Filter Panel - Restored "Card" look */
    .filter-panel {
        background: var(--white);
        border: 1px solid var(--neutral-200);
        border-radius: var(--r-lg);
        padding: 20px 24px;
        margin-bottom: 24px;
        box-shadow: var(--shadow-sm); /* Added shadow back */
    }

    .filter-title {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--neutral-400);
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .filter-row {
        display: flex;
        gap: 12px;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

        .filter-group label {
            font-size: 10.5px;
            font-weight: 600;
            color: var(--neutral-500);
        }

    .filter-select {
        padding: 9px 14px;
        border: 1.5px solid var(--neutral-200);
        border-radius: var(--r);
        font-size: 13px;
        font-family: var(--fb);
        min-width: 180px;
        cursor: pointer;
    }

    .search-wrap {
        position: relative;
        flex: 1;
        min-width: 220px;
    }

        .search-wrap input {
            width: 100%;
            padding: 9px 14px 9px 38px;
            border: 1.5px solid var(--neutral-200);
            border-radius: var(--r);
            font-size: 13px;
            outline: none;
        }

        .search-wrap .si {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--neutral-400);
        }

    .btn-apply {
        background: var(--navy-700);
        color: #fff;
        border: none;
        padding: 9px 22px;
        border-radius: var(--r);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-reset {
        background: var(--white);
        color: var(--neutral-500);
        border: 1.5px solid var(--neutral-200);
        padding: 9px 16px;
        border-radius: var(--r);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    /* Table Section - Restored "Card" look */
    .table-section {
        background: var(--white);
        border: 1px solid var(--neutral-200);
        border-radius: var(--r-lg);
        box-shadow: var(--shadow-sm); /* Added shadow back */
        overflow: hidden;
    }

    .table-header {
        padding: 16px 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--neutral-200);
        background: var(--surface);
    }

    .table-title {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .table-title h3 {
            font-family: var(--fd);
            font-size: 17px;
            color: var(--navy-700);
            font-weight: 600;
        }

    .count-pill {
        background: var(--navy-800);
        color: var(--gold-300);
        font-size: 10px;
        font-weight: 700;
        padding: 3px 12px;
        border-radius: 4px;
        font-family: var(--fm);
    }

    .table-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .btn-dl {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: var(--r);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        border: 1.5px solid;
    }

    .btn-dl-pdf {
        background: #fff5f5;
        border-color: #fecaca;
        color: #991b1b;
    }

    .btn-dl-xl {
        background: #f0fdf4;
        border-color: #bbf7d0;
        color: #166534;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .data-table thead tr {
            background: var(--navy-800);
        }

        .data-table thead th {
            padding: 11px 16px;
            color: rgba(255,255,255,.5);
            font-size: 9.5px;
            font-weight: 700;
            text-transform: uppercase;
            text-align: left;
        }

        .data-table tbody tr {
            border-bottom: 1px solid var(--neutral-200);
            cursor: pointer;
        }

            .data-table tbody tr:hover {
                background: #eff6ff;
            }

        .data-table tbody td {
            padding: 12px 16px;
            color: var(--neutral-700);
        }

    .td-name {
        font-weight: 600;
        color: var(--navy-700);
    }

    .td-town {
        font-size: 11px;
        color: var(--neutral-400);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .seat-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 52px;
        height: 28px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 700;
        font-family: var(--fm);
    }

    .seat-ug {
        background: #eff6ff;
        color: var(--blue-400);
        border: 1px solid #bfdbfe;
    }

    .seat-pg {
        background: #fdf4ff;
        color: #7c3aed;
        border: 1px solid #e9d5ff;
    }

    .seat-zero {
        background: var(--neutral-100);
        color: var(--neutral-400);
        border: 1px solid var(--neutral-200);
    }

    .td-center {
        text-align: center;
    }

    .view-btn {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        font-weight: 600;
        color: var(--blue-400);
        background: var(--blue-100);
        border: 1px solid #bfdbfe;
        border-radius: 5px;
        padding: 4px 12px;
        cursor: pointer;
    }

    .pagination-bar {
        padding: 14px 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top: 1px solid var(--neutral-200);
        background: var(--surface);
    }

    .pg-info {
        font-size: 12px;
        color: var(--neutral-500);
    }

    .pg-controls {
        display: flex;
        gap: 4px;
    }

    .pg-btn {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        border: 1.5px solid var(--neutral-200);
        background: var(--white);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .pg-btn.active {
            background: var(--navy-700);
            color: #fff;
            border-color: var(--navy-700);
        }

    /* ════════════════ MODAL (Image 1 & 2 Fixes) ════════════════ */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(3,6,15,.75);
        backdrop-filter: blur(5px);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        opacity: 0;
        pointer-events: none;
        transition: opacity .25s;
    }

        .modal-overlay.open {
            opacity: 1;
            pointer-events: all;
        }

    .modal-box {
        background: var(--white);
        border-radius: 24px;
        width: 100%;
        max-width: 800px;
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transform: translateY(20px);
        transition: transform .3s;
    }

    .modal-overlay.open .modal-box {
        transform: translateY(0);
    }

    .modal-hdr {
        background: linear-gradient(135deg, var(--navy-800), var(--navy-700));
        padding: 25px 30px;
        position: relative;
        color: #fff;
    }

    .modal-eyebrow {
        font-size: 9px;
        color: rgba(255,255,255,.4);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .modal-college-name {
        font-family: var(--fd);
        font-size: 22px;
        font-weight: 600;
        line-height: 1.3;
    }

    .modal-subtitle {
        margin-top: 10px;
        display: flex;
        gap: 15px;
        font-size: 11px;
        color: rgba(255,255,255,.5);
    }

    /* FIX 1: Close Button Position (Top Right) */
    .modal-close {
        position: absolute;
        top: 20px;
        right: 20px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background .2s;
    }

        .modal-close:hover {
            background: rgba(255,255,255,0.2);
        }

    .modal-stats {
        display: flex;
        background: var(--neutral-50);
        border-bottom: 1px solid var(--neutral-200);
    }

    .mstat {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 20px;
        border-right: 1px solid var(--neutral-200);
    }

    .mstat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: var(--navy-800);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold-300);
    }

    .mstat-num {
        font-family: var(--fd);
        font-size: 24px;
        font-weight: 600;
        color: var(--navy-700);
    }

    .mstat-lbl {
        font-size: 9px;
        color: var(--neutral-400);
        text-transform: uppercase;
    }

    .modal-scroll {
        flex: 1;
        overflow-y: auto;
        padding: 30px;
        background: var(--white);
    }

    .course-sec-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 15px;
        padding: 10px 0;
    }

        .course-sec-head h4 {
            font-family: var(--fd);
            font-size: 17px;
            color: var(--navy-700);
            margin: 0;
        }

    /* FIX 2 & 3: Table Borders and Zebra Striping */
    .course-tbl {
        width: 100%;
        border-collapse: collapse;
        font-size: 12.5px;
        border: 1px solid var(--neutral-200);
        border-radius: 12px;
        overflow: hidden;
    }

        .course-tbl thead tr {
            background: var(--navy-800);
        }

        .course-tbl th {
            padding: 12px 15px;
            color: rgba(255,255,255,.6);
            font-size: 10px;
            text-transform: uppercase;
        }

        .course-tbl td {
            padding: 12px 15px;
            border-bottom: 1px solid var(--neutral-200); /* Ensures bottom border for every row */
            color: var(--neutral-700);
        }
        /* Zebra Striping */
        .course-tbl tbody tr:nth-child(even) {
            background-color: var(--neutral-50);
        }

        .course-tbl tbody tr:nth-child(odd) {
            background-color: var(--white);
        }

    .i-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 40px;
        height: 26px;
        border-radius: 6px;
        font-weight: 700;
        font-family: var(--fm);
    }

    .i-ug {
        background: #eff6ff;
        color: var(--blue-400);
        border: 1px solid #bfdbfe;
    }

    .i-pg {
        background: #fdf4ff;
        color: #7c3aed;
        border: 1px solid #e9d5ff;
    }

    /* FIX 4: Modal Footer Buttons (Image 6 Style) */
    .modal-footer {
        padding: 20px 30px;
        border-top: 1px solid var(--neutral-200);
        background: var(--surface);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-footer-btns {
        display: flex;
        gap: 10px;
    }

    .btn-modal-pdf {
        background: linear-gradient(135deg, var(--navy-700), var(--navy-800));
        color: #fff;
        border: none;
        padding: 10px 20px;
        border-radius: var(--r);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(15,34,72,0.2);
        transition: opacity .2s;
    }

        .btn-modal-pdf:hover {
            opacity: 0.9;
        }

    .btn-modal-close2 {
        background: var(--white);
        color: var(--neutral-500);
        border: 1.5px solid var(--neutral-200);
        padding: 10px 20px;
        border-radius: var(--r);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all .2s;
    }

        .btn-modal-close2:hover {
            border-color: var(--neutral-400);
            color: var(--neutral-900);
        }

    .toast {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: var(--navy-800);
        color: #fff;
        padding: 12px 20px;
        border-radius: var(--r);
        z-index: 9999;
        transform: translateY(80px);
        opacity: 0;
        transition: all .3s;
        border-left: 3px solid var(--gold-300);
    }

        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }

    /* ===== DASHBOARD HEADER FORCE OVERRIDE ===== */

    .dash-header {
        background: #0a1630 !important;
        position: relative !important;
        overflow: hidden !important;
    }

    .header-inner {
        padding: 22px 40px !important;
        display: flex !important;
        align-items: center !important;
        gap: 24px !important;
    }

    .univ-name {
        color: #ffffff !important;
        font-family: 'Playfair Display', serif !important;
        font-size: 32px !important;
        font-weight: 600 !important;
    }

    .univ-eyebrow {
        color: #e0ac2a !important;
    }

    .univ-sub {
        color: rgba(255,255,255,.75) !important;
    }

    .header-badges {
        display: flex !important;
        gap: 8px !important;
    }

    .hbadge {
        color: #fff !important;
    }

    .header-status {
        color: #fff !important;
    }

    .btn-portal {
        background: #e0ac2a !important;
        color: #0a1630 !important;
    }
</style>

<div class="dash-header">
    <div class="header-inner">
        <div class="header-mono">🏛️</div>
        <div class="header-rule"></div>
        <div class="header-text">
            <div class="univ-eyebrow">Rajiv Gandhi University of Health Sciences</div>
            <div class="univ-name">Medical Colleges — Super Admin Dashboard</div>
            <div class="univ-sub"><i class="bi bi-geo-alt-fill" style="color:var(--blue-200);font-size:10px;"></i> Karnataka, India &nbsp;·&nbsp; Academic Year 2026–27</div>
            <div class="header-badges">
                <span class="hbadge hbadge-gold"><i class="bi bi-shield-check"></i> Admin Access</span>
                <span class="hbadge hbadge-blue"><i class="bi bi-mortarboard"></i> Faculty: Medical</span>
                <span class="hbadge hbadge-green"><i class="bi bi-database-check"></i> Live Data</span>
            </div>
        </div>
        <div class="header-cta">
