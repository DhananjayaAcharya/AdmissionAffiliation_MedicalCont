<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<script>
    var ALL_COLLEGES = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Colleges, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = null }));
    var filtered = ALL_COLLEGES.slice();
    var currentPage = 1;
    var pageSize = 10;
    var currentModalData = null;

    (function initFilters() {
    var savedDistrict = '@Html.Raw(Model.SelectedDistrict)';
    var savedTaluk    = '@Html.Raw(Model.SelectedTaluk)';
    if (savedDistrict) loadTaluks(savedDistrict, savedTaluk);
    applyClientFilter();
    })();

    document.getElementById('districtSelect').addEventListener('change', function () {
    loadTaluks(this.value, '');
    applyClientFilter();
    });
    document.getElementById('talukSelect').addEventListener('change', function () { applyClientFilter(); });
    document.getElementById('searchInput').addEventListener('input', function () { applyClientFilter(); });

    function loadTaluks(districtId, selectTalukId) {
    var sel = document.getElementById('talukSelect');
    sel.innerHTML = '<option value="">Loading…</option>';
    sel.disabled = true;
    if (!districtId) {
    sel.innerHTML = '<option value="">— Select District First —</option>';
    return;
    }
    fetch('@Url.Action("GetTaluks", "MedicalSuperAdmin")?districtId=' + encodeURIComponent(districtId))
    .then(r => r.json())
    .then(res => {
    sel.innerHTML = '<option value="">— All Taluks —</option>';
    if (res.Success && res.Taluks) {
    res.Taluks.forEach(t => {
    var o = document.createElement('option');
    o.value = t.TalukID; o.textContent = t.TalukName;
    if (selectTalukId && t.TalukID === selectTalukId) o.selected = true;
    sel.appendChild(o);
    });
    sel.disabled = false;
    } else { sel.innerHTML = '<option value="">No taluks found</option>'; }
    })
    .catch(() => { sel.innerHTML = '<option value="">Error loading taluks</option>'; });
    }

    function applyClientFilter() {
    var distId = document.getElementById('districtSelect').value.trim();
    var talukId = document.getElementById('talukSelect').value.trim();
    var q = document.getElementById('searchInput').value.trim().toLowerCase();
    var sort = document.getElementById('sortSelect').value;

    filtered = ALL_COLLEGES.filter(c => {
    var mDist = !distId || (c.DistrictId && c.DistrictId.trim() === distId);
    var mTaluk = !talukId || (c.TalukId && c.TalukId.trim() === talukId);
    var mQ = !q || (c.CollegeName || '').toLowerCase().indexOf(q) > -1 || (c.CollegeTown || '').toLowerCase().indexOf(q) > -1;
    return mDist && mTaluk && mQ;
    });

    filtered.sort((a, b) => {
    var nA = (a.CollegeName || '').toLowerCase();
    var nB = (b.CollegeName || '').toLowerCase();
    return sort === 'asc' ? nA.localeCompare(nB) : nB.localeCompare(nA);
    });

    currentPage = 1;
    renderTable();
    }

    function applyFilters() { applyClientFilter(); }
    function resetFilters() {
    document.getElementById('districtSelect').value = '';
    document.getElementById('talukSelect').innerHTML = '<option value="">— Select District First —</option>';
    document.getElementById('talukSelect').disabled = true;
    document.getElementById('searchInput').value = '';
    filtered = ALL_COLLEGES.slice();
    currentPage = 1;
    renderTable();
    }

    function renderTable() {
    var tbody = document.getElementById('tableBody');
    tbody.innerHTML = '';
    var total = filtered.length;

    currentPage = Math.min(
    currentPage,
    Math.max(1, Math.ceil(total / pageSize))
    );

    document.getElementById('countPill').textContent = total + ' COLLEGES';
    var totalPages = Math.max(1, Math.ceil(total / pageSize));
    var start = (currentPage - 1) * pageSize;
    var end = Math.min(start + pageSize, total);
    var slice = filtered.slice(start, end);

    if (slice.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5" class="no-results"><h4>No colleges found</h4></td></tr>';
    } else {
    slice.forEach((c, idx) => {
    var tr = document.createElement('tr');
    tr.innerHTML = `<td class="td-sl">${start + idx + 1}</td>
    <td><div class="td-name">${esc(c.CollegeName)}</div><div class="td-town"><i class="bi bi-geo-alt-fill"></i>${esc(c.CollegeTown)}</div></td>
    <td class="td-center"><span class="seat-badge ${c.UGSeats > 0 ? 'seat-ug' : 'seat-zero'}">${c.UGSeats > 0 ? c.UGSeats : '—'}</span></td>
    <td class="td-center"><span class="seat-badge ${c.PGSeats > 0 ? 'seat-pg' : 'seat-zero'}">${c.PGSeats > 0 ? c.PGSeats : '—'}</span></td>
    <td class="td-center"><button class="view-btn" onclick="openModal('${esc(c.CollegeCode)}','${esc(c.CollegeName)}','${esc(c.CollegeTown)}')"><i class="bi bi-eye"></i> View Details</button></td>`;
    tbody.appendChild(tr);
    });
    }
    document.getElementById('pgInfo').innerHTML = `Showing <strong>${total === 0 ? 0 : start + 1}–${end}</strong> of <strong>${total}</strong> colleges`;
    renderPagination(totalPages);
    }

    function renderPagination(totalPages) {

    var ctrl = document.getElementById('pgControls');
    ctrl.innerHTML = '';

    // Previous
    var prev = mkBtn('<i class="bi bi-chevron-left"></i>', currentPage === 1);

    prev.onclick = function () {
    if (currentPage > 1) {
    currentPage--;
    renderTable();
    }
    };

    ctrl.appendChild(prev);

    for (let p = 1; p <= totalPages; p++) {

    if (
    p === 1 ||
    p === totalPages ||
    (p >= currentPage - 2 && p <= currentPage + 2)
    ) {

    let btn = mkBtn(p, false);

    if (p === currentPage)
    btn.classList.add('active');

    btn.onclick = function () {
    currentPage = p;
    renderTable();
    };

    ctrl.appendChild(btn);
    }
    else if (
    p === currentPage - 3 ||
    p === currentPage + 3
    ) {
    let dots = document.createElement('span');
    dots.innerHTML = '...';
    ctrl.appendChild(dots);
    }
    }

    // Next
    var next = mkBtn(
    '<i class="bi bi-chevron-right"></i>',
    currentPage === totalPages
    );

    next.onclick = function () {
    if (currentPage < totalPages) {
    currentPage++;
    renderTable();
    }
    };

    ctrl.appendChild(next);
    }

    function mkBtn(html, disabled) {
    var b = document.createElement('button'); b.className = 'pg-btn'; b.innerHTML = html; b.disabled = disabled; return b;
    }
    function onPageSizeChange() { pageSize = parseInt(document.getElementById('pgSizeSelect').value); currentPage = 1; renderTable(); }

        function openModal(code, name, town) {
        document.getElementById('mCollegeName').textContent = name;
        document.getElementById('mTown').textContent = town;
        document.getElementById('modalOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';

        // Load data...
        fetch('@Url.Action("GetCollegeDetail", "MedicalSuperAdmin")?collegeCode=' + encodeURIComponent(code))
            .then(r => r.json())
            .then(res => {
                if (res.Success) populateModal(res.Data);
                else document.getElementById('mBody').innerHTML = 'Error loading data';
            });
    }

    function closeModal() {
        document.getElementById('modalOverlay').classList.remove('open');
        document.body.style.overflow = '';
    }


        function populateModal(data) {
        currentModalData = data;
        document.getElementById('mTotalCourses').textContent = data.TotalCourses;
        document.getElementById('mTotalIntake').textContent  = data.TotalIntake;
        document.getElementById('mUGIntake').textContent     = data.UGIntake;
        document.getElementById('mPGIntake').textContent     = data.PGIntake;

        var html = '';
        if (data.UGCourses && data.UGCourses.length > 0) {
            html += `<div class="course-group ug-group">
                <div class="course-sec-head">
                    <h4 style="color:var(--blue-400)"><i class="bi bi-mortarboard"></i> Under Graduate (UG) Courses</h4>
                    <span class="cs-badge cs-badge-ug">${data.UGCourses.length} COURSES</span>
                </div>
                ${buildCourseTable(data.UGCourses, 'ug')}
            </div>`;
        }
        if (data.PGCourses && data.PGCourses.length > 0) {
            html += `<div class="course-group pg-group">
                <div class="course-sec-head">
                    <h4 style="color:#7c3aed"><i class="bi bi-award"></i> Post Graduate (PG) Courses</h4>
                    <span class="cs-badge cs-badge-pg">${data.PGCourses.length} COURSES</span>
                </div>
                ${buildCourseTable(data.PGCourses, 'pg')}
            </div>`;
        }

        if (!html) {
            html = '<div style="padding:40px;text-align:center;color:var(--neutral-400);">No course intake data available.</div>';
        }

        document.getElementById('mBody').innerHTML = html;
        document.getElementById('btnPDF').disabled = false;
    }




    function buildCourseTable(rows, level) {
    var isUG = level === 'ug';
    var h = `<table class="course-tbl"><thead><tr><th>SL</th><th>Course</th><th>Intake</th></tr></thead><tbody>`;
    rows.forEach((r, i) => {
    h += `<tr><td>${i+1}</td><td>${esc(r.CourseName)}</td><td><span class="i-badge ${r.PresentIntake > 0 ? (isUG ? 'i-ug' : 'i-pg') : 'i-zero'}">${r.PresentIntake}</span></td></tr>`;
    });
    return h + '</tbody></table>';
    }

    
    function handleOverlayClick(e) { if (e.target.id === 'modalOverlay') closeModal(); }
    function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function isoDate() { return new Date().toISOString().slice(0,10); }
    function showToast(m) { var t = document.getElementById('toast'); t.innerHTML = m; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 3000); }

    function downloadCollegePDF() {
    if (!currentModalData) return;
    var d = currentModalData;
    var jsPDF = window.jspdf.jsPDF;
    var doc = new jsPDF({ unit: 'mm', format: 'a4' });

    doc.setFillColor(10,22,48); doc.rect(0,0,210,28,'F');
    doc.setTextColor(224,172,42); doc.setFontSize(14); doc.setFont('helvetica','bold');
    doc.text('RGUHS Karnataka', 14, 11);
    doc.setTextColor(255,255,255); doc.setFontSize(11);
    doc.text(d.CollegeName, 14, 19);
    doc.setTextColor(150,170,200); doc.setFontSize(8); doc.setFont('helvetica','normal');
    doc.text((d.CollegeTown||'') + ' | Medical Faculty | Academic Year 2026–27', 14, 26);
    doc.setFillColor(224,172,42); doc.rect(0,28,210,1.5,'F');

    doc.setFillColor(248,249,252); doc.roundedRect(12,32,186,22,2,2,'F');
    doc.setDrawColor(226,230,240); doc.roundedRect(12,32,186,22,2,2,'S');
    [{label:'TOTAL COURSES',value:d.TotalCourses,x:14},{label:'TOTAL INTAKE',value:d.TotalIntake,x:66},
    {label:'UG INTAKE',value:d.UGIntake,x:118},{label:'PG INTAKE',value:d.PGIntake,x:158}]
    .forEach(function(b){
    doc.setFontSize(17);doc.setFont('helvetica','bold');doc.setTextColor(15,34,72);
    doc.text(String(b.value),b.x,44);
    doc.setFontSize(7);doc.setFont('helvetica','normal');doc.setTextColor(120,130,160);
    doc.text(b.label,b.x,50);
    });

    var y = 58;
    function addSection(rows, level, color, labelTxt) {
    if (!rows || !rows.length) return;
    if (y > 240) { doc.addPage(); y = 14; }
    var rgb = level === 'UG' ? [239,246,255] : [253,244,255];
    doc.setFillColor(rgb[0],rgb[1],rgb[2]); doc.rect(12,y,186,7,'F');
    doc.setFontSize(8);doc.setFont('helvetica','bold');doc.setTextColor(color[0],color[1],color[2]);
    doc.text(labelTxt, 16, y+5);
    var intake = rows.reduce(function(s,r){return s+r.PresentIntake;},0);
    doc.text(rows.length + ' COURSES | INTAKE: ' + intake, 180, y+5, {align:'right'});
    y += 9;
    doc.autoTable({
    startY:y,
    head:[['SL.','COURSE NAME','INTAKE']],
    body:rows.map(function(r,i){return [i+1,r.CourseName,r.PresentIntake||0];}),
    styles:{fontSize:9,cellPadding:3},
    headStyles:{fillColor:[15,34,72],textColor:[180,200,230],fontStyle:'bold',fontSize:8},
    alternateRowStyles:{fillColor:rgb},
    columnStyles:{0:{cellWidth:14,halign:'center'},2:{cellWidth:22,halign:'center',fontStyle:'bold',textColor:color}},
    margin:{left:12,right:12}
    });
    y = doc.lastAutoTable.finalY + 6;
    }

    addSection(d.UGCourses, 'UG', [45,98,200], 'UNDER GRADUATE (UG) COURSES');
    addSection(d.PGCourses, 'PG', [124,58,237], 'POST GRADUATE (PG) COURSES');

    var pc = doc.internal.getNumberOfPages();
    for (var i = 1; i <= pc; i++) {
    doc.setPage(i); doc.setFontSize(7); doc.setTextColor(160,160,160);
    doc.text('Data sourced from RGUHS Affiliation Records | Confidential', 14, 290);
    doc.text('Page ' + i + ' of ' + pc, 196, 290, {align:'right'});
    }
    doc.save('RGUHS_' + (d.CollegeName||'College').replace(/[^a-zA-Z0-9]/g,'_').substring(0,40) + '_' + isoDate() + '.pdf');
    showToast('<i class="bi bi-check-circle"></i> College PDF downloaded');
    }

     //════════════════════════════════════════════════════════════════
    // EXCEL — college list
    // ════════════════════════════════════════════════════════════════
    function downloadListExcel() {
    var wb = XLSX.utils.book_new();
    var data = [['Sl.No','College Name','Town','District','Taluk','UG Seats','PG Seats','Total Seats','College Code']];
    filtered.forEach(function (c, i) {
    data.push([i+1, c.CollegeName, c.CollegeTown, c.DistrictName || '', c.TalukName || '',
    c.UGSeats||0, c.PGSeats||0, c.UGSeats + c.PGSeats, c.CollegeCode]);
    });
    var ws = XLSX.utils.aoa_to_sheet(data);
    ws['!cols'] = [{wch:6},{wch:52},{wch:18},{wch:22},{wch:20},{wch:10},{wch:10},{wch:12},{wch:12}];
    XLSX.utils.book_append_sheet(wb, ws, 'Medical Colleges');

    var ugt = filtered.reduce(function(s,c){return s+c.UGSeats;},0);
    var pgt = filtered.reduce(function(s,c){return s+c.PGSeats;},0);
    var ws2 = XLSX.utils.aoa_to_sheet([
    ['RGUHS Medical Colleges — Summary'],
    ['Generated', new Date().toLocaleDateString('en-IN')],
    ['Academic Year','2026–27'],[''],
    ['Total Colleges', filtered.length],
    ['Total UG Seats', ugt],['Total PG Seats', pgt],['Total Seats', ugt+pgt]
    ]);
    ws2['!cols'] = [{wch:25},{wch:15}];
    XLSX.utils.book_append_sheet(wb, ws2, 'Summary');
    XLSX.writeFile(wb, 'RGUHS_Medical_Colleges_' + isoDate() + '.xlsx');
    showToast('<i class="bi bi-check-circle"></i> Excel downloaded');
    }

    function downloadListPDF() {
    var jsPDF = window.jspdf.jsPDF;
    var doc = new jsPDF({ orientation: 'landscape', unit: 'mm', format: 'a4' });

    doc.setFillColor(10,22,48); doc.rect(0,0,297,22,'F');
    doc.setTextColor(224,172,42); doc.setFontSize(13); doc.setFont('helvetica','bold');
    doc.text('RGUHS — Medical Affiliated Colleges', 14, 14);
    doc.setTextColor(180,180,180); doc.setFontSize(8); doc.setFont('helvetica','normal');
    doc.text('Academic Year 2026–27 | Faculty: Medical | Generated: ' + new Date().toLocaleDateString('en-IN'), 14, 20);

    var rows = filtered.map(function (c, i) {
    return [i+1, c.CollegeName, c.CollegeTown, c.DistrictName || '', c.TalukName || '',
    c.UGSeats || '—', c.PGSeats || '—', (c.UGSeats + c.PGSeats) || '—'];
    });

    doc.autoTable({
    startY: 26,
    head: [['Sl.', 'College Name', 'Town', 'District', 'Taluk', 'UG Seats', 'PG Seats', 'Total']],
    body: rows,
    styles: { font: 'helvetica', fontSize: 9, cellPadding: 3 },
    headStyles: { fillColor:[15,34,72], textColor:[200,200,200], fontStyle:'bold', fontSize:8 },
    alternateRowStyles: { fillColor:[248,249,252] },
    columnStyles: {
    0: { cellWidth:12, halign:'center' },
    5: { halign:'center', textColor:[45,98,200], fontStyle:'bold' },
    6: { halign:'center', textColor:[124,58,237], fontStyle:'bold' },
    7: { halign:'center', fontStyle:'bold' }
    },
    margin: { left:14, right:14 }
    });

    var pc = doc.internal.getNumberOfPages();
    for (var i = 1; i <= pc; i++) {
    doc.setPage(i); doc.setFontSize(7); doc.setTextColor(150,150,150);
    doc.text('Page ' + i + ' of ' + pc, doc.internal.pageSize.width / 2,
    doc.internal.pageSize.height - 6, { align: 'center' });
    }
    doc.save('RGUHS_Medical_Colleges_' + isoDate() + '.pdf');
    showToast('<i class="bi bi-check-circle"></i> PDF downloaded');
    }

</script>
