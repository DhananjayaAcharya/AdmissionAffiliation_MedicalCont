@model HospitalAffiliationCompositeViewModel
@{
    ViewData["Title"] = "Clinical Facilites";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
}
@{
    var docsPostModel = new HospitalDocumentsToBeUploadedPostModel
    {
        Documents = Model.HospitalDocumentsToBeUploadedList
    };
}

@functions {
    string FacultyKey(int facultyCode) => facultyCode switch
    {
        3 => "Nursing",
        1 => "Medical",
        _ => "Common"
    };

    object? ResolveSectionModel(string sectionName) => sectionName switch
    {
        "InstructionSet" => null, // static
        "HospitalDetails" => Model.ClinicalHospitalDetails,
        "AffiliatedDocuments" => Model.AffiliatedDocumentsPostVM,
        "ClinicalCapacity" => Model.ClinicalCapacity,
        "FieldPracticeArea" => Model.FieldPracticeAreaPostVM,
        "Facilities" => Model.ClinicalHospitalDetails.HospitalFacilities,
        "IndoorBedsUnits" => Model.IndoorBedsUnitsRequirements,
        "IndoorBedsOccupancy" => Model.IndoorBedsOccupancy,
        "HospitalDocumentsToBeUploaded" => new HospitalDocumentsToBeUploadedPostModel
        {
            Documents = Model.HospitalDocumentsToBeUploadedList
        },
        "IndoorDepartment" => Model.IndoorDepartment,
        "OT" => Model.OTRequirements,
        "CasualityRequirements" => Model.CasualityRequirements,
        "CentralLaboratory" => Model.CentralLaboratoryRequirements,
        "CSSDandLaundryRequirements" => Model.CSSDandLaundryRequirements,
        "RadioDiagnosis" => Model.RadioDiagnosisRequirements,
        "BloodBank" => Model.BloodBankRequirements,
        "Yoga" => Model.YogaRequirements,
        "IndoorBeds" => Model.IndoorBedsOccupancy,
        "Pharmacy" => Model.PharmacyRequirements,
        "Utilities" => Model.UtilitiesRequirements,
        "RadiationOncology" => Model.RadiationOncologyRequirements,
        "Anaesthesiology" => Model.AnaesthesiologyRequirements,
        "ArtCenter" => Model.ArtCenterRequirements,
        "OutPatientArea" => Model.OutPatientRequirements,
        "SuperVisionInFieldPracticeArea" => Model.SuperVisionInFieldPracticeArea,
        _ => null
    };
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Clinical Facilities</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        :root {
            --ink: #0f1923;
            --ink-mid: #2e3d4f;
            --ink-muted: #6b7a8d;
            --border: #d4dae3;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --accent: #1a4c8b;
            --accent-lt: #e8edf7;
            --gold: #c9a84c;
            --radius: 10px;
            --shadow: 0 2px 16px rgba(15,25,35,.07);
        }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--ink);
            min-height: 100vh;
            padding: 0;
            margin: 0;
        }

        /* ─── TOP HEADER ─────────────────────────────── */
        .page-header {
            background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
            padding: 28px 40px 24px;
            display: flex;
            align-items: center;
            gap: 18px;
            border-bottom: 3px solid var(--gold);
        }
        .page-header .emblem {
            width: 54px;
            height: 54px;
            border: 2px solid var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .page-header .emblem svg {
            width: 28px;
            height: 28px;
            fill: var(--gold);
        }
        .page-header-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem;
            color: #ffffff;
            letter-spacing: .02em;
        }
        .page-header-text p {
            font-size: .78rem;
            color: rgba(255,255,255,.55);
            margin-top: 3px;
            letter-spacing: .06em;
            text-transform: uppercase;
        }

        .form-wrap {
            max-width: 1280px;
            margin: 32px auto;
            padding: 0 24px 60px;
        }

        .section-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            margin-bottom: 28px;
            animation: fadeUp .35s ease both;
        }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .form-card {
            border-radius: var(--radius);
            border: 1px solid var(--border);
            background: var(--surface);
            box-shadow: var(--shadow);
        }

        .form-header {
            background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
            color: #ffffff;
            padding: 1.25rem 1.5rem;
            border-bottom: 3px solid var(--gold);
        }

        .section-body {
            padding: 1.25rem;
        }

        .form-section {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 1.25rem;
            margin-bottom: 1.5rem;
        }

        .section-title {
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: 1rem;
            border-left: 4px solid var(--accent);
            padding-left: 12px;
        }

        label {
            font-weight: 500;
            color: var(--ink-mid);
            margin-bottom: 0.4rem;
        }

        .form-control,
        .form-select {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.875rem;
            color: var(--ink);
            background: #fafbfc;
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 9px 13px;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--accent);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,76,139,.1);
        }

        .btn {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            border-radius: 8px;
            padding: 10px 26px;
            cursor: pointer;
            letter-spacing: .03em;
            transition: all .18s;
        }

        .btn-primary {
            background: linear-gradient(135deg, #1a4c8b, #1564c0);
            color: #fff;
            box-shadow: 0 3px 14px rgba(26,76,139,.3);
        }

        .btn-primary:hover {
            box-shadow: 0 5px 20px rgba(26,76,139,.4);
            transform: translateY(-1px);
        }

        .btn-success {
            background: linear-gradient(135deg, #1a4c8b, #1564c0);
            color: #fff;
        }

        @@media (max-width: 576px) {
            .section-title {
                font-size: 1rem;
            }
        }

        .input-error {
            border: 2px solid #c0392b !important;
            background: #fdecea;
        }

        .required::after {
            content: " *";
            color: #c0392b;
            font-weight: bold;
        }

        .navigation-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 24px;
            border-top: 1px solid var(--border);
            margin-top: 20px;
        }
    </style>
</head>

<body>

    <!-- Modern Page Header -->
    <div class="page-header">
        <div class="emblem">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM19 19H5V5H19V19ZM12 7C10.34 7 9 8.34 9 10C9 11.66 10.34 13 12 13C13.66 13 15 11.66 15 10C15 8.34 13.66 7 12 7ZM17 17H7V15.88C7 14.63 9.5 13.88 12 13.88C14.5 13.88 17 14.63 17 15.88V17Z" />
            </svg>
        </div>
        <div class="page-header-text">
            <h1>Clinical Facilities</h1>
            <p>Affiliation &amp; Recognition Portal — Hospital &amp; Clinical Infrastructure</p>
        </div>
    </div>

    <div class="form-wrap">
        <div class="card shadow-lg form-card">
            <div class="form-header text-center">
                <h5 class="mb-0">Hospital Details For Affiliation</h5>
            </div>

            <div class="card-body" id="formScrollContainer">

                <input asp-for="@Model.FacultyCode" type="hidden" value="@Model.FacultyCode" />
                <input asp-for="@Model.CollegeCode" type="hidden" value="@Model.CollegeCode" />

                <div id="clinicalFacilitiesSection">
                    @foreach (var section in Model.Sections.FirstOrDefault(s => s.Name == "ClinicalSection")?.SubSections ?? Enumerable.Empty<string>())
                    {
                        var facultyKey = FacultyKey(Model.FacultyCode);
                        var partialPath = $"Sections/ClinicalSection/{section}/_{facultyKey}";

                        var sectionModel = ResolveSectionModel(section);
                        <div class="sub-section" id="@(section)">
                            @if (sectionModel == null)
                            {
                                @await Html.PartialAsync(partialPath)
                            }
                            else
                            {
                                @await Html.PartialAsync(partialPath, sectionModel)
                            }
                        </div>
                    }

                    <!-- Navigation -->
                    <div class="navigation-bar">
                        <a href="#" class="btn btn-ghost">← Previous</a>
                        <a href="@Url.Action("CA_VehicleDetails", "Aff_AHS_ContinousApplication")" 
                           class="btn btn-primary">Next →</a>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>