@model Medical_Affiliation.Models.OTRequirementsPostVM
<style>
    .separation {
        margin: 0.5rem 0;
        border: 1px solid #d0d0d0d6;
        border-radius: 5px;
        padding: 5px;
    }
</style>
@* Anti-forgery token *@
<div class="form-section">
    <div class="section-title required">
        Operation Theater Requirements
    </div>
    <form id="operationTheatreForm" class="mt-3">
        @Html.AntiForgeryToken()
            @* Hidden fields *@
            <input type="hidden" id="CollegeCode" value="@Model.CollegeCode" />
            <input type="hidden" id="FacultyCode" value="@Model.FacultyCode" />
            <input type="hidden" id="AffiliationTypeId" value="@Model.AffiliationTypeId" />
            <input type="hidden" id="HospitalDetailsId" value="@Model.HospitalDetailsId" />

            @if (Model.Requirements != null && Model.Requirements.Any())
            {
                @for (int i = 0; i < Model.Requirements.Count; i++)
                {
                    <div class="col-md-12 d-flex align-items-center justify-content-between separation">
                        <label class="form-check-label"
                           for="req_@Model.Requirements[@i].RequirementId">
                        @Model.Requirements[@i].RequirementName
                        </label>
                    <input type="hidden" asp-for="Requirements[@i].RequirementName" />
                    <input type="hidden" asp-for="Requirements[@i].RequirementId" />

                        <div class="d-flex gap-3">
                            <label>
                                <input type="radio"
                                       class="ot-radio"
                                       name="req_@Model.Requirements[i].RequirementId"
                                       data-id="@Model.Requirements[i].RequirementId"
                                       data-name="@Model.Requirements[i].RequirementName"
                                       value="true"
                                       @(Model.Requirements[i].IsAvailable ? "checked" : "") />
                                Yes
                            </label>

                            <label>
                                <input type="radio"
                                       class="ot-radio"
                                       name="req_@Model.Requirements[i].RequirementId"
                                       data-id="@Model.Requirements[i].RequirementId"
                                       data-name="@Model.Requirements[i].RequirementName"
                                       value="false"
                                       @(!Model.Requirements[i].IsAvailable ? "checked" : "") />
                                No
                            </label>
                        </div>


                    </div>
                }
            }
            else
            {
                <p class="text-muted">No Operation Theatre requirements available.</p>
            }

            @* <div class="mt-3 text-end">
                <button type="button"
                        class="btn btn-primary"
                        onclick="saveOperationTheatreRequirements()">
                    Save
                </button>
            </div> *@
        <div class="text-center mt-3">
            <button type="button"
                    id="SaveOTBtn"
                    class="btn btn-primary">
                Save Operation Requirements
            </button>
        </div>

        </fieldset>
    </form>
</div>
<script>
      document.getElementById('SaveOTBtn').addEventListener('click', saveOperationTheatreRequirements);

    function saveOperationTheatreRequirements() {

        const token =
            document.querySelector('input[name="__RequestVerificationToken"]').value;

        const requirements = [];

        document.querySelectorAll('.ot-radio:checked').forEach(radio => {
            requirements.push({
                requirementId: parseInt(radio.dataset.id),
                requirementName: radio.dataset.name,
                isAvailable: radio.value === "true"
            });
        });

        const payload = {
            collegeCode: document.getElementById('CollegeCode').value,
            facultyCode: parseInt(document.getElementById('FacultyCode').value),
            affiliationTypeId: parseInt(document.getElementById('AffiliationTypeId').value),
            hospitalDetailsId: parseInt(document.getElementById('HospitalDetailsId').value),
            Requirements: requirements
        };

        fetch('@Url.Action("SaveOperationTheatreRequirements", "ContinuationAffiliationClinicalFacilities")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (!response.ok)
                throw new Error('Request failed');
            return response.json();
        })
        .then(result => {
            if (result.success) {
                Swal.fire({
                    icon: "success",
                    title: "saved",
                    text: result.message || 'Operation Theater requirements saved successfully',
                    confirmButtonText: 'OK'
                });
            } else {
                Swal.fire({
                    icon: "error",
                    title: "Failed",
                    text: result.message || 'Failed to save Operation Theater requirements',
                    confirmButtonText: 'OK'
                });
            }
        })
        .catch(error => {
            console.error(error);
            Swal.fire({
                icon: "error",
                title: "Error",
                text: 'Error while saving data.',
                confirmButtonText: 'OK'
            })
        });
    }
</script>
