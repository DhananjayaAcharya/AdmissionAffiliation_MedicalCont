@model ClinicalCapacityViewModel

<div class="form-section">
    <div class="section-title">Capacity & Statistics</div>

    <form id="capacityForm" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Form.HospitalDetailsId" />
        <input type="hidden" asp-for="Form.CollegeCode" />
        <input type="hidden" asp-for="Form.FacultyCode" />
        <input type="hidden" asp-for="Form.AffiliationTypeId" />

        <div class="row g-3">

            <div class="col-md-4">
                <label class="required">Dental Chairs Count</label>
                <input asp-for="Form.DentalChairsCount"
                       class="form-control"
                       placeholder="Enter Number of Dental Chairs" />
            </div>

            <div class="col-md-4">
                <label class="required">Total Beds</label>
                <input asp-for="Form.TotalBeds"
                       class="form-control"
                       placeholder="Enter Total Number of Beds" />
            </div>

            <div class="col-md-4">
                <label class="required">OPD / Day</label>
                <input asp-for="Form.OpdperDay"
                       class="form-control"
                       placeholder="Enter Average OPD per Day" />
            </div>

            <div class="col-md-4">
                <label class="required">IPD Occupancy (%)</label>
                <input asp-for="Form.IpdbedOccupancyPercent" class="form-control" placeholder="Enter IPD Bed Occupancy %" />
            </div>

            <div class="col-md-4">
                <label class="required">Annual OPD (Prev. Year)</label>
                <input asp-for="Form.AnnualOpdprevYear" class="form-control" placeholder="Enter Annual OPD of Previous Year" />
            </div>

            <div class="col-md-4">
                <label class="required">Annual IPD (Prev. Year)</label>
                <input asp-for="Form.AnnualIpdprevYear" class="form-control" placeholder="Enter Annual IPD of Previous Year" />
            </div>

            <div class="col-md-4">
                <label class="required">Distance from College (KM)</label>
                <input asp-for="Form.DistanceBetweenCollegeAndHospitalKm" class="form-control" placeholder="Enter Distance" />
            </div>

            <div class="col-md-8">
                <label class="required">Owner is Member of Trust</label>

                <select asp-for="Form.IsOwnerAmemberOfTrust"
                        asp-items="@(new SelectList(Model.IsOwnerAmemberOfTrustOptions, "Value", "Text"))"
                        class="form-select">

                    <option value="">Select</option>
                </select>
            </div>

            <div class="col-md-6">
                <label class="required">24-Hour Emergency Services Available</label>

                <select asp-for="Form.Has24HourEmergency" class="form-select">
                    <option value="">Select</option>

                    @if (Model.Form.Has24HourEmergency == true)
                    {
                        <option value="true" selected>Yes</option>
                        <option value="false">No</option>
                    }
                    else if (Model.Form.Has24HourEmergency == false)
                    {
                        <option value="true">Yes</option>
                        <option value="false" selected>No</option>
                    }
                    else
                    {
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="required">Critical Care / ICU Services Available</label>

                <select asp-for="Form.HasCriticalCareServices" class="form-select">
                    <option value="">Select</option>
                    @if(Model.Form.HasCriticalCareServices == true)
                    {
                        <option value="true" selected>Yes</option>
                        <option value="false">No</option>
                    }
                    else if (Model.Form.HasCriticalCareServices == false)
                    {
                        <option value="true">Yes</option>
                        <option value="false" selected>No</option>
                    }
                    else
                    { 
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    }
                </select>
            </div>
        </div>

        <div class="text-center mt-3">
            <button type="button" id="saveCapacityBtn" class="btn btn-primary">Save Clinical Capacity</button>
        </div>
    </form>
</div>

<script>
    document.getElementById("saveCapacityBtn").addEventListener("click", function () {
        const form = document.getElementById("capacityForm");
        const formData = new FormData(form);

        fetch('@Url.Action("SaveClinicalCapacity")', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            }
        })
        .then(res => {
            if (!res.ok) throw res;
            return res.json();
        })
        .then(data => {
            Swal.fire("Success", data.message, "success");
        })
        .catch(async err => {
            if (err.json) {
                const errData = await err.json();
                // Custom controller message
                if (errData.message) {
                    Swal.fire({
                        icon: "error",
                        title: "Error",
                        text: errData.message
                    });
                    return;
                }

                // Validation errors
                let errors = [];

                if (errData.errors) {
                    errData.errors.forEach(e => {
                        errors.push(...e.messages);
                    });
                    Swal.fire({
                        icon: "error",
                        title: "Validation Errors",
                        html: errors.join("<br>")
                    });
                }

            } else {

                Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: "Failed to save section."
                });
            }
        });
    });
</script>
