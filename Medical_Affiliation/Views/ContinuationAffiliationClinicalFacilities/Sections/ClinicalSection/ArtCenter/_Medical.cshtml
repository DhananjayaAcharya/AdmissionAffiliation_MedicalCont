@model Medical_Affiliation.Models.ArtCenterRequirementsPostVM
<style>
    .separation {
        margin: 0.5rem 0;
        border: 1px solid #d0d0d0d6;
        border-radius: 5px;
        padding: 5px;
    }
</style>
@* Anti-forgery token *@
<div class="form-section">
    <div class="section-title required">
        Art Center Requirements
    </div>
    <form id="ArtCenterForm" class="mt-3">
        @Html.AntiForgeryToken()
        @* Hidden fields *@
        <input type="hidden" id="CollegeCode" value="@Model.CollegeCode" />
        <input type="hidden" id="FacultyCode" value="@Model.FacultyCode" />
        <input type="hidden" id="AffiliationTypeId" value="@Model.AffiliationTypeId" />
        <input type="hidden" id="HospitalDetailsId" value="@Model.HospitalDetailsId" />

        @if (Model.Requirements != null && Model.Requirements.Any())
        {
            for (int i = 0; i < Model.Requirements.Count; i++)
            {
                <div class="col-md-12 d-flex align-items-center justify-content-between separation">

                    <label class="form-check-label"
                           for="req_@Model.Requirements[i].RequirementId">
                        @Model.Requirements[i].RequirementName
                    </label>

                    <div class="d-flex gap-3">
                        <label>
                            <input type="radio"
                                   class="ArtCenter-radio"
                                   name="req_@Model.Requirements[i].RequirementId"
                                   data-id="@Model.Requirements[i].RequirementId"
                                   data-name="@Model.Requirements[i].RequirementName"
                                   value="true"
                                   @(Model.Requirements[i].IsAvailable ? "checked" : "") />
                            Yes
                        </label>

                        <label>
                            <input type="radio"
                                   class="ArtCenter-radio"
                                   name="req_@Model.Requirements[i].RequirementId"
                                   data-id="@Model.Requirements[i].RequirementId"
                                   data-name="@Model.Requirements[i].RequirementName"
                                   value="false"
                                   @(!Model.Requirements[i].IsAvailable ? "checked" : "") />
                            No
                        </label>
                    </div>


                    @* <input class="form-check-input ArtCenter-checkbox"
                           type="checkbox"
                           id="req_@Model.Requirements[i].RequirementId"
                           data-id="@Model.Requirements[i].RequirementId"
                           data-name="@Model.Requirements[i].RequirementName"
                           @(Model.Requirements[i].IsAvailable ? "checked" : "") /> *@
                </div>
            }
        }
        else
        {
            <p class="text-muted">No Art Center Requirements available.</p>
        }
        <div class="text-center mt-3">
            <button type="button"
                    id="SaveArtCenterBtn"
                    class="btn btn-primary">
                Save Art Center Requirements
            </button>
        </div>

        </fieldset>
    </form>
</div>
<script>
      document.getElementById('SaveArtCenterBtn').addEventListener('click', saveArtCenterRequirements);

    function saveArtCenterRequirements() {

        const token =
            document.querySelector('input[name="__RequestVerificationToken"]').value;

        const requirements = [];

        // document.querySelectorAll('.ArtCenter-checkbox').forEach(cb => {
        //     requirements.push({
        //         requirementId: parseInt(cb.dataset.id),
        //         requirementName: cb.dataset.name,
        //         isAvailable: cb.checked
        //     });
        // });

        document.querySelectorAll('.ArtCenter-radio:checked').forEach(radio => {
            requirements.push({
                requirementId: parseInt(radio.dataset.id),
                requirementName: radio.dataset.name,
                isAvailable: radio.value === "true"
            });
        });
        // debugger;
        const payload = {
            collegeCode: document.getElementById('CollegeCode').value,
            facultyCode: parseInt(document.getElementById('FacultyCode').value),
            affiliationTypeId: parseInt(document.getElementById('AffiliationTypeId').value),
            hospitalDetailsId: parseInt(document.getElementById('HospitalDetailsId').value),
            Requirements: requirements
        };

        fetch('@Url.Action("SaveArtCenterRequirements", "ContinuationAffiliationClinicalFacilities")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (!response.ok)
                throw new Error('Request failed');
            return response.json();
        })
        .then(result => {
            if (result.success) {
                Swal.fire({
                    icon: "success",
                    title: "saved",
                    text: result.message || 'Art Center saved successfully',
                    confirmButtonText: 'OK'
                });
            } else {
                Swal.fire({
                    icon: "error",
                    title: "Failed",
                    text: result.message || 'Failed to save Art Center Requirements',
                    confirmButtonText: 'OK'
                });
            }
        })
        .catch(error => {
            console.error(error);
            Swal.fire({
                icon: "error",
                title: "Error",
                text: 'Error while saving Art Center Requirements data.',
                confirmButtonText: 'OK'
            })
        });
    }
</script>
