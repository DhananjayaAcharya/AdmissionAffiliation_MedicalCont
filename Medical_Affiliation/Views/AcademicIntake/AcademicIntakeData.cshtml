@model AcademicIntakePageViewModel1
@{
    ViewData["Title"] = "Academic Intake Data Submission";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-xl py-5 position-relative">
    <!-- Home / Dashboard Button - Top Right -->
    <a href="@Url.Action("Dashboard", "CollegeLogin")"
       class="btn btn-outline-secondary position-absolute top-0 end-0 mt-2 me-3 shadow-sm"
       title="Go to College Dashboard">
        <i class="bi bi-house-door-fill me-1"></i> Home / Dashboard
    </a>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Success:</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <strong>Error:</strong> Please correct the errors below.
            <ul class="mb-0 mt-2">
                @foreach (var entry in ViewData.ModelState)
                {
                    foreach (var error in entry.Value.Errors)
                    {
                        <li>@error.ErrorMessage</li>
                    }
                }
            </ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="AcademicIntakeData" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="FacultyCode" />
        <input type="hidden" asp-for="CollegeCode" />
        <input type="hidden" asp-for="CollegeName" />
        <input type="hidden" asp-for="FacultyId" />

        <!-- Tabs -->
        <ul class="nav nav-tabs nav-fill mb-4 border-bottom-0" id="intakeTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold py-3" id="ug-tab" data-bs-toggle="tab" data-bs-target="#ug" type="button" role="tab" aria-selected="true">UG (Under Graduate)</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold py-3" id="pg-tab" data-bs-toggle="tab" data-bs-target="#pg" type="button" role="tab">PG (Post Graduate)</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold py-3" id="ss-tab" data-bs-toggle="tab" data-bs-target="#ss" type="button" role="tab">SS (Super Specialty)</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold py-3" id="saved-tab" data-bs-toggle="tab" data-bs-target="#saved" type="button" role="tab">Saved Records</button>
            </li>
        </ul>

        <div class="tab-content border border-top-0 rounded-bottom shadow-sm mb-5" id="intakeTabContent">

            <!-- UG Tab -->
            <div class="tab-pane fade show active p-0" id="ug">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0 fw-bold">Under Graduate (UG) – Intake & Approval Details</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                            <h6 class="mb-0 fw-bold">Additional Courses</h6>
                            <a asp-action="AddCourse" asp-controller="LatestMedicalAffiliation" class="btn btn-outline-primary">
                                <i class="bi bi-plus-circle me-1"></i> Add New Course
                            </a>
                        </div>

                        @if (!Model.UgCourses.Any())
                        {
                            <div class="alert alert-info text-center py-4">
                                No UG courses configured for this institution.
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th rowspan="3" class="align-middle sticky-start border-end text-dark fw-bold"
                                                style="min-width:160px; width:160px; background:#e9ecef; z-index:2;">
                                                Course Name
                                            </th>
                                            <th colspan="1" class="text-center fw-bold" style="background:#f1f5f9; min-width:110px;">2024–25</th>
                                            <th colspan="5" class="text-center fw-bold" style="background:#dbeafe; min-width:140px;">2025–26</th>
                                            <th colspan="3" class="text-center fw-bold" style="background:#d4edda; min-width:140px;">2026–27</th>
                                        </tr>
                                        <tr>
                                            <th class="text-center" style="background:#f1f5f9; min-width:110px;">Existing</th>
                                            <th class="text-center" style="background:#dbeafe; min-width:140px;">Existing</th>
                                            <th class="text-center" style="background:#dbeafe; min-width:160px;">LOP/NMC Increase Intake</th>
                                            <th class="text-center" style="background:#dbeafe; min-width:140px;">Total</th>
                                            <th class="text-center" style="background:#dbeafe; min-width:180px;">NMC Document</th>
                                            <th class="text-center" style="background:#dbeafe; min-width:160px;">Date of LOP</th>
                                            <th class="text-center" style="background:#d4edda; min-width:140px;">Existing</th>
                                            <th class="text-center" style="background:#d4edda; min-width:160px;">Add. Course Requested</th>
                                            <th class="text-center" style="background:#d4edda; min-width:140px;">Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.UgCourses.Count; i++)
                                        {
                                            var course = Model.UgCourses[i];
                                            <tr>
                                                <td class="sticky-start border-end fw-medium"
                                                    style="min-width:160px; width:160px; background:#f8f9fa; z-index:1;">
                                                    @Html.HiddenFor(m => m.UgCourses[i].CourseCode)
                                                    @Html.HiddenFor(m => m.UgCourses[i].CourseName)
                                                    @course.CourseName
                                                </td>

                                                <td class="text-end fw-bold" style="background:#f1f5f9; color:#495057; min-width:110px;">
                                                    @Html.HiddenFor(m => m.UgCourses[i].AY2024_ExistingIntake)
                                                    @Model.UgCourses[i].AY2024_ExistingIntake
                                                </td>

                                                <td class="text-end fw-bold" style="background:#eff6ff; color:#1e40af; min-width:140px;">
                                                    @Html.HiddenFor(m => m.UgCourses[i].AY2025_ExistingIntake)
                                                    @Model.UgCourses[i].AY2025_ExistingIntake
                                                </td>

                                                <td style="background:#eff6ff; padding:0.4rem 0.5rem !important;">
                                                    <input asp-for="UgCourses[i].AY2025_LopNmcIntake"
                                                           class="form-control form-control-xs text-end lop-input"
                                                           type="text"
                                                           maxlength="3"
                                                           inputmode="numeric"
                                                           pattern="[0-9]*"
                                                           data-row-index="@i" />
                                                </td>

                                                <td style="background:#eff6ff; padding:0.4rem 0.5rem !important;">
                                                    <input asp-for="UgCourses[i].AY2025_TotalIntake"
                                                           class="form-control form-control-xs text-end readonly-total"
                                                           readonly />
                                                </td>

                                                <td style="background:#eff6ff; min-width:180px; padding:0.4rem 0.5rem !important;">
                                                    <div class="nmc-container position-relative" data-row-index="@i">
                                                        <input type="file" name="UgCourses[@i].AY2025_NmcDocument"
                                                               class="form-control form-control-xs nmc-file"
                                                               accept=".pdf" />
                                                        @if (!string.IsNullOrEmpty(course.AY2025_NmcDocumentUrl))
                                                        {
                                                            <div class="mt-1 small">
                                                                <span class="badge bg-success">Uploaded</span>
                                                                <a href="@course.AY2025_NmcDocumentUrl" target="_blank" class="ms-2 small">View</a>
                                                            </div>
                                                            <small class="text-muted d-block mt-1">Leave empty to keep current</small>
                                                        }
                                                        <div class="error-message mt-1 small fw-bold">NMC document required</div>
                                                    </div>
                                                </td>

                                                <td style="background:#eff6ff; min-width:160px; padding:0.4rem 0.5rem !important;">
                                                    <div class="date-container position-relative" data-row-index="@i">
                                                        <input asp-for="UgCourses[i].AY2025_LopDate"
                                                               class="form-control form-control-xs lop-date"
                                                               type="date" />
                                                        <div class="error-message mt-1 small fw-bold">LOP date required</div>
                                                    </div>
                                                </td>

                                                <!-- 2026–27 Existing - carry forward from 2025–26 Total -->
                                                <td class="text-end fw-bold" style="background:#e8f5e9; color:#155724; min-width:140px;">
                                                    @Html.HiddenFor(m => m.UgCourses[i].AY2026_ExistingIntake)
                                                    @Model.UgCourses[i].AY2026_ExistingIntake
                                                </td>

                                                <td style="background:#e8f5e9; padding:0.4rem 0.5rem !important;">
                                                    <input asp-for="UgCourses[i].AY2026_AddRequestedIntake"
                                                           class="form-control form-control-xs text-end"
                                                           type="text"
                                                           maxlength="3"
                                                           inputmode="numeric"
                                                           pattern="[0-9]*" />
                                                </td>

                                                <td style="background:#e8f5e9; padding:0.4rem 0.5rem !important;">
                                                    <input asp-for="UgCourses[i].AY2026_TotalIntake"
                                                           class="form-control form-control-xs text-end readonly-total"
                                                           readonly />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-light text-end py-3">
                        <button type="submit" name="saveSection" value="UG" class="btn btn-primary px-5 fw-bold">
                            <i class="bi bi-floppy me-2"></i> SAVE UG INTAKE
                        </button>
                    </div>
                </div>
            </div>

