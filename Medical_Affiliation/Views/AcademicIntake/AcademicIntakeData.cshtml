                                                           pattern="[0-9]*" />
                                                </td>

                                                <td style="background:#e8f5e9; padding:0.4rem 0.5rem !important;">
                                                    <input asp-for="SsCourses[i].AY2026_TotalIntake"
                                                           class="form-control form-control-xs text-end readonly-total"
                                                           readonly />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-light text-end py-3">
                        <button type="submit" name="saveSection" value="SS" class="btn btn-info px-5 fw-bold text-white">
                            <i class="bi bi-floppy me-2"></i> SAVE SS INTAKE
                        </button>
                    </div>
                </div>
            </div>

            <!-- Saved Records Tab -->
            <div class="tab-pane fade p-4" id="saved">
                <div class="card border border-dark border-2 shadow">
                    <div class="card-header bg-secondary text-white py-3">
                        <h5 class="mb-0 fw-bold">Previously Saved Intake Records</h5>
                    </div>
                    <div class="card-body">
                        @if (!Model.SavedIntakes.Any())
                        {
                            <div class="alert alert-info text-center py-4">
                                No previously saved intake records found.
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered table-striped table-hover">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Sl No.</th>
                                            <th>Level</th>
                                            <th>Course Name</th>
                                            <th class="text-end">AY 2025-26 Total</th>
                                            <th class="text-end">AY 2026-27 Total</th>
                                            <th>NMC Doc</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.SavedIntakes.Count; i++)
                                        {
                                            var item = Model.SavedIntakes[i];
                                            <tr>
                                                <td>@(i + 1)</td>
                                                <td>@item.CourseLevel</td>
                                                <td>@item.CourseName</td>
                                                <td class="text-end">@item.AY2025_TotalIntake</td>
                                                <td class="text-end">@item.AY2026_TotalIntake</td>
                                                <td>
                                                    @if (item.HasNmcDocument)
                                                    {
                                                        <span class="badge bg-success">Yes</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">No</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <style>
        .form-control-xs {
            padding: 0.25rem 0.5rem;
            font-size: 0.875rem;
            line-height: 1.25;
            border-radius: 0.25rem;
            height: calc(1.25rem + 0.5rem + 2px);
        }

            .form-control-xs.text-end {
                padding-right: 0.6rem;
            }

        input.form-control-xs {
            width: 100%;
            min-width: 60px;
            max-width: 100%;
        }

        .readonly-total {
            background-color: #f0f9ff !important;
            font-weight: 700 !important;
            color: #1d4ed8 !important;
            border: 2px solid #93c5fd !important;
            pointer-events: none;
        }

        .sticky-start {
            position: sticky;
            left: 0;
            z-index: 1;
            background-color: inherit;
        }

        tr:hover {
            background-color: #f1f5f9 !important;
        }

        .form-control-xs:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,.25);
        }

        .error-message {
            color: #dc3545;
            font-size: 0.78rem;
            display: none;
            margin-top: 3px;
        }

        .field-error {
            border-color: #dc3545 !important;
            background-color: #fff5f5 !important;
        }

        .row-invalid .error-message {
            display: block;
        }
    </style>

    <script>
        function updateRow(row) {
            // ──────────────────────────────
            // 2025–26 calculation
            // ──────────────────────────────
            const ex2025Hidden = row.querySelector('input[name$=".AY2025_ExistingIntake"]');
            const ex2025 = parseInt(ex2025Hidden?.value || '0', 10);

            const lopInput = row.querySelector('.lop-input');
            const lop = parseInt(lopInput?.value || '0', 10);

            const total2025 = ex2025 + lop;
            row.querySelector('input[name$=".AY2025_TotalIntake"]').value = total2025;

            // ──────────────────────────────
            // 2026–27 Existing = 2025–26 Total  (automatic carry forward)
            // ──────────────────────────────
            const ex2026Hidden = row.querySelector('input[name$=".AY2026_ExistingIntake"]');
            const ex2026Display = row.cells[7]; // column index of 2026 Existing display

            if (ex2026Hidden) {
                ex2026Hidden.value = total2025;
            }
            if (ex2026Display) {
                ex2026Display.textContent = total2025;
            }

            // ──────────────────────────────
            // 2026–27 Total
            // ──────────────────────────────
            const add2026Input = row.querySelector('input[name$=".AY2026_AddRequestedIntake"]');
            const add2026 = parseInt(add2026Input?.value || '0', 10);

            const total2026 = total2025 + add2026;
            row.querySelector('input[name$=".AY2026_TotalIntake"]').value = total2026;

            // Validation logic (required fields when increase > 0)
            validateRequiredFields(row, lop > 0);
        }

        function validateRequiredFields(row, hasIncrease) {
            const fileInput = row.querySelector('input[type="file"]');
            const dateInput = row.querySelector('input[type="date"]');
            const nmcContainer = fileInput?.closest('.nmc-container');
            const dateContainer = dateInput?.closest('.date-container');

            if (!fileInput || !dateInput) return;

            if (hasIncrease) {
                fileInput.required = true;
                dateInput.required = true;

                const fileValid = fileInput.files?.length > 0 || !!fileInput.dataset.hasPrevious;
                if (!fileValid) {
                    fileInput.classList.add('field-error');
                    nmcContainer?.classList.add('row-invalid');
                } else {
                    fileInput.classList.remove('field-error');
                    nmcContainer?.classList.remove('row-invalid');
                }

                if (!dateInput.value) {
                    dateInput.classList.add('field-error');
                    dateContainer?.classList.add('row-invalid');
                } else {
                    dateInput.classList.remove('field-error');
                    dateContainer?.classList.remove('row-invalid');
                }
            } else {
                fileInput.required = false;
                dateInput.required = false;
                fileInput.classList.remove('field-error');
                dateInput.classList.remove('field-error');
                nmcContainer?.classList.remove('row-invalid');
                dateContainer?.classList.remove('row-invalid');
            }
        }

        let debounceTimer;
        document.addEventListener('input', e => {
            const input = e.target;
            if (!input.closest('tbody')) return;
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                const row = input.closest('tr');
                if (row) updateRow(row);
            }, 180);
        }, true);

        document.querySelector('form')?.addEventListener('submit', e => {
            let hasError = false;
            document.querySelectorAll('tbody tr').forEach(row => {
                const lopVal = parseInt(row.querySelector('.lop-input')?.value || '0', 10);
                if (lopVal > 0) {
                    const fileInput = row.querySelector('input[type="file"]');
                    const dateInput = row.querySelector('input[type="date"]');
                    if (fileInput && !fileInput.files?.length && !fileInput.dataset.hasPrevious) {
                        hasError = true;
                        fileInput.classList.add('field-error');
                        fileInput.closest('.nmc-container')?.classList.add('row-invalid');
                    }
                    if (dateInput && !dateInput.value) {
                        hasError = true;
                        dateInput.classList.add('field-error');
                        dateInput.closest('.date-container')?.classList.add('row-invalid');
                    }
                }
            });

            if (hasError) {
                e.preventDefault();
                alert('Please upload NMC document and select LOP date where LOP/NMC Increase Intake > 0.');
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('tbody tr').forEach(row => {
                updateRow(row);
            });
        });
    </script>
}