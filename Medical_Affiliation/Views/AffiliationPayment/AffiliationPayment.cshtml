@model AffiliationPaymentViewModel

@{
    ViewData["Title"] = "Affiliation Payment";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PG Course Affiliation</title>
    <style>
            /* ================= ROOT ================= */
            :root {
                --ink: #0f1923;
                --ink-mid: #2e3d4f;
                --ink-muted: #6b7a8d;
                --border: #d4dae3;
                --bg: #f4f6f9;
                --surface: #ffffff;
                --accent: #1a4c8b;
                --accent-lt: #e8edf7;
                --gold: #c9a84c;
                --radius: 10px;
                --shadow: 0 2px 16px rgba(15,25,35,.07);
            }

            /* ================= BODY ================= */
            body {
                font-family: 'DM Sans', sans-serif;
                background: var(--bg);
                color: var(--ink);
            }

            /* ================= HEADER ================= */
            .page-header {
                background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
                padding: 26px 36px;
                display: flex;
                align-items: center;
                gap: 16px;
                border-bottom: 3px solid var(--gold);
            }

            .page-header-text h1 {
                font-family: 'Playfair Display', serif;
                font-size: 1.4rem;
                color: #fff;
            }

            .page-header-text p {
                font-size: .75rem;
                color: rgba(255,255,255,.6);
                letter-spacing: .05em;
            }

            /* ================= WRAPPER ================= */
            .form-wrap {
                max-width: 1200px;
                margin: 30px auto;
                padding: 0 20px 60px;
            }

            .section-body {
                padding: 16px 20px;
            }

            /* ================= CARD ================= */
            .section-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                margin-bottom: 25px;
                overflow: hidden;
            }

            /* ================= HEADER ================= */
            .section-header {
                padding: 14px 22px;
                display: flex;
                align-items: center;
                gap: 12px;
                border-bottom: 1px solid var(--border);
                background: #fafbfc;
            }

                .section-header h2 {
                    font-size: 1rem;
                    font-weight: 600;
                }

            /* ================= TABLE ================= */
            .scrollable-table-container {
                max-height: 350px;
                overflow-y: auto;
                border-radius: 8px;
            }

            .custom-table {
                width: 100%;
                border-collapse: collapse;
            }

                .custom-table thead {
                    position: sticky;
                    top: 0;
                    background: #f8f9fc;
                    z-index: 2;
                }

                .custom-table th {
                    padding: 12px;
                    font-size: 0.75rem;
                    text-transform: uppercase;
                    color: var(--ink-mid);
                    border-bottom: 1px solid var(--border);
                }

                .custom-table td {
                    padding: 10px;
                    border-bottom: 1px solid var(--border);
                }

                .custom-table tr:hover {
                    background: #f8fbff;
                }

            /* ================= INPUT ================= */
            input[type="text"],
            input[type="number"],
            input[type="date"] {
                width: 100%;
                padding: 8px 10px;
                border: 1px solid var(--border);
                border-radius: 6px;
                background: #fafbfc;
                font-size: 0.85rem;
            }

            input:focus {
                border-color: var(--accent);
                background: #fff;
                box-shadow: 0 0 0 2px rgba(26,76,139,.1);
            }

            /* ================= FILE ================= */
            input[type="file"] {
                display: none;
            }

            .custom-upload-btn {
                background: #f1f3f7;
                border: 1px solid var(--border);
                padding: 7px 14px;
                border-radius: 6px;
                font-size: 0.8rem;
                cursor: pointer;
            }

                .custom-upload-btn:hover {
                    background: var(--accent-lt);
                    color: var(--accent);
                }

            /* ================= BUTTON ================= */
            .btn-primary {
                background: linear-gradient(135deg, #1a4c8b, #1564c0);
                color: white;
                border: none;
                padding: 10px 22px;
                border-radius: 8px;
                font-weight: 600;
            }

                .btn-primary:hover {
                    transform: translateY(-1px);
                }
    </style>

    <link rel="stylesheet" href="~/css/common-form.css" />

</head>
<body>


    <div class="page-header">
        <div class="emblem">
            <i class="bi bi-cash-stack" style="font-size: 1.5rem; color: gold;"></i>
        </div>
        <div class="page-header-text">
            <h1>Affiliation Payment</h1>
            <p>Affiliation & Recognition Portal — Payment Details</p>
        </div>
    </div>

    <div class="form-wrap">

        <!-- PAYMENT TABLE -->
        <div class="section-card">
            <div class="section-header">
                <div class="icon-wrap" style="background:#e8edf7;">
                    <i class="bi bi-credit-card" style="font-size:1.3rem; color:#1a4c8b;"></i>
                </div>
                <h2>Payment Details</h2>
            </div>

            <div class="section-body">
                <form asp-action="SavePayment" method="post" enctype="multipart/form-data">

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label>Payment Date</label>
                            <input type="date" asp-for="PaymentDate" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label>Amount</label>
                            <input type="number" step="0.01" asp-for="Amount" class="form-control" required />
                        </div>

                        <div class="col-md-4">
                            <label>Transaction Ref No</label>
                            <input type="text" asp-for="TransactionReferenceNo" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label>Supporting Document</label><br />

                        <input type="file" asp-for="File" id="fileInput" hidden accept=".pdf,.jpg,.png" />

                        <label for="fileInput" class="custom-upload-btn">
                            Upload Document
                        </label>

                        <span id="fileName" class="small text-muted ms-2"></span>

                        @if (!string.IsNullOrEmpty(Model?.SupportingDocument))
                        {
                            <button type="button"
                                    class="btn btn-sm btn-info ms-2"
                                    data-bs-toggle="modal"
                                    data-bs-target="#filePreviewModal">
                                View Document
                            </button>
                        }
                    </div>
                    <input type="hidden" asp-for="Id" />

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary">
                            Save Payment
                        </button>
                    </div>

                </form>
                <div class="modal fade" id="filePreviewModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-xl modal-dialog-centered">
                        <div class="modal-content">

                            <div class="modal-header">
                                <h5 class="modal-title">Document Preview</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body" style="height:80vh;">
                                <iframe id="previewFrame"
                                        src=""
                                        width="100%"
                                        height="100%"
                                        style="border:none;">
                                </iframe>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    @section Scripts {
        <script>
                var previewUrl = '@Url.Action("ViewFile", new { path = Model?.SupportingDocument })';

                var modal = document.getElementById('filePreviewModal');

                modal.addEventListener('show.bs.modal', function () {
                    document.getElementById('previewFrame').src = previewUrl;
                });

                modal.addEventListener('hidden.bs.modal', function () {
                    document.getElementById('previewFrame').src = "";
                });

                // File name display
                document.getElementById("fileInput").addEventListener("change", function () {
                    const fileNameSpan = document.getElementById("fileName");

                    if (this.files.length === 0) {
                        fileNameSpan.innerText = "";
                        return;
                    }

                    const file = this.files[0];

                    const maxSize = 1 * 1024 * 1024;

                    if (file.size > maxSize) {
                        alert("File size must be less than 1 MB");
                        this.value = "";
                        fileNameSpan.innerText = "";
                        return;
                    }

                    fileNameSpan.innerText = file.name;
                });
        </script>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

</body>
</html>