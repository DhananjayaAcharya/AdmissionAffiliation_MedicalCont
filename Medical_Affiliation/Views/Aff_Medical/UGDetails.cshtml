        width: 98%;
        overflow-x: auto;
    }
</style>

<div class="form-container">
    <h2>UG Details</h2>

    <form asp-action="UGDetails" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="FacultyCode" />
        <input type="hidden" asp-for="CollegeCode" />

        <table class="table table-bordered" id="ugDetailsTable">
            <thead>
                <tr>
                    <th>UG Intake</th>
                    <th>Course</th>
                    <th>Fresh/Increase</th>
                    <th>First LOP Date</th>
                    <th>Number of Seats</th>
                    <th>Permitted Year</th>
                    <th>Recognized Year</th>
                    <th>RGUHS Notification</th>
                    <th>GMC</th>
                    <th>NMC</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.UGDetailsList.Count; i++)
                {
                    <tr>
                        <td><input asp-for="UGDetailsList[@i].UGIntake" class="form-control" /></td>
                        <td>
                            <select asp-for="UGDetailsList[@i].Course" class="form-select"
                                    asp-items="@(new SelectList(Model.Courses, "CourseCode", "CourseName"))">
                                <option value="">-- Select Course --</option>
                            </select>
                        </td>
                        <td><input asp-for="UGDetailsList[@i].FreshOrIncrease" class="form-control" /></td>
                        <td><input asp-for="UGDetailsList[@i].FirstLOPDate" type="date" class="form-control" /></td>
                        <td><input asp-for="UGDetailsList[@i].NumberOfSeats" class="form-control" /></td>
                        <td><input asp-for="UGDetailsList[@i].PermittedYear" class="form-control" /></td>
                        <td><input asp-for="UGDetailsList[@i].RecognizedYear" class="form-control" /></td>
                        <td><input asp-for="UGDetailsList[@i].RGUHSNotificationFile" type="file" class="form-control" /></td>
                        <td><input asp-for="UGDetailsList[@i].GMCFile" type="file" class="form-control" /></td>
                        <td><input asp-for="UGDetailsList[@i].NMCFile" type="file" class="form-control" /></td>
                        <td>
                            <button type="button" class="btn btn-add" onclick="addRow()">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                            <button type="button" class="btn btn-delete" onclick="deleteRow(this)">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="d-flex justify-content-end mt-3">
            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-save"></i> Save & Proceed
            </button>
        </div>
    </form>
</div>

<script>
    function addRow() {
        var table = document.getElementById("ugDetailsTable").getElementsByTagName('tbody')[0];
        var newRow = table.rows[0].cloneNode(true);

        // clear values of cloned row
        var inputs = newRow.querySelectorAll("input, select");
        inputs.forEach(el => {
            if (el.type === "file") {
                el.value = null; // reset file inputs
            } else {
                el.value = "";
            }
        });

        table.appendChild(newRow);
    }

    function deleteRow(btn) {
        var row = btn.closest("tr");
        var table = document.getElementById("ugDetailsTable").getElementsByTagName('tbody')[0];

        if (table.rows.length > 1) {
            row.remove();
        } else {
            alert("At least one row is required!");
        }
    }
</script>
 *@