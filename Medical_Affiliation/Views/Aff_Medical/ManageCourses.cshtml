@model Medical_Affiliation.Models.UGPGSSDetailsFormViewModel
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Nodal Officer Details";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    var typeOfAffiliationList = ViewData["TypeOfAffiliationList"] as List<SelectListItem>;
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
    int currentStep = 2;
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<style>
    body {
        background: linear-gradient(135deg, #f8f9fa 0%, #e0f7fa 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #495057;
    }

    h2, h4 {
        color: #00796b; /* Teal color for headings */
        font-weight: 700;
    }

    .card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        background: #ffffff;
        padding: 20px;

    }

    .table thead {
        background: #009688; /* Teal header */
        color: #ffffff;
        text-align: center;
    }

    .table td, .table th {
        vertical-align: middle;
        text-align: center;
        padding: 0.75rem;
    }

    .btn-pill {
        border-radius: 999px;
        padding: .5rem 1rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-add {
        background: #009688; /* Teal Add button */
        color: #ffffff;
    }

        .btn-add:hover {
            background: #00796b;
            transform: translateY(-1px);
        }

    .btn-del {
        background: #e57373; /* Soft red for delete */
        color: #ffffff;
    }

        .btn-del:hover {
            background: #ef5350;
            transform: translateY(-1px);
        }

    .section-actions {
        display: flex;
        gap: .75rem;
        justify-content: flex-end;
    }

    .overflow-wrap {
        overflow-x: auto;
    }
    .container{
        max-width: 1500px;
        margin-left: 190px;
    }

</style>
@if (!string.IsNullOrEmpty(facultyCode))
{
    @await Component.InvokeAsync("Sidebar")
}

<div class="container mt-5">
    <div class="card shadow-lg rounded-4">
        <div class="card-header bg-light">
            <nav aria-label="Form progress">
                <div class="d-flex justify-content-between align-items-center">
                    <h3 class="fw-bold mb-0">@HttpContextAccessor.HttpContext.Session.GetString("CollegeName")</h3>
                    <form asp-controller="Login" asp-action="Login" method="post" class="m-0">
                        <button type="submit" class="btn btn-outline-danger">Logout</button>
                    </form>
                </div>

                <ul class="progressbar" role="progressbar" aria-valuenow="@currentStep" aria-valuemin="1" aria-valuemax="5">
                    <li class="@(currentStep >= 1 ? "active" : "")" aria-current="step">Basic Institute Details</li>
                    <li class="@(currentStep >= 2 ? "active" : "")">Course Details</li>
                    <li class="@(currentStep >= 3 ? "active" : "")">Clinical Material Details</li>
                    <li class="@(currentStep >= 4 ? "active" : "")">College Designation Details</li>
                    <li class="@(currentStep >= 5 ? "active" : "")">Add Faculty Details</li>
                </ul>
            </nav>
        </div>
    </div>
</div>
