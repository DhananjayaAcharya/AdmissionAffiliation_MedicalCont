<script>
    var ugIntakes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.UGIntakes ?? new Dictionary<string, int>()));
    var pgIntakes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.PGIntakes ?? new Dictionary<string, int>()));
    var ssIntakes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.SSIntakes ?? new Dictionary<string, int>()));

    function countRows(section) {
        return document.getElementById(section + 'Body').querySelectorAll('tr').length;
    }

    function addRow(section) {
        const body = document.getElementById(section + 'Body');
        const idx = countRows(section);
        let tpl = document.getElementById('tpl-' + section).innerHTML.replaceAll('__index__', idx);
        body.insertAdjacentHTML('beforeend', tpl);

        // Trigger Intake auto-fill if course is selected
        const newRow = body.querySelectorAll('tr')[idx];
        const selectEl = newRow.querySelector('select');
        if (selectEl && selectEl.value) {
            onCourseChange(selectEl, section.toUpperCase());
        }
    }

    function deleteRow(btn, section) {
        const body = document.getElementById(section + 'Body');
        const rows = body.querySelectorAll('tr');
        if (rows.length <= 1) {
            alert('At least one row is required in ' + section.toUpperCase() + '.');
            return;
        }
        btn.closest('tr').remove();
        reindex(section);
    }

    function reindex(section) {
        const listName = section.toUpperCase() + 'DetailsList';
        const tbody = document.getElementById(section + 'Body');
        tbody.querySelectorAll('tr').forEach((tr, i) => {
            tr.querySelectorAll('input, select, textarea').forEach(el => {
                if (el.name) el.name = el.name.replace(/\[(\d+)\]/, '[' + i + ']');
                if (el.id) el.id = el.id.replace(/_(\d+)_/, '_' + i + '_');
                if (el.type === 'file') el.value = null;
            });
        });
    }

    function beforeSubmitReindex() {
        reindex('ug'); reindex('pg'); reindex('ss');
    }

    (function ensureInitialRows() {
        if (countRows('ug') === 0) addRow('ug');
        if (countRows('pg') === 0) addRow('pg');
        if (countRows('ss') === 0) addRow('ss');
    })();

    function onCourseChange(selectEl, type) {
        const row = selectEl.closest('tr');
        const input = row.querySelector('input[name*="' + type + 'Intake"]');
        if (!input) return;

        const map = type === 'UG' ? ugIntakes : type === 'PG' ? pgIntakes : ssIntakes;
        input.value = map[selectEl.value] || '';
    }
</script>



