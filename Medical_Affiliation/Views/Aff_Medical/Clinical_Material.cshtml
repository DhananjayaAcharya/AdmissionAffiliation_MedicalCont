@model List<Medical_Affiliation.Models.ClinicalMaterialDatum>
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Nodal Officer Details";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    var typeOfAffiliationList = ViewData["TypeOfAffiliationList"] as List<SelectListItem>;
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
    int currentStep = 3;
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #ffffff 0%, #e3f2fd 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        padding: 30px;
        color: #333;
    }

    h2 {
        text-align: center;
        margin-bottom: 25px;
        font-weight: bold;
        color: #1565c0;
        text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.1);
    }

    .card {
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.1);
        background: #ffffff;
    }

    table {
        margin: 0;
        width: 100%;
        border-collapse: collapse;
    }

        table thead th {
            background: #1976d2;
            color: #ffffff;
            text-align: center;
            font-size: 15px;
            padding: 12px;
        }

        table tbody td {
            text-align: center;
            vertical-align: middle;
            padding: 10px;
        }

    input[type="text"] {
        text-align: center;
        border-radius: 8px;
        border: 1px solid #1976d2;
        padding: 8px;
    }

    tr:nth-child(even) td {
        background-color: #f1f8ff;
    }

    tr:nth-child(odd) td {
        background-color: #ffffff;
    }

    /* Bottom Navigation Bar for buttons */
    .bottom-nav {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background: #ffffff;
        padding: 15px 30px;
        display: flex;
        justify-content: space-between;
        box-shadow: 0 -3px 10px rgba(0, 0, 0, 0.1);
    }

        .bottom-nav button {
            background: #1976d2;
            color: #ffffff;
            border: none;
            border-radius: 30px;
            padding: 10px 25px;
            font-size: 16px;
            font-weight: 500;
            cursor: pointer;
        }

            .bottom-nav button:hover {
                background: #1565c0;
            }
</style>
@if (!string.IsNullOrEmpty(facultyCode))
{
    @await Component.InvokeAsync("Sidebar")
}
<div class="container mt-5">
    <div class="card shadow-lg rounded-4">
        <div class="card-header bg-light">
            <nav aria-label="Form progress">
                <div class="d-flex justify-content-between align-items-center">
                    <h3 class="fw-bold mb-0">@HttpContextAccessor.HttpContext.Session.GetString("CollegeName")</h3>
                    <form asp-controller="Login" asp-action="Login" method="post" class="m-0">
                        <button type="submit" class="btn btn-outline-danger">Logout</button>
                    </form>
                </div>

                <ul class="progressbar" role="progressbar" aria-valuenow="@currentStep" aria-valuemin="1" aria-valuemax="5">
                    <li class="@(currentStep >= 1 ? "active" : "")" aria-current="step">Basic Institute Details</li>
                    <li class="@(currentStep >= 2 ? "active" : "")">Course Details</li>
                    <li class="@(currentStep >= 3 ? "active" : "")">Clinical Material Details</li>
                    <li class="@(currentStep >= 4 ? "active" : "")">College Designation Details</li>
                    <li class="@(currentStep >= 5 ? "active" : "")">Add Faculty Details</li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<h2>Year-wise Available Clinical Materials (Previous 3 Years)</h2>

<div class="card">
    <div class="card-body p-0">
        <form asp-action="Clinical_Material" method="post">
            <table class="table table-bordered table-hover mb-0">
                <thead>
                    <tr>
                        <th>Parameter</th>
                        <th>Year1 (2022)</th>
                        <th>Year2 (2023)</th>
                        <th>Year3 (2024)</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <tr>
                            <td>
                                @Model[i].ParametersName
                                <input type="hidden" name="[@i].ParametersId" value="@Model[i].ParametersId" />
                                <input type="hidden" name="[@i].Parameters_Name" value="@Model[i].ParametersName" />
                                <input type="hidden" name="[@i].CollegeCode" value="COL001" />
                                <input type="hidden" name="[@i].FacultyCode" value="FAC001" />
                            </td>
                            <td><input type="text" class="form-control" name="[@i].Year1" placeholder="2022" required /></td>
                            <td><input type="text" class="form-control" name="[@i].Year2" placeholder="2023" required /></td>
                            <td><input type="text" class="form-control" name="[@i].Year3" placeholder="2024" required /></td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Bottom Navigation -->
            <!-- Buttons Section -->
            <div class="mt-4 d-flex justify-content-between">
                <!-- Previous Button (left) -->
                <a asp-controller="Aff_Medical" asp-action="ManageCourses" class="btn btn-outline-secondary sidebar-btn">
                    ⬅ Previous
                </a>

                <!-- Save & Proceed Button (right) -->
                <button type="submit" class="btn btn-outline-secondary sidebar-btn">
                    💾 Save & Proceed ➡
                </button>

            </div>
        </form>
    </div>
</div>
<style>
    .progressbar {
        counter-reset: step;
        display: flex;
        justify-content: space-between;
        padding: 0;
        margin: 20px 0 0;
        list-style: none;
    }

        .progressbar li {
            position: relative;
            flex: 1;
            text-align: center;
            font-size: 14px;
            font-weight: 600;
            color: #6c757d;
        }

            .progressbar li:before {
                counter-increment: step;
                content: counter(step);
                width: 35px;
                height: 35px;
                line-height: 35px;
                border: 2px solid #bbb;
                display: block;
                text-align: center;
                margin: 0 auto 10px;
                border-radius: 50%;
                background-color: #fff;
            }

            .progressbar li:after {
                content: '';
                position: absolute;
                width: 100%;
                height: 2px;
                background-color: #bbb;
                top: 18px;
                left: -50%;
                z-index: -1;
            }

            .progressbar li:first-child:after {
                content: none;
            }

            .progressbar li.active {
                color: #0d6efd;
            }

                .progressbar li.active:before {
                    border-color: #0d6efd;
                    background-color: #0d6efd;
                    color: #fff;
                }

                .progressbar li.active + li:after {
                    background-color: #0d6efd;
                }
</style>
