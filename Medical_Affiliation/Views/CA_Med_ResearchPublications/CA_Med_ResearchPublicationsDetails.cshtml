@model Medical_Affiliation.Models.CA_Med_ResearchPublicationsDetailsVM
@inject IHttpContextAccessor HttpContextAccessor
@using System.Text.Json;

@{
    ViewData["Title"] = "Research and Publication";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
    var raw = HttpContextAccessor.HttpContext.Session.GetString("ExistingCourseLevels");

    var levels = new List<string>();

    if (!string.IsNullOrEmpty(raw))
    {
        try
        {
            levels = JsonSerializer.Deserialize<List<string>>(raw)
                        ?.Select(l => l.Trim().ToUpper())
                        .Distinct()
                        .ToList() ?? new List<string>();
        }
        catch
        {
            levels = new List<string>();
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Research and Publication</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
            :root {
                --ink: #0f1923;
                --ink-mid: #2e3d4f;
                --ink-muted: #6b7a8d;
                --border: #d4dae3;
                --bg: #f4f6f9;
                --surface: #ffffff;
                --accent: #1a4c8b;
                --accent-lt: #e8edf7;
                --gold: #c9a84c;
                --radius: 10px;
                --shadow: 0 2px 16px rgba(15,25,35,.07);
            }

            body {
                font-family: 'DM Sans', sans-serif;
                background: var(--bg);
                color: var(--ink);
                min-height: 100vh;
            }

            /* Page Header - Matching Academic Matters */
            .page-header {
                background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
                padding: 28px 40px 24px;
                display: flex;
                align-items: center;
                gap: 18px;
                border-bottom: 3px solid var(--gold);
            }

                .page-header .emblem {
                    width: 54px;
                    height: 54px;
                    border: 2px solid var(--gold);
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                    .page-header .emblem svg {
                        width: 28px;
                        height: 28px;
                        fill: var(--gold);
                    }

            .page-header-text h1 {
                font-family: 'Playfair Display', serif;
                font-size: 1.45rem;
                color: #ffffff;
                letter-spacing: .02em;
            }

            .page-header-text p {
                font-size: .78rem;
                color: rgba(255,255,255,.55);
                margin-top: 3px;
                letter-spacing: .06em;
                text-transform: uppercase;
            }

            .form-wrap {
                max-width: 1280px;
                margin: 32px auto;
                padding: 0 24px 60px;
            }

            .section-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                box-shadow: var(--shadow);
                overflow: hidden;
                margin-bottom: 28px;
                animation: fadeUp .35s ease both;
            }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(12px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .section-header {
                padding: 16px 24px;
                display: flex;
                align-items: center;
                gap: 12px;
                border-bottom: 1px solid var(--border);
                background: #fafbfc;
            }

                .section-header .icon-wrap {
                    width: 38px;
                    height: 38px;
                    border-radius: 8px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: var(--accent-lt);
                }

                .section-header h2 {
                    font-size: 1.02rem;
                    font-weight: 600;
                    letter-spacing: .03em;
                    color: var(--ink);
                    margin: 0;
                }

            .section-body {
                padding: 1.75rem;
            }

            .custom-table {
                width: 100%;
                border-collapse: collapse;
            }

                .custom-table th, .custom-table td {
                    padding: 12px 16px;
                    border-bottom: 1px solid var(--border);
                    vertical-align: middle;
                }

                .custom-table th {
                    background: #f8f9fc;
                    color: var(--ink-mid);
                    font-weight: 600;
                    text-transform: uppercase;
                    font-size: 0.76rem;
                    letter-spacing: 0.05em;
                }

                .custom-table tr:hover {
                    background: #f8fbff;
                }

            .form-control {
                font-size: 0.875rem;
                background: #fafbfc;
                border: 1px solid var(--border);
                border-radius: 7px;
                padding: 9px 13px;
            }

                .form-control:focus {
                    border-color: var(--accent);
                    background: #fff;
                    box-shadow: 0 0 0 3px rgba(26,76,139,.1);
                }

            .custom-upload-btn {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: var(--accent);
                color: white;
                padding: 10px 18px;
                border-radius: 8px;
                font-size: 0.83rem;
                font-weight: 600;
                cursor: pointer;
                transition: all 0.2s;
            }

                .custom-upload-btn:hover {
                    background: #1564c0;
                    transform: translateY(-1px);
                }

            input[type="file"] {
                display: none !important;
            }

            .btn {
                font-family: 'DM Sans', sans-serif;
                font-size: 0.85rem;
                font-weight: 600;
                border-radius: 8px;
                padding: 10px 26px;
                letter-spacing: .03em;
                transition: all .18s;
            }

            .btn-primary {
                background: linear-gradient(135deg, #1a4c8b, #1564c0);
                color: #fff;
                box-shadow: 0 3px 14px rgba(26,76,139,.3);
            }

                .btn-primary:hover {
                    box-shadow: 0 5px 20px rgba(26,76,139,.4);
                    transform: translateY(-1px);
                }

            .btn-success {
                background: linear-gradient(135deg, #1e7e4e, #27ae60);
                color: #fff;
                box-shadow: 0 3px 14px rgba(30,126,78,.3);
            }

                .btn-success:hover {
                    box-shadow: 0 5px 20px rgba(30,126,78,.4);
                    transform: translateY(-1px);
                }

            .btn-secondary {
                background: transparent;
                border: 1px solid var(--border);
                color: var(--ink-muted);
            }

                .btn-secondary:hover {
                    border-color: var(--ink-mid);
                    color: var(--ink);
                }

            .check-label {
                font-weight: 500;
                cursor: pointer;
            }

            /* File name display */
            .file-name-display {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                margin-left: 10px;
                font-size: 0.82rem;
                color: var(--ink-mid);
                background: #eef2f8;
                border: 1px solid var(--border);
                border-radius: 6px;
                padding: 5px 10px;
                max-width: 260px;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
                vertical-align: middle;
            }

                .file-name-display i {
                    color: var(--accent);
                    flex-shrink: 0;
                }
    </style>

    <link rel="stylesheet" href="~/css/common-form.css" />

</head>
<body>
    <!-- Page Header -->
    <div class="page-header">
        <div class="emblem">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM19 19H5V5H19V19Z" />
                <path d="M14 17H7V15H14V17ZM17 13H7V11H17V13ZM17 9H7V7H17V9Z" />
            </svg>
        </div>
        <div class="page-header-text">
            <h1>Research and Publication</h1>
            @* <p>Postgraduate Courses — Research, Projects & Academic Activities</p> *@
        </div>
    </div>

    <div class="form-wrap">
        <form asp-action="CA_Med_ResearchPublicationsDetails" method="post" enctype="multipart/form-data" id="researchForm">
            @Html.AntiForgeryToken()

            <!-- 4.a Number of Publications -->
            @foreach (var level in levels)
            {
                var data = Model.CourseData.ContainsKey(level)
                    ? Model.CourseData[level]
                    : null;

                <div class="section-card">
                    <div class="section-header">
                        <div class="icon-wrap">
                            <i class="bi bi-journal-text" style="font-size:1.5rem; color:#1a4c8b;"></i>
                        </div>
                        <h2>@level - Number of Publications</h2>
                    </div>

                    <div class="section-body">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Number of Publications</label>
                                <input type="number"
                                       name="CourseData[@level].PublicationsNo"
                                       value="@data?.PublicationsNo"
                                       class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Upload Publications PDF</label>

                                <label for="publicationsPdf_@level" class="custom-upload-btn">
                                    <i class="bi bi-upload"></i> Choose File
                                </label>

                                <input type="file"
                                       id="publicationsPdf_@level"
                                       name="PublicationsPdf_@level"
                                       accept="application/pdf"
                                       onchange="handleFileChange(this, 'publicationsPdfName_@level')" />

                                <span class="file-name-display" id="publicationsPdfName_@level" style="display:none;">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                    <span class="name-text"></span>
                                </span>

                                @if (!string.IsNullOrEmpty(data?.PublicationsPdfName))
                                {
                                    <a asp-action="ViewPublicationsPdf"
                                           asp-route-type="Publications"
                                           asp-route-level="@level"
                                           target="_blank"
                                           class="btn btn-secondary ms-3">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            @foreach (var level in levels)
            {
                var data = Model.CourseData.ContainsKey(level)
                    ? Model.CourseData[level]
                    : null;

                <div class="section-card">
                    <div class="section-header">
                        <div class="icon-wrap">
                            <i class="bi bi-lightbulb-fill" style="font-size:1.5rem; color:#1a4c8b;"></i>
                        </div>
                        <h2>@level - Research Projects</h2>
                    </div>

                    <div class="section-body">

                        <!-- Table -->
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th style="width:10%">No</th>
                                    <th style="width:25%">Category</th>
                                    <th style="width:32.5%">RGUHS Funded</th>
                                    <th style="width:32.5%">External Body Funding</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-center">1</td>
                                    <td class="fw-semibold">Students</td>
                                    <td>
                                        <input type="number"
                                               name="CourseData[@level].StudentsRGUHSFunded"
                                               value="@data?.StudentsRguhsfunded"
                                               class="form-control" />
                                    </td>
                                    <td>
                                        <input type="number"
                                               name="CourseData[@level].StudentsExternalBodyFunding"
                                               value="@data?.StudentsExternalBodyFunding"
                                               class="form-control" />
                                    </td>
                                </tr>

                                <tr>
                                    <td class="text-center">2</td>
                                    <td class="fw-semibold">Faculty</td>
                                    <td>
                                        <input type="number"
                                               name="CourseData[@level].FacultyRGUHSFunded"
                                               value="@data?.FacultyRguhsfunded"
                                               class="form-control" />
                                    </td>
                                    <td>
                                        <input type="number"
                                               name="CourseData[@level].FacultyExternalBodyFunding"
                                               value="@data?.FacultyExternalBodyFunding"
                                               class="form-control" />
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Students PDF -->
                        <div class="mt-4 pt-3 border-top" style="display:flex; gap:1rem">
                            <div>
                                <label class="form-label fw-semibold">Upload Students Projects PDF</label>
                            </div>

                            <label for="studentsProjectsPdf_@level" class="custom-upload-btn">
                                <i class="bi bi-upload"></i> Choose File
                            </label>

                            <input type="file"
                                   id="studentsProjectsPdf_@level"
                                   name="StudentsProjectsPdf_@level"
                                   accept="application/pdf"
                                   onchange="handleFileChange(this, 'studentsProjectsPdfName_@level')" />

                            <span class="file-name-display" id="studentsProjectsPdfName_@level" style="display:none;">
                                <i class="bi bi-file-earmark-pdf"></i>
                                <span class="name-text"></span>
                            </span>

                            @if (!string.IsNullOrEmpty(data?.StudentsProjectsPdfName))
                            {
                                <a asp-action="ViewStudentsProjectsPdf"
                                       asp-route-type="StudentsProjects"
                                       asp-route-level="@level"
                                       target="_blank"
                                       class="btn btn-secondary ms-3">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            }
                        </div>

                        <!-- Faculty PDF -->
                        <div class="mt-4" style="display:flex; gap:1rem">
                            <div>
                                <label class="form-label fw-semibold">Upload Faculty Projects PDF</label>
                            </div>

                            <label for="facultyProjectsPdf_@level" class="custom-upload-btn">
                                <i class="bi bi-upload"></i> Choose File
                            </label>

                            <input type="file"
                                   id="facultyProjectsPdf_@level"
                                   name="FacultyProjectsPdf_@level"
                                   accept="application/pdf"
                                   onchange="handleFileChange(this, 'facultyProjectsPdfName_@level')" />

                            <span class="file-name-display" id="facultyProjectsPdfName_@level" style="display:none;">
                                <i class="bi bi-file-earmark-pdf"></i>
                                <span class="name-text"></span>
                            </span>

                            @if (!string.IsNullOrEmpty(data?.FacultyProjectsPdfName))
                            {
                                <a asp-action="ViewFacultyProjectsPdf"
                                       asp-route-type="FacultyProjects"
                                       asp-route-level="@level"
                                       target="_blank"
                                       class="btn btn-secondary ms-3">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            }
                        </div>

                    </div>
                </div>
            }

            <!-- 4.c Clinical Trials -->
            @if (levels.Contains("UG"))
            {
                var data = Model.CourseData.ContainsKey("UG")
                    ? Model.CourseData["UG"]
                    : null;

                <div class="section-card">
                    <div class="section-header">
                        <div class="icon-wrap">
                            <i class="bi bi-clipboard-pulse" style="font-size:1.5rem; color:#1a4c8b;"></i>
                        </div>
                        <h2>UG - Clinical Trials</h2>
                    </div>

                    <div class="section-body" style="display:flex; gap:1rem">

                        <div>
                            <label class="form-label fw-semibold">
                                Upload Clinical Trials PDF <span class="text-danger">*</span>
                            </label>
                        </div>

                        <label for="clinicalTrialsPdf_UG" class="custom-upload-btn">
                            <i class="bi bi-upload"></i> Choose File
                        </label>

                        <input type="file"
                               id="clinicalTrialsPdf_UG"
                               name="ClinicalTrialsPdf_UG"
                               accept="application/pdf"
                               onchange="handleFileChange(this, 'clinicalTrialsPdfName_UG')" />

                        <span class="file-name-display" id="clinicalTrialsPdfName_UG" style="display:none;">
                            <i class="bi bi-file-earmark-pdf"></i>
                            <span class="name-text"></span>
                        </span>

                        @if (!string.IsNullOrEmpty(data?.ClinicalTrialsPdfName))
                        {
                            <a asp-action="ViewClinicalTrialsPdf"
                                   asp-route-type="ClinicalTrials"
                                   asp-route-level="UG"
                                   target="_blank"
                                   class="btn btn-secondary ms-3">
                                <i class="bi bi-eye"></i> View Clinical Trials
                            </a>
                        }

                    </div>
                </div>
            }

            <!-- Action Buttons -->
            <div class="d-flex justify-content-center align-items-center mt-5">
                @* <a asp-controller="Medical_ContinuousAffiliation"
                   asp-action="Medical_DepartmentOfficesAndEducationalUnit"
                   class="btn btn-secondary">← Previous</a> *@

                <button type="submit" class="btn btn-success">
                    <i class="bi bi-cloud-arrow-up me-2"></i>Save Research & Publication Details
                </button>

                @* <a asp-controller="Aff_CA_MedicalLibrary"
                   asp-action="Aff_CA_Medical_LibraryDetails"
                   class="btn btn-primary">Next → Library Details</a> *@
            </div>
        </form>

        <!-- 4.d Other Academic Activities (Department-wise) -->
        @if (levels.Contains("UG"))
        {
            <div class="section-card mt-5">
                <div class="section-header">
                    <div class="icon-wrap">
                        <i class="bi bi-people-fill" style="font-size:1.5rem; color:#1a4c8b;"></i>
                    </div>
                    <h2>4.d Other Academic Activities (Department-wise)</h2>
                </div>
                <div class="section-body">
                    <form asp-action="SaveOtherAcademicActivity" method="post" enctype="multipart/form-data" class="mb-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="CourseLevel" value="UG" />
                        
                        <div class="row align-items-end g-3">
                            <div class="col-md-4">
                                <label class="form-label">Department <span class="text-danger">*</span></label>
                                <select name="DepartmentCode" class="form-control" required>
                                    <option value="">-- Select Department --</option>
                                    @foreach (var d in Model.Departments)
                                    {
                                        <option value="@d.DepartmentCode">@d.DepartmentName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Activity <span class="text-danger">*</span></label>
                                <select name="ActivityId" class="form-control" required>
                                    <option value="">-- Select Activity --</option>
                                    @foreach (var a in Model.ActivityMasters)
                                    {
                                        <option value="@a.Id">@a.ActivityName</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Upload PDF <span class="text-danger">*</span></label>
                                <label for="activityPdf_UG" class="custom-upload-btn w-100 justify-content-center">
                                    <i class="bi bi-upload"></i> Choose File
                                </label>
                                <input type="file" id="activityPdf_UG" name="ActivityPdf" accept="application/pdf" style="display:none;" required onchange="handleFileChange(this, 'activityPdfName')" />
                                <span class="file-name-display" id="activityPdfName" style="display:none;">
                                    <i class="bi bi-file-earmark-pdf"></i>
                                    <span class="name-text"></span>
                                </span>
                            </div>
                        </div>
                        <div class="col-md-12 my-4">
                            <button type="submit" class="btn btn-success w-100">Save</button>
                        </div>
                    </form>

                    @if (Model.OtherActivities?.Any(x => x.Id > 0) == true)
                    {
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Department</th>
                                    <th>Activity</th>
                                    <th>PDF</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.OtherActivities.Where(x => x.Id > 0))
                                {
                                    <tr>
                                        <td>@row.DepartmentWise</td>
                                        <td>@row.ActivityName</td>
                                        <td>
                                            <a asp-action="ViewOtherActivityPdf" asp-route-id="@row.Id"
                                                   class="btn btn-secondary btn-sm" target="_blank">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                        </td>
                                        <td class="text-center">
                                            <form asp-action="DeleteOtherAcademicActivity" asp-route-id="@row.Id"
                                                  method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="button" class="btn btn-secondary btn-sm text-danger"
                                                        onclick="confirmDelete(this)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }

        <!-- 5. Committees -->
        <div class="section-card mt-5">
            <div class="section-header">
                <div class="icon-wrap">
                    <i class="bi bi-diagram-3" style="font-size:1.5rem; color:#1a4c8b;"></i>
                </div>
                <h2>5. Committees</h2>
            </div>
            <div class="section-body">
                @if (Model.Committees?.Any() == true)
                {
                    <form asp-action="SaveCommitteeDetails" method="post" enctype="multipart/form-data" id="committeeForm">
                        @Html.AntiForgeryToken()

                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Committee Name</th>
                                    <th class="text-center" style="width:120px;">Available</th>
                                    <th>Document</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Committees.Count; i++)
                                {
                                    var committee = Model.Committees[i];
                                    <tr>
                                        <input type="hidden" name="Committees[@i].CourseLevel" value="@committee.CourseLevel" />
                                        <input type="hidden" name="Committees[@i].CommitteeId" value="@committee.CommitteeId" />
                                        <input type="hidden" name="Committees[@i].CommitteeName" value="@committee.CommitteeName" />
                                        <td class="fw-semibold">
                                            @committee.CommitteeName

                                            @if (committee.CourseLevel != null &&  committee.CourseLevel?.Trim().ToUpper() == "UG")
                                            {
                                                <span class="badge bg-info ms-2">UG Only</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <select name="Committees[@i].IsPresent" class="form-control is-present-select">
                                                <option value="">-- Select --</option>
                                                <option value="Y" selected="@(committee.IsPresent == "Y")">Yes</option>
                                                <option value="N" selected="@(committee.IsPresent == "N")">No</option>
                                            </select>
                                        </td>
                                        <td>
                                            <div class="file-upload-wrapper" style="display:@(committee.IsPresent == "Y" ? "block" : "none")">
                                                <label for="committeePdf_@i" class="custom-upload-btn">
                                                    <i class="bi bi-upload"></i> Choose File
                                                </label>
                                                <input type="file" id="committeePdf_@i" name="Committees[@i].CommitteePdf"
                                                       accept="application/pdf"
                                                       onchange="handleFileChange(this, 'committeePdfName_@i')" />
                                                <span class="file-name-display" id="committeePdfName_@i" style="display:none;">
                                                    <i class="bi bi-file-earmark-pdf"></i>
                                                    <span class="name-text"></span>
                                                </span>
                                                @if (!string.IsNullOrEmpty(committee.CommitteePdfName))
                                                {
                                                    <a asp-action="ViewCommitteePdf" asp-route-committeeId="@committee.CommitteeId"
                                                           target="_blank" class="btn btn-secondary mt-2 d-inline-block">
                                                        <i class="bi bi-eye"></i> View
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="text-center mt-4">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-cloud-arrow-up me-2"></i>Save Committee Details
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-5">
            <a asp-controller="Medical_ContinuousAffiliation"
               asp-action="Medical_DepartmentOfficesAndEducationalUnit"
               class="btn btn-secondary">← Previous</a>

            @* <button type="submit" class="btn btn-success">
                <i class="bi bi-cloud-arrow-up me-2"></i>Save Research & Publication Details
            </button> *@

            <a asp-controller="Aff_CA_MedicalLibrary"
               asp-action="Aff_CA_Medical_LibraryDetails"
               class="btn btn-primary">Next →</a>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
                // File validation: PDF only, max 2MB, show filename
                function handleFileChange(input, displayId) {
                    const file = input.files[0];
                    const display = document.getElementById(displayId);

                    if (!file) {
                        if (display) display.style.display = 'none';
                        return;
                    }

                    // PDF type check
                    if (file.type !== 'application/pdf') {
                        Swal.fire({
                            icon: 'error',
                            title: 'Invalid File Type',
                            text: 'Only PDF files are allowed.',
                            confirmButtonColor: '#d33'
                        });
                        input.value = '';
                        if (display) display.style.display = 'none';
                        return;
                    }

                    // 2MB size check
                    if (file.size > 2 * 1024 * 1024) {
                        Swal.fire({
                            icon: 'error',
                            title: 'File Too Large',
                            text: 'File size must not exceed 2MB.',
                            confirmButtonColor: '#d33'
                        });
                        input.value = '';
                        if (display) display.style.display = 'none';
                        return;
                    }

                    // Show filename
                    if (display) {
                        display.querySelector('.name-text').textContent = file.name;
                        display.style.display = 'inline-flex';
                    }
                }

                // Confirm Delete for Other Academic Activities
                function confirmDelete(button) {
                    const form = button.closest('form');
                    Swal.fire({
                        title: 'Are you sure?',
                        text: 'You want to delete this activity?',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        confirmButtonText: 'Yes, delete it!',
                        cancelButtonText: 'No, cancel'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            form.submit();
                        }
                    });
                }

                // Toggle file upload visibility for Committees
                document.addEventListener('DOMContentLoaded', function () {
                    document.querySelectorAll('.is-present-select').forEach(select => {
                        function toggleFileUpload() {
                            const row = select.closest('tr');
                            const wrapper = row.querySelector('.file-upload-wrapper');
                            if (wrapper) {
                                wrapper.style.display = select.value === 'Y' ? 'block' : 'none';
                            }
                        }
                        toggleFileUpload();
                        select.addEventListener('change', toggleFileUpload);
                    });
                });

                // SweetAlert for TempData messages
                @if (TempData["Error"] != null)
                {
                            <text>
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Save Failed',
                                    text: '@TempData["Error"]',
                                    timer: 10000,
                                    confirmButtonColor: '#d33'
                                });
                            </text>
                }

                @if (TempData["Success"] != null && Context.Request.Method == "POST")
                {
                            <text>
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Success',
                                    text: '@TempData["Success"]',
                                    confirmButtonColor: '#198754',
                                    timer: 2500,
                                    timerProgressBar: true
                                });
                            </text>
                }
        </script>
    }
</body>
</html>