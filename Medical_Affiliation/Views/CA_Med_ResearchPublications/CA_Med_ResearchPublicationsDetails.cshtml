@model Medical_Affiliation.Models.CA_Med_ResearchPublicationsDetailsVM
@inject IHttpContextAccessor HttpContextAccessor
@using System.Text.Json;

@{
    ViewData["Title"] = "Research and Publication";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
    var levels = Model.ExistingCourseLevels ?? new List<string>();
    bool hasUG = levels.Contains("UG");
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap');

    :root {
        --ink: #0f1923;
        --ink-mid: #2e3d4f;
        --ink-muted: #6b7a8d;
        --border: #d4dae3;
        --bg: #f4f6f9;
        --surface: #ffffff;
        --accent: #1a4c8b;
        --accent-lt: #e8edf7;
        --gold: #c9a84c;
        --radius: 12px;
        --shadow: 0 4px 20px rgba(15,25,35,.08);
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--ink);
        min-height: 100vh;
    }

    .page-header {
        background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
        padding: 28px 40px 24px;
        display: flex;
        align-items: center;
        gap: 18px;
        border-bottom: 3px solid var(--gold);
    }

        .page-header .emblem {
            width: 54px;
            height: 54px;
            border: 2px solid var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .page-header .emblem svg {
                width: 28px;
                height: 28px;
                fill: var(--gold);
            }

    .page-header-text h1 {
        font-family: 'Playfair Display', serif;
        font-size: 1.45rem;
        color: #ffffff;
        letter-spacing: .02em;
    }

    .form-wrap {
        max-width: 1100px; /* Reduced width for better readability */
        margin: 32px auto;
        padding: 0 24px 60px;
    }

    .section-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
        margin-bottom: 30px;
        animation: fadeUp .35s ease both;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .section-header {
        padding: 16px 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid var(--border);
        background: #fafbfc;
    }

        .section-header .icon-wrap {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--accent-lt);
        }

        .section-header h2 {
            font-size: 1.02rem;
            font-weight: 600;
            color: var(--ink);
            margin: 0;
        }

    .section-body {
        padding: 2rem;
    }

    /* Table Styling */
    .custom-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1rem;
    }

        .custom-table th {
            background: #f8f9fc;
            color: var(--ink-mid);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 0.05em;
            padding: 12px 16px;
            border-bottom: 2px solid var(--border);
            text-align: left;
        }

        .custom-table td {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border);
        }

    /* Input and Control Styling */
    .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--ink-mid);
        margin-bottom: 8px;
        display: block;
    }

    .form-control {
        font-size: 0.875rem;
        background: #fafbfc;
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: 10px 13px;
    }

    /* --- NEW: Upload Group Logic --- */
    .upload-group {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 8px;
        flex-wrap: wrap;
    }

    .custom-upload-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--accent);
        color: white;
        padding: 8px 16px;
        border-radius: 7px;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 0; /* Override layout */
    }

        .custom-upload-btn:hover {
            background: #1564c0;
            transform: translateY(-1px);
        }

    input[type="file"] {
        display: none !important;
    }

    .file-name-display {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.8rem;
        color: var(--ink-mid);
        background: #eef2f8;
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 6px 12px;
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .btn-view {
        background: #fff;
        border: 1px solid var(--border);
        color: var(--accent);
        font-size: 0.8rem;
        padding: 7px 14px;
        border-radius: 7px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-view:hover {
            background: var(--accent-lt);
            border-color: var(--accent);
        }

    .btn-success-main {
        background: linear-gradient(135deg, #1e7e4e, #27ae60);
        color: white;
        border: none;
        padding: 12px 30px;
        font-weight: 600;
        border-radius: 8px;
        box-shadow: 0 4px 12px rgba(30,126,78,0.3);
    }
</style>

<link rel="stylesheet" href="~/css/common-form.css" />

<div class="page-header">
    <div class="emblem">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM19 19H5V5H19V19Z" />
            <path d="M14 17H7V15H14V17ZM17 13H7V11H17V13ZM17 9H7V7H17V9Z" />
        </svg>
    </div>
    <div class="page-header-text">
        <h1>Research and Publication</h1>
    </div>
</div>

<div class="form-wrap">
    <form asp-action="CA_Med_ResearchPublicationsDetails" method="post" enctype="multipart/form-data" id="researchForm">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger" style="margin-bottom:12px; font-size:0.8rem;"></div>

        <!-- 4.a Number of Publications -->
        <div class="section-card">
            <div class="section-header">
                <div class="icon-wrap"><i class="bi bi-journal-text" style="font-size:1.5rem; color:#1a4c8b;"></i></div>
                <h2>a. Number of Publications during last 3 years</h2>
            </div>
            <div class="section-body">
                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="form-label">Number of Publications <span class="text-danger">*</label>
                        <input asp-for="PublicationsNo" type="number" min="0" class="form-control" />
                        <span asp-validation-for="PublicationsNo" class="text-danger"></span>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Upload Publications PDF <span class="text-danger">*</span> <small class="text-muted">Uploading the Document is Compulsory</small></label>
                        <div class="upload-group">
                            <label for="publicationsPdf" class="custom-upload-btn">
                                <i class="bi bi-upload"></i> Choose File
                            </label>
                            <input type="file" id="publicationsPdf" name="PublicationsPdf" accept="application/pdf" onchange="handleFileChange(this,'publicationsPdfName')" />
                            <span class="file-name-display" id="publicationsPdfName" style="display:none;">
                                <i class="bi bi-file-earmark-pdf"></i><span class="name-text"></span>
                            </span>
                            @if (!string.IsNullOrEmpty(Model.PublicationsPdfName))
                            {
                                <a asp-action="ViewPublicationsPdf" target="_blank" class="btn-view">
                                    <i class="bi bi-eye"></i> View PDF
                                </a>
                            }
                        </div>
                        <span asp-validation-for="PublicationsPdf" class="text-danger d-block mt-1"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4.b Research Projects -->
        <div class="section-card">
            <div class="section-header">
                <div class="icon-wrap"><i class="bi bi-lightbulb-fill" style="font-size:1.5rem; color:#1a4c8b;"></i></div>
                <h2>b. Research Projects</h2>
            </div>
            <div class="section-body">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th style="width:8%">No</th>
                            <th style="width:22%">Category</th>
                            <th>RGUHS Funded</th>
                            <th>External Body Funding</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="text-center">1</td>
                            <td class="fw-semibold">Students</td>
                            <td><input asp-for="StudentsRGUHSFunded" type="number" min="0" class="form-control" /></td>
                            <td><input asp-for="StudentsExternalBodyFunding" type="number" min="0" class="form-control" /></td>
                        </tr>
                        <tr>
                            <td class="text-center">2</td>
                            <td class="fw-semibold">Faculty</td>
                            <td><input asp-for="FacultyRGUHSFunded" type="number" min="0" class="form-control" /></td>
                            <td><input asp-for="FacultyExternalBodyFunding" type="number" min="0" class="form-control" /></td>
                        </tr>
                    </tbody>
                </table>

                <div class="mt-4">
                    <label class="form-label">Upload Students Projects PDF <span class="text-danger">*</span> <small class="text-muted">Uploading the Document is Compulsory</small></label>
                    <div class="upload-group">
                        <label for="studentsProjectsPdf" class="custom-upload-btn">
                            <i class="bi bi-upload"></i> Choose File
                        </label>
                        <input type="file" id="studentsProjectsPdf" name="StudentsProjectsPdf" accept="application/pdf" onchange="handleFileChange(this,'studentsProjectsPdfName')" />
                        <span class="file-name-display" id="studentsProjectsPdfName" style="display:none;">
                            <i class="bi bi-file-earmark-pdf"></i><span class="name-text"></span>
                        </span>
                        @if (!string.IsNullOrEmpty(Model.StudentsProjectsPdfName))
                        {
                            <a asp-action="ViewStudentsProjectsPdf" target="_blank" class="btn-view">
                                <i class="bi bi-eye"></i> View PDF
                            </a>
                        }
                    </div>
                    <span asp-validation-for="StudentsProjectsPdf" class="text-danger d-block mt-1"></span>
                </div>

                <div class="mt-4">
                    <label class="form-label">Upload Faculty Projects PDF <span class="text-danger">*</span> <small class="text-muted">Uploading the Document is Compulsory</small></label>
                    <div class="upload-group">
                        <label for="facultyProjectsPdf" class="custom-upload-btn">
                            <i class="bi bi-upload"></i> Choose File
                        </label>
                        <input type="file" id="facultyProjectsPdf" name="FacultyProjectsPdf" accept="application/pdf" onchange="handleFileChange(this,'facultyProjectsPdfName')" />
                        <span class="file-name-display" id="facultyProjectsPdfName" style="display:none;">
                            <i class="bi bi-file-earmark-pdf"></i><span class="name-text"></span>
                        </span>
                        @if (!string.IsNullOrEmpty(Model.FacultyProjectsPdfName))
                        {
                            <a asp-action="ViewFacultyProjectsPdf" target="_blank" class="btn-view">
                                <i class="bi bi-eye"></i> View PDF
                            </a>
                        }
                    </div>
                    <span asp-validation-for="FacultyProjectsPdf" class="text-danger d-block mt-1"></span>
                </div>
            </div>
        </div>

        <!-- 4.c Clinical Trials -->
        <div class="section-card">
            <div class="section-header">
                <div class="icon-wrap"><i class="bi bi-heart-pulse-fill" style="font-size:1.5rem; color:#1a4c8b;"></i></div>
                <h2>c. Clinical Trials</h2>
            </div>
            <div class="section-body">
                <label class="form-label">Upload Clinical Trials PDF <span class="text-danger">*</span> <small class="text-muted">Uploading the Document is Compulsory</small></label>
                <div class="upload-group">
                    <label for="clinicalTrialsPdf" class="custom-upload-btn">
                        <i class="bi bi-upload"></i> Choose File
                    </label>
                    <input type="file" id="clinicalTrialsPdf" name="ClinicalTrialsPdf" accept="application/pdf" onchange="handleFileChange(this,'clinicalTrialsPdfName')" />
                    <span class="file-name-display" id="clinicalTrialsPdfName" style="display:none;">
                        <i class="bi bi-file-earmark-pdf"></i><span class="name-text"></span>
                    </span>
                    @if (!string.IsNullOrEmpty(Model.ClinicalTrialsPdfName))
                    {
                        <a asp-action="ViewClinicalTrialsPdf" target="_blank" class="btn-view">
                            <i class="bi bi-eye"></i> View PDF
                        </a>
                    }
                </div>
                <span asp-validation-for="ClinicalTrialsPdf" class="text-danger d-block mt-1"></span>
            </div>
        </div>

        <div class="text-center mt-5">
            <button type="submit" class="btn btn-success-main">
                <i class="bi bi-cloud-arrow-up me-2"></i>Save Research &amp; Publication Details
            </button>
        </div>
    </form>
        

    <!-- ── 4.d Other Academic Activities — FIX: only for UG colleges ─── -->
    
        <div class="section-card mt-4">
            <div class="section-header">
                <div class="icon-wrap"><i class="bi bi-people-fill" style="font-size:1.5rem; color:#1a4c8b;"></i></div>
            <h2>4.d Other Academic Activities (Department-wise) <span class="badge bg-info ms-2">Only For UG</span></h2>
            </div>
            <div class="section-body">
            <form asp-controller="CA_Med_ResearchPublications"
                  asp-action="SaveOtherAcademicActivity"
                  method="post"
                  enctype="multipart/form-data"
                  class="mb-4">
                    @Html.AntiForgeryToken()
                    <div class="row align-items-end g-3">
                        <div class="col-md-4">
                            <label class="form-label">Department <span class="text-danger">*</span></label>
                            <select name="DepartmentCode" class="form-control" required>
                                <option value="">-- Select Department --</option>
                                @foreach (var d in Model.Departments)
                                {
                                    <option value="@d.DepartmentCode">@d.DepartmentName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Activity <span class="text-danger">*</span></label>
                            <select name="ActivityId" class="form-control" required>
                                <option value="">-- Select Activity --</option>
                                @foreach (var a in Model.ActivityMasters)
                                {
                                    <option value="@a.Id">@a.ActivityName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Upload PDF <span class="text-danger">*</span></label>
                            <label for="activityPdf" class="custom-upload-btn w-100 justify-content-center">
                                <i class="bi bi-upload"></i> Choose File
                            </label>
                            <input type="file" id="activityPdf" name="ActivityPdf" accept="application/pdf"
                                   required onchange="handleFileChange(this,'activityPdfName')" />
                            <span class="file-name-display" id="activityPdfName" style="display:none;">
                                <i class="bi bi-file-earmark-pdf"></i><span class="name-text"></span>
                            </span>
                        </div>
                    </div>
                    <div class="col-md-12 my-4">
                        <button type="submit" class="btn btn-success w-100">Save Activity</button>
                    </div>
                </form>

                @if (Model.OtherActivities?.Any(x => x.Id > 0) == true)
                {
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Department</th>
                                <th>Activity</th>
                                <th>PDF</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.OtherActivities.Where(x => x.Id > 0))
                            {
                                <tr>
                                    <td>@row.DepartmentWise</td>
                                    <td>@row.ActivityName</td>
                                    <td>
                                        <a asp-action="ViewOtherActivityPdf" asp-route-id="@row.Id"
                                           class="btn btn-secondary btn-sm" target="_blank">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <form asp-action="DeleteOtherAcademicActivity" asp-route-id="@row.Id"
                                              method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-secondary btn-sm text-danger"
                                                    onclick="confirmDelete(this)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    

    <!-- ── 5. Committees ─────────────────────────────────────────────────── -->
    <div class="section-card mt-4">
        <div class="section-header">
            <div class="icon-wrap"><i class="bi bi-diagram-3" style="font-size:1.5rem; color:#1a4c8b;"></i></div>
            <h2>5. Committees</h2>
        </div>
        <div class="section-body">
            <div class="mb-3">
                <span class="text-danger fw-bold" style="font-size:0.85rem;">
                    The uploading of document is compulsory if its available
                </span>
            </div>

            @if (Model.Committees?.Any() == true)
            {
                <form asp-action="SaveCommitteeDetails" method="post" enctype="multipart/form-data" id="committeeForm">
                    @Html.AntiForgeryToken()
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Committee Name</th>
                                <th class="text-center" style="width:120px;">Available</th>
                                <th>Document</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Committees.Count; i++)
                            {
                                var committee = Model.Committees[i];
                                <tr>
                                    <input type="hidden" name="Committees[@i].CommitteeId" value="@committee.CommitteeId" />
                                    <input type="hidden" name="Committees[@i].CommitteeName" value="@committee.CommitteeName" />
                                    <td class="fw-semibold">
                                        @committee.CommitteeName
                                        @if (committee.CourseLevel?.ToUpper() == "UG")
                                        {
                                            <span class="badge bg-info ms-2">UG *</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <select name="Committees[@i].IsPresent" class="form-control is-present-select">
                                            <option value="">-- Select --</option>
                                            <option value="Y" @(committee.IsPresent == "Y" ? "selected" : "")>Yes</option>
                                            <option value="N" @(committee.IsPresent == "N" ? "selected" : "")>No</option>
                                        </select>
                                    </td>
                                    <td>
                                        @* FIX: Wrapped in upload-group for same-line alignment *@
                                        <div class="upload-group" style="display:@(committee.IsPresent == "Y" ? "flex" : "none")">
                                            <label for="committeePdf_@i" class="custom-upload-btn">
                                                <i class="bi bi-upload"></i> Choose File
                                            </label>
                                            <input type="file" id="committeePdf_@i"
                                                   name="Committees[@i].CommitteePdf"
                                                   accept="application/pdf"
                                                   onchange="handleFileChange(this,'committeePdfName_@i')" />
                                            <span class="file-name-display" id="committeePdfName_@i" style="display:none;">
                                                <i class="bi bi-file-earmark-pdf"></i><span class="name-text"></span>
                                            </span>
                                            @if (!string.IsNullOrEmpty(committee.CommitteePdfName))
                                            {
                                                <a asp-action="ViewCommitteePdf"
                                                   asp-route-committeeId="@committee.CommitteeId"
                                                   target="_blank" class="btn-view">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="mt-3">
                        <small class="text-danger fw-semibold">
                            * Note: For PG and SS colleges, please select <strong>NO</strong> for UG committees.
                        </small>
                    </div>

                    <div class="text-center mt-4">
                        <button type="submit" class="btn btn-success-main">
                            <i class="bi bi-cloud-arrow-up me-2"></i>Save Committee Details
                        </button>
                    </div>
                </form>
            }
        </div>
    </div>

    <!-- Navigation -->
    <div class="d-flex justify-content-between align-items-center mt-4">
        <a asp-controller="CA_Med_StaffDetails"
           asp-action="CA_Med_StaffDetails"
           class="btn btn-secondary">← Previous</a>
        <a asp-controller="Aff_CA_MedicalLibrary"
           asp-action="Aff_CA_Medical_LibraryDetails"
           class="btn btn-primary">Next →</a>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <script>
        // File validation: PDF only, max 2 MB, show filename
        function handleFileChange(input, displayId) {
            const file = input.files[0];
            const display = document.getElementById(displayId);

            if (!file) { if (display) display.style.display = 'none'; return; }

            if (file.type !== 'application/pdf') {
                Swal.fire({ icon: 'error', title: 'Invalid File Type', text: 'Only PDF files are allowed.', confirmButtonColor: '#d33' });
                input.value = '';
                if (display) display.style.display = 'none';
                return;
            }

            if (file.size > 5 * 1024 * 1024) {
                Swal.fire({ icon: 'error', title: 'File Too Large', text: 'File size must not exceed 5 MB.', confirmButtonColor: '#d33' });
                input.value = '';
                if (display) display.style.display = 'none';
                return;
            }

            if (display) {
                display.querySelector('.name-text').textContent = file.name;
                display.style.display = 'inline-flex';
            }
        }

        // Delete confirmation
        function confirmDelete(button) {
            const form = button.closest('form');
            Swal.fire({
                title: 'Are you sure?', text: 'You want to delete this activity?',
                icon: 'warning', showCancelButton: true,
                confirmButtonColor: '#d33', cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!', cancelButtonText: 'No, cancel'
            }).then(result => { if (result.isConfirmed) form.submit(); });
        }

        // Toggle PDF upload visibility for committees
                document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.is-present-select').forEach(select => {
                function toggleFileUpload() {
                    const row = select.closest('tr');
                    const wrapper = row.querySelector('.upload-group');

                    if (wrapper) {
                        wrapper.style.display = select.value === 'Y' ? 'flex' : 'none';
                    }
                }

                toggleFileUpload();
                select.addEventListener('change', toggleFileUpload);
            });
        });

        // ── SweetAlert for TempData messages ─────────────────────────────────
        // FIX: removed the incorrect && Context.Request.Method == "POST" check.
        // After a redirect (POST→GET), method is always GET, so success
        // alerts NEVER showed. TempData is the correct signal — no method check needed.
        @if (TempData["Error"] != null)
        {
                <text>
                    Swal.fire({
                        icon: 'error', title: 'Save Failed',
                        text: '@Html.Raw(TempData["Error"])',
                        timer: 10000, confirmButtonColor: '#d33'
                    });
                </text>
        }

        @if (TempData["Success"] != null)
        {
                <text>
                    Swal.fire({
                        icon: 'success', title: 'Saved!',
                        text: '@Html.Raw(TempData["Success"])',
                        confirmButtonColor: '#198754',
                        timer: 2500, timerProgressBar: true
                    });
                </text>
        }
    </script>
}
