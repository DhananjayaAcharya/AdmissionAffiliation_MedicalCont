    <div class="modal fade" id="collegeModal" tabindex="-1" aria-labelledby="collegeModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content" style="border:none;border-radius:18px;overflow:hidden;box-shadow:0 32px 90px rgba(4,16,31,.32);">

                <!-- Header -->
                <div class="modal-header modal-course-header">
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:10px;color:rgba(255,255,255,.45);letter-spacing:1.3px;text-transform:uppercase;margin-bottom:5px;display:flex;align-items:center;gap:6px;">
                            <i class="bi bi-building"></i> Affiliated College &nbsp;·&nbsp; RGUHS Karnataka
                        </div>
                        <h5 class="modal-title" id="collegeModalLabel"
                            style="font-family:'Playfair Display',Georgia,serif;color:#fff;font-size:18px;font-weight:700;line-height:1.3;margin:0;">
                            —
                        </h5>
                        <div id="modalMeta" style="font-size:11.5px;color:rgba(255,255,255,.5);margin-top:6px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;"></div>
                    </div>
                    <button type="button" class="btn-close btn-close-white ms-3" data-bs-dismiss="modal" aria-label="Close" style="opacity:.65;flex-shrink:0;"></button>
                </div>

                <!-- Summary strip -->
                <div class="modal-summary-strip" id="modalSummary"></div>

                <!-- Body -->
                <div class="modal-body" style="padding:0;">
                    <div style="padding:20px 24px 24px;">

                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px;">
                            <div style="font-family:'Playfair Display',Georgia,serif;font-size:15px;font-weight:700;color:var(--navy);display:flex;align-items:center;gap:8px;">
                                <i class="bi bi-journal-bookmark-fill" style="color:var(--royal);"></i>
                                Courses &amp; Intake Details
                            </div>
                            <div id="modalCourseCount"
                                 style="background:var(--royal);color:#fff;font-size:10px;font-weight:700;padding:4px 14px;border-radius:20px;letter-spacing:.8px;">
                            </div>
                        </div>

                        <!-- Spinner -->
                        <div id="modalSpinner" class="text-center py-5">
                            <div class="spinner-border" role="status"
                                 style="width:2.4rem;height:2.4rem;border-width:.24em;color:var(--royal);">
                                <span class="visually-hidden">Loading…</span>
                            </div>
                            <div style="font-size:12px;color:var(--muted);margin-top:12px;">Fetching course data…</div>
                        </div>

                        <!-- Error -->
                        <div id="modalError" style="display:none;text-align:center;padding:40px 0;">
                            <div style="font-size:42px;opacity:.25;margin-bottom:12px;">⚠️</div>
                            <div style="font-size:14px;font-weight:600;color:var(--navy);margin-bottom:5px;">Could not load data</div>
                            <div style="font-size:12px;color:var(--muted);">Please check your connection and try again.</div>
                        </div>

                        <!-- Empty -->
                        <div id="modalEmpty" style="display:none;text-align:center;padding:40px 0;">
                            <div style="font-size:42px;opacity:.25;margin-bottom:12px;">📭</div>
                            <div style="font-size:14px;font-weight:600;color:var(--navy);margin-bottom:5px;">No courses found</div>
                            <div style="font-size:12px;color:var(--muted);">No course records are available for this college.</div>
                        </div>

                        <!-- Table -->
                        <div id="modalTableWrap" style="display:none;overflow-x:auto;border-radius:10px;border:1px solid var(--border);box-shadow:var(--shadow-sm);">
                            <table class="course-table">
                                <thead>
                                    <tr>
                                        <th style="width:40px;">SlNo</th>
                                        <th class="col-course-code">Course Code</th>
                                        <th>Course Name</th>
                                        <th style="width:110px;text-align:center;">Existing Intake</th>
                                    </tr>
                                </thead>
                                <tbody id="modalTableBody"></tbody>
                            </table>
                        </div>

                    </div>
                </div>

                <!-- Footer -->
                <div class="modal-footer" style="border-top:1px solid var(--border);padding:12px 24px;background:var(--off);justify-content:space-between;flex-wrap:wrap;gap:8px;">
                    <div style="font-size:10.5px;color:var(--muted);display:flex;align-items:center;gap:5px;">
                        <i class="bi bi-shield-check" style="color:var(--royal);"></i>
                        Data sourced from RGUHS Affiliation Records
                    </div>
                    <button type="button" class="btn-clr" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle"></i> Close
                    </button>
                </div>

            </div>
        </div>
    </div>
    <!-- /modal -->
    <!-- Bootstrap JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>

    <script>
        /* ── Live clock ── */
        function tick() {
            var el = document.getElementById('liveClock');
            if (!el) return;
            var now = new Date();
            el.textContent =
                now.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) + '  ' +
                now.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
        tick(); setInterval(tick, 1000);

        /* ── Mobile nav toggle ── */
        var toggle = document.getElementById('navToggle');
        var navLinks = document.getElementById('navLinks');
        if (toggle && navLinks) {
            toggle.addEventListener('click', function () { navLinks.classList.toggle('open'); });
        }

        /* ── Body layout height (desktop) ── */
        function fitLayout() {
            var bl = document.getElementById('bodyLayout');
            if (!bl) return;
            if (window.innerWidth < 1200) { bl.style.height = 'auto'; return; }
            var offsetTop = bl.getBoundingClientRect().top + window.scrollY;
            var footerH   = document.querySelector('.site-footer').offsetHeight;
            var totalH    = document.documentElement.scrollHeight;
            bl.style.height = (totalH - offsetTop - footerH) + 'px';
        }
        fitLayout();
        window.addEventListener('resize', fitLayout);

        /* ════════════════════════════════════════
           COLLEGE COURSES MODAL
        ════════════════════════════════════════ */
        var _modal = new bootstrap.Modal(document.getElementById('collegeModal'));

        function openCollegeModal(code, name, town, faculty) {

            document.getElementById('collegeModalLabel').textContent = name;
            document.getElementById('modalMeta').innerHTML =
                '<span style="display:inline-flex;align-items:center;gap:4px;"><i class="bi bi-geo-alt-fill" style="color:#7aadff;"></i>' + town + '</span>' +
                '<span style="opacity:.35;">·</span>' +
                '<span style="display:inline-flex;align-items:center;gap:4px;"><i class="bi bi-mortarboard-fill" style="color:#7aadff;"></i>' + faculty + '</span>';

            document.getElementById('modalSummary').innerHTML       = '';
            document.getElementById('modalSpinner').style.display   = 'block';
            document.getElementById('modalError').style.display     = 'none';
            document.getElementById('modalEmpty').style.display     = 'none';
            document.getElementById('modalTableWrap').style.display = 'none';
            document.getElementById('modalCourseCount').textContent  = '';

            _modal.show();

            fetch('/MainDashboard/CollegeCourses?collegeCode=' + encodeURIComponent(code))
                .then(function (res) {
                    if (!res.ok) throw new Error('HTTP ' + res.status);
                    return res.json();
                })
                .then(function (data) {
                    document.getElementById('modalSpinner').style.display = 'none';

                    if (!data || data.length === 0) {
                        document.getElementById('modalEmpty').style.display = 'block';
                        return;
                    }

                    var totalIntake = data.reduce(function (s, x) { return s + (x.existingIntake || 0); }, 0);
                    document.getElementById('modalSummary').innerHTML =
                        makeSummaryPill('bi-journal-bookmark-fill', data.length, 'Total Courses') +
                        makeSummaryPill('bi-people-fill',           totalIntake,  'Total Intake');

                    document.getElementById('modalCourseCount').textContent =
                        data.length + ' COURSE' + (data.length !== 1 ? 'S' : '');

                    var rows = data.map(function (row, i) {
                        var intake = (row.existingIntake !== null && row.existingIntake !== undefined)
                            ? row.existingIntake : null;

                        var intakeCell = intake !== null && intake > 0
                            ? '<span class="intake-badge intake-badge-filled">' + intake + '</span>'
                            : '<span class="intake-badge intake-badge-zero">—</span>';

                        return '<tr>' +
                            '<td class="td-num">' + (i + 1) + '</td>' +
                            '<td class="col-course-code"><span class="td-code">' + (row.courseCode || '—') + '</span></td>' +
                            '<td style="font-weight:500;line-height:1.5;color:var(--navy);">' + (row.courseName || '—') + '</td>' +
                            '<td style="text-align:center;">' + intakeCell + '</td>' +
                            '</tr>';
                    }).join('');

                    document.getElementById('modalTableBody').innerHTML = rows;
                    document.getElementById('modalTableWrap').style.display = 'block';
                })
                .catch(function () {
                    document.getElementById('modalSpinner').style.display = 'none';
                    document.getElementById('modalError').style.display   = 'block';
                });
        }

        function makeSummaryPill(icon, value, label) {
            return '<div class="modal-summary-pill">' +
                '<div class="msp-icon"><i class="bi ' + icon + '"></i></div>' +
                '<div>' +
                    '<div class="msp-num">' + value + '</div>' +
                    '<div class="msp-lbl">' + label + '</div>' +
                '</div>' +
                '</div>';
        }
    </script>

</body>
</html>
