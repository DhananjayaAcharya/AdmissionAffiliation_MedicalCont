    <!-- ════ BODY LAYOUT ════ -->
    <div class="body-layout" id="bodyLayout">

        <!-- MAIN PANE -->
        <div class="main-pane">

            <div class="sec-head">
                <h3>Streams &amp; Affiliated Colleges</h3>
                <div class="sec-line"></div>
                <span class="sec-chip"><i class="bi bi-calendar3"></i> 2026–27</span>
            </div>

            <!-- Faculty Chips -->
            <div class="faculty-scroll">
                @{
                    bool allActive = Model.ActiveFaculty == "ALL";
                    string allUrl = Url.Action("Rguhsdashboard", new { faculty = "ALL", search = Model.SearchTerm });
                }
                <a class="fac-chip @(allActive ? "active" : "")" href="@allUrl">
                    🏛️ All Streams <span class="chip-cnt">@Model.TotalColleges</span>
                </a>
                @foreach (var fac in Model.Faculties)
                {
                    bool isActive = Model.ActiveFaculty == fac.FacultyId;
                    string facUrl = Url.Action("Rguhsdashboard", new { faculty = fac.FacultyId, search = Model.SearchTerm });
                    <a class="fac-chip @(isActive ? "active" : "")" href="@facUrl">
                        @fac.Icon @fac.FacultyName <span class="chip-cnt">@fac.CollegeCount</span>
                    </a>
                }
            </div>

            <!-- Search / Filter Bar -->
            <form method="get" action="@Url.Action("Rguhsdashboard")" class="filter-bar">
                <input type="hidden" name="faculty" value="@Model.ActiveFaculty" />
                <div class="search-field">
                    <i class="bi bi-search si"></i>
                    <input type="text" name="search" id="searchInput" value="@Model.SearchTerm"
                           placeholder="Search college name or town…" autocomplete="off" />
                </div>
                <button type="submit" class="btn-srch"><i class="bi bi-search"></i> Search</button>
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <a class="btn-clr" href="@Url.Action("Rguhsdashboard", new { faculty = Model.ActiveFaculty })">
                        <i class="bi bi-x-circle"></i> Clear
                    </a>
                }
                <div class="res-badge">
                    <strong>@Model.Colleges.Count</strong> college@(Model.Colleges.Count != 1 ? "s" : "") found
                </div>
            </form>

            <!-- College Cards -->
            <div class="college-grid">
                @if (Model.Colleges.Count == 0)
                {
                    <div class="empty-state">
                        <div class="em-ico">🔍</div>
                        <h4>No colleges found</h4>
                        <p>No colleges match your current filter or search term.</p>
                        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.ActiveFaculty != "ALL")
                        {
                            <a href="@Url.Action("Rguhsdashboard")"
                               style="display:inline-flex;align-items:center;gap:6px;margin-top:14px;color:var(--blue-400);font-weight:600;text-decoration:none;font-size:13px;">
                                <i class="bi bi-arrow-left"></i> Show all colleges
                            </a>
                        }
                    </div>
                }
                else
                {
                    @foreach (var c in Model.Colleges)
                    {
                        var safeName = c.CollegeName.Replace("'", "\\'").Replace("\"", "&quot;");
                        var safeFac = (c.FacultyIcon + " " + c.FacultyName).Replace("'", "\\'");
                        var safeTown = c.CollegeTown.Replace("'", "\\'");

                        <div class="c-card"
                             onclick="openCollegeModal('@c.CollegeCode','@safeName','@safeTown','@safeFac')"
                             title="Click to view courses">
                            <div class="c-name">@c.CollegeName</div>
                            <div class="c-meta">
                                <span class="c-town">
                                    <i class="bi bi-geo-alt-fill"></i>@c.CollegeTown
                                </span>
                                <span class="c-fac">@c.FacultyIcon @c.FacultyName</span>
                            </div>
                            <div class="c-arrow">
                                View Courses <i class="bi bi-arrow-up-right"></i>
                            </div>
                        </div>
                    }
                }
            </div>

