@using static Medical_Affiliation.Controllers.MainDashboardController
@model RguhsDashboardViewModel
@{
    ViewData["Title"] = "RGUHS – Admission & Affiliation Portal";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <meta name="description" content="Rajiv Gandhi University of Health Sciences – Admission & Affiliation Portal Karnataka" />
    <title>RGUHS – Admission &amp; Affiliation Portal | Karnataka</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" />

    <style>
        /* ════════════════════════════════════════
                                                           DESIGN TOKENS
                                                        ════════════════════════════════════════ */
        :root {
            --navy: #04101f;
            --navy2: #071a35;
            --blue: #0b2a5e;
            --royal: #1046aa;
            --sky: #1a5bcc;
            --sky2: #2271e8;
            --gold: #c4891a;
            --gold2: #f0bf38;
            --off: #f0f4fb;
            --surface: #e4ecf7;
            --muted: #5e6f8c;
            --border: #ccd7ed;
            --white: #ffffff;
            --shadow-sm: 0 2px 10px rgba(4,16,31,.06);
            --shadow-md: 0 6px 24px rgba(4,16,31,.11);
            --shadow-lg: 0 14px 48px rgba(4,16,31,.18);
            --r: 10px;
            --r2: 16px;
            --fd: 'Playfair Display', Georgia, serif;
            --fb: 'DM Sans', system-ui, sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
            font-size: 15px;
        }

        body {
            font-family: var(--fb);
            background: var(--off);
            color: var(--navy);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* ════ UTILITY BAR ════ */
        .util-bar {
            background: var(--navy);
            padding: 5px 0;
            border-bottom: 1px solid rgba(255,255,255,.05);
            width: 100%;
        }

        .util-inner {
            width: 100%;
            padding: 0 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            flex-wrap: wrap;
        }

        .util-links {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            align-items: center;
        }

            .util-links a {
                color: rgba(255,255,255,.48);
                text-decoration: none;
                font-size: 11px;
                letter-spacing: .3px;
                transition: color .18s;
                display: flex;
                align-items: center;
                gap: 4px;
            }

                .util-links a:hover {
                    color: var(--gold2);
                }

        .live-clock {
            color: rgba(255,255,255,.38);
            font-size: 11px;
            font-variant-numeric: tabular-nums;
        }

        .lang-sel {
            background: rgba(255,255,255,.07);
            border: 1px solid rgba(255,255,255,.12);
            color: rgba(255,255,255,.65);
            padding: 3px 8px;
            border-radius: 5px;
            font-size: 11px;
            font-family: var(--fb);
            cursor: pointer;
        }

        /* ════ SITE HEADER ════ */
        .site-header {
            background: linear-gradient(135deg, #003087 0%, #0046b0 50%, #0055cc 100%);
            color: white;
            width: 100%;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            position: relative;
            overflow: hidden;
        }

            .site-header::before {
                content: '';
                position: absolute;
                inset: 0;
                pointer-events: none;
                background: radial-gradient(ellipse 900px 500px at 90% -20%, rgba(240,191,56,.09) 0%, transparent 60%), radial-gradient(ellipse 400px 300px at -5% 120%, rgba(26,91,204,.25) 0%, transparent 60%);
            }

            .site-header::after {
                content: '';
                position: absolute;
                inset: 0;
                pointer-events: none;
                background-image: radial-gradient(circle, rgba(255,255,255,.018) 1px, transparent 1px);
                background-size: 28px 28px;
            }

        .header-inner {
            width: 100%;
            padding: 18px 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            position: relative;
            z-index: 1;
            flex-wrap: nowrap;
        }

        .emblem {
            flex-shrink: 0;
            display: flex;
            align-items: center;
        }

        .university-logo {
            height: 84px;
            width: auto;
            object-fit: contain;
            filter: drop-shadow(0 3px 10px rgba(0,0,0,0.35));
            border-radius: 8px;
            display: block;
        }

        .header-text {
            flex: 1 1 0;
            min-width: 0;
        }

        .univ-name {
            font-family: var(--fd);
            font-size: clamp(14px, 1.6vw, 24px);
            color: #fff;
            line-height: 1.22;
            font-weight: 700;
        }

        .univ-sub {
            font-size: clamp(10px, 0.9vw, 13px);
            color: rgba(255,255,255,.65);
            margin-top: 5px;
            letter-spacing: .3px;
        }

        .badge-row {
            display: flex;
            gap: 6px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .hbadge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: clamp(9px, 0.8vw, 12px);
            font-weight: 600;
            letter-spacing: .35px;
            border: 1px solid;
            white-space: nowrap;
        }

        .hbadge-gold {
            background: rgba(255,215,0,.15);
            border-color: rgba(255,215,0,.42);
            color: #ffd700;
        }

        .header-actions {
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 9px;
        }

        .btn-portal {
            background: linear-gradient(135deg, #ffd700 0%, #f0a500 100%);
            color: #003087;
            border: none;
            padding: clamp(9px,0.9vw,13px) clamp(16px,1.6vw,28px);
            border-radius: 50px;
            font-size: clamp(11px, 0.95vw, 15px);
            font-weight: 700;
            font-family: var(--fb);
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(255,215,0,.42);
            transition: transform .15s, box-shadow .15s;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            text-decoration: none;
            white-space: nowrap;
        }

            .btn-portal:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(255,215,0,.55);
                color: #003087;
            }

        .portal-note {
            color: rgba(255,255,255,.8);
            font-size: clamp(9px, 0.78vw, 12px);
            display: flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }

        .pulse-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #00ff9d;
            flex-shrink: 0;
            box-shadow: 0 0 8px #00ff9d;
            animation: pglow 2s ease-in-out infinite;
        }

        @@keyframes pglow {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: .3;
            }
        }

        /* ════ PRIMARY NAV ════ */
        .primary-nav {
            background: var(--navy);
            border-bottom: 2px solid var(--gold);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 3px 18px rgba(4,16,31,.5);
            width: 100%;
        }

        .nav-inner {
            width: 100%;
            padding: 0 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .nav-links {
            display: flex;
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .nav-links a {
                display: flex;
                align-items: center;
                gap: 5px;
                padding: 13px 14px;
                color: rgba(255,255,255,.58);
                text-decoration: none;
                font-size: 12px;
                font-weight: 500;
                letter-spacing: .2px;
                border-bottom: 2px solid transparent;
                margin-bottom: -2px;
                transition: color .2s, border-color .2s;
                white-space: nowrap;
            }

                .nav-links a:hover {
                    color: var(--gold2);
                    border-bottom-color: var(--gold2);
                }

                .nav-links a.active {
                    color: var(--gold2);
                    border-bottom-color: var(--gold2);
                    font-weight: 600;
                }

        .nav-toggle {
            display: none;
            background: none;
            border: 1px solid rgba(255,255,255,.2);
            color: #fff;
            padding: 6px 10px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
            flex-shrink: 0;
        }

        .nav-search {
            position: relative;
        }

            .nav-search input {
                background: rgba(255,255,255,.07);
                border: 1px solid rgba(255,255,255,.11);
                color: #fff;
                padding: 7px 13px 7px 32px;
                border-radius: 7px;
                font-size: 12px;
                font-family: var(--fb);
                width: 175px;
                outline: none;
                transition: all .2s;
            }

                .nav-search input::placeholder {
                    color: rgba(255,255,255,.26);
                }

                .nav-search input:focus {
                    border-color: var(--gold);
                    background: rgba(255,255,255,.1);
                    width: 205px;
                }

            .nav-search .ns-icon {
                position: absolute;
                left: 9px;
                top: 50%;
                transform: translateY(-50%);
                color: rgba(255,255,255,.3);
                font-size: 12px;
                pointer-events: none;
            }

        /* ════ TICKER ════ */
        .ticker-bar {
            background: linear-gradient(90deg, #c0830e, var(--gold));
            display: flex;
            align-items: stretch;
            overflow: hidden;
            height: 34px;
            width: 100%;
        }

        .ticker-label {
            background: var(--navy);
            color: var(--gold2);
            padding: 0 16px;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.6px;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 7px;
            flex-shrink: 0;
            border-right: 1px solid rgba(255,255,255,.09);
            text-transform: uppercase;
        }

        .blink-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #e63;
            animation: blink 1.1s ease-in-out infinite;
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1
            }

            50% {
                opacity: .1
            }
        }

        .ticker-track {
            overflow: hidden;
            flex: 1;
            display: flex;
            align-items: center;
        }

        .ticker-inner {
            display: flex;
            white-space: nowrap;
            animation: tscroll 55s linear infinite;
        }

            .ticker-inner:hover {
                animation-play-state: paused;
            }

        @@keyframes tscroll {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        .t-item {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 11.5px;
            font-weight: 600;
            color: var(--navy);
            padding-right: 48px;
        }

            .t-item a {
                color: var(--navy);
                text-decoration: none;
            }

                .t-item a:hover {
                    text-decoration: underline;
                }

        /* ════ HERO STRIP ════ */
        .hero-strip {
            background: linear-gradient(100deg, var(--royal) 0%, var(--sky) 55%, var(--sky2) 100%);
            padding: 20px 40px;
            position: relative;
            overflow: hidden;
            width: 100%;
        }

            .hero-strip::before {
                content: '';
                position: absolute;
                right: -60px;
                top: -80px;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                border: 56px solid rgba(255,255,255,.04);
            }

        .hero-inner {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
        }

        .hero-text h2 {
            font-family: var(--fd);
            font-size: clamp(14px, 1.7vw, 22px);
            color: #fff;
            font-weight: 700;
            line-height: 1.25;
        }

        .hero-text p {
            font-size: 12px;
            color: rgba(255,255,255,.58);
            margin-top: 4px;
        }

        .stat-pills {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .stat-pill {
            background: rgba(255,255,255,.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,.15);
            border-radius: var(--r2);
            padding: 11px 18px;
            text-align: center;
            min-width: 82px;
            transition: background .2s, transform .2s;
        }

            .stat-pill:hover {
                background: rgba(255,255,255,.18);
                transform: translateY(-2px);
            }

        .stat-num {
            font-family: var(--fd);
            font-size: 26px;
            color: var(--gold2);
            font-weight: 700;
            line-height: 1;
        }

        .stat-lbl {
            font-size: 9.5px;
            color: rgba(255,255,255,.5);
            margin-top: 3px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* ════ HERO CAROUSEL ════ */
        .rguhs-carousel {
            width: 100%;
            overflow: hidden;
            background: var(--navy);
            line-height: 0;
        }

        .carousel-img {
            width: 100%;
            height: clamp(200px, 42vw, 520px);
            object-fit: cover;
            object-position: center;
            display: block;
            filter: brightness(.78);
            transition: filter .3s;
        }

        .rguhs-carousel:hover .carousel-img {
            filter: brightness(.72);
        }

        .carousel-caption-custom {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: clamp(14px, 3vw, 36px) clamp(18px, 5vw, 60px);
            background: linear-gradient(to top, rgba(4,16,31,.82) 0%, rgba(4,16,31,.35) 70%, transparent 100%);
            text-align: left;
            line-height: 1;
        }

        .cc-tag {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--gold);
            color: var(--navy);
            font-size: clamp(9px, 1vw, 11px);
            font-weight: 700;
            letter-spacing: .9px;
            text-transform: uppercase;
            padding: 4px 12px;
            border-radius: 20px;
            margin-bottom: clamp(6px, 1.2vw, 12px);
        }

        .cc-title {
            font-family: var(--fd);
            font-size: clamp(14px, 2.8vw, 36px);
            font-weight: 700;
            color: #fff;
            line-height: 1.2;
            margin-bottom: clamp(4px, 0.8vw, 10px);
            text-shadow: 0 2px 12px rgba(0,0,0,.4);
        }

        .cc-sub {
            font-size: clamp(10px, 1.3vw, 15px);
            color: rgba(255,255,255,.72);
            line-height: 1.4;
        }

        .rguhs-carousel .carousel-indicators {
            margin-bottom: clamp(8px, 1.5vw, 18px);
            gap: 4px;
        }

            .rguhs-carousel .carousel-indicators button {
                width: clamp(18px, 2.5vw, 32px);
                height: 4px;
                border-radius: 2px;
                background: rgba(255,255,255,.38);
                border: none;
                transition: background .25s, width .25s;
            }

                .rguhs-carousel .carousel-indicators button.active {
                    background: var(--gold2);
                    width: clamp(28px, 4vw, 52px);
                }

        .rguhs-ctrl {
            width: clamp(36px, 4vw, 54px);
            opacity: 0;
            transition: opacity .22s;
        }

        .rguhs-carousel:hover .rguhs-ctrl {
            opacity: 1;
        }

        .rguhs-carousel .carousel-control-prev-icon,
        .rguhs-carousel .carousel-control-next-icon {
            background-color: rgba(4,16,31,.5);
            border-radius: 50%;
            padding: 14px;
            background-size: 50%;
        }

        /* ════ BODY LAYOUT ════ */
        .body-layout {
            display: flex;
            overflow: hidden;
            width: 100%;
        }

        .main-pane {
            flex: 1;
            min-width: 0;
            overflow-y: auto;
            padding: 26px 26px 48px;
            scrollbar-width: thin;
            scrollbar-color: var(--border) transparent;
        }

            .main-pane::-webkit-scrollbar {
                width: 5px;
            }

            .main-pane::-webkit-scrollbar-thumb {
                background: var(--border);
                border-radius: 4px;
            }

        .side-pane {
            width: 292px;
            flex-shrink: 0;
            background: var(--white);
            border-left: 1px solid var(--border);
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: var(--border) transparent;
        }

            .side-pane::-webkit-scrollbar {
                width: 4px;
            }

            .side-pane::-webkit-scrollbar-thumb {
                background: var(--border);
                border-radius: 4px;
            }

        /* ── SECTION HEADER ── */
        .sec-head {
            display: flex;
            align-items: center;
            gap: 13px;
            margin-bottom: 18px;
        }

            .sec-head h3 {
                font-family: var(--fd);
                font-size: 19px;
                color: var(--navy);
                font-weight: 700;
                white-space: nowrap;
            }

        .sec-line {
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .sec-chip {
            background: var(--royal);
            color: #fff;
            font-size: 9px;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 20px;
            letter-spacing: .9px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        /* ── FACULTY CHIPS ── */
        .faculty-scroll {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            padding-bottom: 6px;
            margin-bottom: 20px;
            scrollbar-width: none;
        }

            .faculty-scroll::-webkit-scrollbar {
                display: none;
            }

        .fac-chip {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 14px;
            border-radius: 40px;
            border: 1.5px solid var(--border);
            background: var(--white);
            color: var(--navy);
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            white-space: nowrap;
            flex-shrink: 0;
            transition: all .2s;
            box-shadow: var(--shadow-sm);
        }

            .fac-chip:hover {
                border-color: var(--sky);
                color: var(--royal);
                transform: translateY(-2px);
                box-shadow: var(--shadow-md);
            }

            .fac-chip.active {
                background: linear-gradient(135deg, var(--royal) 0%, var(--sky2) 100%);
                border-color: transparent;
                color: #fff;
                box-shadow: 0 4px 18px rgba(16,70,170,.32);
                transform: translateY(-2px);
            }

        .chip-icon {
            font-size: 15px;
            line-height: 1;
        }

        .chip-cnt {
            background: rgba(0,0,0,.1);
            border-radius: 20px;
            padding: 1px 7px;
            font-size: 10px;
            font-weight: 700;
        }

        .fac-chip.active .chip-cnt {
            background: rgba(255,255,255,.2);
        }

        /* ── FILTER BAR ── */
        .filter-bar {
            display: flex;
            gap: 9px;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .search-field {
            position: relative;
            flex: 1;
            min-width: 200px;
            max-width: 420px;
        }

            .search-field input {
                width: 100%;
                padding: 10px 14px 10px 38px;
                border: 1.5px solid var(--border);
                border-radius: var(--r);
                font-size: 13px;
                font-family: var(--fb);
                background: var(--white);
                color: var(--navy);
                outline: none;
                box-shadow: var(--shadow-sm);
                transition: border-color .2s, box-shadow .2s;
            }

                .search-field input:focus {
                    border-color: var(--royal);
                    box-shadow: 0 0 0 3px rgba(16,70,170,.1);
                }

            .search-field .si {
                position: absolute;
                left: 11px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--muted);
                font-size: 13px;
                pointer-events: none;
            }

        .btn-srch {
            background: linear-gradient(135deg, var(--royal) 0%, var(--sky) 100%);
            color: #fff;
            border: none;
            padding: 10px 20px;
            border-radius: var(--r);
            font-size: 12.5px;
            font-weight: 600;
            font-family: var(--fb);
            cursor: pointer;
            box-shadow: 0 3px 12px rgba(16,70,170,.28);
            transition: opacity .2s, transform .15s;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .btn-srch:hover {
                opacity: .9;
                transform: translateY(-1px);
            }

        .btn-clr {
            background: var(--white);
            color: var(--muted);
            border: 1.5px solid var(--border);
            padding: 10px 14px;
            border-radius: var(--r);
            font-size: 12.5px;
            font-family: var(--fb);
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: border-color .2s, color .2s;
        }

            .btn-clr:hover {
                border-color: var(--sky);
                color: var(--navy);
            }

        .res-badge {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--r);
            padding: 10px 15px;
            font-size: 12px;
            color: var(--muted);
            white-space: nowrap;
            box-shadow: var(--shadow-sm);
        }

            .res-badge strong {
                color: var(--navy);
                font-weight: 700;
            }

        /* ── COLLEGE GRID ── */
        .college-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(252px, 1fr));
            gap: 14px;
        }

        .c-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            padding: 16px 16px 36px;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: transform .22s, box-shadow .22s, border-color .22s;
            animation: fadeup .32s ease both;
            cursor: pointer;
        }

            .c-card:hover {
                transform: translateY(-4px);
                box-shadow: var(--shadow-lg);
                border-color: #a8c0e6;
            }

            .c-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, var(--royal) 0%, var(--gold) 100%);
            }

            .c-card::after {
                content: '';
                position: absolute;
                bottom: -18px;
                right: -18px;
                width: 70px;
                height: 70px;
                border-radius: 50%;
                background: var(--off);
                opacity: .5;
            }

        @@keyframes fadeup {
            from {
                opacity: 0;
                transform: translateY(13px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .c-card:nth-child(1) {
            animation-delay: .04s
        }

        .c-card:nth-child(2) {
            animation-delay: .08s
        }

        .c-card:nth-child(3) {
            animation-delay: .12s
        }

        .c-card:nth-child(4) {
            animation-delay: .16s
        }

        .c-card:nth-child(5) {
            animation-delay: .20s
        }

        .c-card:nth-child(6) {
            animation-delay: .24s
        }

        .c-card:nth-child(7) {
            animation-delay: .28s
        }

        .c-card:nth-child(8) {
            animation-delay: .32s
        }

        .c-card:nth-child(n+9) {
            animation-delay: .36s
        }

        .c-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 9px;
        }

        .c-code {
            display: none;
        }

        .c-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #27ae60;
            box-shadow: 0 0 0 3px rgba(39,174,96,.14);
        }

        .c-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--navy);
            line-height: 1.45;
            margin-bottom: 11px;
            position: relative;
            z-index: 1;
        }

        .c-foot {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 7px;
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
        }

        .c-town {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            color: var(--muted);
        }

        .c-fac {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            background: var(--off);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 2px 8px;
            font-size: 10px;
            font-weight: 500;
            color: var(--muted);
        }

        .c-view-label {
            position: absolute;
            bottom: 10px;
            right: 13px;
            font-size: 9.5px;
            color: var(--sky);
            font-weight: 600;
            z-index: 2;
            display: flex;
            align-items: center;
            gap: 3px;
            opacity: 0;
            transform: translateY(4px);
            transition: opacity .2s, transform .2s;
        }

        .c-card:hover .c-view-label {
            opacity: 1;
            transform: translateY(0);
        }

        .empty-state {
            grid-column: 1/-1;
            text-align: center;
            padding: 60px 20px;
            color: var(--muted);
        }

            .empty-state .em-ico {
                font-size: 50px;
                opacity: .3;
                margin-bottom: 12px;
            }

            .empty-state h4 {
                font-size: 15px;
                font-weight: 600;
                margin-bottom: 5px;
                color: var(--navy);
            }

        /* ── SIDEBAR WIDGETS ── */
        .widget {
            border-bottom: 1px solid var(--border);
        }

            .widget:last-child {
                border-bottom: none;
            }

        .w-head {
            background: linear-gradient(90deg, var(--navy) 0%, var(--blue) 100%);
            padding: 11px 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .w-head h4 {
                font-family: var(--fd);
                color: #fff;
                font-size: 14px;
                font-weight: 600;
            }

            .w-head i {
                color: var(--gold2);
                font-size: 14px;
            }

        .upd-list {
            list-style: none;
        }

        .upd-item {
            border-bottom: 1px solid var(--surface);
            padding: 10px 15px;
            transition: background .14s;
        }

            .upd-item:last-child {
                border-bottom: none;
            }

            .upd-item:hover {
                background: var(--off);
            }

            .upd-item a {
                display: block;
                text-decoration: none;
                color: var(--navy);
                font-size: 12px;
                line-height: 1.48;
                font-weight: 500;
            }

                .upd-item a:hover {
                    color: var(--royal);
                }

        .upd-date {
            font-size: 10px;
            color: var(--muted);
            margin-top: 2px;
        }

        .u-tag {
            display: inline-block;
            font-size: 9px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 4px;
            letter-spacing: .5px;
            margin-bottom: 3px;
        }

        .tag-new {
            background: #fff0f0;
            color: #b52a2a;
            border: 1px solid #f8cbc8;
        }

        .tag-imp {
            background: #fff9e0;
            color: #7a5500;
            border: 1px solid #f0d870;
        }

        .tag-info {
            background: #e8f0fe;
            color: var(--royal);
            border: 1px solid #bcd0f8;
        }

        .qlink-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1px;
            background: var(--border);
        }

        .qlink {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 5px;
            padding: 13px 8px;
            background: var(--white);
            text-decoration: none;
            color: var(--navy);
            font-size: 10.5px;
            font-weight: 600;
            text-align: center;
            transition: background .14s, color .14s;
        }

            .qlink:hover {
                background: var(--off);
                color: var(--royal);
            }

            .qlink i {
                font-size: 19px;
                color: var(--royal);
            }

        .hl-body {
            padding: 13px 15px;
            display: flex;
            flex-direction: column;
            gap: 9px;
        }

        .hl-row {
            display: flex;
            align-items: center;
            gap: 9px;
        }

        .hl-icon {
            width: 30px;
            height: 30px;
            border-radius: 7px;
            background: var(--off);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .hl-icon i {
                font-size: 14px;
                color: var(--royal);
            }

        .hl-lbl {
            font-size: 10px;
            color: var(--muted);
            margin-bottom: 1px;
        }

        .hl-val {
            font-size: 12px;
            font-weight: 600;
            color: var(--navy);
        }

            .hl-val a {
                color: var(--royal);
                text-decoration: none;
            }

                .hl-val a:hover {
                    text-decoration: underline;
                }

        /* ── MODAL STYLES ── */
        .modal-course-header {
            background: linear-gradient(135deg, #003087 0%, #0055cc 100%);
            border: none;
            padding: 20px 24px;
        }

        .modal-summary-strip {
            display: flex;
            border-bottom: 1px solid var(--border);
            background: var(--off);
        }

        .modal-summary-pill {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 20px;
            border-right: 1px solid var(--border);
        }

            .modal-summary-pill:last-child {
                border-right: none;
            }

        .msp-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: linear-gradient(135deg, var(--royal), var(--sky));
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .msp-icon i {
                color: #fff;
                font-size: 16px;
            }

        .msp-num {
            font-family: var(--fd);
            font-size: 22px;
            font-weight: 700;
            color: var(--navy);
            line-height: 1;
        }

        .msp-lbl {
            font-size: 9.5px;
            color: var(--muted);
            letter-spacing: .8px;
            text-transform: uppercase;
            margin-top: 2px;
        }

        .course-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12.5px;
        }

            .course-table thead tr {
                background: linear-gradient(90deg, var(--navy) 0%, var(--blue) 100%);
            }

            .course-table thead th {
                padding: 11px 14px;
                color: var(--gold2);
                font-size: 10px;
                font-weight: 700;
                letter-spacing: .9px;
                text-transform: uppercase;
                white-space: nowrap;
                border: none;
            }

                .course-table thead th:last-child {
                    text-align: center;
                }

            .course-table tbody tr {
                border-bottom: 1px solid var(--surface);
                transition: background .12s;
            }

                .course-table tbody tr:last-child {
                    border-bottom: none;
                }

                .course-table tbody tr:nth-child(even) {
                    background: var(--off);
                }

                .course-table tbody tr:nth-child(odd) {
                    background: var(--white);
                }

                .course-table tbody tr:hover {
                    background: #e8f0fd;
                }

            .course-table tbody td {
                padding: 11px 14px;
                color: var(--navy);
                vertical-align: middle;
            }

        .td-num {
            color: var(--muted);
            font-size: 11px;
            width: 36px;
        }

        .col-course-code {
            display: none;
        }

        .td-code {
            font-family: 'Courier New', monospace;
            font-size: 11px;
            color: var(--royal);
            background: #eaf0fc;
            padding: 3px 8px;
            border-radius: 5px;
            white-space: nowrap;
            display: inline-block;
        }

        .td-intake {
            text-align: center;
            font-weight: 700;
            font-size: 15px;
            color: var(--royal);
        }

        .td-intake-zero {
            color: var(--muted);
            font-weight: 400;
            font-size: 13px;
        }

        .intake-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 44px;
            height: 28px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
        }

        .intake-badge-filled {
            background: linear-gradient(135deg, #e8f4ff, #d0e8ff);
            color: var(--royal);
            border: 1px solid #b0d0f0;
        }

        .intake-badge-zero {
            background: var(--surface);
            color: var(--muted);
            border: 1px solid var(--border);
        }

        /* ── FOOTER ── */
        .site-footer {
            background: var(--navy);
            border-top: 2px solid var(--gold);
            width: 100%;
        }

        .footer-grid {
            width: 100%;
            padding: 28px 40px 18px;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 28px;
        }

        .foot-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .foot-logo {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: rgba(255,255,255,.07);
            border: 1px solid rgba(196,137,26,.33);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--fd);
            font-size: 16px;
            color: var(--gold2);
            font-weight: 700;
            flex-shrink: 0;
        }

        .foot-name {
            font-family: var(--fd);
            color: #fff;
            font-size: 13.5px;
            line-height: 1.35;
        }

            .foot-name span {
                display: block;
                font-size: 10.5px;
                color: rgba(255,255,255,.35);
                font-family: var(--fb);
                margin-top: 2px;
            }

        .foot-desc {
            font-size: 11.5px;
            color: rgba(255,255,255,.36);
            line-height: 1.7;
        }

        .foot-col h5 {
            font-size: 10px;
            font-weight: 700;
            color: var(--gold2);
            letter-spacing: 1.1px;
            text-transform: uppercase;
            margin-bottom: 11px;
        }

        .foot-col ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 7px;
        }

            .foot-col ul li a {
                color: rgba(255,255,255,.43);
                text-decoration: none;
                font-size: 11.5px;
                transition: color .18s;
            }

                .foot-col ul li a:hover {
                    color: var(--gold2);
                }

        .footer-bar {
            width: 100%;
            padding: 11px 40px;
            border-top: 1px solid rgba(255,255,255,.06);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
        }

            .footer-bar p {
                font-size: 10.5px;
                color: rgba(255,255,255,.26);
            }

            .footer-bar a {
                color: var(--gold2);
                text-decoration: none;
            }

        /* ════ RESPONSIVE ════ */
        @@media (min-width: 1400px) {
            .header-inner, .nav-inner, .hero-strip, .footer-grid, .footer-bar {
                padding-left: 56px;
                padding-right: 56px;
            }

            .university-logo {
                height: 92px;
            }
        }

        @@media (max-width: 1199px) {
            .body-layout {
                height: auto !important;
                flex-direction: column;
                overflow: visible;
            }

            .main-pane {
                overflow: visible;
            }

            .side-pane {
                width: 100%;
                border-left: none;
                border-top: 1px solid var(--border);
                overflow: visible;
            }

            .footer-grid {
                grid-template-columns: 1fr 1fr;
            }

            .header-inner {
                padding: 14px 24px;
                gap: 14px;
            }

            .nav-inner {
                padding: 0 24px;
            }

            .hero-strip {
                padding: 16px 24px;
            }

            .footer-grid {
                padding: 24px 24px 16px;
            }

            .footer-bar {
                padding: 10px 24px;
            }

            .university-logo {
                height: 72px;
            }

            .univ-sub {
                display: none;
            }
        }

        @@media (max-width: 991px) {
            .header-inner {
                padding: 12px 20px;
                flex-wrap: wrap;
                gap: 10px;
            }

            .university-logo {
                height: 64px;
            }

            .univ-name {
                font-size: 16px;
            }

            .univ-sub {
                display: none;
            }

            .badge-row {
                margin-top: 6px;
            }

            .portal-note {
                display: none;
            }

            .btn-portal {
                padding: 9px 18px;
                font-size: 12px;
            }

            .nav-toggle {
                display: block;
            }

            .nav-links {
                display: none;
                flex-direction: column;
                position: absolute;
                top: 100%;
                left: 0;
                right: 0;
                background: var(--navy);
                z-index: 999;
                border-bottom: 2px solid var(--gold);
                padding: 6px 0;
            }

                .nav-links.open {
                    display: flex;
                }

                .nav-links a {
                    padding: 12px 20px;
                    border-bottom: none;
                    border-top: 1px solid rgba(255,255,255,.05);
                }

            .nav-search {
                display: none;
            }

            .primary-nav {
                position: sticky;
                top: 0;
            }

            .hero-strip {
                padding: 14px 20px;
            }

            .hero-text h2 {
                font-size: 15px;
            }

            .stat-pill {
                padding: 8px 12px;
                min-width: 68px;
            }

            .stat-num {
                font-size: 20px;
            }

            .footer-grid {
                grid-template-columns: 1fr 1fr;
                padding: 20px;
            }

            .footer-bar {
                padding: 10px 20px;
            }

            .modal-summary-strip {
                flex-wrap: wrap;
            }

            .modal-summary-pill {
                min-width: 50%;
                border-bottom: 1px solid var(--border);
            }
        }

        @@media (max-width: 767px) {
            .util-inner {
                padding: 0 16px;
            }

            .util-links a span {
                display: none;
            }

            .header-inner {
                padding: 12px 16px;
            }

            .university-logo {
                height: 58px;
            }

            .univ-name {
                font-size: 14px;
            }

            .hero-strip {
                padding: 12px 16px;
            }

            .stat-pills {
                gap: 7px;
            }

            .stat-pill {
                padding: 7px 10px;
                min-width: 60px;
            }

            .stat-num {
                font-size: 18px;
            }

            .stat-lbl {
                font-size: 8.5px;
            }

            .main-pane {
                padding: 16px 14px 40px;
            }

            .college-grid {
                grid-template-columns: 1fr 1fr;
                gap: 10px;
            }

            .footer-grid {
                grid-template-columns: 1fr;
                padding: 18px 16px;
            }

            .footer-bar {
                padding: 10px 16px;
                flex-direction: column;
                align-items: flex-start;
                gap: 5px;
            }
            /* Carousel */
            .carousel-img {
                height: clamp(180px, 52vw, 300px);
                object-position: center 20%;
            }

            .carousel-caption-custom {
                padding: 12px 16px;
            }

            .rguhs-ctrl {
                opacity: .7;
            }
        }

        @@media (max-width: 599px) {
            .util-links {
                gap: 10px;
            }

                .util-links a {
                    font-size: 10px;
                }

            .header-inner {
                flex-direction: column;
                align-items: center;
                text-align: center;
                padding: 14px 14px 12px;
                gap: 10px;
            }

            .university-logo {
                height: 68px;
            }

            .univ-name {
                font-size: 15px;
                white-space: normal;
                text-align: center;
            }

            .univ-sub {
                display: block;
                font-size: 10px;
                text-align: center;
            }

            .badge-row {
                justify-content: center;
            }

            .header-actions {
                width: 100%;
                align-items: center;
            }

            .btn-portal {
                width: 100%;
                justify-content: center;
                padding: 11px 20px;
                font-size: 13px;
                border-radius: 10px;
            }

            .portal-note {
                display: flex;
                justify-content: center;
                font-size: 10px;
            }

            .hero-inner {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }

            .stat-pills {
                width: 100%;
                justify-content: space-between;
            }

            .stat-pill {
                flex: 1;
                min-width: 0;
                padding: 8px 6px;
            }

            .ticker-label {
                padding: 0 10px;
                font-size: 9px;
                letter-spacing: 1px;
            }

            .college-grid {
                grid-template-columns: 1fr;
            }

            .footer-grid {
                grid-template-columns: 1fr;
            }

            .modal-summary-pill {
                min-width: 100%;
            }
            /* Carousel */
            .carousel-img {
                height: 210px;
            }

            .cc-sub {
                display: none;
            }
        }

        @@media (max-width: 380px) {
            .university-logo {
                height: 54px;
            }

            .univ-name {
                font-size: 13px;
            }

            .hbadge {
                font-size: 9px;
                padding: 3px 9px;
            }

            .btn-portal {
                font-size: 12px;
            }

            .stat-num {
                font-size: 16px;
            }
        }
    </style>
</head>
<body>

    <!-- ════ UTILITY BAR ════ -->
    <div class="util-bar">
        <div class="util-inner">
            <div class="util-links">
                <a href="https://www.rguhs.ac.in" target="_blank"><i class="bi bi-globe2"></i><span>www.rguhs.ac.in</span></a>
                <a href="https://rguhs.karnataka.gov.in/rguhsec/" target="_blank"><i class="bi bi-file-earmark-check"></i><span>Eligibility Certificate</span></a>
                <a href="https://rguhs.karnataka.gov.in/rguhs_online/" target="_blank"><i class="bi bi-bar-chart-line"></i><span>Results Portal</span></a>
                <a href="https://www.rguhs.ac.in/notification_circulars_rguhs.html" target="_blank"><i class="bi bi-bell"></i><span>Notifications</span></a>
                <a href="https://www.rguhs.ac.in" target="_blank"><i class="bi bi-headset"></i><span>Help Desk</span></a>
            </div>
            <div style="display:flex;align-items:center;gap:10px;">
                <span class="live-clock" id="liveClock"></span>
                <select class="lang-sel"><option>English</option><option>ಕನ್ನಡ</option></select>
            </div>
        </div>
    </div>

    <!-- ════ HEADER ════ -->
    <header class="site-header">
        <div class="header-inner">
            <div class="emblem">
                <img src="~/images/newLogo.jpeg" alt="Rajiv Gandhi University of Health Sciences Logo" class="university-logo" />
            </div>
            <div class="header-text">
                <div class="univ-name">Rajiv Gandhi University of Health Sciences, Karnataka</div>
                <div class="univ-sub">4th 'T' Block, Jayanagar, Bangalore – 560 041 &nbsp;·&nbsp; Established 1996</div>
                <div class="badge-row">
                    <span class="hbadge hbadge-gold"><i class="bi bi-bank2"></i> Government of Karnataka</span>
                </div>
            </div>
            <div class="header-actions">
