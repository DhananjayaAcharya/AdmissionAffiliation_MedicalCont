@using static Medical_Affiliation.Controllers.MainDashboardController
@model RguhsDashboardViewModel
@{
    ViewData["Title"] = "RGUHS – College Details Portal";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <meta name="description" content="Rajiv Gandhi University of Health Sciences – Affiliated College Details Portal" />
    <title>RGUHS – College Details | Karnataka</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <style>
        /* ══════════════════════════════════
                   DESIGN TOKENS
                ══════════════════════════════════ */
        :root {
            --navy-950: #03060f;
            --navy-900: #060d1f;
            --navy-800: #0a1630;
            --navy-700: #0f2248;
            --navy-600: #163060;
            --navy-500: #1e4080;
            --blue-400: #2d62c8;
            --blue-300: #4a7dd8;
            --blue-200: #8ab0eb;
            --blue-100: #d4e4f9;
            --gold-600: #8a6200;
            --gold-500: #b07d00;
            --gold-400: #c99210;
            --gold-300: #e0ac2a;
            --gold-200: #f0cc6b;
            --gold-100: #fdf0c0;
            --neutral-50: #f8f9fc;
            --neutral-100: #f0f2f8;
            --neutral-200: #e2e6f0;
            --neutral-300: #c8cedf;
            --neutral-400: #8f9ab5;
            --neutral-500: #5e6b88;
            --neutral-700: #2a3450;
            --neutral-900: #0f1624;
            --white: #ffffff;
            --red: #c0392b;
            --green: #1a7a4a;
            --surface: #f4f6fc;
            --fd: 'Playfair Display', Georgia, serif;
            --fb: 'DM Sans', system-ui, sans-serif;
            --fm: 'DM Mono', 'Courier New', monospace;
            --r-sm: 6px;
            --r: 10px;
            --r-lg: 16px;
            --r-xl: 24px;
            --shadow-xs: 0 1px 3px rgba(6,13,31,.06), 0 1px 2px rgba(6,13,31,.04);
            --shadow-sm: 0 2px 8px rgba(6,13,31,.08), 0 1px 3px rgba(6,13,31,.05);
            --shadow-md: 0 4px 20px rgba(6,13,31,.10), 0 2px 8px rgba(6,13,31,.06);
            --shadow-lg: 0 12px 40px rgba(6,13,31,.14), 0 4px 16px rgba(6,13,31,.08);
            --shadow-xl: 0 24px 64px rgba(6,13,31,.20), 0 8px 24px rgba(6,13,31,.10);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
            font-size: 15px;
        }

        body {
            font-family: var(--fb);
            background: var(--neutral-50);
            color: var(--neutral-900);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        /* ══════════════ UTILITY BAR ══════════════ */
        .util-bar {
            background: var(--navy-900);
            border-bottom: 1px solid rgba(255,255,255,.05);
        }

        .util-inner {
            max-width: 100%;
            padding: 0 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 38px;
            gap: 8px;
        }

        .util-links {
            display: flex;
            gap: 0;
            align-items: center;
        }

            .util-links a {
                color: rgba(255,255,255,.4);
                text-decoration: none;
                font-size: 11px;
                letter-spacing: .3px;
                font-weight: 400;
                transition: color .18s, background .18s;
                display: flex;
                align-items: center;
                gap: 6px;
                padding: 0 15px;
                height: 38px;
                border-right: 1px solid rgba(255,255,255,.06);
            }

                .util-links a:first-child {
                    border-left: 1px solid rgba(255,255,255,.06);
                }

                .util-links a:hover {
                    color: var(--gold-300);
                    background: rgba(255,255,255,.03);
                }

                .util-links a i {
                    font-size: 11px;
                }

        .util-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .live-clock {
            color: rgba(255,255,255,.32);
            font-size: 11px;
            font-family: var(--fm);
            letter-spacing: .4px;
        }

        .lang-sel {
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.1);
            color: rgba(255,255,255,.5);
            padding: 4px 10px 4px 8px;
            border-radius: 5px;
            font-size: 11px;
            font-family: var(--fb);
            cursor: pointer;
            outline: none;
        }

        /* ══════════════ HEADER ══════════════ */
        .site-header {
            background: var(--navy-800);
            position: relative;
            overflow: hidden;
        }

            .site-header::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(255,255,255,.018) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.018) 1px, transparent 1px);
                background-size: 60px 60px;
                pointer-events: none;
            }

            .site-header::after {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(ellipse 900px 350px at 80% -60%, rgba(192,146,16,.10) 0%, transparent 60%), radial-gradient(ellipse 600px 500px at -5% 120%, rgba(30,64,128,.28) 0%, transparent 55%);
                pointer-events: none;
            }

        .header-inner {
            padding: 24px 40px;
            display: flex;
            align-items: center;
            gap: 28px;
            position: relative;
            z-index: 1;
        }

        /* Gold accent rule */
        .header-rule {
            width: 2px;
            height: 72px;
            background: linear-gradient(to bottom, transparent, var(--gold-300), transparent);
            flex-shrink: 0;
            opacity: .7;
        }

        .university-logo {
            height: 76px;
            width: auto;
            object-fit: contain;
            border-radius: var(--r);
            flex-shrink: 0;
            filter: drop-shadow(0 3px 12px rgba(0,0,0,.35));
        }

        .header-text {
            flex: 1;
            min-width: 0;
        }

        .univ-eyebrow {
            font-size: 9.5px;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--gold-300);
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 10px;
            opacity: .85;
        }

            .univ-eyebrow::before, .univ-eyebrow::after {
                content: '';
                display: block;
                height: 1px;
                width: 28px;
                background: linear-gradient(90deg, var(--gold-300), transparent);
            }

            .univ-eyebrow::after {
                background: linear-gradient(270deg, var(--gold-300), transparent);
            }

        .univ-name {
            font-family: var(--fd);
            font-size: clamp(17px, 1.9vw, 27px);
            color: #fff;
            font-weight: 600;
            line-height: 1.2;
            letter-spacing: .1px;
        }

        .univ-sub {
            font-size: 11px;
            color: rgba(255,255,255,.38);
            margin-top: 7px;
            letter-spacing: .3px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .univ-sub i {
                font-size: 10px;
                color: var(--blue-200);
                opacity: .7;
            }

        .header-badges {
            display: flex;
            gap: 7px;
            margin-top: 11px;
            flex-wrap: wrap;
        }

        .hbadge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 11px;
            border-radius: 4px;
            font-size: 9.5px;
            font-weight: 600;
            letter-spacing: .6px;
            text-transform: uppercase;
            border: 1px solid;
            white-space: nowrap;
        }

        .hbadge-gold {
            background: rgba(224,172,42,.08);
            border-color: rgba(224,172,42,.22);
            color: var(--gold-200);
        }

        .hbadge-blue {
            background: rgba(45,98,200,.12);
            border-color: rgba(45,98,200,.3);
            color: #93c5fd;
        }

        .header-cta {
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 10px;
        }

        .btn-portal {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 26px;
            background: linear-gradient(135deg, var(--gold-300) 0%, var(--gold-400) 50%, var(--gold-500) 100%);
            color: var(--navy-900);
            border: none;
            border-radius: var(--r);
            font-size: 13px;
            font-weight: 700;
            font-family: var(--fb);
            letter-spacing: .2px;
            text-decoration: none;
            cursor: pointer;
            box-shadow: 0 4px 18px rgba(192,146,16,.28), inset 0 1px 0 rgba(255,255,255,.25);
            transition: transform .18s, box-shadow .18s;
            white-space: nowrap;
        }

            .btn-portal:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 28px rgba(192,146,16,.38), inset 0 1px 0 rgba(255,255,255,.25);
                color: var(--navy-900);
            }

        .header-status {
            font-size: 10px;
            color: rgba(255,255,255,.3);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .pulse-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #22c55e;
            box-shadow: 0 0 0 3px rgba(34,197,94,.18);
            animation: pulseAnim 2.4s ease-in-out infinite;
        }
        @@keyframes pulseAnim {
            0%,100% {
            opacity: 1;
            box-shadow: 0 0 0 3px rgba(34,197,94,.18);
        }

        50% {
            opacity: .6;
            box-shadow: 0 0 0 7px rgba(34,197,94,.04);
        }

        }

        /* ══════════════ GOLD STRIPE ══════════════ */
        .header-stripe {
            height: 3px;
            background: linear-gradient(90deg, var(--navy-800) 0%, var(--navy-700) 8%, var(--gold-400) 30%, var(--gold-200) 50%, var(--gold-400) 70%, var(--navy-700) 92%, var(--navy-800) 100%);
        }

        /* ══════════════ TICKER ══════════════ */
        .ticker-bar {
            background: var(--navy-700);
            display: flex;
            align-items: stretch;
            overflow: hidden;
            height: 40px;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

        .ticker-label {
            background: linear-gradient(135deg, var(--gold-300), var(--gold-400));
            color: var(--navy-900);
            padding: 0 22px 0 18px;
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 2.2px;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
            text-transform: uppercase;
            clip-path: polygon(0 0, 100% 0, 90% 100%, 0 100%);
            padding-right: 30px;
        }

        .blink-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--navy-800);
            animation: blinkAnim 1.1s ease-in-out infinite;
        }
        @@keyframes blinkAnim {
            0%,100%

        {
            opacity: 1
        }

        50% {
            opacity: .1
        }

        }

        .ticker-track {
            overflow: hidden;
            flex: 1;
            display: flex;
            align-items: center;
        }

        .ticker-inner {
            display: flex;
            white-space: nowrap;
            animation: tickerScroll 55s linear infinite;
        }

            .ticker-inner:hover {
                animation-play-state: paused;
            }
        @@keyframes tickerScroll {
            0%

        {
            transform: translateX(0)
        }

        100% {
            transform: translateX(-50%)
        }

        }

        .t-item {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 11.5px;
            font-weight: 500;
            color: rgba(255,255,255,.5);
            padding-right: 60px;
        }

            .t-item i {
                color: var(--gold-300);
                font-size: 10px;
            }

            .t-item a {
                color: rgba(255,255,255,.7);
                text-decoration: none;
                transition: color .18s;
            }

                .t-item a:hover {
                    color: var(--gold-300);
                }

        /* ══════════════ HERO CAROUSEL ══════════════ */
        .rguhs-carousel {
            width: 100%;
            overflow: hidden;
            background: var(--navy-950);
            line-height: 0;
        }

        .carousel-img {
            width: 100%;
            height: clamp(220px, 38vw, 480px);
            object-fit: cover;
            object-position: center;
            display: block;
            filter: brightness(.62) saturate(1.05);
            transition: filter .5s;
        }

        .rguhs-carousel:hover .carousel-img {
            filter: brightness(.56) saturate(1.05);
        }

        .carousel-caption-custom {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: clamp(18px,3.2vw,50px) clamp(24px,5vw,68px);
            background: linear-gradient(to top, rgba(3,6,15,.92) 0%, rgba(3,6,15,.45) 60%, transparent 100%);
            text-align: left;
            line-height: 1;
        }

        .cc-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--gold-300);
            color: var(--navy-900);
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 1.8px;
            text-transform: uppercase;
            padding: 5px 14px;
            border-radius: 3px;
            margin-bottom: clamp(8px,1.5vw,18px);
        }

        .cc-title {
            font-family: var(--fd);
            font-size: clamp(17px, 3vw, 42px);
            font-weight: 600;
            color: #fff;
            line-height: 1.18;
            margin-bottom: clamp(6px,1vw,13px);
            text-shadow: 0 2px 20px rgba(0,0,0,.5);
        }

        .cc-sub {
            font-size: clamp(10px, 1.1vw, 13.5px);
            color: rgba(255,255,255,.56);
            letter-spacing: .3px;
        }

        .rguhs-carousel .carousel-indicators {
            margin-bottom: clamp(12px, 2vw, 24px);
            gap: 4px;
        }

            .rguhs-carousel .carousel-indicators button {
                width: clamp(18px, 2.2vw, 30px);
                height: 3px;
                border-radius: 2px;
                background: rgba(255,255,255,.25);
                border: none;
                transition: background .25s, width .25s;
            }

                .rguhs-carousel .carousel-indicators button.active {
                    background: var(--gold-300);
                    width: clamp(28px, 4vw, 52px);
                }

        .rguhs-ctrl {
            width: clamp(36px,4vw,50px);
            opacity: 0;
            transition: opacity .22s;
        }

        .rguhs-carousel:hover .rguhs-ctrl {
            opacity: 1;
        }

        .rguhs-carousel .carousel-control-prev-icon,
        .rguhs-carousel .carousel-control-next-icon {
            background-color: rgba(3,6,15,.55);
            border-radius: 50%;
            padding: 14px;
            background-size: 48%;
            border: 1px solid rgba(255,255,255,.12);
        }

        /* ══════════════ STATS STRIP ══════════════ */
        .stats-strip {
            background: var(--navy-700);
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

        .stats-inner {
            display: flex;
            padding: 0 40px;
        }

        .stat-item {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 20px 26px;
            border-right: 1px solid rgba(255,255,255,.07);
            transition: background .2s;
        }

            .stat-item:first-child {
                padding-left: 0;
            }

            .stat-item:last-child {
                border-right: none;
            }

            .stat-item:hover {
                background: rgba(255,255,255,.03);
            }

        .stat-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: rgba(224,172,42,.1);
            border: 1px solid rgba(224,172,42,.2);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .stat-icon i {
                color: var(--gold-300);
                font-size: 17px;
            }

        .stat-num {
            font-family: var(--fd);
            font-size: 30px;
            color: #fff;
            font-weight: 600;
            line-height: 1;
            letter-spacing: -.5px;
        }

        .stat-lbl {
            font-size: 9.5px;
            color: rgba(255,255,255,.34);
            margin-top: 4px;
            letter-spacing: 1.2px;
            text-transform: uppercase;
        }

        /* ══════════════ BODY LAYOUT ══════════════ */
        .body-layout {
            display: flex;
            overflow: hidden;
            width: 100%;
        }

        /* ══════════════ MAIN PANE ══════════════ */
        .main-pane {
            flex: 1;
            min-width: 0;
            overflow-y: auto;
            padding: 32px 32px 60px;
            scrollbar-width: thin;
            scrollbar-color: var(--neutral-200) transparent;
        }

            .main-pane::-webkit-scrollbar {
                width: 5px;
            }

            .main-pane::-webkit-scrollbar-thumb {
                background: var(--neutral-200);
                border-radius: 4px;
            }

        /* Section heading */
        .sec-head {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 22px;
        }

            .sec-head h3 {
                font-family: var(--fd);
                font-size: 23px;
                color: var(--navy-700);
                font-weight: 600;
                white-space: nowrap;
                letter-spacing: .1px;
            }

        .sec-line {
            flex: 1;
            height: 1px;
            background: var(--neutral-200);
        }

        .sec-chip {
            background: var(--navy-800);
            color: var(--gold-300);
            font-size: 9px;
            font-weight: 700;
            padding: 4px 13px;
            border-radius: 4px;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            white-space: nowrap;
            border: 1px solid rgba(224,172,42,.2);
        }

        /* ── Faculty Chips ── */
        .faculty-scroll {
            display: flex;
            gap: 7px;
            overflow-x: auto;
            padding-bottom: 4px;
            margin-bottom: 22px;
            scrollbar-width: none;
        }

            .faculty-scroll::-webkit-scrollbar {
                display: none;
            }

        .fac-chip {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 16px;
            border-radius: var(--r);
            border: 1.5px solid var(--neutral-200);
            background: var(--white);
            color: var(--neutral-700);
            text-decoration: none;
            font-size: 12.5px;
            font-weight: 500;
            white-space: nowrap;
            flex-shrink: 0;
            transition: all .2s;
            box-shadow: var(--shadow-xs);
        }

            .fac-chip:hover {
                border-color: var(--blue-300);
                color: var(--navy-600);
                box-shadow: var(--shadow-sm);
                transform: translateY(-1px);
            }

            .fac-chip.active {
                background: var(--navy-700);
                border-color: transparent;
                color: #fff;
                box-shadow: 0 4px 18px rgba(15,34,72,.22);
                transform: translateY(-1px);
            }

        .chip-cnt {
            background: rgba(0,0,0,.08);
            border-radius: 4px;
            padding: 1px 7px;
            font-size: 10.5px;
            font-weight: 700;
            font-family: var(--fm);
        }

        .fac-chip.active .chip-cnt {
            background: rgba(255,255,255,.15);
        }

        /* ── Filter Bar ── */
        .filter-bar {
            display: flex;
            gap: 9px;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .search-field {
            position: relative;
            flex: 1;
            min-width: 200px;
            max-width: 420px;
        }

            .search-field input {
                width: 100%;
                padding: 11px 14px 11px 40px;
                border: 1.5px solid var(--neutral-200);
                border-radius: var(--r);
                font-size: 13px;
                font-family: var(--fb);
                background: var(--white);
                color: var(--neutral-900);
                outline: none;
                box-shadow: var(--shadow-xs);
                transition: border-color .2s, box-shadow .2s;
            }

                .search-field input:focus {
                    border-color: var(--blue-300);
                    box-shadow: 0 0 0 3px rgba(45,98,200,.1);
                }

                .search-field input::placeholder {
                    color: var(--neutral-400);
                }

            .search-field .si {
                position: absolute;
                left: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--neutral-400);
                font-size: 13px;
                pointer-events: none;
            }

        .btn-srch {
            background: var(--navy-700);
            color: #fff;
            border: none;
            padding: 11px 22px;
            border-radius: var(--r);
            font-size: 13px;
            font-weight: 600;
            font-family: var(--fb);
            cursor: pointer;
            box-shadow: 0 3px 14px rgba(15,34,72,.22);
            transition: opacity .2s, transform .15s;
            display: flex;
            align-items: center;
            gap: 6px;
            letter-spacing: .2px;
        }

            .btn-srch:hover {
                opacity: .85;
                transform: translateY(-1px);
            }

        .btn-clr {
            background: var(--white);
            color: var(--neutral-500);
            border: 1.5px solid var(--neutral-200);
            padding: 11px 16px;
            border-radius: var(--r);
            font-size: 13px;
            font-family: var(--fb);
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: border-color .2s, color .2s;
        }

            .btn-clr:hover {
                border-color: var(--blue-300);
                color: var(--neutral-900);
            }

        .res-badge {
            background: var(--white);
            border: 1px solid var(--neutral-200);
            border-radius: var(--r);
            padding: 11px 16px;
            font-size: 12px;
            color: var(--neutral-500);
            white-space: nowrap;
            box-shadow: var(--shadow-xs);
            font-family: var(--fm);
        }

            .res-badge strong {
                color: var(--navy-700);
                font-weight: 700;
            }

        /* ── College Cards ── */
        .college-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            max-height: 540px;
            overflow-y: auto;
            scroll-behavior: smooth;
            padding-right: 4px;
        }

            .college-grid::-webkit-scrollbar {
                width: 5px;
            }

            .college-grid::-webkit-scrollbar-thumb {
                background: var(--neutral-200);
                border-radius: 4px;
            }

        .c-card {
            background: var(--white);
            border: 1px solid var(--neutral-200);
            border-radius: var(--r-lg);
            padding: 20px 22px 44px;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow-xs);
            transition: transform .22s cubic-bezier(.22,1,.36,1), box-shadow .22s, border-color .22s;
            animation: cardFadeUp .35s ease both;
            cursor: pointer;
        }

            .c-card:hover {
                transform: translateY(-4px);
                box-shadow: var(--shadow-md);
                border-color: var(--neutral-300);
            }
            /* Left accent on hover */
            .c-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                bottom: 0;
                width: 3px;
                background: linear-gradient(to bottom, var(--navy-600), var(--gold-300));
                opacity: 0;
                transition: opacity .22s;
                border-radius: 3px 0 0 3px;
            }

            .c-card:hover::before {
                opacity: 1;
            }

        @@keyframes cardFadeUp {
            from

        {
            opacity: 0;
            transform: translateY(14px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .c-card:nth-child(1) {
            animation-delay: .04s
        }

        .c-card:nth-child(2) {
            animation-delay: .08s
        }

        .c-card:nth-child(3) {
            animation-delay: .12s
        }

        .c-card:nth-child(4) {
            animation-delay: .16s
        }

        .c-card:nth-child(5) {
            animation-delay: .20s
        }

        .c-card:nth-child(6) {
            animation-delay: .24s
        }

        .c-card:nth-child(n+7) {
            animation-delay: .28s
        }

        .c-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--navy-700);
            line-height: 1.55;
            margin-bottom: 12px;
        }

        .c-meta {
            position: absolute;
            bottom: 14px;
            left: 22px;
            right: 22px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 6px;
        }

        .c-town {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 10.5px;
            color: var(--neutral-500);
        }

            .c-town i {
                color: var(--blue-300);
                font-size: 10px;
            }

        .c-fac {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            background: var(--surface);
            border: 1px solid var(--neutral-200);
            border-radius: 4px;
            padding: 2px 9px;
            font-size: 10px;
            font-weight: 500;
            color: var(--neutral-500);
        }

        .c-arrow {
            position: absolute;
            bottom: 13px;
            right: 18px;
            font-size: 11px;
            color: var(--blue-400);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 3px;
            opacity: 0;
            transform: translateX(4px);
            transition: opacity .2s, transform .2s;
        }

        .c-card:hover .c-arrow {
            opacity: 1;
            transform: translateX(0);
        }

        .empty-state {
            grid-column: 1/-1;
            text-align: center;
            padding: 64px 20px;
            color: var(--neutral-400);
        }

            .empty-state .em-ico {
                font-size: 52px;
                opacity: .18;
                margin-bottom: 14px;
            }

            .empty-state h4 {
                font-size: 16px;
                font-weight: 600;
                margin-bottom: 6px;
                color: var(--navy-700);
            }

        /* ══════════════ SIDEBAR ══════════════ */
        .side-pane {
            width: 300px;
            flex-shrink: 0;
            background: var(--white);
            border-left: 1px solid var(--neutral-200);
            overflow-y: auto;
            scrollbar-width: thin;
            scrollbar-color: var(--neutral-200) transparent;
        }

            .side-pane::-webkit-scrollbar {
                width: 4px;
            }

            .side-pane::-webkit-scrollbar-thumb {
                background: var(--neutral-200);
                border-radius: 4px;
            }

        .widget {
            border-bottom: 1px solid var(--neutral-200);
        }

            .widget:last-child {
                border-bottom: none;
            }

        .w-head {
            padding: 13px 18px;
            display: flex;
            align-items: center;
            gap: 9px;
            background: var(--surface);
            border-bottom: 1px solid var(--neutral-200);
        }

            .w-head h4 {
                font-family: var(--fd);
                color: var(--navy-700);
                font-size: 14.5px;
                font-weight: 600;
                letter-spacing: .1px;
            }

            .w-head i {
                color: var(--navy-600);
                font-size: 13.5px;
            }

        /* Updates */
        .upd-list {
            list-style: none;
        }

        .upd-item {
            border-bottom: 1px solid var(--neutral-200);
            padding: 12px 18px;
            transition: background .14s;
        }

            .upd-item:last-child {
                border-bottom: none;
            }

            .upd-item:hover {
                background: var(--surface);
            }

            .upd-item a {
                display: block;
                text-decoration: none;
                color: var(--neutral-700);
                font-size: 12px;
                line-height: 1.6;
                font-weight: 500;
            }

                .upd-item a:hover {
                    color: var(--navy-600);
                }

        .upd-date {
            font-size: 10px;
            color: var(--neutral-400);
            margin-top: 4px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .u-tag {
            display: inline-block;
            font-size: 8.5px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 3px;
            letter-spacing: .7px;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        .tag-new {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        .tag-imp {
            background: #fefce8;
            color: #92400e;
            border: 1px solid #fde68a;
        }

        .tag-info {
            background: #eff6ff;
            color: var(--navy-600);
            border: 1px solid #bfdbfe;
        }

        /* Quick links */
        .qlink-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1px;
            background: var(--neutral-200);
        }

        .qlink {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 15px 8px;
            background: var(--white);
            text-decoration: none;
            color: var(--neutral-700);
            font-size: 10.5px;
            font-weight: 600;
            text-align: center;
            transition: background .14s, color .14s;
        }

            .qlink:hover {
                background: var(--surface);
                color: var(--navy-600);
            }

            .qlink i {
                font-size: 20px;
                color: var(--navy-600);
            }

        /* Helpline */
        .hl-body {
            padding: 14px 18px;
            display: flex;
            flex-direction: column;
            gap: 13px;
        }

        .hl-row {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .hl-icon {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: var(--surface);
            border: 1px solid var(--neutral-200);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .hl-icon i {
                font-size: 13px;
                color: var(--navy-600);
            }

        .hl-lbl {
            font-size: 9.5px;
            color: var(--neutral-400);
            margin-bottom: 2px;
            letter-spacing: .4px;
        }

        .hl-val {
            font-size: 12px;
            font-weight: 600;
            color: var(--navy-700);
        }

            .hl-val a {
                color: var(--blue-400);
                text-decoration: none;
            }

                .hl-val a:hover {
                    text-decoration: underline;
                }

        /* ══════════════ MODAL ══════════════ */
        .modal-course-header {
            background: linear-gradient(135deg, var(--navy-800) 0%, var(--navy-700) 100%);
            border: none;
            padding: 24px 28px;
        }

        .modal-summary-strip {
            display: flex;
            border-bottom: 1px solid var(--neutral-200);
            background: var(--neutral-50);
        }

        .modal-summary-pill {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 17px 24px;
            border-right: 1px solid var(--neutral-200);
        }

            .modal-summary-pill:last-child {
                border-right: none;
            }

        .msp-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--navy-800);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .msp-icon i {
                color: var(--gold-300);
                font-size: 16px;
            }

        .msp-num {
            font-family: var(--fd);
            font-size: 26px;
            font-weight: 600;
            color: var(--navy-700);
            line-height: 1;
        }

        .msp-lbl {
            font-size: 9px;
            color: var(--neutral-400);
            letter-spacing: 1.1px;
            text-transform: uppercase;
            margin-top: 3px;
        }

        .course-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12.5px;
        }

            .course-table thead tr {
                background: var(--navy-800);
            }

            .course-table thead th {
                padding: 11px 15px;
                color: rgba(255,255,255,.5);
                font-size: 9.5px;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                border: none;
                white-space: nowrap;
            }

                .course-table thead th:last-child {
                    text-align: center;
                }

            .course-table tbody tr {
                border-bottom: 1px solid var(--neutral-200);
                transition: background .12s;
            }

                .course-table tbody tr:last-child {
                    border-bottom: none;
                }

                .course-table tbody tr:nth-child(even) {
                    background: var(--neutral-50);
                }

                .course-table tbody tr:nth-child(odd) {
                    background: var(--white);
                }

                .course-table tbody tr:hover {
                    background: #eff6ff;
                }

            .course-table tbody td {
                padding: 11px 15px;
                color: var(--neutral-700);
                vertical-align: middle;
            }

        .td-num {
            color: var(--neutral-400);
            font-size: 11px;
            width: 36px;
            font-family: var(--fm);
        }

        .col-course-code {
            display: none;
        }

        .td-code {
            font-family: var(--fm);
            font-size: 10.5px;
            color: var(--blue-400);
            background: #eff6ff;
            padding: 3px 9px;
            border-radius: 4px;
            white-space: nowrap;
            display: inline-block;
            border: 1px solid #bfdbfe;
        }

        .intake-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 44px;
            height: 28px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 700;
            font-family: var(--fm);
        }

        .intake-badge-filled {
            background: #eff6ff;
            color: var(--blue-400);
            border: 1px solid #bfdbfe;
        }

        .intake-badge-zero {
            background: var(--neutral-100);
            color: var(--neutral-400);
            border: 1px solid var(--neutral-200);
        }

        /* ══════════════ FOOTER ══════════════ */
        .site-footer {
            background: var(--navy-900);
            border-top: 2px solid var(--gold-400);
        }

        .footer-grid {
            padding: 38px 40px 24px;
            display: grid;
            grid-template-columns: 2.2fr 1fr 1fr 1fr;
            gap: 32px;
        }

        .foot-brand {
            display: flex;
            align-items: center;
            gap: 13px;
            margin-bottom: 13px;
        }

        .foot-monogram {
            width: 48px;
            height: 48px;
            border-radius: 11px;
            background: rgba(224,172,42,.1);
            border: 1px solid rgba(224,172,42,.22);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--fd);
            font-size: 18px;
            color: var(--gold-300);
            font-weight: 700;
            flex-shrink: 0;
        }

        .foot-name {
            font-family: var(--fd);
            color: #fff;
            font-size: 14px;
            line-height: 1.3;
            font-weight: 500;
        }

            .foot-name span {
                display: block;
                font-size: 10px;
                color: rgba(255,255,255,.26);
                font-family: var(--fb);
                margin-top: 3px;
                letter-spacing: .3px;
            }

        .foot-desc {
            font-size: 11.5px;
            color: rgba(255,255,255,.28);
            line-height: 1.85;
        }

        .foot-col h5 {
            font-size: 9.5px;
            font-weight: 700;
            color: var(--gold-300);
            letter-spacing: 1.6px;
            text-transform: uppercase;
            margin-bottom: 14px;
            padding-bottom: 9px;
            border-bottom: 1px solid rgba(224,172,42,.14);
        }

        .foot-col ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 9px;
        }

            .foot-col ul li a {
                color: rgba(255,255,255,.32);
                text-decoration: none;
                font-size: 12px;
                transition: color .18s;
                display: flex;
                align-items: center;
                gap: 7px;
            }

                .foot-col ul li a::before {
                    content: '';
                    display: block;
                    width: 3px;
                    height: 3px;
                    border-radius: 50%;
                    background: rgba(224,172,42,.3);
                    flex-shrink: 0;
                }

                .foot-col ul li a:hover {
                    color: var(--gold-300);
                }

        .footer-bar {
            padding: 14px 40px;
            border-top: 1px solid rgba(255,255,255,.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
        }

            .footer-bar p {
                font-size: 10.5px;
                color: rgba(255,255,255,.2);
            }

            .footer-bar a {
                color: rgba(224,172,42,.6);
                text-decoration: none;
            }

                .footer-bar a:hover {
                    color: var(--gold-300);
                }

        /* ══════════════ RESPONSIVE ══════════════ */
        @@media (min-width: 1400px) {
            .header-inner, .stats-inner, .footer-grid, .footer-bar

        {
            padding-left: 60px;
            padding-right: 60px;
        }

        .main-pane {
            padding: 36px 38px 64px;
        }

        .util-inner {
            padding: 0 60px;
        }

        }
        @@media (max-width: 1199px) {
            .body-layout

        {
            flex-direction: column;
            height: auto !important;
            overflow: visible;
        }

        .main-pane {
            overflow: visible;
        }

        .side-pane {
            width: 100%;
            border-left: none;
            border-top: 1px solid var(--neutral-200);
            overflow: visible;
        }

        .footer-grid {
            grid-template-columns: 1fr 1fr;
        }

        .stats-inner {
            padding: 0 24px;
        }

        .college-grid {
            grid-template-columns: 1fr 1fr 1fr;
        }

        }
        @@media (max-width: 991px) {
            .header-inner

        {
            padding: 16px 20px;
            flex-wrap: wrap;
        }

        .university-logo {
            height: 64px;
        }

        .univ-name {
            font-size: 18px;
        }

        .univ-sub {
            display: none;
        }

        .stats-inner {
            flex-wrap: wrap;
            padding: 0 20px;
        }

        .stat-item {
            min-width: 45%;
            border-bottom: 1px solid rgba(255,255,255,.05);
        }

        .footer-grid {
            padding: 24px 20px;
        }

        .footer-bar {
            padding: 12px 20px;
        }

        .college-grid {
            grid-template-columns: 1fr 1fr;
        }

        .modal-summary-strip {
            flex-wrap: wrap;
        }

        .modal-summary-pill {
            min-width: 50%;
            border-bottom: 1px solid var(--neutral-200);
        }

        }
        @@media (max-width: 767px) {
            .util-inner

        {
            padding: 0 16px;
        }

        .util-links a span {
            display: none;
        }

        .header-inner {
            padding: 14px 16px;
        }

        .university-logo {
            height: 56px;
        }

        .univ-name {
            font-size: 16px;
        }

        .main-pane {
            padding: 20px 14px 48px;
        }

        .college-grid {
            grid-template-columns: 1fr;
            max-height: none;
        }

        .footer-grid {
            grid-template-columns: 1fr;
            padding: 20px 16px;
        }

        .footer-bar {
            padding: 12px 16px;
            flex-direction: column;
            align-items: flex-start;
        }

        .carousel-img {
            height: clamp(190px,54vw,310px);
        }

        }
        @@media (max-width: 599px) {
            .header-inner

        {
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 18px 16px;
        }

        .header-rule {
            display: none;
        }

        .university-logo {
            height: 68px;
        }

        .univ-name {
            font-size: 17px;
            text-align: center;
        }

        .univ-eyebrow {
            justify-content: center;
        }

        .univ-sub {
            display: flex;
            justify-content: center;
            font-size: 10px;
        }

        .header-badges {
            justify-content: center;
        }

        .header-cta {
            width: 100%;
            align-items: center;
        }

        .btn-portal {
            width: 100%;
            justify-content: center;
            font-size: 14px;
            padding: 13px 20px;
        }

        .stats-inner {
            flex-direction: column;
        }

        .stat-item {
            width: 100%;
            border-right: none;
        }

        }
    </style>
</head>
<body>

    <!-- ════ UTILITY BAR ════ -->
    <div class="util-bar">
        <div class="util-inner">
            <div class="util-links">
                <a href="https://www.rguhs.ac.in" target="_blank"><i class="bi bi-globe2"></i><span>www.rguhs.ac.in</span></a>
                <a href="https://rguhs.karnataka.gov.in/rguhsec/" target="_blank"><i class="bi bi-file-earmark-check"></i><span>Eligibility Certificate</span></a>
                <a href="https://rguhs.karnataka.gov.in/rguhs_online/" target="_blank"><i class="bi bi-bar-chart-line"></i><span>Results Portal</span></a>
                <a href="https://www.rguhs.ac.in/notification_circulars_rguhs.html" target="_blank"><i class="bi bi-bell"></i><span>Notifications</span></a>
                <a href="https://www.rguhs.ac.in" target="_blank"><i class="bi bi-headset"></i><span>Help Desk</span></a>
            </div>
            <div class="util-right">
                <span class="live-clock" id="liveClock"></span>
                <select class="lang-sel"><option>English</option><option>ಕನ್ನಡ</option></select>
            </div>
        </div>
    </div>

    <!-- ════ HEADER ════ -->
    <header class="site-header">
        <div class="header-inner">
            <div class="header-rule"></div>
            <img src="~/images/newLogo.jpeg" alt="RGUHS Logo" class="university-logo" />
            <div class="header-text">
                <div class="univ-eyebrow">Government of Karnataka</div>
                <div class="univ-name">Rajiv Gandhi University of Health Sciences, Karnataka</div>
                <div class="univ-sub">
                    <i class="bi bi-geo-alt-fill"></i>
                    4th 'T' Block, Jayanagar, Bangalore – 560 041 &nbsp;·&nbsp; Established 1996
                </div>
                
            </div>
            <div class="header-cta">
                <a asp-controller="MainDashboard" asp-action="MultiLogin" class="btn-portal" target="_blank">
                    <i class="bi bi-box-arrow-in-right"></i> Login to Portal
                </a>
                <div class="header-status">
                    <div class="pulse-dot"></div>
                    Admission &amp; Affiliation System — Live
                </div>
            </div>
        </div>
    </header>
    <div class="header-stripe"></div>

    <!-- ════ TICKER ════ -->
    <div class="ticker-bar">
        <div class="ticker-label"><div class="blink-dot"></div>Live Updates</div>
        <div class="ticker-track">
            <div class="ticker-inner">
                <span class="t-item"><i class="bi bi-megaphone-fill"></i><a href="http://www.rguhs.ac.in/">Visit Official RGUHS Website</a></span>
                <span class="t-item"><i class="bi bi-info-circle-fill"></i><a href="https://rguhsaca.karnataka.gov.in/admissionaffiliation/MainDashboard/MultiLogin">Medical College Details Submission Has Commenced for Existing Colleges</a></span>
                <span class="t-item"><i class="bi bi-megaphone-fill"></i><a href="http://www.rguhs.ac.in/">Visit Official RGUHS Website</a></span>
                <span class="t-item"><i class="bi bi-info-circle-fill"></i><a href="https://rguhsaca.karnataka.gov.in/admissionaffiliation/MainDashboard/MultiLogin">Medical College Details Submission Has Commenced for Existing Colleges</a></span>
            </div>
        </div>
    </div>

    <!-- ════ HERO CAROUSEL ════ -->
    <div id="rguhsCarousel" class="carousel slide rguhs-carousel" data-bs-ride="carousel" data-bs-interval="4500">
        <div class="carousel-indicators">
