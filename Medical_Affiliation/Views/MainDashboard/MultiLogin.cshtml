        </div><!-- /main -->
        <!-- FOOTER -->
       @*  <footer class="foot">
            <span>&copy; @DateTime.Now.Year &nbsp;Rajiv Gandhi University of Health Sciences, Karnataka — All rights reserved.</span>
            <span>
                <a href="#">Help &amp; Support</a><span class="fsep">&bull;</span>
