    <script>
        /* ── TAB SWITCHING ── */
        const TABS={c:{tab:'tb-c',panel:'pn-c'},u:{tab:'tb-u',panel:'pn-u'},l:{tab:'tb-l',panel:'pn-l'}};
        function go(k){
          Object.values(TABS).forEach(v=>{
            document.getElementById(v.tab).classList.remove('on');
            document.getElementById(v.panel).classList.remove('on');
          });
          document.getElementById(TABS[k].tab).classList.add('on');
          const p=document.getElementById(TABS[k].panel);
          p.classList.add('on');p.style.animation='none';
          requestAnimationFrame(()=>p.style.animation='');
        }
        /* ── LIC SUB-TABS ── */
        function licTab(n){
          ['signup','login'].forEach(x=>{
            document.getElementById('lt-'+x).classList.remove('on');
            document.getElementById('lic-'+x).classList.remove('on');
          });
          document.getElementById('lt-'+n).classList.add('on');
          document.getElementById('lic-'+n).classList.add('on');
        }
        /* ── PASSWORD TOGGLE ── */
        function togglePw(id,btn){
          const el=document.getElementById(id),ic=btn.querySelector('i');
          el.type=el.type==='password'?'text':'password';
          ic.className=el.type==='password'?'bi bi-eye':'bi bi-eye-slash';
        }

        $(function(){
          /* Captcha refresh */
          $('#cap-c-ref').on('click',function(){
            var $b=$(this);$b.css('transform','rotate(180deg)');
            $.get('@Url.Action("GenerateCaptcha", "Login")',function(d){
              $('#cap-c').text(d.newCaptcha);
              $('#CaptchaCodeHidden').val(d.newCaptcha);
              setTimeout(()=>$b.css('transform',''),350);
            });
          });

          /* Faculty → College cascade */
          // $('#FacultyId').on('change',function(){
          //   var id=$(this).val(),$c=$('#CollegeId');
          //   $c.empty().append('<option value="">— Select College —</option>');
          //   if(id){
          //     $.get('@Url.Action("GetCollegesByFaculty", "Login")',{facultyId:id},function(data){
          //       $.each(data,function(i,c){$c.append($('<option>',{value:c.value,text:c.text,'data-code':c.code}));});
          //     });
          //   }
          // });
          /* Auto-set username */
          $('#CollegeId').on('change',function(){
            $('#CollegeUsername').val($(this).find('option:selected').data('code')||'');
          });

          /* College login error */
          @if (TempData["LoginError"] != null)
        {
                <text>
                Swal.fire({icon:'error',title:'Login Failed',text:'@Html.Raw(TempData["LoginError"])',confirmButtonColor:'#1a56c4',confirmButtonText:'Try Again'});
                document.querySelector('.captcha-val')&&(document.querySelector('.captcha-val').value='');
                </text>
          }

          /* University model errors */
          @{
                var allErrs = string.Join(" ", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage));
          }
          @if (!ViewData.ModelState.IsValid && Context.Request.Method == "POST" && !string.IsNullOrEmpty(allErrs))
        {
                <text>
                go('u');
                Swal.fire({icon:'error',title:'Login Failed',html:'@Html.Raw(allErrs.Replace("\r\n", "<br>"))',confirmButtonColor:'#1a56c4'});
                </text>
          }

          /* University client-side validation */
          $('#univForm').on('submit',function(e){
            if(!$.trim($('#univ-user').val())||!$.trim($('#pw-u').val())){
              e.preventDefault();
              Swal.fire({icon:'warning',title:'Required Fields',text:'Please enter both Username and Password.',confirmButtonColor:'#1a56c4'});
            }
          });

          /* LIC role cascade */
          $(document).on('click','.role-btn',function(){
            $('.role-btn').removeClass('on');$(this).addClass('on');
            var role=$(this).data('role');$('#selectedRole').val(role);
            fetch('/LICInspection/GetNamesByRole?role='+encodeURIComponent(role))
              .then(r=>r.json()).then(data=>{
                var $d=$('#nameDropdown');
                $d.html('<option value="">— Select Name —</option>');
                if(data&&data.length)data.forEach(n=>$d.append($('<option>',{value:n,text:n})));
                else $d.append('<option value="">No names found</option>');
              }).catch(e=>console.error(e));
          });

          /* Signup success */
          @if (TempData["SuccessMessage"] != null)
        {
                <text>
                go('l');licTab('login');
                Swal.fire({icon:'success',title:'Account Created',text:'@TempData["SuccessMessage"]',confirmButtonColor:'#0d7a6b'});
                </text>
          }
        });
    </script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
