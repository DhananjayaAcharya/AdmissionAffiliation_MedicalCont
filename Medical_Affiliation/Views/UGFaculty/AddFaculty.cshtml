        // ── Confirm / Preview ─────────────────────────────────────────
        function confirmData() {
            if (!facultyRows.length) { showAlert('Please insert at least one record first.','danger'); return; }
            clearAlert();
            const pb = document.getElementById('previewBody');
            pb.innerHTML = '';
            facultyRows.forEach((r,i) => {
                pb.innerHTML += `<tr>
                    <td>${i+1}</td><td>${escHtml(r.deptName)}</td><td>${escHtml(r.name)}</td>
                    <td>${escHtml(r.desigName)}</td><td>${escHtml(r.dob)}</td><td>${escHtml(r.doa)}</td>
                    <td>${escHtml(r.mobile)}</td><td>${escHtml(r.pan)}</td><td>${escHtml(r.regNo)||'—'}</td>
                    <td>${escHtml(r.aebas)}</td><td>${escHtml(r.qual)}</td>
                    <td>${escHtml(r.nature)}</td><td>${escHtml(r.exp)}</td>
                </tr>`;
            });
            new bootstrap.Modal(document.getElementById('previewModal')).show();
        }

        // ── Save & PDF ────────────────────────────────────────────────
        async function saveFaculty() {
            if (!facultyRows.length) return;
            const btn = document.querySelector('.btn-declare');
            if (btn) { btn.disabled = true; btn.textContent = 'Saving...'; }
            try {
                const resp = await fetch(URLS.saveFaculty, {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify([])});
                const res  = await resp.json();
                if (res.success) {
                    bootstrap.Modal.getInstance(document.getElementById('previewModal')).hide();
                    await generatePDF(facultyRows);
                    onDeclared();
                } else {
                    showAlert(res.message,'danger');
                }
            } catch(err) {
                showAlert('Server communication error.','danger');
            } finally {
                if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-cloud-check"></i> Save &amp; Generate PDF'; }
            }
        }

        function onDeclared() {
            declared = false; syncTableGrid(); clearGridSearch();
            document.getElementById('step1Badge').className = 'step-pill done';
            document.getElementById('step2Badge').className = 'step-pill done';
            document.getElementById('step3Badge').className = 'step-pill active';
            showAlert('Data saved successfully! Upload the signed copy below.','success');
            document.getElementById('uploadSection').style.display = 'block';
            document.getElementById('uploadSection').scrollIntoView({behavior:'smooth',block:'start'});
        }

        function handleFileSelect(input) {
            if (input.files && input.files[0]) {
                selectedFile = input.files[0];
                document.getElementById('fileChosen').textContent = selectedFile.name;
                document.getElementById('btnUpload').disabled = false;
            }
        }
        function handleDrop(event) {
            event.preventDefault();
            document.getElementById('uploadZone').classList.remove('dragover');
            const files = event.dataTransfer.files;
            if (files && files[0]) {
                selectedFile = files[0];
                document.getElementById('fileChosen').textContent = selectedFile.name;
                document.getElementById('btnUpload').disabled = false;
            }
        }
        function handleUpload() {
            if (!selectedFile) return;
            const fd = new FormData();
            fd.append('signedDocument', selectedFile);
            fetch(URLS.upload, {method:'POST', body:fd}).then(r => {
                if (r.ok) onUploadComplete();
                else showAlert('Upload failed. Please try again.','danger');
            });
        }
        function onUploadComplete() {
            declared = true;
            document.getElementById('uploadSection').style.display    = 'none';
            document.getElementById('completedSection').style.display = 'block';
            document.getElementById('step3Badge').className           = 'step-pill done';
            document.getElementById('entryFormCard').style.display    = 'none';
            document.getElementById('confirmBtnWrap').style.display   = 'none';
            syncTableGrid();
            showAlert('Signed copy uploaded successfully. Workflow complete.','success');
        }

        // ── LIST TAB ──────────────────────────────────────────────────
        function loadAllFaculty() {
            const tbody = document.getElementById('listBody');
            tbody.innerHTML = `<tr><td colspan="16" class="text-center py-4"><i class="bi bi-hourglass-split me-2"></i>Loading records...</td></tr>`;
            document.getElementById('listPagination').style.display = 'none';

            $.getJSON(URLS.getAllFaculty, function(res) {
                if (!res.success || !res.data || res.data.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="16" class="text-center py-4 text-muted">No records found</td></tr>`;
                    document.getElementById('totalCountChip').textContent = '0 records';
                    return;
                }
                allListData = res.data.map(r => {
                    const dM  = departments.find(d => d.id === r.departmentCode);
                    const dsM = designations.find(d => d.id === r.designationCode);
                    return { ...r, _deptName:dM?dM.name:(r.departmentCode||''), _desigName:dsM?dsM.name:(r.designationCode||''), _photoPath:normalisePhotoPath(r.photoFilePath) };
                });
                document.getElementById('totalCountChip').textContent = allListData.length + ' records';
                $('#listCountBadge').text(allListData.length).show();
                filteredListData = [...allListData];
                currentPage = 1;
                renderListTable();
            });
        }

        function onSearchInput(input) {
            const val = input.value.trim();
            document.getElementById('searchClearBtn').style.display = val ? 'flex' : 'none';
            applyFilters();
        }
        function clearSearch() {
            document.getElementById('listSearchInput').value = '';
            document.getElementById('searchClearBtn').style.display = 'none';
            applyFilters();
        }
        function resetAllFilters() {
            document.getElementById('listSearchInput').value = '';
            document.getElementById('searchClearBtn').style.display = 'none';
            document.getElementById('filterDept').value    = '';
            document.getElementById('filterDesig').value   = '';
            document.getElementById('filterNature').value  = '';
            applyFilters();
        }
        function applyFilters() {
            const q      = (document.getElementById('listSearchInput').value||'').toLowerCase().trim();
            const dept   = document.getElementById('filterDept').value;
            const desig  = document.getElementById('filterDesig').value;
            const nature = document.getElementById('filterNature').value;
            filteredListData = allListData.filter(r => {
                const hay = [r._deptName,r._desigName,r.nameOftheFaculty,r.mobileNo,r.panNo,r.stateCouncilRegNo,r.aEBASAttendId,r.professionalQualification,r.natureOfEmployment,r.dob,r.dateOfAppointment].join(' ').toLowerCase();
                if (q      && !hay.includes(q))                      return false;
                if (dept   && r.departmentCode    !== dept)          return false;
                if (desig  && r.designationCode   !== desig)         return false;
                if (nature && r.natureOfEmployment!== nature)        return false;
                return true;
            });
            currentPage = 1;
            renderActiveChips(q,dept,desig,nature);
            updateResultBar(q,dept,desig,nature);
            renderListTable();
        }
        function renderActiveChips(q,dept,desig,nature) {
            let html='';
            if (q) html+=chip(`Search: "${q}"`,`clearSearch()`);
            if (dept)  { const n=departments.find(d=>d.id===dept);   html+=chip('Dept: '+(n?n.name:dept),`document.getElementById('filterDept').value='';applyFilters()`); }
            if (desig) { const n=designations.find(d=>d.id===desig); html+=chip('Desig: '+(n?n.name:desig),`document.getElementById('filterDesig').value='';applyFilters()`); }
            if (nature) html+=chip('Emp: '+nature,`document.getElementById('filterNature').value='';applyFilters()`);
            document.getElementById('filterChips').innerHTML=html;
        }
        function chip(label,code) { return `<span class="filter-chip">${escHtml(label)}<span class="chip-remove" onclick="${code}"><i class="bi bi-x"></i></span></span>`; }
        function updateResultBar(q,dept,desig,nature) {
            const bar=document.getElementById('searchResultBar');
            if (q||dept||desig||nature) {
                bar.style.display='flex';
                document.getElementById('resultCountText').innerHTML=`Showing <strong>${filteredListData.length}</strong> of <strong>${allListData.length}</strong> records`;
            } else { bar.style.display='none'; }
        }
        function sortList(colIdx) {
            if (sortColIdx===colIdx) sortAsc=!sortAsc; else { sortColIdx=colIdx; sortAsc=true; }
            const keys=['_idx','_deptName','nameOftheFaculty','_desigName','dob','dateOfAppointment','mobileNo','panNo','stateCouncilRegNo','aEBASAttendId','professionalQualification','natureOfEmployment','teachingExpInYrs'];
            filteredListData.sort((a,b) => {
                const av=String(a[keys[colIdx]]||'').toLowerCase(), bv=String(b[keys[colIdx]]||'').toLowerCase();
                return sortAsc ? av.localeCompare(bv) : bv.localeCompare(av);
            });
            document.querySelectorAll('.list-tbl thead th').forEach((th,i) => {
                th.classList.remove('sort-asc','sort-desc');
                const ico=th.querySelector('.sort-icon');
                if(ico) ico.className='bi bi-chevron-expand sort-icon';
                if(i===colIdx){ th.classList.add(sortAsc?'sort-asc':'sort-desc'); if(ico) ico.className=`bi bi-chevron-${sortAsc?'up':'down'} sort-icon`; }
            });
            currentPage=1; renderListTable();
        }
        function changeRowsPerPage() { rowsPerPage=parseInt(document.getElementById('rowsPerPage').value); currentPage=1; renderListTable(); }
        function goToPage(p) { currentPage=p; renderListTable(); }

        function renderListTable() {
            const tbody  = document.getElementById('listBody');
            const total  = filteredListData.length;
            const pages  = Math.max(1, Math.ceil(total/rowsPerPage));
            if (currentPage>pages) currentPage=pages;
            const start    = (currentPage-1)*rowsPerPage;
            const end      = Math.min(start+rowsPerPage, total);
            const pageData = filteredListData.slice(start, end);
            const q        = (document.getElementById('listSearchInput').value||'').toLowerCase().trim();

            if (!pageData.length) {
                tbody.innerHTML=`<tr class="no-results-row"><td colspan="16">
                    <i class="bi bi-search no-results-icon"></i>
                    <div class="no-results-title">No results found</div>
                    <div class="no-results-sub text-muted">Try adjusting your search or filters</div>
                    <button class="btn btn-sm btn-outline-secondary mt-3" onclick="resetAllFilters()"><i class="bi bi-x-circle me-1"></i>Clear all filters</button>
                </td></tr>`;
            } else {
                let html='';
                pageData.forEach((r,idx) => {
                    const ph = r._photoPath
                        ? `<img src="${escHtml(r._photoPath)}" style="width:44px;height:52px;object-fit:cover;border-radius:5px;border:1px solid #e2e8f0;" onerror="this.style.display='none';">`
                        : `<span class="text-muted" style="font-size:.75rem;">—</span>`;
                    html+=`<tr>
                        <td>${start+idx+1}</td>
                        <td>${highlight(r._deptName,q)}</td>
                        <td style="font-weight:600;">${highlight(r.nameOftheFaculty||'',q)}</td>
                        <td>${highlight(r._desigName,q)}</td>
                        <td>${highlight(r.dob||'',q)}</td>
                        <td>${highlight(r.dateOfAppointment||'',q)}</td>
                        <td>${highlight(r.mobileNo||'',q)}</td>
                        <td>${highlight(r.panNo||'',q)}</td>
                        <td>${highlight(r.stateCouncilRegNo||'',q)}</td>
                        <td>${highlight(r.aEBASAttendId||'',q)}</td>
                        <td>${highlight(r.professionalQualification||'',q)}</td>
                        <td>${highlight(r.natureOfEmployment||'',q)}</td>
                        <td>${highlight(r.teachingExpInYrs||'',q)}</td>
                        <td class="text-center">${ph}</td>
                        <td class="text-center">
                            <button class="btn-view-faculty" onclick="openListFacultyModal(${start+idx})">
                                <i class="bi bi-eye-fill"></i> View
                            </button>
                        </td>
                        <td><span class="badge-submitted"><i class="bi bi-check-circle-fill"></i> Submitted</span></td>
                    </tr>`;
                });
                tbody.innerHTML=html;
            }

            const pag=document.getElementById('listPagination');
            pag.style.display=total>0?'flex':'none';
            document.getElementById('paginationInfo').textContent=`Showing ${total?start+1:0}–${end} of ${total}`;
            const btnW=document.getElementById('paginationBtns');
            const W=2;
            let btns=`<button class="pg-btn" onclick="goToPage(${currentPage-1})" ${currentPage===1?'disabled':''}><i class="bi bi-chevron-left"></i></button>`;
            for(let p=1;p<=pages;p++){
                if(p===1||p===pages||(p>=currentPage-W&&p<=currentPage+W)) btns+=`<button class="pg-btn ${p===currentPage?'active':''}" onclick="goToPage(${p})">${p}</button>`;
                else if(p===currentPage-W-1||p===currentPage+W+1) btns+=`<button class="pg-btn" disabled>…</button>`;
            }
            btns+=`<button class="pg-btn" onclick="goToPage(${currentPage+1})" ${currentPage===pages?'disabled':''}><i class="bi bi-chevron-right"></i></button>`;
            btnW.innerHTML=btns;
        }

        function highlight(text,q) {
            const safe=escHtml(text);
            if(!q) return safe;
            const re=new RegExp('('+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')','gi');
            return safe.replace(re,'<mark class="search-highlight">$1</mark>');
        }

        function switchTab(tab) {
            document.getElementById('tabBtnAdd').classList.toggle('active',  tab==='add');
            document.getElementById('tabBtnList').classList.toggle('active', tab==='list');
            document.getElementById('tabAdd').classList.toggle('active',     tab==='add');
            document.getElementById('tabList').classList.toggle('active',    tab==='list');
            if (tab==='list') loadAllFaculty();
        }

        function showAlert(msg,type) {
            const icon=type==='success'?'check-circle-fill':'exclamation-triangle-fill';
            const box=document.getElementById('alertBox');
            if(box) box.innerHTML=`<div class="alert alert-${type} d-flex align-items-center gap-2 py-2 mb-2" style="font-size:.83rem;border-radius:9px;"><i class="bi bi-${icon}"></i> ${escHtml(msg)}</div>`;
        }
        function clearAlert() { const box=document.getElementById('alertBox'); if(box) box.innerHTML=''; }

        // ── PDF GENERATION ────────────────────────────────────────────
        async function generatePDF(rows) {
            try {
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF({ orientation:'landscape', unit:'mm', format:'a4' });
                const PW = doc.internal.pageSize.getWidth();
                const PH = doc.internal.pageSize.getHeight();
                const cn = (COLLEGE_NAME||'').trim();
                const NAVY=[26,58,99], NB=[36,78,130], BLUE=[26,115,232], SIL=[210,218,228];
                const WHT=[255,255,255], TXT=[30,40,55], SUB=[100,116,139], ACC=[5,150,105], LGT=[247,249,252];

                function drawHeader(p,tp) {
                    doc.setFillColor(...NB); doc.rect(0,0,PW,18,'F');
                    doc.setFont('helvetica','bold'); doc.setFontSize(12.5); doc.setTextColor(...WHT);
                    doc.text(cn.toUpperCase(),PW/2,8.5,{align:'center'});
                    doc.setFont('helvetica','normal'); doc.setFontSize(7.5); doc.setTextColor(200,225,255);
                    doc.text('UNDERGRADUATE FACULTY DETAILS REPORT',PW/2,14.5,{align:'center'});
                    doc.setFillColor(...BLUE); doc.rect(0,18,PW,1.2,'F');
                    doc.setFont('helvetica','normal'); doc.setFontSize(7); doc.setTextColor(...SUB);
                    const today=new Date().toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
                    doc.text('Generated : '+today,10,24.5);
                    doc.text('Page '+p+' of '+tp,PW-10,24.5,{align:'right'});
                    doc.setDrawColor(...SIL); doc.setLineWidth(0.3); doc.line(10,26.5,PW-10,26.5);
                }
                function drawFooter() {
                    doc.setFillColor(...NAVY); doc.rect(0,PH-8,PW,8,'F');
                    doc.setFont('helvetica','italic'); doc.setFontSize(7); doc.setTextColor(190,215,255);
                    doc.text('This is a computer-generated document. Alterations without authorisation are invalid.',PW/2,PH-3.2,{align:'center'});
                }

                const head=[['#','Department','Faculty Name','Designation','DOB','Appt. Date','Mobile','PAN No.','Reg. No.','AEBAS ID','Qualification','Nature','Exp.']];
                const body=rows.map((r,i)=>[i+1,r.deptName||'—',r.name||'—',r.desigName||'—',r.dob||'—',r.doa||'—',r.mobile||'—',r.pan||'—',r.regNo||'—',r.aebas||'—',r.qual||'—',r.nature||'—',r.exp!=null?r.exp+' yr':'—']);

                drawHeader(1,'?');
                doc.autoTable({
                    startY:30, head, body, theme:'grid',
                    margin:{left:8,right:8,bottom:14},
                    styles:{font:'helvetica',fontSize:7,textColor:TXT,lineColor:SIL,lineWidth:0.25,cellPadding:{top:3,bottom:3,left:2.5,right:2.5},valign:'middle',overflow:'linebreak'},
                    headStyles:{fillColor:NAVY,textColor:WHT,fontStyle:'bold',halign:'center',valign:'middle',fontSize:7,lineColor:NAVY,minCellHeight:9},
                    alternateRowStyles:{fillColor:LGT},
                    bodyStyles:{minCellHeight:11},
                    columnStyles:{0:{cellWidth:7,halign:'center',fontStyle:'bold'},1:{cellWidth:24},2:{cellWidth:28,fontStyle:'bold'},3:{cellWidth:22},4:{cellWidth:22,halign:'center'},5:{cellWidth:22,halign:'center'},6:{cellWidth:22,halign:'center'},7:{cellWidth:22,halign:'center'},8:{cellWidth:22},9:{cellWidth:20},10:{cellWidth:26},11:{cellWidth:18},12:{cellWidth:10,halign:'center'}},
                    didDrawPage:function(data){drawHeader(data.pageNumber,'?');drawFooter();}
                });

                doc.addPage();
                const TP=doc.internal.getNumberOfPages();
                for(let p=1;p<=TP;p++){doc.setPage(p);doc.setFillColor(248,250,253);doc.rect(0,18,PW,10,'F');drawHeader(p,TP);}
                doc.setPage(TP); drawFooter();

                const M=14, iW=PW-M*2, bT=32;
                doc.setFillColor(...NAVY); doc.roundedRect(M,bT,iW,11,2,2,'F');
                doc.setFont('helvetica','bold'); doc.setFontSize(11); doc.setTextColor(...WHT);
                doc.text('DECLARATION BY THE PRINCIPAL / DEAN',PW/2,bT+7,{align:'center'});
                const cT=bT+15;
                doc.setFillColor(...LGT); doc.setDrawColor(...SIL); doc.setLineWidth(0.4);
                doc.roundedRect(M,cT,iW,15,2,2,'FD');
                doc.setDrawColor(...SIL); doc.line(M+iW/2,cT+2,M+iW/2,cT+13);
                doc.setFont('helvetica','bold'); doc.setFontSize(7); doc.setTextColor(...SUB);
                doc.text('INSTITUTION',M+5,cT+5.5); doc.text('TOTAL FACULTY ON RECORD',M+iW/2+5,cT+5.5);
                doc.setFont('helvetica','bold'); doc.setFontSize(10); doc.setTextColor(...TXT);
                doc.text(doc.splitTextToSize(cn,iW/2-12)[0],M+5,cT+11.5);
                doc.setTextColor(...BLUE); doc.setFontSize(14);
                doc.text(String(rows.length),M+iW/2+5,cT+12);

                const dBT=cT+20, dBH=55;
                doc.setFillColor(252,254,255); doc.setDrawColor(...SIL); doc.setLineWidth(0.4);
                doc.roundedRect(M,dBT,iW,dBH,2,2,'FD');
                doc.setFillColor(...ACC); doc.roundedRect(M,dBT,3.5,dBH,1,1,'F');

                const p1='I, the undersigned, hereby solemnly declare that all the information pertaining to the faculty members of '+cn+' as listed in this document is true, complete, and accurate to the best of my knowledge and belief.';
                const p2='The details of teaching staff including their qualifications, designations, dates of appointment, registration numbers, and attendance identifiers have been duly verified against original documents maintained at the institution.';
                const p3='This declaration is submitted in compliance with the requirements of the Medical Affiliation Authority and I accept full responsibility for the accuracy of the data herein.';

                doc.setFont('helvetica','normal'); doc.setFontSize(8.5); doc.setTextColor(...TXT);
                let ty=dBT+8; const lH=4.6, tW=iW-14, tX=M+8;
                [p1,p2,p3].forEach((p,i)=>{const ls=doc.splitTextToSize(p,tW);doc.text(ls,tX,ty);ty+=ls.length*lH+(i<2?4:0);});

                const sT=dBT+dBH+8, bW=(iW-8)/3, bH=26;
                [{label:'Date',x:M},{label:'Stamp / Seal',x:M+bW+4},{label:'Principal / Dean Signature',x:M+(bW+4)*2}].forEach(b=>{
                    doc.setFillColor(...LGT); doc.setDrawColor(...SIL); doc.setLineWidth(0.35);
                    doc.roundedRect(b.x,sT,bW,bH,2,2,'FD');
                    doc.setFont('helvetica','bold'); doc.setFontSize(7); doc.setTextColor(...SUB);
                    doc.text(b.label.toUpperCase(),b.x+bW/2,sT+5.5,{align:'center'});
                    doc.setDrawColor(190,200,215); doc.setLineWidth(0.5);
                    doc.line(b.x+8,sT+bH-6,b.x+bW-8,sT+bH-6);
                });

                const nT=sT+bH+6;
                doc.setFillColor(255,251,235); doc.setDrawColor(253,200,60); doc.setLineWidth(0.4);
                doc.roundedRect(M,nT,iW,12,2,2,'FD');
                doc.setFillColor(245,158,11); doc.roundedRect(M,nT,3.5,12,1,1,'F');
                doc.setFont('helvetica','bold'); doc.setFontSize(7.5); doc.setTextColor(120,53,15);
                doc.text('NOTE :',M+7,nT+5);
                doc.setFont('helvetica','normal'); doc.setFontSize(7.5);
                doc.text(doc.splitTextToSize('Any subsequent alteration to this document without proper authority shall render it invalid and may attract disciplinary action.',iW-30),M+22,nT+5);
                doc.text(doc.splitTextToSize('Please ensure all entries are cross-verified before submission to the Affiliation Authority.',iW-14),M+7,nT+9.5);
                doc.save('Faculty_List_Report.pdf');
            } catch(err) { console.error(err); alert('PDF generation failed: '+err.message); }
        }

        function exportListPDF() {
            const data=filteredListData.length?filteredListData:allListData;
            if(!data.length){Swal.fire({icon:'warning',title:'No Data',text:'No records to export.'});return;}
            try {
                const {jsPDF}=window.jspdf;
                const doc=new jsPDF({orientation:'landscape',unit:'mm',format:'a4'});
                const PW=doc.internal.pageSize.width, PH=doc.internal.pageSize.height;
                doc.setFillColor(13,27,42);doc.rect(0,0,PW,22,'F');
                doc.setFont('helvetica','bold');doc.setFontSize(13);doc.setTextColor(255,255,255);
                doc.text((COLLEGE_NAME||'').toUpperCase(),PW/2,11,{align:'center'});
                doc.setFont('helvetica','normal');doc.setFontSize(8);doc.setTextColor(180,200,230);
                doc.text('UG Faculty List Export',PW/2,18,{align:'center'});
                doc.autoTable({
                    head:[['#','Department','Faculty Name','Designation','Mobile','PAN','Qualification','Employment','Exp (Yrs)']],
                    body:data.map((r,i)=>[i+1,r._deptName||r.departmentCode||'',r.nameOftheFaculty||'',r._desigName||r.designationCode||'',r.mobileNo||'',r.panNo||'',r.professionalQualification||'',r.natureOfEmployment||'',r.teachingExpInYrs||'']),
                    startY:26,theme:'grid',
                    styles:{fontSize:8,cellPadding:2},
                    headStyles:{fillColor:[13,27,42],textColor:255,fontStyle:'bold'},
                    alternateRowStyles:{fillColor:[240,244,248]}
                });
                const tot=doc.internal.getNumberOfPages();
                for(let i=1;i<=tot;i++){doc.setPage(i);doc.setFillColor(13,27,42);doc.rect(0,PH-9,PW,9,'F');doc.setFontSize(7);doc.setTextColor(255,255,255);doc.text('Page '+i+' of '+tot+' | Generated: '+new Date().toLocaleDateString(),PW/2,PH-3.5,{align:'center'});}
                doc.save('UG_Faculty_List.pdf');
            } catch(e){Swal.fire({icon:'error',title:'PDF Export Failed',text:e.message});}
        }

        function exportExcel() {
            const data=filteredListData.length?filteredListData:allListData;
            if(!data.length){Swal.fire({icon:'warning',title:'No Data',text:'No records to export.'});return;}
            try {
                const excelData=data.map((r,i)=>({'SL No':i+1,'Department':r._deptName||r.departmentCode||'','Faculty Name':r.nameOftheFaculty||'','Designation':r._desigName||r.designationCode||'','DOB':r.dob||'','Date Of Appointment':r.dateOfAppointment||'','Mobile Number':r.mobileNo||'','PAN Number':r.panNo||'','State Council Reg No':r.stateCouncilRegNo||'','AEBAS Attend ID':r.aEBASAttendId||'','Professional Qualification':r.professionalQualification||'','Nature Of Employment':r.natureOfEmployment||'','Teaching Experience (Yrs)':r.teachingExpInYrs||''}));
                const ws=XLSX.utils.json_to_sheet(excelData);
                const wb=XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb,ws,'UG Faculty List');
                XLSX.writeFile(wb,'UG_Faculty_List.xlsx');
            } catch(e){Swal.fire({icon:'error',title:'Excel Export Failed',text:e.message});}
        }

        $(function() { syncTableGrid(); });




                const IS_LOCKED = @(isLocked.ToString().ToLower());

        document.addEventListener("DOMContentLoaded", function () {

            if (IS_LOCKED) {

                // Disable all inputs/selects/buttons inside form
                document.querySelectorAll('#entryFormCard input, #entryFormCard select, #entryFormCard button')
                    .forEach(el => {
                        el.disabled = true;
                    });

                // Disable confirm button
                const confirmBtn = document.getElementById('btnConfirm');

                if (confirmBtn) {
                    confirmBtn.disabled = true;
                    confirmBtn.style.opacity = "0.6";
                    confirmBtn.style.cursor = "not-allowed";
                    confirmBtn.innerHTML =
                        '<i class="bi bi-lock-fill"></i> Faculty Data Already Submitted';
                }

                // Disable delete buttons
                document.querySelectorAll('.btn-del').forEach(btn => {
                    btn.disabled = true;
                });
            }
        });
    </script>
