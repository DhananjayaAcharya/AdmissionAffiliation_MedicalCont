@model AffiliationPgCourseViewModel
@{
    ViewData["Title"] = "PG Course Affiliation";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
    var courseLevel= Context.Session.GetString("CourseLevel");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PG Course Affiliation</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --ink: #0f1923;
            --ink-mid: #2e3d4f;
            --ink-muted: #6b7a8d;
            --border: #d4dae3;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --accent: #1a4c8b;
            --accent-lt: #e8edf7;
            --danger: #c0392b;
            --gold: #c9a84c;
            --radius: 10px;
            --shadow: 0 2px 16px rgba(15,25,35,.07);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--ink);
            min-height: 100vh;
        }

        /* ─── TOP HEADER ─────────────────────────────── */
        .page-header {
            background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
            padding: 28px 40px 24px;
            display: flex;
            align-items: center;
            gap: 18px;
            border-bottom: 3px solid var(--gold);
        }

        .page-header .emblem {
            width: 54px;
            height: 54px;
            border: 2px solid var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .page-header .emblem svg {
            width: 28px;
            height: 28px;
            fill: var(--gold);
        }

        .page-header-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem;
            color: #ffffff;
            letter-spacing: .02em;
        }

        .page-header-text p {
            font-size: .78rem;
            color: rgba(255,255,255,.55);
            margin-top: 3px;
            letter-spacing: .06em;
            text-transform: uppercase;
        }

        .form-wrap {
            max-width: 1280px;
            margin: 32px auto;
            padding: 0 24px 60px;
        }

        .section-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            margin-bottom: 28px;
            animation: fadeUp .35s ease both;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .section-header {
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--border);
            background: #fafbfc;
        }

        .section-header .icon-wrap {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .section-header h2 {
            font-size: 1.02rem;
            font-weight: 600;
            letter-spacing: .03em;
            color: var(--ink);
            margin: 0;
        }

        .section-body {
            padding: 1rem;
        }

        /* Scrollable Table */
        .scrollable-table-container {
            max-height: 380px;
            overflow-y: auto;
            border: 1px solid var(--border);
            border-radius: 8px;
        }

        .custom-table {
            width: 100%;
            border-collapse: collapse;
        }

        .custom-table thead {
            position: sticky;
            top: 0;
            z-index: 10;
            background: #f8f9fc;
        }

        .custom-table th, .custom-table td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
        }

        .custom-table th {
            background: #f8f9fc;
            color: var(--ink-mid);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.76rem;
            letter-spacing: 0.05em;
        }

        .custom-table tr:hover {
            background: #f8fbff;
        }

        .scrollable-table-container::-webkit-scrollbar {
            width: 8px;
        }
        .scrollable-table-container::-webkit-scrollbar-thumb {
            background: #c1c9d4;
            border-radius: 4px;
        }

        /* Form Controls */
        input[type="text"], input[type="number"], input[type="date"], textarea {
            width: 100%;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.875rem;
            color: var(--ink);
            background: #fafbfc;
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 9px 13px;
        }

        input:focus, textarea:focus {
            border-color: var(--accent);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,76,139,.1);
        }

        /* Hide default file input completely */
        input[type="file"] {
            display: none !important;
        }

        /* Custom Upload Button */
        .custom-upload-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #f1f3f7;
            color: var(--ink-mid);
            border: 1px solid var(--border);
            padding: 9px 18px;
            border-radius: 8px;
            font-size: 0.83rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .custom-upload-btn:hover {
            background: var(--accent-lt);
            border-color: var(--accent);
            color: var(--accent);
        }

        .btn {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            border-radius: 8px;
            padding: 10px 26px;
            cursor: pointer;
            letter-spacing: .03em;
            transition: all .18s;
        }

        .btn-ghost {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--ink-muted);
        }

        .btn-ghost:hover {
            border-color: var(--ink-mid);
            color: var(--ink);
        }

        .btn-primary {
            background: linear-gradient(135deg, #1a4c8b, #1564c0);
            color: #fff;
            box-shadow: 0 3px 14px rgba(26,76,139,.3);
        }

        .btn-primary:hover {
            box-shadow: 0 5px 20px rgba(26,76,139,.4);
            transform: translateY(-1px);
        }

        .badge-intake {
            background: #e8edf7;
            color: var(--accent);
            padding: 6px 14px;
            border-radius: 9999px;
            font-size: 0.82rem;
            font-weight: 500;
        }

    </style>

    <link rel="stylesheet" href="~/css/common-form.css" />

</head>
<body>

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div class="emblem">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
        </div>
        <div class="page-header-text">
            <h1>PG Course Details</h1>
            @* <p>Affiliation &amp; Recognition Portal — Postgraduate Courses</p> *@
        </div>
    </div>

    <div class="form-wrap">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:20px; font-size:0.85rem;"></div>

        <!-- Degree + Diploma Overview -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 32px;">
            <!-- PG Degree & Diploma Cards (unchanged) -->
            <div class="section-card">
                <div class="section-header" style="background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%); color: white;">
                    <div class="icon-wrap" style="background: rgba(255,255,255,0.25);">
                        <i class="bi bi-mortarboard-fill" style="font-size: 1.5rem; color: white;"></i>
                    </div>
                    <h2 style="color: white;">PG Degree Courses</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container">
                        <table class="custom-table">
                            <thead>
                                <tr><th>Course Name</th><th class="text-center">Intake</th></tr>
                            </thead>
                            <tbody>
                                @if (Model.PgDegreeCourses.Any())
                                {
                                    @foreach (var course in Model.PgDegreeCourses)
                                    {
                                        <tr>
                                            <td>@course.CourseName</td>
                                            <td class="text-center"><span class="badge-intake">@course.CollegeIntake</span></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="2" class="text-center py-4 text-muted">No PG Degree courses available</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="section-card">
                <div class="section-header" style="background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%); color: white;">
                    <div class="icon-wrap" style="background: rgba(255,255,255,0.25);">
                        <i class="bi bi-file-earmark-text-fill" style="font-size: 1.5rem; color: white;"></i>
                    </div>
                    <h2 style="color: white;">PG Diploma Courses</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container">
                        <table class="custom-table">
                            <thead>
                                <tr><th>Course Name</th><th class="text-center">Intake</th></tr>
                            </thead>
                            <tbody>
                                @if (Model.PgDiplomaCourses.Any())
                                {
                                    @foreach (var course in Model.PgDiplomaCourses)
                                    {
                                        <tr>
                                            <td>@course.CourseName</td>
                                            <td class="text-center">
                                                <span class="badge-intake" style="background:#e3f4f4; color:#1a7f7a;">@course.CollegeIntake</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="2" class="text-center py-4 text-muted">No PG Diploma courses available</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- PG Course Particulars -->
        <div class="section-card">
            <form asp-action="SavePgCourseParticulars" method="post">
                <input type="hidden" name="CollegeCode" value="@Model.CollegeCode" />
                <div class="section-header">
                    <div class="icon-wrap" style="background:#e8edf7;">
                        <i class="bi bi-journal-check" style="font-size:1.3rem; color:#1a4c8b;"></i>
                    </div>
                    <h2>Course Particulars &amp; Recognition</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container" style="max-height: 380px;">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Course</th>
                                    <th>Date of LOP</th>
                                    <th>Date of NMC Recognition</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var index = 0;
                                }
                                @foreach (var course in Model.AllCourses)
                                {
                                    <tr>
                                        <td>@course.CourseName</td>
                                        <td><input type="date" class="form-control" name="Courses[@index].DateofLOP" value="@(course.DateofLOP?.ToString("yyyy-MM-dd") ?? "")" /></td>
                                        <td><input type="date" class="form-control" name="Courses[@index].DateofRecognitionByNMC" value="@(course.DateofRecognitionByNMC?.ToString("yyyy-MM-dd") ?? "")" /></td>
                                        <input type="hidden" name="Courses[@index].CourseCode" value="@course.CourseCode" />
                                        <input type="hidden" name="Courses[@index].CourseName" value="@course.CourseName" />
                                        <input type="hidden" name="Courses[@index].CourseLevel" value="@course.CourseLevel" />
                                        <input type="hidden" name="Courses[@index].CoursePrefix" value="@course.CoursePrefix" />
                                        <input type="hidden" name="Courses[@index].CollegeCode" value="@Model.CollegeCode" />
                                        <input type="hidden" name="Courses[@index].CollegeIntake" value="@course.CollegeIntake" />
                                        <input type="hidden" name="Courses[@index].RguhsIntake" value="@course.RguhsIntake" />
                                    </tr>
                                    index++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div style="padding:20px 24px; border-top:1px solid var(--border); text-align:center;">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-cloud-arrow-up me-2"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>

        <!-- GOK Details -->
        <div class="section-card">
            <form asp-action="SavePgCoursesForGOK" method="post" enctype="multipart/form-data">
                <input type="hidden" name="CollegeCode" value="@Model.CollegeCode" />
                <div class="section-header">
                    <div class="icon-wrap" style="background:#fdf3e0;">
                        <i class="bi bi-file-earmark-text" style="font-size:1.3rem; color:#a0660a;"></i>
                    </div>
                    <h2>GOK – Government Order Details</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container" style="max-height: 380px;">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Course</th>
                                    <th class="text-center">Sanctioned Intake</th>
                                    <th>Date of GOK</th>
                                    <th>Academic Year</th>
                                    <th>GOK Document</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var gokIndex = 0;
                                }
                                @foreach (var course in Model.PgCoursesGOK)
                                {
                                    <tr>
                                        <td>@course.CourseName</td>
                                        <td class="text-center">
                                            <input type="number" class="form-control text-center" readonly 
                                                   name="PgCoursesGOK[@gokIndex].RguhsIntake" value="@course.RguhsIntake" />
                                        </td>
                                        <td>
                                            <input type="date" class="form-control" 
                                                   name="PgCoursesGOK[@gokIndex].DateofGOK" 
                                                   value="@(course.DateofGOK?.ToString("yyyy-MM-dd") ?? "")" />
                                        </td>
                                        <td>
                                            <input type="text" class="form-control" 
                                                   name="PgCoursesGOK[@gokIndex].AcademicYear" 
                                                   value="@course.AcademicYear" placeholder="YYYY-YY" />
                                        </td>
                                        <td>
                                            <!-- Hidden file input -->
                                            <input type="file" id="gokFile_@gokIndex" name="PgCoursesGOK[@gokIndex].GOKDocumentFile"
                                                   accept=".pdf,.jpg,.jpeg,.png" onchange="updateFileName(@gokIndex)" />

                                            <input type="hidden" id="gokFileSize_@gokIndex" name="PgCoursesGOK[@gokIndex].GOKDocumentSize" />

                                            <!-- Custom Upload Button -->
                                            <label for="gokFile_@gokIndex" class="custom-upload-btn">
                                                <i class="bi bi-upload"></i> Upload GOK Document
                                            </label>

                                            <span id="fileName_@gokIndex" class="small text-muted d-none fw-medium ms-3"></span>

                                            @if (course.HasGOKDocument)
                                            {
                                                <a asp-action="ViewGokDocument" asp-route-courseCode="@course.CourseCode"
                                                   asp-route-collegecode="@Model.CollegeCode" target="_blank"
                                                   class="btn btn-ghost ms-2">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            }
                                        </td>
                                        <input type="hidden" name="PgCoursesGOK[@gokIndex].CourseCode" value="@course.CourseCode" />
                                        <input type="hidden" name="PgCoursesGOK[@gokIndex].CourseName" value="@course.CourseName" />
                                        <input type="hidden" name="PgCoursesGOK[@gokIndex].CourseLevel" value="@course.CourseLevel" />
                                        <input type="hidden" name="PgCoursesGOK[@gokIndex].CoursePrefix" value="@course.CoursePrefix" />
                                        <input type="hidden" name="PgCoursesGOK[@gokIndex].CollegeCode" value="@Model.CollegeCode" />
                                        <input type="hidden" name="PgCoursesGOK[@gokIndex].CollegeIntake" value="@course.CollegeIntake" />
                                        <input type="hidden" name="PgCoursesGOK[@gokIndex].RguhsIntake" value="@course.RguhsIntake" />
                                    </tr>
                                    gokIndex++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div style="padding:20px 24px; border-top:1px solid var(--border); text-align:center;">
                    <small class="text-muted">Maximum file size: 1 MB</small><br>
                    <button type="submit" class="btn btn-primary mt-2">
                        <i class="bi bi-cloud-arrow-up me-2"></i>Save GOK Details
                    </button>
                </div>
            </form>
        </div>

        <!-- RGUHS Permission Details -->
        <div class="section-card">
            <form asp-action="SavePgCoursesRguhs" method="post" enctype="multipart/form-data">
                <input type="hidden" name="CollegeCode" value="@Model.CollegeCode" />
                <div class="section-header">
                    <div class="icon-wrap" style="background:#e3f4f4;">
                        <i class="bi bi-building-check" style="font-size:1.3rem; color:#1a7f7a;"></i>
                    </div>
                    <h2>RGUHS Permission Details</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container" style="max-height: 380px;">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Course</th>
                                    <th class="text-center">Sanctioned Intake</th>
                                    <th>RGUHS Document</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var rguhsIndex = 0;
                                }
                                @foreach (var course in Model.PgCoursesRguhs)
                                {
                                    <tr>
                                        <td>@course.CourseName</td>
                                        <td class="text-center">
                                            <input type="number" class="form-control text-center"
                                                   name="PgCoursesRguhs[@rguhsIndex].RguhsIntake" value="@course.RguhsIntake" min="0" />
                                        </td>
                                        <td>
                                            <input type="file" id="rguhsFile_@rguhsIndex" name="PgCoursesRguhs[@rguhsIndex].RGUHSDocumentFile"
                                                   accept=".pdf,.jpg,.jpeg,.png" onchange="updateRguhsFileName(@rguhsIndex)" />

                                            <input type="hidden" id="rguhsFileSize_@rguhsIndex" name="PgCoursesRguhs[@rguhsIndex].RGUHSDocumentSize" />

                                            <label for="rguhsFile_@rguhsIndex" class="custom-upload-btn">
                                                <i class="bi bi-upload"></i> Upload RGUHS Document
                                            </label>

                                            <span id="rguhsFileName_@rguhsIndex" class="small text-muted d-none fw-medium ms-3"></span>

                                            @if (course.HasRguhsDocument)
                                            {
                                                <a asp-action="ViewRguhsDocument" asp-route-courseCode="@course.CourseCode"
                                                   class="btn btn-ghost ms-2" target="_blank">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            }
                                        </td>
                                        <input type="hidden" name="PgCoursesRguhs[@rguhsIndex].CourseCode" value="@course.CourseCode" />
                                        <input type="hidden" name="PgCoursesRguhs[@rguhsIndex].CourseName" value="@course.CourseName" />
                                        <input type="hidden" name="PgCoursesRguhs[@rguhsIndex].CourseLevel" value="@course.CourseLevel" />
                                        <input type="hidden" name="PgCoursesRguhs[@rguhsIndex].CoursePrefix" value="@course.CoursePrefix" />
                                    </tr>
                                    rguhsIndex++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div style="padding:20px 24px; border-top:1px solid var(--border); text-align:center;">
                    <small class="text-muted">Maximum file size: 1 MB</small><br>
                    <button type="submit" class="btn btn-primary mt-2">
                        <i class="bi bi-cloud-arrow-up me-2"></i>Save RGUHS Details
                    </button>
                </div>
            </form>
        </div>

        <!-- Other NMC Permitted Courses -->
        <div class="section-card">
            <form asp-action="SaveOtherDeptCourses" method="post" enctype="multipart/form-data">
                <div class="section-header">
                    <div class="icon-wrap" style="background:#eaebee;">
                        <i class="bi bi-plus-circle" style="font-size:1.3rem; color:#2d3748;"></i>
                    </div>
                    <h2>Other NMC Permitted Courses</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container" style="max-height: 380px;">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Course</th>
                                    <th class="text-center">NMC Permission</th>
                                    <th class="text-center">Admissions / Year</th>
                                    <th>NMC Document</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var nmcIndex = 0;
                                }
                                @foreach (var course in Model.OtherCoursesPermittedByNMC)
                                {
                                    <tr>
                                        <td>@course.CourseName</td>
                                        <td class="text-center">
                                            <input type="checkbox" name="OtherCoursesPermittedByNMC[@nmcIndex].PermissionByNMC"
                                                   value="true" @(course.PermissionByNMC ? "checked" : "") />
                                        </td>
                                        <td class="text-center">
                                            <input type="number" class="form-control text-center"
                                                   name="OtherCoursesPermittedByNMC[@nmcIndex].AdmissionsPerYear"
                                                   value="@course.AdmissionsPerYear" min="0" />
                                        </td>
                                        <td>
                                            <input type="file" id="nmcFile_@nmcIndex" name="OtherCoursesPermittedByNMC[@nmcIndex].NMCdocumentFile"
                                                   accept=".pdf,.jpg,.jpeg,.png" onchange="updateNmcFileName(@nmcIndex)" />

                                            <input type="hidden" id="nmcFileSize_@nmcIndex" name="OtherCoursesPermittedByNMC[@nmcIndex].NMCdocumentSize" />

                                            <label for="nmcFile_@nmcIndex" class="custom-upload-btn">
                                                <i class="bi bi-upload"></i> Upload NMC Document
                                            </label>

                                            <span id="nmcFileName_@nmcIndex" class="small text-muted d-none fw-medium ms-3"></span>

                                            @if (course.HasNMCdocument)
                                            {
                                                <a asp-action="ViewNMCDocument" asp-route-courseCode="@course.CourseCode"
                                                   class="btn btn-ghost ms-2" target="_blank">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            }
                                        </td>
                                        <input type="hidden" name="OtherCoursesPermittedByNMC[@nmcIndex].CourseCode" value="@course.CourseCode" />
                                        <input type="hidden" name="OtherCoursesPermittedByNMC[@nmcIndex].CourseName" value="@course.CourseName" />
                                        <input type="hidden" name="OtherCoursesPermittedByNMC[@nmcIndex].CourseLevel" value="@course.CourseLevel" />
                                        <input type="hidden" name="OtherCoursesPermittedByNMC[@nmcIndex].CoursePrefix" value="@course.CoursePrefix" />
                                        <input type="hidden" name="OtherCoursesPermittedByNMC[@nmcIndex].CollegeCode" value="@Model.CollegeCode" />
                                        <input type="hidden" name="OtherCoursesPermittedByNMC[@nmcIndex].FacultyCode" value="@course.FacultyCode" />
                                    </tr>
                                    nmcIndex++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- Navigation -->
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 0 .5rem;">
                    @* <a asp-action="Aff_TrustMemberDetails" asp-controller="ContinuesAffiliation_Facultybased"
                       class="btn btn-ghost">← Previous</a> *@

                    <a asp-action="Aff_PrincipalDetails" asp-controller="ContinuesAffiliation_Facultybased"
                       class="btn btn-ghost">← Previous</a>
                        <div style="padding:20px 24px; border-top:1px solid var(--border); text-align:center;">
                            <small class="text-muted">Maximum file size: 1 MB</small><br>
                            <button type="submit" class="btn btn-primary mt-2">
                                <i class="bi bi-cloud-arrow-up me-2"></i>Save
                            </button>
                        </div>
                    @* <a asp-action="CoursesOffered" asp-controller="AffiliationPg"
                       class="btn btn-primary">Next →</a> *@

                    <a asp-action="ContinuousAffiliationIncreaseintake" asp-controller="IncreaseIntake"
                       class="btn btn-primary">Next →</a>
                </div>
            </form>
        </div>

    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            function updateFileName(index) {
                const input = document.getElementById("gokFile_" + index);
                const label = document.getElementById("fileName_" + index);
                const sizeInput = document.getElementById("gokFileSize_" + index);
                if (!input || !label || !sizeInput) return;

                const maxSize = 1 * 1024 * 1024;
                if (input.files.length === 0) {
                    label.classList.add("d-none");
                    sizeInput.value = "";
                    return;
                }

                const file = input.files[0];
                if (file.size > maxSize) {
                    Swal.fire({ icon: 'error', title: 'File too large', text: `GOK document must be 1 MB or smaller.` });
                    input.value = "";
                    label.classList.add("d-none");
                    sizeInput.value = "";
                    return;
                }

                label.innerText = file.name;
                label.classList.remove("d-none");
                sizeInput.value = file.size;
            }

            function updateRguhsFileName(index) {
                const input = document.getElementById("rguhsFile_" + index);
                const label = document.getElementById("rguhsFileName_" + index);
                const sizeInput = document.getElementById("rguhsFileSize_" + index);
                const maxSize = 1 * 1024 * 1024;

                if (input.files.length === 0) {
                    label.classList.add("d-none");
                    sizeInput.value = "";
                    return;
                }

                const file = input.files[0];
                if (file.size > maxSize) {
                    Swal.fire({ icon: 'error', title: 'File too large', text: `RGUHS document must be 1 MB or less.` });
                    input.value = "";
                    sizeInput.value = "";
                    return;
                }

                label.innerText = file.name;
                label.classList.remove("d-none");
                sizeInput.value = file.size;
            }

            function updateNmcFileName(index) {
                const input = document.getElementById("nmcFile_" + index);
                const label = document.getElementById("nmcFileName_" + index);
                const sizeInput = document.getElementById("nmcFileSize_" + index);
                const maxSize = 2 * 1024 * 1024;

                if (!input.files.length) {
                    label.classList.add("d-none");
                    sizeInput.value = "";
                    return;
                }

                const file = input.files[0];
                if (file.size > maxSize) {
                    Swal.fire({ icon: 'error', title: 'File too large', text: `NMC document must be 1 MB or smaller.` });
                    input.value = "";
                    label.classList.add("d-none");
                    sizeInput.value = "";
                    return;
                }

                label.innerText = file.name;
                label.classList.remove("d-none");
                sizeInput.value = file.size;
            }

            // TempData Success Messages
            const gokMessage = '@TempData["GokSavemsg"]';
            const rguhsMessage = '@TempData["Rguhs"]';
            const otherMsg = '@TempData["others"]';
            const licMsg = '@TempData["Lic"]';
            const pgparticulars = '@TempData["pgparticulars"]';

            if (gokMessage) Swal.fire({ icon: 'success', title: 'Success', text: gokMessage, timer: 3000, showConfirmButton: false });
            if (rguhsMessage) Swal.fire({ icon: 'success', title: 'Success', text: rguhsMessage, timer: 3000, showConfirmButton: false });
            if (otherMsg) Swal.fire({ icon: 'success', title: 'Success', text: otherMsg, timer: 3000, showConfirmButton: false });
            if (licMsg) Swal.fire({ icon: 'success', title: 'Success', text: licMsg, timer: 3000, showConfirmButton: false });
            if (pgparticulars) Swal.fire({ icon: 'success', title: 'Success', text: pgparticulars, timer: 3000, showConfirmButton: false });
        </script>
    }
</body>
</html>