        /* =====================================================
           Other Course Save
        ===================================================== */
        $('#btnSaveOtherCourse').click(function(){

           var hasAnyData=false;
           var hasError=false;
           var errorRows=[];

           $('#otherCourseForm tbody tr').each(function(){

              var courseVal=
                 $(this).find('select').val();

              var fileVal=
                 $(this)
                 .find('input[type=file]')
                 .val();

              var hasExistingFile=
                 $(this)
                 .find('a.btn-outline-primary')
                 .length>0;

              if(courseVal!=='' || fileVal!==''){
                 hasAnyData=true;
              }

              if(courseVal==='' && fileVal===''){
                 return true;
              }

              if(
                 courseVal!=='' &&
                 fileVal==='' &&
                 !hasExistingFile
              ){
                 hasError=true;

                 errorRows.push(
                   '📄 Upload document for '
                   + courseVal
                 );
              }

              if(
                 courseVal==='' &&
                 fileVal!==''
              ){
                 hasError=true;

                 errorRows.push(
                  '📚 Select course for uploaded file'
                 );
              }

           });

           if(!hasAnyData){
              Swal.fire({
                 icon:'info',
                 title:'Nothing to Save',
                 text:'No new data entered to save.'
              });
              return;
           }

           if(hasError){
              Swal.fire({
                 icon:'error',
                 title:'Validation Error',
                 html:errorRows.join('<br>')
              });
              return;
           }

           $('#otherCourseForm').submit();

        });


        /* =====================================================
           2 MB File Validation
        ===================================================== */
        document.addEventListener(
         'change',
         function(e){

           if(
             e.target.type==='file'
             && e.target.files.length>0
           ){

              if(
                e.target.files[0].size
                >2097152
              ){

                Swal.fire({
                  icon:'error',
                  title:'File too large',
                  text:'Maximum allowed file size is 2 MB'
                });

                e.target.value='';
              }

           }

         });

        }); // document.ready
    </script>
}