                        </tr>
                    </thead>

                    <tbody>
                        @for (int i = 0; i < Model.PermissionList.Count; i++)
                        {
                            <tr>

                                @*  {{!-- Column 1: Course --}} *@
                                <td class="text-start">
                                    @Model.PermissionList[i].CourseName
                                    <input asp-for="PermissionList[i].CourseName" type="hidden" />
                                    <input asp-for="PermissionList[i].CourseCode" type="hidden" />
                                    <input asp-for="PermissionList[i].Id" type="hidden" />
                                </td>

                                @* {{!-- Column 2: Permission dropdown --}} *@
                                <td>
                                    @* <select asp-for="PermissionList[i].PermissionStatus"
                                        class="form-select permission-dd">
                                    <option value="">--Select--</option>
                                    <option value="Yes">Yes</option>
                                    <option value="No">No</option>
                                </select> *@

