@model Medical_Affiliation.Models.CA_SS_FullViewVM
@{
    ViewData["Title"] = "Super Specialty Courses";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
    var courseLevel = Context.Session.GetString("CourseLevel");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Super Specialty Courses</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        :root {
            --ink: #0f1923;
            --ink-mid: #2e3d4f;
            --ink-muted: #6b7a8d;
            --border: #d4dae3;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --accent: #1a4c8b;
            --accent-lt: #e8edf7;
            --danger: #c0392b;
            --gold: #c9a84c;
            --radius: 10px;
            --shadow: 0 2px 16px rgba(15,25,35,.07);
        }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--ink);
            min-height: 100vh;
        }
        /* ─── TOP HEADER ─────────────────────────────── */
        .page-header {
            background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
            padding: 28px 40px 24px;
            display: flex;
            align-items: center;
            gap: 18px;
            border-bottom: 3px solid var(--gold);
        }
        .page-header .emblem {
            width: 54px;
            height: 54px;
            border: 2px solid var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .page-header .emblem svg {
            width: 28px;
            height: 28px;
            fill: var(--gold);
        }
        .page-header-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem;
            color: #ffffff;
            letter-spacing: .02em;
        }
        .page-header-text p {
            font-size: .78rem;
            color: rgba(255,255,255,.55);
            margin-top: 3px;
            letter-spacing: .06em;
            text-transform: uppercase;
        }
        .form-wrap {
            max-width: 1280px;
            margin: 32px auto;
            padding: 0 24px 60px;
        }
        .section-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            margin-bottom: 28px;
            animation: fadeUp .35s ease both;
        }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .section-header {
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--border);
            background: #fafbfc;
        }
        .section-header .icon-wrap {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .section-header h2 {
            font-size: 1.02rem;
            font-weight: 600;
            letter-spacing: .03em;
            color: var(--ink);
            margin: 0;
        }
        .section-body {
            padding: 1rem;
        }
        .scrollable-table-container {
            max-height: 420px;
            overflow-y: auto;
            border: 1px solid var(--border);
            border-radius: 8px;
        }
        .custom-table {
            width: 100%;
            border-collapse: collapse;
        }
        .custom-table thead {
            position: sticky;
            top: 0;
            z-index: 10;
            background: #f8f9fc;
        }
        .custom-table th, .custom-table td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }
        .custom-table th {
            background: #f8f9fc;
            color: var(--ink-mid);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.76rem;
            letter-spacing: 0.05em;
        }
        .custom-table tr:hover {
            background: #f8fbff;
        }
        .scrollable-table-container::-webkit-scrollbar {
            width: 8px;
        }
        .scrollable-table-container::-webkit-scrollbar-thumb {
            background: #c1c9d4;
            border-radius: 4px;
        }
        input[type="text"], input[type="number"], input[type="date"], select, textarea {
            width: 100%;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.875rem;
            color: var(--ink);
            background: #fafbfc;
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 9px 13px;
        }
        input:focus, select:focus, textarea:focus {
            border-color: var(--accent);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,76,139,.1);
        }
        .btn {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            border-radius: 8px;
            padding: 10px 26px;
            cursor: pointer;
            letter-spacing: .03em;
            transition: all .18s;
        }
        .btn-ghost {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--ink-muted);
        }
        .btn-ghost:hover {
            border-color: var(--ink-mid);
            color: var(--ink);
        }
        .btn-primary {
            background: linear-gradient(135deg, #1a4c8b, #1564c0);
            color: #fff;
            box-shadow: 0 3px 14px rgba(26,76,139,.3);
        }
        .btn-primary:hover {
            box-shadow: 0 5px 20px rgba(26,76,139,.4);
            transform: translateY(-1px);
        }
        .badge-intake {
            background: #e8edf7;
            color: var(--accent);
            padding: 6px 14px;
            border-radius: 9999px;
            font-size: 0.82rem;
            font-weight: 500;
        }
        .caution-box {
            background: #ffecec;
            border: 1px solid #dc3545;
            color: #b02a37;
            padding: 14px 18px;
            border-radius: 8px;
            font-weight: 500;
            margin-bottom: 24px;
        }
    </style>
</head>
<body>
    <!-- PAGE HEADER -->
    <div class="page-header">
        <div class="emblem">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
        </div>
        <div class="page-header-text">
            <h1>Super Specialty Courses</h1>
            <p>Affiliation &amp; Recognition Portal — DM / M.Ch Courses</p>
        </div>
    </div>

    <div class="form-wrap">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:20px; font-size:0.85rem;"></div>

        <!-- Caution Message -->
        @if (!string.IsNullOrEmpty(Model.CautionMessage))
        {
            <div class="caution-box">
                ⚠ @Model.CautionMessage
            </div>
        }

        <!-- DM Courses Overview -->
        <div class="section-card">
            <div class="section-header" style="background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%); color: white;">
                <div class="icon-wrap" style="background: rgba(255,255,255,0.25);">
                    <i class="bi bi-mortarboard-fill" style="font-size: 1.5rem; color: white;"></i>
                </div>
                <h2 style="color: white;">a. DM (Doctor of Medicine) Courses</h2>
            </div>
            <div class="section-body">
                <div class="scrollable-table-container">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Sl No</th>
                                <th>Course Name</th>
                                <th class="text-center">Intake</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.DMCourses.Any())
                            {
                                int i = 1;
                                foreach (var row in Model.DMCourses)
                                {
                                    <tr>
                                        <td>@i</td>
                                        <td>@row.CourseName</td>
                                        <td class="text-center"><span class="badge-intake">@(row.PresentIntake ?? 0)</span></td>
                                    </tr>
                                    i++;
                                }
                            }
                            else
                            {
                                <tr><td colspan="3" class="text-center py-4 text-muted">No DM Courses Found</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- M.Ch Courses Overview -->
        <div class="section-card">
            <div class="section-header" style="background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%); color: white;">
                <div class="icon-wrap" style="background: rgba(255,255,255,0.25);">
                    <i class="bi bi-mortarboard-fill" style="font-size: 1.5rem; color: white;"></i>
                </div>
                <h2 style="color: white;">b. M.Ch (Master of Chirurgiae) Courses</h2>
            </div>
            <div class="section-body">
                <div class="scrollable-table-container">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Sl No</th>
                                <th>Course Name</th>
                                <th class="text-center">Intake</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.MChCourses.Any())
                            {
                                int j = 1;
                                foreach (var row in Model.MChCourses)
                                {
                                    <tr>
                                        <td>@j</td>
                                        <td>@row.CourseName</td>
                                        <td class="text-center"><span class="badge-intake">@(row.PresentIntake ?? 0)</span></td>
                                    </tr>
                                    j++;
                                }
                            }
                            else
                            {
                                <tr><td colspan="3" class="text-center py-4 text-muted">No M.Ch Courses Found</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- 3.a Date of LOP -->
        <div class="section-card">
            <form asp-action="SaveLOP" method="post">
                @Html.AntiForgeryToken()
                <div class="section-header">
                    <div class="icon-wrap" style="background:#e8edf7;">
                        <i class="bi bi-calendar-check" style="font-size:1.3rem; color:#1a4c8b;"></i>
                    </div>
                    <h2>3.a Date of LOP &amp; Recognition</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Subject / Course</th>
                                    <th>Sanctioned Intake</th>
                                    <th>Date of LOP</th>
                                    <th>Date of Recognition</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.LopList.Count; i++)
                                {
                                    <tr>
                                        <td>@Model.LopList[i].CourseName</td>
                                        <td class="text-center">@Model.LopList[i].SanctionedIntake</td>
                                        <td>
                                            <input asp-for="LopList[i].LopDate" type="date" class="form-control" />
                                        </td>
                                        <td>
                                            <input asp-for="LopList[i].RecognitionDate" type="date" class="form-control" />
                                        </td>
                                        <input asp-for="LopList[i].SanctionedIntake" type="hidden" />
                                        <input asp-for="LopList[i].CourseName" type="hidden" />
                                        <input asp-for="LopList[i].CourseCode" type="hidden" />
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div style="padding:20px 24px; border-top:1px solid var(--border); text-align:center;">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-cloud-arrow-up me-2"></i>Save LOP Dates
                    </button>
                </div>
            </form>
        </div>

        <!-- 3.b.i Particulars (Permission) -->
        <div class="section-card">
            <form asp-action="SavePermission" method="post" enctype="multipart/form-data" id="permissionForm">
                @Html.AntiForgeryToken()
                <div class="section-header">
                    <div class="icon-wrap" style="background:#e8edf7;">
                        <i class="bi bi-journal-check" style="font-size:1.3rem; color:#1a4c8b;"></i>
                    </div>
                    <h2>3.b.i Particulars (Permission by NMC)</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Course</th>
                                    <th>Permission Status</th>
                                    <th>NMC Document</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.PermissionList.Count; i++)
                                {
                                    <tr>
                                        <td>@Model.PermissionList[i].CourseName</td>
                                        <td>
                                            <select asp-for="PermissionList[i].PermissionStatus" class="form-select permission-dd">
                                                <option value="">--Select--</option>
                                                <option value="Yes" selected="@(Model.PermissionList[i].PermissionStatus == "Yes")">Yes</option>
                                                <option value="No" selected="@(Model.PermissionList[i].PermissionStatus == "No")">No</option>
                                            </select>
                                        </td>
                                        <td>
                                            <input asp-for="PermissionList[i].PermissionFile" type="file" accept=".pdf" 
                                                   class="form-control permission-file" style="display:none;" />
                                            @if (Model.PermissionList[i].HasFile)
                                            {
                                                <a asp-action="ViewPermissionFile" asp-route-id="@Model.PermissionList[i].Id"
                                                   class="btn btn-ghost ms-2" target="_blank">
                                                    <i class="bi bi-eye"></i> View Document
                                                </a>
                                            }
                                        </td>
                                        <input asp-for="PermissionList[i].CourseName" type="hidden" />
                                        <input asp-for="PermissionList[i].CourseCode" type="hidden" />
                                        <input asp-for="PermissionList[i].Id" type="hidden" />
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div style="padding:20px 24px; border-top:1px solid var(--border); text-align:center;">
                    <button type="button" class="btn btn-primary" id="btnSavePermission">
                        <i class="bi bi-cloud-arrow-up me-2"></i>Save Particulars
                    </button>
                </div>
            </form>
        </div>

        <!-- 3.b.ii Affiliation -->
        <div class="section-card">
            <form asp-action="SaveAffiliation" method="post" enctype="multipart/form-data" id="affiliationForm">
                @Html.AntiForgeryToken()
                <div class="section-header">
                    <div class="icon-wrap" style="background:#e3f4f4;">
                        <i class="bi bi-building-check" style="font-size:1.3rem; color:#1a7f7a;"></i>
                    </div>
                    <h2>3.b.ii Affiliation Details</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Course</th>
                                    <th>Sanctioned Intake</th>
                                    <th>Affiliation Date</th>
                                    <th>Supporting Document</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.AffiliationList.Count; i++)
                                {
                                    <tr>
                                        <td>@Model.AffiliationList[i].CourseName</td>
                                        <td class="text-center">@Model.AffiliationList[i].SanctionedIntake</td>
                                        <td>
                                            <input asp-for="AffiliationList[i].AffiliationDate" type="date" class="form-control aff-date" />
                                        </td>
                                        <td>
                                            <input asp-for="AffiliationList[i].SupportingDoc" type="file" accept=".pdf" 
                                                   class="form-control aff-file" />
                                            @if (Model.AffiliationList[i].HasFile)
                                            {
                                                <a asp-action="ViewAffiliationFile" asp-route-id="@Model.AffiliationList[i].Id"
                                                   class="btn btn-ghost ms-2" target="_blank">
                                                    <i class="bi bi-eye"></i> View Document
                                                </a>
                                            }
                                        </td>
                                        <input asp-for="AffiliationList[i].CourseName" type="hidden" />
                                        <input asp-for="AffiliationList[i].CourseCode" type="hidden" />
                                        <input asp-for="AffiliationList[i].SanctionedIntake" type="hidden" />
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div style="padding:20px 24px; border-top:1px solid var(--border); text-align:center;">
                    <button type="button" class="btn btn-primary" id="btnSaveAffiliation">
                        <i class="bi bi-cloud-arrow-up me-2"></i>Save Affiliation Details
                    </button>
                </div>
            </form>
        </div>

        <!-- 3.b.iii LIC Inspection -->
        <div class="section-card">
            <form asp-action="SaveLICInspection" method="post">
                @Html.AntiForgeryToken()
                <div class="section-header">
                    <div class="icon-wrap" style="background:#fdf3e0;">
                        <i class="bi bi-clipboard-check" style="font-size:1.3rem; color:#a0660a;"></i>
                    </div>
                    <h2>iii. Date of Previous Inspection by LIC</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Sl</th>
                                    <th>Course</th>
                                    <th>Inspection Date</th>
                                    <th>Action Taken</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.LICInspections.Count; i++)
                                {
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td>@Model.LICInspections[i].CourseName</td>
                                        <td>
                                            <input asp-for="LICInspections[i].InspectionDate" type="date" class="form-control" />
                                        </td>
                                        <td>
                                            <textarea asp-for="LICInspections[i].ActionTaken" class="form-control" rows="2"></textarea>
                                        </td>
                                        <input asp-for="LICInspections[i].CourseName" type="hidden" />
                                        <input asp-for="LICInspections[i].CollegeCode" type="hidden" />
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div style="padding:20px 24px; border-top:1px solid var(--border); text-align:center;">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-cloud-arrow-up me-2"></i>Save LIC Inspection Details
                    </button>
                </div>
            </form>
        </div>

        <!-- 3.b.iv Other Courses -->
        <div class="section-card">
            <form asp-action="SaveOtherCourse" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="section-header">
                    <div class="icon-wrap" style="background:#eaebee;">
                        <i class="bi bi-plus-circle" style="font-size:1.3rem; color:#2d3748;"></i>
                    </div>
                    <h2>3.b.iv Other Courses</h2>
                </div>
                <div class="section-body">
                    <div class="scrollable-table-container">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Course</th>
                                    <th>Supporting Document</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.OtherCourses.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            <select asp-for="OtherCourses[i].CourseName" class="form-select">
                                                <option value="">--Select--</option>
                                                @foreach (var c in Model.OtherCourses[i].CourseList)
                                                {
                                                    <option value="@c" selected="@(c == Model.OtherCourses[i].CourseName)">@c</option>
                                                }
                                                @if (!string.IsNullOrEmpty(Model.OtherCourses[i].CourseName) &&
                                                     !Model.OtherCourses[i].CourseList.Contains(Model.OtherCourses[i].CourseName))
                                                {
                                                    <option value="@Model.OtherCourses[i].CourseName" selected>@Model.OtherCourses[i].CourseName</option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <input asp-for="OtherCourses[i].SupportingDoc" type="file" accept=".pdf" class="form-control" />
                                            @if (!string.IsNullOrEmpty(Model.OtherCourses[i].ExistingFileName))
                                            {
                                                <a asp-action="ViewOtherCourseFile" asp-route-id="@Model.OtherCourses[i].Id"
                                                   class="btn btn-ghost ms-2" target="_blank">
                                                    <i class="bi bi-eye"></i> View Document
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div style="padding:20px 24px; border-top:1px solid var(--border); text-align:center;">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-cloud-arrow-up me-2"></i>Save Other Course Details
                    </button>
                </div>
            </form>
        </div>

        <!-- Navigation -->
       @*  <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0;">
            <a asp-controller="ContinuesAffiliation_FacultybasedSS" asp-action="Aff_TrustMemberDetails"
               asp-route-courseLevel="@courseLevel"
               class="btn btn-ghost">
                ← Previous (Trust Member Details)
            </a>
            <a asp-controller="ContinuesAffiliation_Facultybased" asp-action="Dean_DirectorDetails"
               asp-route-courseLevel="@courseLevel"
               class="btn btn-primary">
                Next → Dean/Director Details
            </a>
        </div> *@

        <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 0;">
            <a asp-controller="AffiliationSS" asp-action="AssociatedInstitutions"
               asp-route-courseLevel="@courseLevel"
               class="btn btn-ghost">
                ← Previous
            </a>
            <a asp-controller="Medical_ContinuousAffiliation" asp-action="Medical_LandBuildingdetails"
               asp-route-courseLevel="@courseLevel"
               class="btn btn-primary">
                Next 
            </a>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
            // Your existing JavaScript (Permission + Affiliation validation) remains unchanged
            $(document).on('change', '.permission-dd', function () {
                var row = $(this).closest('tr');
                if ($(this).val() === 'Yes') {
                    row.find('.permission-file').show();
                } else {
                    row.find('.permission-file').hide();
                }
            });

            $(document).ready(function () {
                $('.permission-dd').each(function () {
                    var row = $(this).closest('tr');
                    if ($(this).val() === 'Yes') {
                        row.find('.permission-file').show();
                    } else {
                        row.find('.permission-file').hide();
                    }
                });

                // Affiliation Validation
                $('#btnSaveAffiliation').on('click', function () {
                    var hasError = false;
                    var errorRows = [];
                    $('#affiliationForm tbody tr').each(function () {
                        var dateVal = $(this).find('.aff-date').val();
                        var fileVal = $(this).find('.aff-file').val();
                        var hasExistingFile = $(this).find('a.btn-ghost').length > 0;
                        var courseName = $(this).find('td:first').text().trim();

                        if (dateVal !== '' && !hasExistingFile && fileVal === '') {
                            hasError = true;
                            errorRows.push('📅 ' + courseName + ' — please upload a document');
                        }
                        if (fileVal !== '' && dateVal === '') {
                            hasError = true;
                            errorRows.push('📄 ' + courseName + ' — please enter affiliation date');
                        }
                    });

                    if (hasError) {
                        Swal.fire({ icon: 'error', title: 'Validation Error', html: errorRows.join('<br>') });
                        return;
                    }
                    $('#affiliationForm').submit();
                });

                // Permission Validation
                $('#btnSavePermission').on('click', function () {
                    var hasError = false;
                    var errorRows = [];
                    $('#permissionForm tbody tr').each(function () {
                        var permVal = $(this).find('.permission-dd').val();
                        var fileVal = $(this).find('.permission-file').val();
                        var hasExistingFile = $(this).find('a.btn-ghost').length > 0;
                        var courseName = $(this).find('td:first').text().trim();

                        if (permVal === 'Yes' && !hasExistingFile && fileVal === '') {
                            hasError = true;
                            errorRows.push(courseName);
                        }
                    });

                    if (hasError) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Document Required',
                            html: 'Please upload a document for:<br><strong>' + errorRows.join('<br>') + '</strong>'
                        });
                        return;
                    }
                    $('#permissionForm').submit();
                });
            });

            // Success Messages from TempData
            @if (TempData["Success"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: '@TempData["Success"]',
                    timer: 3000,
                    showConfirmButton: false
                });
                </text>
            }
        </script>
    }
</body>
</html>