@model Medical_Affiliation.Models.CA_SS_FullViewVM

@{
    ViewData["Title"] = "Super Specialty Courses";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    body {
        font-family: 'DM Sans',sans-serif;
        background: var(--bg);
        color: var(--ink);
    }

    .page-wrapper {
        background: #fff;
        border: 1px solid #d4dae3;
        border-radius: 10px;
        box-shadow: 0 2px 16px rgba(15,25,35,.07);
        padding: 34px;
        margin-top: 100px;
    }

    .caution-box {
        background: #ffecec;
        border: 1px solid #dc3545;
        color: #b02a37;
        padding: 15px;
        border-radius: 8px;
        font-weight: 600;
        margin-bottom: 25px;
    }

    h4 {
        margin-top: 40px;
        font-weight: 600;
        color: #2c3e50;
    }

    table th {
        background: #0d6efd;
        color: white;
        text-align: center;
    }

    table td {
        vertical-align: middle;
        text-align: center;
    }

    /* new styles  */

    .nav-strip {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 0;
    }



    :root {
        --ink: #0f1923;
        --ink-mid: #2e3d4f;
        --ink-muted: #6b7a8d;
        --border: #d4dae3;
        --bg: #f4f6f9;
        --surface: #ffffff;
        --accent: #1a4c8b;
        --accent-lt: #e8edf7;
        --gold: #c9a84c;
        --radius: 10px;
        --shadow: 0 2px 16px rgba(15,25,35,.07);
    }

    body {
        font-family: 'DM Sans',sans-serif;
        background: var(--bg);
        color: var(--ink);
    }

    /* ========= Top Banner ========= */

    .page-header {
        background: linear-gradient(135deg,#0f1923 0%,#1a4c8b 100%);
        padding: 28px 40px 24px;
        display: flex;
        align-items: center;
        gap: 18px;
        border-bottom: 3px solid var(--gold);
    }

        .page-header .emblem {
            width: 54px;
            height: 54px;
            border: 2px solid var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

    .page-header-text h1 {
        font-family: 'Playfair Display',serif;
        font-size: 1.45rem;
        color: #fff;
        margin: 0;
    }

    .page-header-text p {
        color: rgba(255,255,255,.55);
        font-size: .78rem;
        margin-top: 4px;
        text-transform: uppercase;
    }

    /* ========= Page Width ========= */

    .form-wrap {
        max-width: 1400px;
        margin: 30px auto;
        padding: 20px 35px 60px;
    }

    /* ========= Cards ========= */

    .section-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
        margin-bottom: 28px;
    }

    .section-header {
        padding: 16px 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid var(--border);
        background: #fafbfc;
    }

        .section-header h2 {
            font-size: 1.02rem;
            font-weight: 600;
            margin: 0;
        }

    .icon-wrap {
        width: 38px;
        height: 38px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .section-body {
        padding: 1rem;
    }

    /* ========= Tables ========= */

    .scrollable-table-container {
        max-height: 420px;
        overflow-y: auto;
        border: 1px solid var(--border);
        border-radius: 8px;
    }

    .custom-table {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-table thead {
            position: sticky;
            top: 0;
            background: #f8f9fc;
            z-index: 10;
        }

        .custom-table th,
        .custom-table td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .custom-table th {
            font-size: .76rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            font-weight: 600;
            color: var(--ink-mid);
        }

        .custom-table tr:hover {
            background: #f8fbff;
        }

    /* ========= Inputs ========= */

    input[type=text],
    input[type=number],
    input[type=date],
    input[type=file],
    select,
    textarea,
    .form-control,
    .form-select {
        width: 100%;
        background: #fafbfc;
        border: 1px solid var(--border);
        border-radius: 7px;
        padding: 9px 13px;
        font-size: .875rem;
    }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: var(--accent);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,76,139,.10);
            outline: none;
        }

    /* ========= Buttons ========= */

    .btn {
        font-size: .85rem;
        font-weight: 600;
        border-radius: 8px;
        padding: 10px 26px;
        transition: .18s;
    }

    .btn-primary {
        background: linear-gradient(135deg,#1a4c8b,#1564c0);
        color: #fff;
        border: none;
        box-shadow: 0 3px 14px rgba(26,76,139,.30);
    }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 5px 20px rgba(26,76,139,.40);
        }

    .btn-secondary,
    .btn-ghost {
        background: #fff;
        border: 1px solid var(--border);
        color: var(--ink-muted);
    }

        .btn-secondary:hover,
        .btn-ghost:hover {
            border-color: var(--ink-mid);
            color: var(--ink);
        }

    /* ========= Badges ========= */

    .badge-intake {
        background: #e8edf7;
        color: var(--accent);
        padding: 6px 14px;
        border-radius: 999px;
        font-size: .82rem;
    }

    /* ========= Navigation strip ========= */

    .nav-strip {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 0;
    }

    /* ========= Scrollbar ========= */

    .scrollable-table-container::-webkit-scrollbar {
        width: 8px;
    }

    .scrollable-table-container::-webkit-scrollbar-thumb {
        background: #c1c9d4;
        border-radius: 4px;
    }
</style>

<div class="page-header">
    <div class="emblem">
        <i class="bi bi-mortarboard-fill" style="color:#c9a84c;"></i>
    </div>
    <div class="page-header-text">
        <h1>Super Specialty Courses</h1>
        <p>Affiliation & Recognition Portal</p>
    </div>
</div>

<div class="form-wrap">
    <div class="container mt-4 mb-5">

        <div class="page-wrapper">

            <h3 class="text-center mb-4">
                Super Specialty Courses Applied
            </h3>

            <!-- ================= CAUTION ================= -->
            <div class="caution-box">
                ⚠ @Model.CautionMessage
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @Html.ValidationSummary(false)
                </div>
            }


            <!-- ===================================================== -->
            <!-- ================= DM ================================ -->
            <!-- ===================================================== -->

            <h4>a. DM (Doctor of Medicine)</h4>

            <table class="table table-bordered table-striped">

                <thead>
                    <tr>
                        <th>Sl No</th>
                        <th>Course</th>
                        <th>Intake</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.DMCourses.Any())
                    {
                        int i = 1;

                        foreach (var row in Model.DMCourses)
                        {
                            <tr>
                                <td>@i</td>
                                <td class="text-start">@row.CourseName</td>
                                <td>@(row.PresentIntake ?? 0)</td>
                            </tr>

                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3">No DM Courses Found</td>
                        </tr>
                    }

                </tbody>
            </table>

            <!-- ===================================================== -->
            <!-- ================= M.CH ============================== -->
            <!-- ===================================================== -->

            <h4>b. M.Ch (Master of Chirurgiae)</h4>

            <table class="table table-bordered table-striped">

                <thead>
                    <tr>
                        <th>Sl No</th>
                        <th>Course</th>
                        <th>Intake</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.MChCourses.Any())
                    {
                        int j = 1;

                        foreach (var row in Model.MChCourses)
                        {
                            <tr>
                                <td>@j</td>
                                <td class="text-start">@row.CourseName</td>
                                <td>@(row.PresentIntake ?? 0)</td>
                            </tr>

                            j++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3">No M.Ch Courses Found</td>
                        </tr>
                    }

                </tbody>
            </table>


