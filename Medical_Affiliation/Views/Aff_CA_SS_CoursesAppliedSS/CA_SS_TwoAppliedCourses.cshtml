              var courseName=
                 $(this).find('td:first').text().trim();

              if(dateVal!=='' || fileVal!==''){
                 hasAnyData=true;
              }

              if(
                 dateVal!=='' &&
                 !hasExistingFile &&
                 fileVal===''
              ){
                 hasError=true;

                 errorRows.push(
