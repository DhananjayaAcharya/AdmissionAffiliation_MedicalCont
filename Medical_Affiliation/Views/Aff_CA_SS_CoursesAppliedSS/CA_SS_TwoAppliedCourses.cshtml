            @* 3.b.iv *@
            <form asp-action="SaveOtherCourse"
                  method="post"
                  enctype="multipart/form-data"
                  id="otherCourseForm">

                @Html.AntiForgeryToken()

                <h4>3.b.iv Other Courses</h4>

                <table class="table table-bordered">

                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Document</th>
                        </tr>
                    </thead>

                    <tbody>
                        @for (int i = 0; i < Model.OtherCourses.Count; i++)
                        {
                            <tr>

                                <td>




                                    <input asp-for="OtherCourses[i].Id" type="hidden" />



                                    <select asp-for="OtherCourses[i].CourseName"
                                            class="form-select">

                                        <option value="">--Select--</option>

                                        @foreach (var c in Model.OtherCourses[i].CourseList)
                                        {
                                            <option value="@c"
                                                    selected="@(c == Model.OtherCourses[i].CourseName)">
                                                @c
                                            </option>
                                        }

                                        @* IMPORTANT: If selected value not in list, show it *@
                                        @if (!string.IsNullOrEmpty(Model.OtherCourses[i].CourseName) &&
                                                                            !Model.OtherCourses[i].CourseList.Contains(Model.OtherCourses[i].CourseName))
                                        {
                                            <option value="@Model.OtherCourses[i].CourseName" selected>
                                                @Model.OtherCourses[i].CourseName
                                            </option>
                                        }

                                    </select>
                                </td>

                                <td>

                                    <input asp-for="OtherCourses[i].SupportingDoc"
                                           type="file"
                                           class="form-control" />

                                    @if (!string.IsNullOrEmpty(Model.OtherCourses[i].ExistingFileName))
                                    {
                                        <a asp-action="ViewOtherCourseFile"
                                           asp-route-id="@Model.OtherCourses[i].Id"
                                           class="btn btn-sm btn-outline-primary mt-1"
                                           target="_blank">
                                            📄 View Uploaded File
                                        </a>
                                    }

                                </td>


                            </tr>
                        }
                    </tbody>

                </table>

                @*             <div class="text-end">
                <button type="submit" class="btn btn-success">
                    Save Other Course Details
                </button>
            </div> *@

                @*  <button type="button"
                    class="btn btn-success"
                    id="btnSaveOtherCourse">
                Save Other Course Details
            </button> *@

                <div class="text-end mt-3">
                    <button type="button"
                            class="btn btn-success"
                            id="btnSaveOtherCourse">
                        Save Other Course Details
                    </button>
                </div>

            </form>

            <!-- Previous / Next buttons -->
            @{
                var rawLevels = Context.Session.GetString("ExistingCourseLevels");

                List<string> levels;

                if (string.IsNullOrWhiteSpace(rawLevels))
                {
                    levels = new List<string>();
                }
                else
                {
                    try
                    {
                        levels = System.Text.Json.JsonSerializer
                        .Deserialize<List<string>>(rawLevels)?
                        .Select(x => x.Trim().ToUpper())
                        .ToList()
                        ?? new List<string>();
                    }
                    catch
                    {
                        levels = rawLevels.Split(',')
                        .Select(x => x.Trim().ToUpper())
                        .ToList();
                    }
                }

                // ================= Previous Button =================
                string prevController;
                string prevAction;

                if (levels.Contains("UG"))
                {
                    prevController = "ContinuesAffiliation_Facultybased";
                    prevAction = "Details_Of_MBBS";
                }
                else
                {
                    prevController = "ContinuesAffiliation_Facultybased";
                    prevAction = "Aff_PrincipalDetails";
                }


                // ================= Next Button =================
                string nextController;
                string nextAction;

                if (levels.Contains("PG"))
                {
                    nextController = "AffiliationPgCourse";
                    nextAction = "PgCourses";
                }
                else
                {
                    nextController = "ContinuousAffiliationIncreaseintake";
                    nextAction = "IncreaseIntake";
                }
            }

            <!-- Previous / Next Buttons -->
            <div class="nav-strip">
                <a asp-controller="@prevController"
                   asp-action="@prevAction"
                   class="btn btn-secondary btn-lg shadow">
                    ← Previous
                </a>

                <a asp-controller="@nextController"
                   asp-action="@nextAction"
                   class="btn btn-primary btn-lg shadow">
                    Next →
                </a>
            </div>
        </div>
    </div>
</div>

<!-- end container -->
<!-- SweetAlert CDN (if not already in layout) -->
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire("Success","@TempData["Success"]","success");
        </script>
    }

    @if (TempData["Info"] != null)
    {
        <script>
            Swal.fire({
                icon:'info',
                title:'Nothing to Save',
                text:'@TempData["Info"]'
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
               icon:'error',
               title:'Validation Error',
               text:'@TempData["Error"]',
               confirmButtonColor:'#dc2626'
            });
        </script>
    }

    <script>
        $(document).ready(function(){

        /* =====================================================
           Permission dropdown show/hide
        ===================================================== */
        $(document).on('change','.permission-dd',function(){

           var row=$(this).closest('tr');

           if($(this).val()==='Yes'){
              row.find('.permission-file').show();
           }
           else{
              row.find('.permission-file').hide();
           }
        });

        $('.permission-dd').each(function(){

           var row=$(this).closest('tr');

           if($(this).val()==='Yes'){
              row.find('.permission-file').show();
           }
           else{
              row.find('.permission-file').hide();
           }
        });


        /* =====================================================
           LOP Save
        ===================================================== */
        $('#btnSaveLOP').click(function(){

           var hasAnyData=false;

           $('#lopForm tbody tr').each(function(){

              var lop=
               $(this).find('input[type=date]').eq(0).val();

              var recog=
               $(this).find('input[type=date]').eq(1).val();

              if(lop!=='' || recog!==''){
                 hasAnyData=true;
              }
           });

           if(!hasAnyData){
              Swal.fire({
                 icon:'info',
                 title:'Nothing to Save',
                 text:'No new data entered to save.'
              });
              return;
           }

           $('#lopForm').submit();

        });


        /* =====================================================
           Permission Save
        ===================================================== */
        $('#btnSavePermission').click(function(){

           var hasAnyData=false;
           var hasError=false;
           var errorRows=[];

           $('#permissionForm tbody tr').each(function(){

              var permVal=
                 $(this).find('.permission-dd').val();

              var fileVal=
                 $(this).find('.permission-file').val();

              var hasExistingFile=
                 $(this)
                 .find('a.btn-outline-primary')
                 .length>0;

              var courseName=
                 $(this).find('td:first').text().trim();

              if(permVal!=='' || fileVal!==''){
                 hasAnyData=true;
              }

              if(
                 permVal==='Yes'
                 && !hasExistingFile
                 && fileVal===''
              ){
                 hasError=true;
                 errorRows.push(courseName);
              }

           });

           if(!hasAnyData){
              Swal.fire({
                icon:'info',
                title:'Nothing to Save',
                text:'No new data entered to save.'
              });
              return;
           }

           if(hasError){
              Swal.fire({
                 icon:'error',
                 title:'Document Required',
                 html:
                   'Please upload document for:<br><strong>'
                   + errorRows.join('<br>')
                   + '</strong>'
              });
              return;
           }

           $('#permissionForm').submit();

        });


        /* =====================================================
           Affiliation Save
        ===================================================== */
        $('#btnSaveAffiliation').click(function(){

           var hasAnyData=false;
           var hasError=false;
           var errorRows=[];

           $('#affiliationForm tbody tr').each(function(){

              var dateVal=
                 $(this).find('.aff-date').val();

