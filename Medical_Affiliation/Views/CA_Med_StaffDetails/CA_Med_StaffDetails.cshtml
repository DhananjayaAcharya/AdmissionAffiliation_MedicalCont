@model Medical_Affiliation.Models.StaffDetailsCombinedViewModel
@{
    ViewData["Title"] = "Staff Details";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap');

    :root {
        --navy: #0f2545;
        --navy-mid: #1a3a6b;
        --light-blue: #2a6ab8; /* Lighter blue for Save buttons */
        --light-blue-hover: #1f5a9e;
        --cream: #f9f7f2;
        --white: #ffffff;
        --border: #ddd8cc;
        --text: #1a1a1a;
        --text-muted: #6b6358;
        --danger: #c0392b;
        --success: #1a6b3a;
        --radius: 6px;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background-color: var(--cream);
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
    }

    .page-shell {
        background-color: var(--cream);
        min-height: 100vh;
        /* padding: 36px 0 48px; */
    }

    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        /* padding: 0 24px; */
    }

    /* Header */
    .page-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        /* border-radius: 10px 10px 0 0; */
        padding: 28px 36px 24px;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: repeating-linear-gradient(-45deg, transparent, transparent 18px, rgba(255,255,255,0.015) 18px, rgba(255,255,255,0.015) 36px);
        }

        .page-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 36px;
            right: 36px;
            height: 2px;
            background: linear-gradient(90deg, transparent, #b8882a, transparent);
        }

    .header-eyebrow, .header-subtitle {
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #d4a84b;
        margin-bottom: 6px;
    }

    .header-title {
        font-family: 'EB Garamond', serif;
        font-size: 1.85rem;
        font-weight: 500;
        color: white;
        letter-spacing: 0.01em;
        line-height: 1.2;
    }

    .header-badge {
        position: absolute;
        top: 28px;
        right: 36px;
        background: rgba(184,136,42,0.15);
        border: 1px solid rgba(184,136,42,0.4);
        border-radius: 4px;
        padding: 5px 14px;
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        color: #d4a84b;
        text-transform: uppercase;
    }

    /* Form Card */
    .form-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-top: none;
        border-radius: 0 0 10px 10px;
        padding: 1rem 36px 36px;
        box-shadow: 0 4px 20px rgba(15,37,69,0.07);
    }

    .section-label {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 1rem 0 18px 0;
    }

    .section-label-text {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .section-label-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, var(--border), transparent);
    }

    .section-block {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        margin-bottom: 28px;
    }

    .section-block-header {
        background: linear-gradient(180deg, #f1ede4 0%, #ebe6db 100%);
        border-bottom: 2px solid var(--border);
        padding: 12px 16px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--navy);
    }

    .section-block-body {
        padding: 28px;
    }

    /* Improved spacing and dividers between items */
    .form-item {
        margin-bottom: 32px;
        padding-bottom: 24px;
        border-bottom: 1px solid var(--border);
    }

        .form-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
            margin-bottom: 0;
        }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.83rem;
    }

        .data-table thead th {
            padding: 10px 12px;
            background: linear-gradient(180deg, #f5f2ec 0%, #ede8df 100%);
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--navy);
            border-bottom: 2px solid var(--border);
        }

        .data-table td {
            padding: 12px;
            border-bottom: 1px solid #f0ece4;
        }

    .form-control, .form-select {
        width: 100%;
        border: 1px solid #d9d3c8;
        border-radius: 4px;
        padding: 8px 11px;
        font-size: 0.82rem;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--navy-mid);
            box-shadow: 0 0 0 3px rgba(26,58,107,0.1);
        }

    .file-upload-area {
        border: 1.5px dashed #d9d3c8;
        border-radius: 6px;
        padding: 14px;
        background: #faf8f4;
        margin: 8px 0 12px 0;
    }

    .view-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #1e7e4e;
        color: white;
        border: none;
        padding: 7px 16px;
        border-radius: 4px;
        font-size: 0.78rem;
        text-decoration: none;
        margin-top: 6px;
    }

        .view-btn:hover {
            background: #146c3a;
        }

    /* Updated Button Colors */
    .btn-save {
        background: linear-gradient(135deg, var(--light-blue), #2a6ab8);
        color: white;
        border: none;
        padding: 10px 28px;
        border-radius: 4px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-save:hover {
            background: linear-gradient(135deg, var(--light-blue-hover), #1f5a9e);
            transform: translateY(-1px);
        }

    .btn-prev {
        background: #f0f2f7;
        border: 1px solid var(--border);
        color: var(--text-muted);
        padding: 10px 24px;
        border-radius: 4px;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.2s;
    }

        .btn-prev:hover {
            background: #e6e9f0;
            color: var(--navy-mid);
            border-color: var(--navy-mid);
        }

    .navigation-buttons {
        display: flex;
        justify-content: space-between;
        margin-top: 40px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
    }

    .long-label {
        font-weight: 600;
        line-height: 1.45;
        margin-bottom: 10px;
    }

    .text-danger {
        font-size: 0.68rem;
        color: var(--danger);
        margin-top: 4px;
    }
</style>
<link rel="stylesheet" href="~/css/common-form.css" />
<div class="page-shell">
    <div class="page-container">

        @* <div class="page-header">
            <div class="header-eyebrow">Continuous Affiliation · Staff Particulars</div>
            <div class="header-title">Staff Details</div>
            <div class="header-subtitle">Pay Scale and Other Staff Particulars</div>
            <div class="header-badge">Staff Particulars</div>
        </div> *@

        <div class="page-header">
            <div class="emblem">
                <i class="fas fa-book-medical"></i>
            </div>
            <div class="page-header-text">
                <h1>Staff Particulars</h1>
                <p>Pay Scale and Other Staff Particulars</p>
            </div>
        </div>

        <div class="form-card">

            <!-- Pay Scale Section -->
            <div class="section-label">
                <span class="section-label-text">1 — Staff Pay Scale</span>
                <span class="section-label-line"></span>
            </div>
            <div class="section-block">
                <div class="section-block-header">Pay Scale Details</div>
                <div class="section-block-body">
                    <form asp-action="SavePayScale" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="CourseLevel" />

                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Designation</th>
                                    <th>Pay Scale (₹)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.StaffPayScaleList.Count; i++)
                                {
                                    <tr>
                                        <td>@Model.StaffPayScaleList[i].Designation</td>
                                        <td>
                                            <input asp-for="StaffPayScaleList[@i].PayScale" type="number" min="0" step="0.01" class="form-control" />
                                            <span asp-validation-for="StaffPayScaleList[@i].PayScale" class="text-danger"></span>
                                        </td>
                                        <input type="hidden" asp-for="StaffPayScaleList[@i].DesignationSlNo" />
                                        <input type="hidden" asp-for="StaffPayScaleList[@i].Designation" />
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="text-end mt-4">
                            <button type="submit" class="btn-save">Save Staff Pay Scale</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Staff Particulars (Other) -->
            <div class="section-label">
                <span class="section-label-text">2 — Staff Particulars (Other)</span>
                <span class="section-label-line"></span>
            </div>
            <div class="section-block">
                <div class="section-block-body">

                    <form asp-action="SaveStaffOther" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <!-- b -->
                        <!-- b -->
                        <div class="form-item">

                            <label class="long-label">
                                b. Whether all teachers working in the college are updated in the online teacher's database and EMS - Examiners List
                            </label>

                            <select asp-for="StaffOther.TeachersUpdatedInEMS"
                                    class="form-select"
                                    id="TeachersUpdatedDropdown">

                                <option value="">-- Select --</option>

                                <option value="Y"
                                        selected="@(Model.StaffOther.TeachersUpdatedInEMS == "Y")">
                                    Yes
                                </option>

                                <option value="N"
                                        selected="@(Model.StaffOther.TeachersUpdatedInEMS == "N")">
                                    No
                                </option>

                            </select>

                            <span asp-validation-for="StaffOther.TeachersUpdatedInEMS"
                                  class="text-danger"></span>


                            <!-- Changes by Ram on 23/04/2026 -->
                            <!-- show file exactly like c -->

                            <div id="TeachersUpdatedFileDiv"
                                 style="display:@(
                                 Model.StaffOther.TeachersUpdatedInEMS == "Y"
                                 ? "block"
                                 : "none"
                                          );
         margin-top:16px;">

                                <div class="file-upload-area">
                                    <input asp-for="ExaminerDetailsPdf"
                                           type="file"
                                           class="file-validate"
                                           accept="application/pdf" />
                                </div>

                                <span asp-validation-for="ExaminerDetailsPdf"
                                      class="text-danger"></span>

                                @if (!string.IsNullOrEmpty(
                                                                Model.StaffOther.ExaminerDetailsPdfName))
                                {
                                    <a href="@Url.Action(
                                                       "ViewStaffOtherPdf",
                                                       "CA_Med_StaffDetails",
                                                       new { type = "Examiner" })"
                                   target="_blank"
                                   class="view-btn">

                                        <i class="fas fa-eye"></i>
                                        View EMS / Examiner Document

                                    </a>
                                                                }

                            </div>

                        </div>

                        <!-- c -->
                        <div class="form-item">
                            <label class="long-label">
                                c. Department wise Examiner's details ... (Enclose form-16 of all the teachers)
                            </label>
                            <label><b>Is the Document Attached?</b></label>
                            <select asp-for="StaffOther.ExaminerDetailsAttached" class="form-select" id="ExaminerDetailsAttachedDropdown">
                                <option value="">-- Select --</option>
                                <option value="Y" selected="@(Model.StaffOther.ExaminerDetailsAttached == "Y")">Yes</option>
                                <option value="N" selected="@(Model.StaffOther.ExaminerDetailsAttached == "N")">No</option>
                            </select>
                            <span asp-validation-for="StaffOther.ExaminerDetailsAttached" class="text-danger"></span>

                            <div id="ExaminerFileDiv" style="display: @(Model.StaffOther.ExaminerDetailsAttached == "Y" ? "block" : "none"); margin-top: 16px;">
                                <div class="file-upload-area">
                                    <input asp-for="ExaminerDetailsPdf" type="file" class="file-validate" accept="application/pdf" />
                                </div>
                                <span asp-validation-for="ExaminerDetailsPdf" class="text-danger"></span>

                                @if (!string.IsNullOrEmpty(Model.StaffOther.ExaminerDetailsPdfName))
                                {
                                    <a href="@Url.Action("ViewStaffOtherPdf", "CA_Med_StaffDetails", new { type = "Examiner" })"
                                       target="_blank" class="view-btn">
                                        <i class="fas fa-eye"></i> View Examiner Details Document
                                    </a>
                                }
                            </div>
                        </div>

                        <!-- d -->
                        <div class="form-item">
                            <label class="long-label">
                                d. AEBAS details of all the staff
                                (Enclose last three months attendance report)
                                <span style="color:red;">*</span>
                            </label>

                            <small style="
                                        display:block;
                                        margin-bottom:10px;
                                        color:red;
                                        font-size:0.72rem;
                                        font-weight:600;">
                                Document should be compulsorily uploaded.
                            </small>
                            <div class="file-upload-area">
                                <input asp-for="AEBASLastThreeMonthsPdf" type="file" class="file-validate" accept="application/pdf" />
                            </div>
                            <span asp-validation-for="AEBASLastThreeMonthsPdf" class="text-danger"></span>
                            @if (!string.IsNullOrEmpty(Model.StaffOther.AEBASLastThreeMonthsPdfName))
                            {
                                <a href="@Url.Action("ViewStaffOtherPdf", "CA_Med_StaffDetails", new { type = "AEBAS3Months" })"
                                   target="_blank" class="view-btn">
                                    <i class="fas fa-eye"></i> View AEBAS Last Three Months Document
                                </a>
                            }
                        </div>

                        <!-- e -->
                        <div class="form-item">
                            <label class="long-label">
                                e. AEBAS details of all the staff on the day of inspection
                                (Enclose copy)
                                <span style="color:red;">*</span>
                            </label>

                            <small style="
                                            display:block;
                                            margin-bottom:10px;
                                            color:red;
                                            font-size:0.72rem;
                                            font-weight:600;">
                                Document should be compulsorily uploaded.
                            </small>
                            <div class="file-upload-area">
                                <input asp-for="AEBASInspectionDayPdf" type="file" class="file-validate" accept="application/pdf" />
                            </div>
                            <span asp-validation-for="AEBASInspectionDayPdf" class="text-danger"></span>
                            @if (!string.IsNullOrEmpty(Model.StaffOther.AEBASInspectionDayPdfName))
                            {
                                <a href="@Url.Action("ViewStaffOtherPdf", "CA_Med_StaffDetails", new { type = "AEBASInspection" })"
                                   target="_blank" class="view-btn">
                                    <i class="fas fa-eye"></i> View AEBAS Inspection Document
                                </a>
                            }
                        </div>

                        <!-- f -->
                        <div class="form-item">
                            <label class="long-label">f. Whether following registers are maintained</label>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                                <div>
                                    <label>i. Service Register</label>
                                    <select asp-for="StaffOther.ServiceRegisterMaintained" class="form-select">
                                        <option value="">-- Select --</option>
                                        <option value="Y" selected="@(Model.StaffOther.ServiceRegisterMaintained == "Y")">Yes</option>
                                        <option value="N" selected="@(Model.StaffOther.ServiceRegisterMaintained == "N")">No</option>
                                    </select>
                                </div>
                                <div>
                                    <label>ii. Acquittance registers</label>
                                    <select asp-for="StaffOther.AcquittanceRegisterMaintained" class="form-select">
                                        <option value="">-- Select --</option>
                                        <option value="Y" selected="@(Model.StaffOther.AcquittanceRegisterMaintained == "Y")">Yes</option>
                                        <option value="N" selected="@(Model.StaffOther.AcquittanceRegisterMaintained == "N")">No</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- g -->
                        <div class="form-item">
                            <label class="long-label">
                                g. Provident fund benefit provided (Give details)
                                <span style="color:red;">*</span>
                            </label>

                            <small style="
                                            display:block;
                                            margin-bottom:10px;
                                            color:red;
                                            font-size:0.72rem;
                                            font-weight:600;">
                                Document should be compulsorily uploaded.
                            </small>
                            <div class="file-upload-area">
                                <input asp-for="ProvidentFundPdf" type="file"  class="file-validate" accept="application/pdf" />
                            </div>
                            <span asp-validation-for="ProvidentFundPdf" class="text-danger"></span>
                            @if (!string.IsNullOrEmpty(Model.StaffOther.ProvidentFundPdfName))
                            {
                                <a href="@Url.Action("ViewStaffOtherPdf", "CA_Med_StaffDetails", new { type = "PF" })"
                                   target="_blank" class="view-btn">
                                    <i class="fas fa-eye"></i> View Provident Fund Document
                                </a>
                            }
                        </div>

                        <!-- h -->
                       @*  <div class="form-item">
                            <label class="long-label">h. Whether ESI benefits are provided (Give Details)</label>
                            <div class="file-upload-area">
                                <input asp-for="ESIPdf" type="file" class="file-validate" accept="application/pdf" />
                            </div>
                            <span asp-validation-for="ESIPdf" class="text-danger"></span>
                            @if (!string.IsNullOrEmpty(Model.StaffOther.ESIPdfName))
                            {
                                <a href="@Url.Action("ViewStaffOtherPdf", "CA_Med_StaffDetails", new { type = "ESI" })"
                                   target="_blank" class="view-btn">
                                    <i class="fas fa-eye"></i> View ESI Document
                                </a>
                            }
                        </div> *@

                        <!-- ===================================================== -->
                        <!-- Changes by Ram on 23/04/2026 -->
                        <!-- Separate UG Specific Section -->
                        <!-- ===================================================== -->

                        <div class="section-block">
                            <div class="section-block-header"
                                 style="background:linear-gradient(180deg,#dbeafe 0%,#bfdbfe 100%);
                                 color:#0f2545;">
                                For UG - ESI
                            </div>

                            <div class="section-block-body">

                                @if (Model.ExistingCourseLevels.Contains("UG"))
                                {
                                    if (Model.CourseLevel == "UG" ||
                                    string.IsNullOrEmpty(Model.CourseLevel))
                                    {
                                        <!-- UG editable block -->
                                        <div class="form-item">
                                            <label class="long-label">
                                                h. Whether ESI benefits are provided (Give Details)
                                            </label>

                                            <div class="file-upload-area">
                                                <input asp-for="ESIPdf"
                                                       type="file"
                                                       class="file-validate"
                                                       accept="application/pdf" />
                                            </div>

                                            <span asp-validation-for="ESIPdf"
                                                  class="text-danger"></span>

                                            @if (!string.IsNullOrEmpty(Model.StaffOther.ESIPdfName))
                                            {
                                                <a href="@Url.Action(
                                                                                 "ViewStaffOtherPdf",
                                                                                 "CA_Med_StaffDetails",
                                                                                 new { type = "ESI" })"
                                       target="_blank"
                                       class="view-btn">

                                                    <i class="fas fa-eye"></i>
                                                    View ESI Document
                                                </a>
                                                                        }
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- PG / SS show no -->
                                        <div class="form-item">
                                            <label class="long-label">
                                                h. Whether ESI benefits are provided
                                            </label>

                                            <select class="form-select" disabled>
                                                <option selected>No</option>
                                            </select>

                                            <small style="display:block;
                                          margin-top:10px;
                                          color:#6b6358;">
                                                Not applicable for this course level.
                                            </small>
                                        </div>
                                    }
                                }

                            </div>
                        </div>

                        <div class="text-end mt-4">
                            <button type="submit" class="btn-save">Save Staff Particulars (Other)</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Navigation -->
            <div class="navigation-buttons">
                <a asp-controller="Aff_CA_Med_FinanceDetails"
                   asp-action="Med_CA_AccountAndFeeDetails"
                   class="btn-prev">← Previous</a>
                <a asp-controller="CA_Med_ResearchPublications"
                   asp-action="CA_Med_ResearchPublicationsDetails"
                   class="btn-save">Next →</a>
            </div>

           

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
                    // Changes by Ram on 23/04/2026

        // c block
        const ddlC = document.getElementById("ExaminerDetailsAttachedDropdown");
        const fileDivC = document.getElementById("ExaminerFileDiv");

        // b block
        const ddlB = document.getElementById("TeachersUpdatedDropdown");
        const fileDivB = document.getElementById("TeachersUpdatedFileDiv");


        function toggleExaminerDiv() {
            if (ddlC && fileDivC) {
                fileDivC.style.display =
                    ddlC.value === "Y"
                    ? "block"
                    : "none";
            }
        }

        function toggleTeachersDiv() {
            if (ddlB && fileDivB) {
                fileDivB.style.display =
                    ddlB.value === "Y"
                    ? "block"
                    : "none";
            }
        }


        if (ddlC) {
            ddlC.addEventListener(
                "change",
                toggleExaminerDiv
            );

            toggleExaminerDiv();
        }

        if (ddlB) {
            ddlB.addEventListener(
                "change",
                toggleTeachersDiv
            );

            toggleTeachersDiv();
        }

            @if (TempData["Success"] != null)
            {
                        <text>
                        Swal.fire({
                            icon: 'success',
                            title: 'Saved Successfully!',
                            text: '@TempData["Success"]',
                            confirmButtonColor: '#28a745',
                            timer: 4000,
                            timerProgressBar: true
                        });
                        </text>
            }

            document.addEventListener("change", function (e) {

                if (e.target.classList.contains("file-validate")) {

                    const file = e.target.files[0];
                    const maxSize = 2 * 1024 * 1024; // ✅ 2MB

                    if (file) {

                        // ❌ SIZE CHECK
                        if (file.size > maxSize) {
                            Swal.fire({
                                icon: "error",
                                title: "File too large",
                                text: "Maximum allowed size is 2MB"
                            });

                            e.target.value = "";
                            return;
                        }

                        // ❌ TYPE CHECK
                        const ext = file.name.split('.').pop().toLowerCase();
                        if (ext !== "pdf") {
                            Swal.fire({
                                icon: "error",
                                title: "Invalid file",
                                text: "Only PDF files are allowed"
                            });

                            e.target.value = "";
                            return;
                        }
                    }
                }

            });
        });
    </script>
}