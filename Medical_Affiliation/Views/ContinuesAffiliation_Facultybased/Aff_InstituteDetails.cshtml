    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
        <script>
            $(document).ready(function () {

                function loadTaluks(selectedTaluk = "") {

                    var district = $("#districtDropdown").val();

                    if (district !== "") {

                        $.get('@Url.Action("GetTaluksByDistrictt", "ContinuesAffiliation_Facultybased")',
                            { district: district },
                            function (data) {

                                $("#talukDropdown").empty();
                                $("#talukDropdown").append('<option value="">— Select Taluk —</option>');

                                $.each(data, function (i, item) {

                                    var selected = item.text === selectedTaluk ? "selected" : "";

                                    $("#talukDropdown").append(
                                        '<option value="' + item.text + '" ' + selected + '>' + item.text + '</option>'
                                    );
                                });
                            });
                    }
                }

                $("#districtDropdown").change(function () {
                    loadTaluks();
                });

                // ✅ IMPORTANT: Auto load on edit
                var existingTaluk = '@Model.Taluk';
                if ($("#districtDropdown").val()) {
                    loadTaluks(existingTaluk);
                }

            });
        </script>
        <script>
            //below new code added by ram on 16/04/2026 for file size validation

            document.querySelectorAll('input[type="file"]').forEach(function (input) {

                input.addEventListener("change", function () {

                    if (this.files.length > 0) {

                        const file = this.files[0];
                        const maxSize = 2 * 1024 * 1024; // 2 MB

                        if (file.size > maxSize) {

                            Swal.fire({
                                icon: 'warning',
                                title: 'File too large',
                                text: 'File size should not exceed 2 MB.',
                                timer: 7000,
                                timerProgressBar: true,
                                showConfirmButton: true,
                                confirmButtonText: 'OK'
                            });

                            this.value = ""; // clear file
                            return;
                        }
                    }
                });

            });

            //new code of ram ends here
        </script>
    }
