@model HostelFacilityListVm

@{
    ViewData["Title"] = "Hostel Facilities";
}

<style>
    :root {
        --primary: #0d6efd;
        --border-color: #dee2e6;
        --text-main: #212529;
        --text-muted: #6c757d;
        --radius-md: 0.375rem;
    }

    body {
        background-color: #f8f9fa;
    }

    .institution-form-shell {
        min-height: 100vh;
        padding: 24px 0 32px;
    }

    .institution-form-card {
        background: #fff;
        border-radius: 0.75rem;
        border: 1px solid #e5e5e5;
        box-shadow: 0 2px 6px rgba(0,0,0,.04);
    }

    .institution-form-card-inner {
        padding: 24px;
    }

    .form-header-modern {
        display: flex;
        gap: 12px;
        align-items: center;
        border-bottom: 1px solid #e5e5e5;
        padding-bottom: 12px;
        margin-bottom: 20px;
    }

    .form-header-icon {
        width: 40px;
        height: 40px;
        background: var(--primary);
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .facilities-table-container {
        border: 1px solid #e5e5e5;
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        background: #f1f3f5;
        padding: 12px;
        font-size: .82rem;
        text-transform: uppercase;
        text-align: center;
    }

        thead th:first-child {
            text-align: left;
            width: 70%;
        }

    tbody td {
        padding: 12px;
        border-top: 1px solid #f1f3f5;
        vertical-align: middle;
    }

    .modern-switch {
        position: relative;
        width: 52px;
        height: 28px;
    }

        .modern-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .switch-slider {
        position: absolute;
        inset: 0;
        background: #adb5bd;
        border-radius: 30px;
        transition: .3s;
    }

        .switch-slider::before {
            content: "";
            position: absolute;
            width: 22px;
            height: 22px;
            left: 3px;
            bottom: 3px;
            background: #fff;
            border-radius: 50%;
            transition: .3s;
        }

    input:checked + .switch-slider {
        background: var(--primary);
    }

        input:checked + .switch-slider::before {
            transform: translateX(22px);
        }

    .switch-label {
        margin-left: 10px;
        font-weight: 500;
    }

    .form-actions {
        display: flex;
        justify-content: space-between;
        margin-top: 24px;
        padding-top: 16px;
        border-top: 1px solid #e5e5e5;
    }
</style>

<div class="institution-form-shell">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">

                <div class="institution-form-card">
                    <div class="institution-form-card-inner">

                        <div class="form-header-modern">
                            <div class="form-header-icon">
                                <i class="fas fa-building"></i>
                            </div>
                            <div>
                                <h4 class="mb-0">Hostel Facilities</h4>
                                <small class="text-muted">College Code: @Model.CollegeCode</small>
                            </div>
                        </div>

                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success">@TempData["Success"]</div>
                        }
                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger">@TempData["Error"]</div>
                        }

                        <form method="post"
                              asp-action="AFF_HostelDetailswithfacilities"
                              asp-controller="ContinuesAffiliation_Facultybased">

                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(m => m.FacultyCode)
                            @Html.HiddenFor(m => m.CollegeCode)

                            <div class="facilities-table-container">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Facility</th>
                                            <th>Available</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.Rows.Count; i++)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@Model.Rows[i].HostelFacilityName</strong>
                                                    <div class="text-muted small">
                                                        ID: @Model.Rows[i].HostelFacilityId
                                                    </div>
                                                </td>
                                                <td class="text-center">

                                                    @Html.HiddenFor(m => m.Rows[i].HostelFacilityId)
                                                    @Html.HiddenFor(m => m.Rows[i].HostelFacilityName)
                                                    @Html.HiddenFor(m => m.Rows[i].FacultyCode)
                                                    @Html.HiddenFor(m => m.Rows[i].CollegeCode)
                                                    @Html.HiddenFor(m => m.Rows[i].AffId)

                                                    <label class="d-inline-flex align-items-center">
                                                        <div class="modern-switch">
                                                            <!-- false when unchecked -->
                                                            <input type="hidden"
                                                                   name="Rows[@i].IsAvailable"
                                                                   value="false" />

                                                            <!-- true when checked -->
                                                            <input type="checkbox"
                                                                   name="Rows[@i].IsAvailable"
                                                                   value="true"
                                                                   @(Model.Rows[i].IsAvailable ? "checked" : "") />

                                                            <span class="switch-slider"></span>
                                                        </div>

                                                        <span class="switch-label">
                                                            @(Model.Rows[i].IsAvailable ? "Yes" : "No")
                                                        </span>
                                                    </label>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="form-actions">
                                <a asp-action="Aff_HostelDetails"
                                   asp-controller="ContinuesAffiliation_Facultybased"
                                   class="btn btn-secondary">
                                    ⬅ Previous
                                </a>

                                <button type="submit" class="btn btn-primary">
                                    Save &amp; Proceed ➡
                                </button>
                            </div>

                        </form>

                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.modern-switch input[type="checkbox"]').forEach(cb => {
            const label = cb.closest('label').querySelector('.switch-label');
            const update = () => label.textContent = cb.checked ? 'Yes' : 'No';
            cb.addEventListener('change', update);
            update();
        });
    </script>
}
