@model Medical_Affiliation.Models.MedicalUGBedDistributionVm
@{
    ViewData["Title"] = "Bed Distribution – MBBS";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bed Distribution – MBBS</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        :root {
            --ink: #0f1923;
            --ink-mid: #2e3d4f;
            --ink-muted: #6b7a8d;
            --border: #d4dae3;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --accent: #1a4c8b;
            --accent-lt: #e8edf7;
            --gold: #c9a84c;
            --radius: 10px;
            --shadow: 0 2px 16px rgba(15,25,35,.07);
        }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--ink);
            min-height: 100vh;
        }

        /* TOP HEADER - Same as PG Affiliation */
        .page-header {
            background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
            padding: 28px 40px 24px;
            display: flex;
            align-items: center;
            gap: 18px;
            border-bottom: 3px solid var(--gold);
        }
        .page-header .emblem {
            width: 54px;
            height: 54px;
            border: 2px solid var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .page-header .emblem svg {
            width: 28px;
            height: 28px;
            fill: var(--gold);
        }
        .page-header-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem;
            color: #ffffff;
            letter-spacing: .02em;
        }
        .page-header-text p {
            font-size: .78rem;
            color: rgba(255,255,255,.55);
            margin-top: 3px;
            letter-spacing: .06em;
            text-transform: uppercase;
        }

        .form-wrap {
            max-width: 1280px;
            margin: 32px auto;
            padding: 0 24px 60px;
        }
        .section-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            margin-bottom: 28px;
            animation: fadeUp .35s ease both;
        }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .section-header {
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--border);
            background: #fafbfc;
        }
        .section-header .icon-wrap {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #e8edf7;
        }
        .section-header h2 {
            font-size: 1.05rem;
            font-weight: 600;
            letter-spacing: .03em;
            color: var(--ink);
            margin: 0;
        }

        /* Bed Distribution Specific Styles */
        .bed-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: .4rem;
            border-bottom: 1px solid var(--border);
        }
        .bed-item:hover {
            background: #f8fbff;
        }
        .bed-label {
            font-size: 0.96rem;
            font-weight: 500;
            color: var(--ink-mid);
            flex: 1;
        }
        .bed-input-group {
            width: 130px;
            flex-shrink: 0;
        }
        .bed-input {
            width: 100%;
            font-size: 1.02rem;
            font-weight: 600;
            text-align: center;
            padding: 8px 14px;
            border: 1px solid var(--border);
            border-radius: 8px;
            background: #fafbfc;
            transition: all 0.2s;
        }
        .bed-input:focus {
            border-color: var(--accent);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,76,139,.1);
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #f8f9fc;
            padding: .7rem 1rem;
            border-top: 2px solid var(--border);
            font-weight: 500;
        }
        .total-label {
            font-size: 1.02rem;
            color: var(--ink);
        }
        .total-value {
            font-size: 1rem;
            font-weight: 600;
            color: var(--accent);
            min-width: 120px;
            text-align: center;
        }

        .grand-total-box {
            background: linear-gradient(135deg, #ecfdf5, #d1fae5);
            border: 2px solid #6ee7b7;
            border-radius: var(--radius);
            padding: .4rem .6rem;
            margin: 1rem 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .grand-total-box .total-label {
            font-size: 1rem;
            font-weight: 600;
            color: #065f46;
        }
        .grand-total-box .total-value {
            font-size: 1rem;
            font-weight: 800;
            color: #10b981;
            background: white;
            padding: .6rem .8rem;
            border-radius: 10px;
            box-shadow: 0 3px 12px rgba(16,185,129,.15);
        }

        .btn {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem;
            font-weight: 600;
            border-radius: 8px;
            padding: 12px 32px;
            letter-spacing: .03em;
            transition: all .18s;
        }
        .btn-primary {
            background: linear-gradient(135deg, #1a4c8b, #1564c0);
            color: #fff;
            box-shadow: 0 3px 14px rgba(26,76,139,.3);
        }
        .btn-primary:hover {
            box-shadow: 0 5px 20px rgba(26,76,139,.4);
            transform: translateY(-1px);
        }

        .btn-prev {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-muted);
            font-size: 0.82rem;
            font-weight: 500;
            padding: 8px 20px;
            border-radius: 4px;
            cursor: pointer;
            transition: background 0.15s, color 0.15s, border-color 0.15s;
            font-family: 'DM Sans', sans-serif;
        }

        .btn-next {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
            color: var(--white);
            font-size: 0.82rem;
            font-weight: 600;
            padding: 9px 26px;
            border-radius: 4px;
            text-decoration: none;
            transition: opacity 0.15s, box-shadow 0.15s;
        }
    </style>

    <link rel="stylesheet" href="~/css/common-form.css" />

</head>
<body>
    <!-- PAGE HEADER -->
    <div class="page-header">
        <div class="emblem">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
        </div>
        <div class="page-header-text">
            <h1>Bed Distribution – MBBS</h1>
            <p>Clinical Infrastructure & Facilities</p>
        </div>
    </div>

    <div class="form-wrap">
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:20px; font-size:0.85rem;"></div>

        <div class="section-card">
            <div class="section-header">
                <div class="icon-wrap">
                    <i class="bi bi-hospital-fill" style="font-size:1.55rem; color:#1a4c8b;"></i>
                </div>
                <h2>Beds Distribution for MBBS and Respective PG Courses</h2>
            </div>

            <div class="p-4">
                <form asp-action="MedicalUGBedDistribution" method="post" id="bedForm">
                    @Html.AntiForgeryToken()

                    <!-- A. Medicine & Allied -->
                    <div class="section" style="margin-bottom: 2.5rem;">
                        <h5 class="section-title" style="font-size:1.05rem; font-weight:600; color:var(--accent); margin-bottom:1.1rem; border-left:5px solid #1a4c8b; padding-left:14px;">
                            A. Medicine & Allied
                        </h5>
                        <div class="bed-item">
                            <div class="bed-label">General Medicine</div>
                            <div class="bed-input-group">
                                <input asp-for="GenMedicine" class="bed-input medicine" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">Paediatrics</div>
                            <div class="bed-input-group">
                                <input asp-for="Paediatrics" class="bed-input medicine" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">Skin & V.D.</div>
                            <div class="bed-input-group">
                                <input asp-for="SkinVD" class="bed-input medicine" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">Psychiatry</div>
                            <div class="bed-input-group">
                                <input asp-for="Psychiatry" class="bed-input medicine" type="number" min="0" />
                            </div>
                        </div>
                        <div class="total-row">
                            <div class="total-label">Total Medicine & Allied</div>
                            <div class="total-value" id="totalMedicine">0</div>
                        </div>
                    </div>

                    <!-- B. Surgery & Allied -->
                    <div class="section" style="margin-bottom: 2.5rem;">
                        <h5 class="section-title" style="font-size:1.05rem; font-weight:600; color:var(--accent); margin-bottom:1.1rem; border-left:5px solid #1a4c8b; padding-left:14px;">
                            B. Surgery & Allied
                        </h5>
                        <div class="bed-item">
                            <div class="bed-label">General Surgery</div>
                            <div class="bed-input-group">
                                <input asp-for="GenSurgery" class="bed-input surgery" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">Orthopaedics</div>
                            <div class="bed-input-group">
                                <input asp-for="Orthopaedics" class="bed-input surgery" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">Ophthalmology</div>
                            <div class="bed-input-group">
                                <input asp-for="Ophthalmology" class="bed-input surgery" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">ENT</div>
                            <div class="bed-input-group">
                                <input asp-for="ENT" class="bed-input surgery" type="number" min="0" />
                            </div>
                        </div>
                        <div class="total-row">
                            <div class="total-label">Total Surgery & Allied</div>
                            <div class="total-value" id="totalSurgery">0</div>
                        </div>
                    </div>

                    <!-- C. OBG -->
                    <div class="section" style="margin-bottom: 2.5rem;">
                        <h5 class="section-title" style="font-size:1.05rem; font-weight:600; color:var(--accent); margin-bottom:1.1rem; border-left:5px solid #1a4c8b; padding-left:14px;">
                            C. Obstetrics & Gynaecology
                        </h5>
                        <div class="bed-item">
                            <div class="bed-label">Obstetrics & ANC</div>
                            <div class="bed-input-group">
                                <input asp-for="ObstetricsANC" class="bed-input obg" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">Gynaecology</div>
                            <div class="bed-input-group">
                                <input asp-for="Gynaecology" class="bed-input obg" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">Postpartum</div>
                            <div class="bed-input-group">
                                <input asp-for="Postpartum" class="bed-input obg" type="number" min="0" />
                            </div>
                        </div>
                        <div class="total-row">
                            <div class="total-label">Total OBG</div>
                            <div class="total-value" id="totalOBG">0</div>
                        </div>
                    </div>

                    <!-- Grand Total -->
                    <div class="grand-total-box">
                        <div class="total-label">GRAND TOTAL BEDS (Clinical)</div>
                        <div class="total-value" id="grandTotal">0</div>
                    </div>

                    <!-- II. OT -->
                    <div class="section" style="margin-bottom: 2.2rem;">
                        <h5 class="section-title" style="font-size:1.05rem; font-weight:600; color:var(--accent); margin-bottom:1.1rem; border-left:5px solid #1a4c8b; padding-left:14px;">
                            II. Operation Theatres
                        </h5>
                        <div class="bed-item">
                            <div class="bed-label">Major OT</div>
                            <div class="bed-input-group">
                                <input asp-for="MajorOT" class="bed-input other" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">Minor OT</div>
                            <div class="bed-input-group">
                                <input asp-for="MinorOT" class="bed-input other" type="number" min="0" />
                            </div>
                        </div>
                    </div>

                    <!-- III. Intensive Care -->
                    <div class="section" style="margin-bottom: 2.2rem;">
                        <h5 class="section-title" style="font-size:1.05rem; font-weight:600; color:var(--accent); margin-bottom:1.1rem; border-left:5px solid #1a4c8b; padding-left:14px;">
                            III. Intensive Care Facilities
                        </h5>
                        <div class="bed-item">
                            <div class="bed-label">ICCU</div>
                            <div class="bed-input-group">
                                <input asp-for="ICCU" class="bed-input icu" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">ICU</div>
                            <div class="bed-input-group">
                                <input asp-for="ICU" class="bed-input icu" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">PICU / NICU</div>
                            <div class="bed-input-group">
                                <input asp-for="PICU_NICU" class="bed-input icu" type="number" min="0" />
                            </div>
                        </div>
                        <div class="bed-item">
                            <div class="bed-label">SICU</div>
                            <div class="bed-input-group">
                                <input asp-for="SICU" class="bed-input icu" type="number" min="0" />
                            </div>
                        </div>
                        <div class="total-row">
                            <div class="total-label">Total ICU Beds</div>
                            <div class="total-value" id="totalICUBedsDisplay">0</div>
                            <input asp-for="TotalICUBeds" type="hidden" id="totalICUBeds" />
                        </div>
                    </div>

                    <!-- Casualty -->
                    <div class="section">
                        <h5 class="section-title" style="font-size:1.05rem; font-weight:600; color:var(--accent); margin-bottom:1.1rem; border-left:5px solid #1a4c8b; padding-left:14px;">
                            Casualty
                        </h5>
                        <div class="bed-item">
                            <div class="bed-label">Casualty Beds</div>
                            <div class="bed-input-group">
                                <input asp-for="CasualtyBeds" class="bed-input other" type="number" min="0" />
                            </div>
                        </div>
                    </div>

                    @* <div style="padding:30px 24px 20px; border-top:1px solid var(--border); text-align:center; margin-top:20px;">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-2"></i> Save Distribution
                        </button>
                    </div> *@

                    <div class="form-footer">

                        <!-- 🔹 PREVIOUS -->
                        <a asp-controller="Aff_AHS_ContinousApplication"
                           asp-action="CA_VehicleDetails"
                           class="btn-prev">← Previous</a>

                        @* <div class="footer-right"> *@

                            <!-- SAVE BUTTON -->
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-floppy me-2"></i> Save Distribution
                            </button>

                            <!-- 🔹 NEXT -->
                            <a asp-controller="CA_Aff_AcademicMatters"
                               asp-action="AcademicMatters"
                               class="btn-next">Next →</a>

                        @* </div> *@

                    </div>
                </form>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const calculate = () => {
                    let med = 0;
                    document.querySelectorAll('.medicine').forEach(el => med += Number(el.value) || 0);
                    document.getElementById('totalMedicine').textContent = med;

                    let surg = 0;
                    document.querySelectorAll('.surgery').forEach(el => surg += Number(el.value) || 0);
                    document.getElementById('totalSurgery').textContent = surg;

                    let obg = 0;
                    document.querySelectorAll('.obg').forEach(el => obg += Number(el.value) || 0);
                    document.getElementById('totalOBG').textContent = obg;

                    let icu = 0;
                    document.querySelectorAll('.icu').forEach(el => icu += Number(el.value) || 0);
                    document.getElementById('totalICUBeds').value = icu;
                    document.getElementById('totalICUBedsDisplay').textContent = icu;

                    const grand = med + surg + obg;
                    document.getElementById('grandTotal').textContent = grand;
                };

                document.querySelectorAll('input[type="number"]').forEach(input => {
                    input.addEventListener('input', calculate);
                    input.addEventListener('change', calculate);
                });

                calculate();
            });

            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Saved Successfully',
                    text: '@TempData["SuccessMessage"]',
                    timer: 3000,
                    showConfirmButton: false
                });
                </text>
            }
        </script>
    }
</body>
</html>