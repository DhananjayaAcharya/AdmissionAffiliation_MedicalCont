    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
            $(document).ready(function () {

                /* ══════════════════════════════════════════════
                   FILE UPLOAD VALIDATION
                ══════════════════════════════════════════════ */
                const fileInput = document.getElementById("documentFile");
                const fileNameDisplay = document.getElementById("fileName");

                if (fileInput) {
                    fileInput.addEventListener("change", function () {
                        if (this.files.length > 0) {
                            const file = this.files[0];
                            const maxSize = 2 * 1024 * 1024;

                            if (file.size > maxSize) {
                                Swal.fire({
                                    icon: 'warning',
                                    title: 'File too large',
                                    text: 'File size should not exceed 2 MB.'
                                });
                                this.value = "";
                                fileNameDisplay.textContent = "";
                                return;
                            }
                            fileNameDisplay.textContent = "Selected: " + file.name;
                        } else {
                            fileNameDisplay.textContent = "";
                        }
                    });
                }

                /* ══════════════════════════════════════════════
                   DISTRICT → TALUK AJAX
                ══════════════════════════════════════════════ */
                $("#districtDropdown").change(function () {
                    var district = $(this).val();
                    $("#talukDropdown").html('<option>Loading...</option>');

                    if (district) {
                        $.get('@Url.Action("GetTaluksByDistrict", "ContinuesAffiliation_Facultybased")',
                            { district: district },
                            function (data) {
                                let html = '<option value="">— Select Taluk —</option>';
                                $.each(data, function (i, item) {
                                    html += `<option value="${item.value}">${item.text}</option>`;
                                });
                                $("#talukDropdown").html(html);
                            });
                    } else {
                        $("#talukDropdown").html('<option value="">— Select Taluk —</option>');
                    }
                });

                /* ══════════════════════════════════════════════
                   COURSE TOGGLE + LOAD
                ══════════════════════════════════════════════ */
                const courseToggleBtn = document.getElementById('courseToggleBtn');
                const courseSection   = document.getElementById('courseSection');
                const courseIcon      = document.getElementById('courseIcon');
                let courseLoaded = false;

                if (courseToggleBtn && courseSection) {
                    courseToggleBtn.addEventListener('click', function () {
                        let isVisible = courseSection.style.display === 'block';

                        if (!isVisible) {
                            courseSection.style.display = 'block';
                            courseIcon.textContent = '➖';
                            if (!courseLoaded) { loadCourses(); courseLoaded = true; }
                        } else {
                            courseSection.style.display = 'none';
                            courseIcon.textContent = '➕';
                        }
                    });
                }

                function loadCourses() {
                    $('#courseSection').html('<p style="padding:10px;">Loading...</p>');

                    $.ajax({
                        url: '@Url.Action("GetCoursesByCollege", "ContinuesAffiliation_Facultybased")',
                        type: 'GET',
                        success: function (res) {
                            if (!res.success) {
                                $('#courseSection').html(`<p style="color:red;">${res.message}</p>`);
                                return;
                            }
                            if (res.data.length === 0) {
                                $('#courseSection').html('<p style="padding:10px;">No courses found</p>');
                                return;
                            }

                            let html = `
                                <table class="course-table">
                                    <thead>
                                        <tr>
                                            <th>Course Name</th>
                                            <th>Existing Intake</th>
                                            <th>Present Intake</th>
                                        </tr>
                                    </thead>
                                    <tbody>`;

                            $.each(res.data, function (i, item) {
                                html += `<tr>
                                    <td>${item.courseName}</td>
                                    <td>${item.existingIntake}</td>
                                    <td>${item.presentIntake}</td>
                                </tr>`;
                            });

                            html += '</tbody></table>';
                            $('#courseSection').html(html);
                        },
                        error: function () {
                            $('#courseSection').html('<p style="color:red;padding:10px;">Error loading data</p>');
                        }
                    });
                }

                /* ══════════════════════════════════════════════
                   TYPE OF INSTITUTION → TRUST SECTION TOGGLE
                   Fetches OrganizationCategory from DB via AJAX.
                   Shows Trust/Management section only when
                   OrganizationCategory = 'P' (Private).
                   Hides it when OrganizationCategory = 'G' (Govt).
                ══════════════════════════════════════════════ */
                const trustSection = document.getElementById('trustManagementSection');

                function applyTrustVisibility(orgCategory) {
                    if (!trustSection) return;

                    const isPrivate = (orgCategory || '').trim().toUpperCase() === 'P';

                    if (isPrivate) {
                        trustSection.classList.remove('trust-hidden');
                        // Re-enable fields so the user can fill them in (optional)
                        trustSection.querySelectorAll('.trust-field input, .trust-field select, .trust-field textarea')
                            .forEach(el => el.removeAttribute('disabled'));
                    } else {
                        trustSection.classList.add('trust-hidden');
                        // Disable fields so they are excluded from server-side ModelState
                        trustSection.querySelectorAll('.trust-field input, .trust-field select, .trust-field textarea')
                            .forEach(el => el.setAttribute('disabled', 'disabled'));
                    }
                }

                // On dropdown change → fetch category from server
                $('#typeOfInstitutionDropdown').on('change', function () {
                    const selectedId = $(this).val();

                    if (!selectedId) {
                        // Nothing selected → hide trust section
                        applyTrustVisibility('');
                        return;
                    }

                    $.ajax({
                        url: '@Url.Action("GetInstitutionOrgCategory", "ContinuesAffiliation_Facultybased")',
                        type: 'GET',
                        data: { institutionTypeId: selectedId },
                        success: function (res) {
                            if (res && res.success) {
                                applyTrustVisibility(res.orgCategory);
                            } else {
                                applyTrustVisibility('');
                            }
                        },
                        error: function () {
                            applyTrustVisibility('');
                        }
                    });
                });

                // On page load, trigger change if a value is already selected (edit mode)
                const initialTypeVal = $('#typeOfInstitutionDropdown').val();
                if (initialTypeVal) {
                    $('#typeOfInstitutionDropdown').trigger('change');
                } else {
                    applyTrustVisibility(''); // default hidden
                }

                /* ══════════════════════════════════════════════
                   FORM SUBMIT — FOCUS VALIDATION
                   Finds the FIRST empty required field, scrolls
                   to it, focuses it, and shows toast + badge.
                ══════════════════════════════════════════════ */
                $('#institutionForm').on('submit', function (e) {

                    // Remove previous error states
                    document.querySelectorAll('.field-invalid').forEach(el => el.classList.remove('field-invalid'));
                    document.querySelectorAll('.field-focus-target').forEach(el => el.classList.remove('field-focus-target'));
                    document.querySelectorAll('.field-err-msg').forEach(el => el.remove());
                    document.querySelectorAll('.section-card.has-error').forEach(el => el.classList.remove('has-error'));

                    const trustVisible = !trustSection.classList.contains('trust-hidden');
                    let errors = [];
                    let firstErrorEl = null;

                    // Collect all required field-wraps that are visible
                    document.querySelectorAll('.field-wrap[data-required]').forEach(wrap => {
                        // Skip trust fields when trust section is hidden
                        if (!trustVisible && wrap.closest('#trustManagementSection')) return;

                        const input    = wrap.querySelector('input:not([type="checkbox"]):not([readonly]):not([disabled])');
                        const select   = wrap.querySelector('select:not([disabled])');
                        const textarea = wrap.querySelector('textarea:not([disabled])');

                        const el     = input || select || textarea;
                        const label  = wrap.dataset.label || 'Field';
                        let isEmpty  = false;

                        if (el) {
                            const val = el.value ? el.value.trim() : '';
                            isEmpty = val === '' || val === '0';
                        }

                        if (isEmpty) {
                            wrap.classList.add('field-invalid');

                            // Inline error msg
                            const msg = document.createElement('span');
                            msg.className = 'field-err-msg';
                            msg.textContent = `${label} is required.`;
                            wrap.appendChild(msg);

                            // Mark parent card
                            const card = wrap.closest('.section-card');
                            if (card) card.classList.add('has-error');

                            errors.push(label);

                            if (!firstErrorEl) firstErrorEl = el;
                        }
                    });

                    if (errors.length > 0) {
                        e.preventDefault();

                        // Focus + pulse ring on first error field
                        if (firstErrorEl) {
                            const wrap = firstErrorEl.closest('.field-wrap');
                            if (wrap) wrap.classList.add('field-focus-target');

                            // Scroll with offset for fixed header
                            const rect   = firstErrorEl.getBoundingClientRect();
                            const offset = window.scrollY + rect.top - 100;
                            window.scrollTo({ top: offset, behavior: 'smooth' });

                            // Small delay so scroll finishes before focus
                            setTimeout(() => firstErrorEl.focus(), 380);
                        }

                        // Toast
                        const count = errors.length;
                        document.getElementById('toastMsg').textContent =
                            `${count} required field${count > 1 ? 's' : ''} need attention.`;
                        document.getElementById('toastSub').textContent =
                            `First missing: ${errors[0]}`;
                        document.getElementById('validationToast').classList.add('show');

                        // Auto-hide toast after 5s
                        setTimeout(() => {
                            document.getElementById('validationToast').classList.remove('show');
                        }, 5000);

                        // Floating badge
                        const badge = document.getElementById('missingBadge');
                        badge.textContent = `⚠ ${count} field${count > 1 ? 's' : ''} missing — click to jump`;
                        badge.classList.add('show');
                        setTimeout(() => badge.classList.remove('show'), 8000);

                        return false;
                    }
                });

                // When user starts fixing a field — clear its error state
                document.querySelectorAll('.field-wrap[data-required] input, .field-wrap[data-required] select, .field-wrap[data-required] textarea')
                    .forEach(el => {
                        el.addEventListener('input', clearFieldError);
                        el.addEventListener('change', clearFieldError);
                    });

                function clearFieldError() {
                    const wrap = this.closest('.field-wrap');
                    if (!wrap) return;
                    wrap.classList.remove('field-invalid', 'field-focus-target');
                    const msg = wrap.querySelector('.field-err-msg');
                    if (msg) msg.remove();

                    // Remove card error border only if no more errors in that card
                    const card = wrap.closest('.section-card');
                    if (card && !card.querySelector('.field-invalid')) {
                        card.classList.remove('has-error');
                    }
                }

            }); // end document.ready

            /* ══════════════════════════════════════════════
               MOBILE VALIDATOR (GLOBAL)
            ══════════════════════════════════════════════ */
            function validateMobile(input) {
                input.value = input.value.replace(/\D/g, '').slice(0, 10);
            }

            /* ══════════════════════════════════════════════
               SCROLL TO FIRST ERROR (badge click)
            ══════════════════════════════════════════════ */
            function scrollToFirstError() {
                const first = document.querySelector('.field-invalid input, .field-invalid select, .field-invalid textarea');
                if (first) {
                    const rect   = first.getBoundingClientRect();
                    const offset = window.scrollY + rect.top - 100;
                    window.scrollTo({ top: offset, behavior: 'smooth' });
                    setTimeout(() => first.focus(), 380);
                }
            }

        </script>
    }
</body>
</html>
