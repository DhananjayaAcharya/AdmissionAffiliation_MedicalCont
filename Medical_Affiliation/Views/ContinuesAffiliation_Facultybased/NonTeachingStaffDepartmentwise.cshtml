@model TeachingStaffDepartmentWiseVm

@{
    ViewData["Title"] = "Non-Teaching Staff Details";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap');

    :root {
        --navy: #0f2545;
        --navy-mid: #1a3a6b;
        --gold: #b8882a;
        --gold-light: #d4a84b;
        --cream: #f9f7f2;
        --white: #ffffff;
        --border: #ddd8cc;
        --text: #1a1a1a;
        --text-muted: #6b6358;
        --danger: #c0392b;
        --success: #1a6b3a;
        --radius: 6px;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background-color: var(--cream);
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
    }

    /* ── Page Shell ── */
    .page-shell {
        background-color: var(--cream);
        min-height: 100vh;
        padding: 36px 0 56px;
    }

    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
    }

    /* ── Header ── */
    .page-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        border-radius: 10px 10px 0 0;
        padding: 28px 36px 24px;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: repeating-linear-gradient( -45deg, transparent, transparent 18px, rgba(255,255,255,0.015) 18px, rgba(255,255,255,0.015) 36px );
        }

        .page-header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 36px;
            right: 36px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
        }

    .header-eyebrow {
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--gold-light);
        margin-bottom: 6px;
        position: relative;
    }

    .header-title {
        font-family: 'EB Garamond', serif;
        font-size: 1.85rem;
        font-weight: 500;
        color: var(--white);
        letter-spacing: 0.01em;
        line-height: 1.2;
        position: relative;
    }

    .header-subtitle {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.55);
        margin-top: 6px;
        font-weight: 300;
        position: relative;
    }

    .header-badge {
        position: absolute;
        top: 28px;
        right: 36px;
        background: rgba(184,136,42,0.15);
        border: 1px solid rgba(184,136,42,0.4);
        border-radius: 4px;
        padding: 5px 14px;
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        color: var(--gold-light);
        text-transform: uppercase;
    }

    /* ── Form Card ── */
    .form-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-top: none;
        border-radius: 0 0 10px 10px;
        padding: 32px 36px 40px;
        box-shadow: 0 4px 20px rgba(15,37,69,0.07);
    }

    /* ── Section Label ── */
    .section-label {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

    .section-label-text {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-muted);
        white-space: nowrap;
    }

    .section-label-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, var(--border), transparent);
    }

    /* ── Table Wrap ── */
    .table-wrap {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        margin-bottom: 20px;
        padding-top: 1rem !important;
        padding-bottom: 1rem !important;
    }

    /* ── Data Table ── */
    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.83rem;
        margin-bottom: 1rem;
    }

        .data-table thead {
            background: linear-gradient(180deg, #f1ede4 0%, #ebe6db 100%);
        }

            .data-table thead th {
                padding: 10px 12px;
                font-size: 0.66rem;
                font-weight: 700;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--navy);
                border-bottom: 2px solid var(--border);
                border-right: 1px solid var(--border);
                text-align: center;
                white-space: nowrap;
                vertical-align: middle;
            }

                .data-table thead th:first-child {
                    border-left: 3px solid var(--gold);
                }

                .data-table thead th:last-child {
                    border-right: none;
                }

        .data-table tbody tr {
            border-bottom: 1px solid #f0ece4;
            transition: background 0.15s;
        }

            .data-table tbody tr:last-child {
                border-bottom: none;
            }

            .data-table tbody tr:nth-child(even) {
                background: #faf8f4;
            }

            .data-table tbody tr:hover {
                background: #f3eed8 !important;
            }

        .data-table td {
            padding: 7px 10px;
            border-right: 1px solid #f0ece4;
            vertical-align: middle;
        }

            .data-table td:last-child {
                border-right: none;
            }

    .td-slno {
        width: 52px;
        text-align: center;
        font-family: 'EB Garamond', serif;
        font-size: 0.95rem;
        color: var(--navy-mid);
        font-weight: 600;
    }

    .td-action {
        width: 56px;
        text-align: center;
    }

    /* ── Form Controls ── */
    .form-control {
        width: 100%;
        border: 1px solid #d9d3c8;
        border-radius: 4px;
        padding: 6px 9px;
        font-size: 0.82rem;
        font-family: 'DM Sans', sans-serif;
        color: var(--text);
        background: var(--white);
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--navy-mid);
            box-shadow: 0 0 0 3px rgba(26,58,107,0.1);
        }

    /* Salary input group */
    .salary-wrap {
        display: flex;
        align-items: center;
        border: 1px solid #d9d3c8;
        border-radius: 4px;
        overflow: hidden;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .salary-wrap:focus-within {
            border-color: var(--navy-mid);
            box-shadow: 0 0 0 3px rgba(26,58,107,0.1);
        }

    .salary-prefix {
        background: #f3f0e8;
        border-right: 1px solid #d9d3c8;
        padding: 6px 10px;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-muted);
        flex-shrink: 0;
    }

    .salary-wrap .form-control {
        border: none;
        border-radius: 0;
        text-align: right;
        box-shadow: none !important;
    }

        .salary-wrap .form-control:focus {
            box-shadow: none !important;
        }

    /* ── Remove button ── */
    .btn-remove-row {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: transparent;
        border: 1.5px solid #e0bcbc;
        color: var(--danger);
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        line-height: 1;
    }

        .btn-remove-row:hover {
            background: var(--danger);
            border-color: var(--danger);
            color: #fff;
        }

    /* ── Add Row button ── */
    .btn-add-row {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: transparent;
        border: 1.5px solid linear-gradient(135deg, var(--navy), var(--navy-mid));
        color: var(--success);
        font-size: 0.8rem;
        font-weight: 600;
        padding: 7px 18px;
        border-radius: 4px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
        font-family: 'DM Sans', sans-serif;
        letter-spacing: 0.04em;
    }

        .btn-add-row:hover {
            background: linear-gradient(135deg, var(--navy), var(--navy-mid));
            color: #fff;
        }

    /* ── Footer ── */
    .form-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 20px;
        border-top: 1px solid var(--border);
        margin-top: 4px;
    }

    .btn-prev {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-muted);
        font-size: 0.82rem;
        font-weight: 500;
        padding: 8px 20px;
        border-radius: 4px;
        text-decoration: none;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
        font-family: 'DM Sans', sans-serif;
    }

        .btn-prev:hover {
            border-color: var(--navy-mid);
            color: var(--navy);
            background: #f3f0e8;
            text-decoration: none;
        }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        border: none;
        color: var(--white);
        font-size: 0.82rem;
        font-weight: 600;
        padding: 9px 26px;
        border-radius: 4px;
        cursor: pointer;
        transition: opacity 0.15s, box-shadow 0.15s;
        font-family: 'DM Sans', sans-serif;
        letter-spacing: 0.04em;
        position: relative;
        overflow: hidden;
    }

        .btn-save::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--gold);
        }

        .btn-save:hover {
            opacity: 0.9;
            box-shadow: 0 4px 14px rgba(15,37,69,0.3);
        }

    /* ── Empty state ── */
    .empty-notice {
        text-align: center;
        padding: 28px 16px;
        color: var(--text-muted);
        font-size: 0.85rem;
        background: #faf8f4;
    }
    .btn-next {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 100%);
        color: var(--white);
        font-size: 0.82rem;
        font-weight: 600;
        padding: 9px 26px;
        border-radius: 4px;
        text-decoration: none;
        transition: opacity 0.15s, box-shadow 0.15s;
    }
</style>
<link rel="stylesheet" href="~/css/common-form.css" />

<div class="page-shell">
    <div class="page-container">

        <!-- Header -->
        <div class="page-header head">
            @* <div class="header-eyebrow">Continuous Affiliation · Faculty Details</div> *@
            <div class="header-title">Non-Teaching Staff Details</div>
            <div class="header-subtitle">Enter details of all non-teaching staff members</div>
            @* <div class="header-badge">Staff Details</div> *@
        </div>

        <!-- Form Card -->
        <div class="form-card">

            <form asp-action="NonTeachingStaffDepartmentwise" method="post" id="staffForm">
                @Html.AntiForgeryToken()

                <div class="section-label">
                    <span class="section-label-text">Staff Records</span>
                    <span class="section-label-line"></span>
                </div>

                <div class="table-wrap">
                    <table class="data-table" id="staffTable">
                        <thead>
                            <tr>
                                <th style="width:52px;">#</th>
                                <th style="text-align:left; padding-left:12px;">Staff Name</th>
                                <th style="min-width:160px;">Designation</th>
                                <th style="width:150px;">Mobile Number</th>
                                <th style="width:170px;">Salary (₹)</th>
                                <th style="width:56px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.NonTeachingStaff.Count == 0)
                            {
                                <tr id="emptyRow">
                                    <td colspan="6" class="empty-notice">
                                        No records yet. Click <strong>+ Add Row</strong> to begin.
                                    </td>
                                </tr>
                            }
                            @for (int i = 0; i < Model.NonTeachingStaff.Count; i++)
                            {
                                <tr class="staff-row">
                                    <td class="td-slno row-number">@(i + 1)</td>
                                    <td style="text-align:left; min-width:180px;">
                                        <input asp-for="NonTeachingStaff[i].StaffName"
                                               class="form-control" placeholder="Full name" />
                                        <input asp-for="NonTeachingStaff[i].Id" type="hidden" />
                                    </td>
                                    <td>
                                        <input asp-for="NonTeachingStaff[i].Designation"
                                               class="form-control" placeholder="Designation" />
                                    </td>
                                    <td>
                                        <input asp-for="NonTeachingStaff[i].MobileNumber"
                                               class="form-control" style="text-align:center;"
                                               maxlength="10" placeholder="10-digit number" />
                                    </td>
                                    <td>
                                        <div class="salary-wrap">
                                            <span class="salary-prefix">₹</span>
                                            <input asp-for="NonTeachingStaff[i].SalaryPaid"
                                                   class="form-control"
                                                   type="number" min="0" step="1" placeholder="0" />
                                        </div>
                                    </td>
                                    <td class="td-action">
                                        <button type="button" class="btn-remove-row remove-row" title="Remove">&#8722;</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <button type="button" id="addRow" class="btn-add-row">
                        <span style="font-size:1.1rem; line-height:1;">+</span> Add Row
                    </button>
                </div>

                <!-- Footer -->
                <div class="form-footer">
                    @* <div style="display:flex; gap:10px; align-items:center;"> *@
                        <a asp-action="TeachingStaffDepartmentWise" class="btn-prev">← Previous</a>
                        <button type="submit" class="btn-save">&#128190; Save →</button>
                    @* </div> *@
                    <a asp-controller="ContinuesAffiliation_Facultybased"
                       asp-action="Aff_HostelDetails"
                       class="btn-next">Next →</a>

                </div>

            </form>
        </div><!-- /.form-card -->
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    let rowIndex = @Model.NonTeachingStaff.Count;

    // ── Add Row ──
    document.getElementById("addRow").addEventListener("click", function () {
        // Remove empty-state row if present
        const emptyRow = document.getElementById("emptyRow");
        if (emptyRow) emptyRow.remove();

        const tbody = document.querySelector("#staffTable tbody");
        const idx   = rowIndex++;
        const tr    = document.createElement("tr");
        tr.className = "staff-row";
        tr.innerHTML = `
            <td class="td-slno row-number">${tbody.children.length + 1}</td>
            <td style="text-align:left; min-width:180px;">
                <input name="NonTeachingStaff[${idx}].StaffName"
                       class="form-control" placeholder="Full name" />
                <input type="hidden" name="NonTeachingStaff[${idx}].Id" value="" />
            </td>
            <td>
                <input name="NonTeachingStaff[${idx}].Designation"
                       class="form-control" placeholder="Designation" />
            </td>
            <td>
                <input name="NonTeachingStaff[${idx}].MobileNumber"
                       class="form-control" style="text-align:center;"
                       maxlength="10" placeholder="10-digit number" />
            </td>
            <td>
                <div class="salary-wrap">
                    <span class="salary-prefix">₹</span>
                    <input name="NonTeachingStaff[${idx}].SalaryPaid"
                           class="form-control"
                           type="number" min="0" step="1" placeholder="0" />
                </div>
            </td>
            <td class="td-action">
                <button type="button" class="btn-remove-row remove-row" title="Remove">&#8722;</button>
            </td>`;
        tbody.appendChild(tr);
        refreshNumbers();
    });

    // ── Remove Row with confirmation ──
    document.addEventListener("click", async function (e) {
        const btn = e.target.closest(".remove-row");
        if (!btn) return;

        const result = await Swal.fire({
            title: 'Remove this staff member?',
            text: 'This action cannot be undone.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#c0392b',
            cancelButtonColor: '#1a3a6b',
            confirmButtonText: 'Yes, remove',
            cancelButtonText: 'Cancel'
        });

        if (result.isConfirmed) {
            btn.closest("tr").remove();
            refreshNumbers();

            // Show empty state if no rows left
            if (!document.querySelectorAll("#staffTable tbody .staff-row").length) {
                document.querySelector("#staffTable tbody").innerHTML =
                    `<tr id="emptyRow"><td colspan="6" class="empty-notice">No records yet. Click <strong>+ Add Row</strong> to begin.</td></tr>`;
            }

            Swal.fire({
                title: 'Removed!', text: 'Staff record deleted.',
                icon: 'success', timer: 1400, showConfirmButton: false
            });
        }
    });

    // ── Submit with loading ──
    document.getElementById("staffForm").addEventListener("submit", async function () {
        await Swal.fire({
            title: 'Saving...', allowOutsideClick: false,
            didOpen: () => Swal.showLoading()
        });
    });

    function refreshNumbers() {
        document.querySelectorAll("#staffTable tbody .row-number").forEach((el, i) => {
            el.textContent = i + 1;
        });
    }
</script>
