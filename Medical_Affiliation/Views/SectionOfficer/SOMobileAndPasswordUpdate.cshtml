 <div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white d-flex">
                    <a asp-controller="@ViewBag.Controller" asp-action="@ViewBag.Dashboard" asp-route-username="@ViewBag.UserName" class="nav-link btn btn-outline-primary">
                        🏠 Home
                    </a>
                    <h4 class="mb-0 text-center w-75">College Mobile & Password Update</h4>
                </div>

                <div class="card-body">
                    <!-- Faculty Dropdown -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Select Faculty</label>
                        <select id="FacultyId" class="form-select">
                            <option value="">-- Select Faculty --</option>
                            @foreach (var item in Model.FacultyList)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <!-- Scrollable Colleges Section -->
                    <div id="collegesContainer" style="max-height: 60vh; overflow-y: auto; border: 1px solid #e0e0e0; border-radius: 6px; padding: 10px;">
                        <div class="alert alert-info text-center m-0">
                            Please select a faculty to load colleges.
                        </div>
                    </div>

                    <!-- Save All Button -->
                    <div class="text-center mt-3">
                        <button id="saveAllBtn" class="btn btn-success px-4" style="display: none;">💾 Save All</button>
                    </div>
                </div>

               @*  <div class="card-footer text-center text-muted small">
                    © @DateTime.Now.Year Medical Affiliation Portal
                </div> *@
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

@section Scripts {
    <script>
        $(document).ready(function () {

            $('#FacultyId').change(function () {
                var facultyId = $(this).val();
                var container = $('#collegesContainer');
                var saveBtn = $('#saveAllBtn');

                saveBtn.hide();
                container.html('<div class="text-center my-4"><div class="spinner-border text-primary"></div><p>Loading colleges...</p></div>');

                if (facultyId) {
                    $.get('@Url.Action("GetCollegesForSoMobileUpdate")', { facultyId: facultyId })
                        .done(function (data) {
                            if (data.length === 0) {
                                container.html('<div class="alert alert-warning text-center m-0">No colleges found for this faculty.</div>');
                                return;
                            }

                            let formHtml = `
                                        <form id="collegeUpdateForm">
                                            <div class="table-responsive" style="max-height:55vh; overflow-y:auto;">
                                                <table id="collegeTable" class="table table-striped table-bordered align-middle mb-0">
                                                    <thead class="table-light">
                                                        <tr class="sticky-top">
                                                            <th style="width: 10%">Code</th>
                                                            <th style="width: 35%">College Name</th>
                                                            <th style="width: 25%">Mobile Number</th>
                                                            <th style="width: 25%">Password</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                    `;

                            $.each(data, function (i, c) {
                                formHtml += `
                                            <tr>
                                                <td>
                                                    ${c.collegeCode ?? '-'}
                                                    <input type="hidden" name="CollegeList[${i}].CollegeCode" value="${c.collegeCode}" />
                                                    <input type="hidden" name="CollegeList[${i}].CollegeName" value="${c.collegeName}" />
                                                </td>
                                                <td>${c.collegeName}</td>
                                                <td>
                                                    <input type="text"
                                                           name="CollegeList[${i}].MobileNumber"
                                                           class="form-control form-control-sm"
                                                           value="${c.principalMobileNumber ?? ''}"
                                                           placeholder="Enter mobile" />
                                                </td>
                                                <td>
                                                    <input type="text"
                                                           name="CollegeList[${i}].Password"
                                                           class="form-control form-control-sm"
                                                           value="${c.password ?? ''}"
                                                           placeholder="Enter password"
                                                           readonly />
                                                </td>
                                            </tr>
                                        `;
                            });

                            formHtml += `
                                                    </tbody>
                                                </table>
                                            </div>
                                        </form>
                                    `;

                            container.html(formHtml);
                            saveBtn.show();

                            // Initialize DataTable
                            $('#collegeTable').DataTable({
                                scrollY: '45vh',
                                scrollCollapse: true,
                                paging: false,
                                searching: true,
                                info: false
                            });
                        })
                        .fail(function () {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: 'Error loading colleges.',
                                confirmButtonColor: '#d33'
                            });
                        });
                } else {
                    container.html('<div class="alert alert-info text-center m-0">Please select a faculty to load colleges.</div>');
                    saveBtn.hide();
                }
            });

            // Bulk Save
            $('#saveAllBtn').click(function () {
                var form = $('#collegeUpdateForm');
                if (form.length === 0) {
                    Swal.fire({
                        icon: 'info',
                        title: 'No Data',
                        text: 'There is no data to submit.',
                        confirmButtonColor: '#3085d6'
                    });
                    return;
                }

                var serialized = form.serialize();

                $.ajax({
                    url: '@Url.Action("UpdateCollegesBulk")',
                    type: 'POST',
                    data: serialized,
                    beforeSend: function () {
                        Swal.fire({
                            title: 'Saving...',
                            text: 'Please wait while we update college details.',
                            allowOutsideClick: false,
                            didOpen: () => {
                                Swal.showLoading();
                            }
                        });
                    },
                    success: function (res) {
                        Swal.close();

                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Success!',
                                text: res.message,
                                confirmButtonColor: '#198754',
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                $('#FacultyId').trigger('change');
                            });
                        } else {
                            Swal.fire({
                                icon: 'warning',
                                title: 'Update Failed',
                                text: res.message || 'Update failed.',
                                confirmButtonColor: '#d33'
                            });
                        }
                    },
                    error: function () {
                        Swal.close();
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: 'An error occurred while saving data.',
                            confirmButtonColor: '#d33'
                        });
                    }
                });

            });

        });
    </script>
}
