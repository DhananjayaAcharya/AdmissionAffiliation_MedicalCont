@model AHSSOupdateIntakeDetails
@{
    ViewData["Title"] = "College Course Details";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css" />

    <style>
        body {
            background: linear-gradient(135deg, #1d4ed8, #9333ea, #f43f5e);
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
        }

        table.dataTable thead th {
            background-color: #2563eb;
            color: white;
            font-weight: 700;
            padding: 12px;
        }

        table.dataTable tbody tr:hover {
            background-color: #f1f5f9;
        }
    </style>
</head>
<body>
    <div class="container py-4">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="text-white fw-bold">
                <i class="fas fa-university me-2"></i> College Course Details
            </h1>

            <div class="">
                <a asp-controller="SectionOfficer" asp-action="SODashboard" class="btn btn-primary">
                    <i class="fas fa-home me-1"></i> Home
                </a>
                @* <form asp-controller="SectionOfficer" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-sign-out-alt me-1"></i> Logout
                    </button>
                </form> *@
            </div>
        </div>

        <!-- Filters -->
        <form method="get" asp-action="SOIntakeDetails" class="row g-3 bg-white p-4 rounded shadow-sm mb-4">
            <div class="col-md-3">
                <label for="facultycode" class="form-label fw-semibold">Select Faculty</label>
                <select id="facultycode" name="facultycode" class="form-select" asp-items="Model.Faculties"></select>
            </div>
            <div class="col-md-7">
                <label for="collegeCode" class="form-label fw-semibold">Select College</label>
                <select id="collegeCode" name="collegeCode" class="form-select" asp-items="Model.Colleges"></select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search me-1"></i> Load
                </button>
            </div>
        </form>

        <!-- Course Details Card -->
        <div class="card mb-4 bg-white rounded shadow-sm">
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.CollegeName) || !string.IsNullOrEmpty(Model.CollegeTown))
                {
                    <h2 class="text-center text-primary fw-bold mb-4">
                        @Model.CollegeName@if (!string.IsNullOrEmpty(Model.CollegeTown))
                        {
                            @(", " + Model.CollegeTown)
                        }
                    </h2>
                }

                @if (Model?.AHScourseIntakeViewModel != null && Model.AHScourseIntakeViewModel.Any())
                {
                    <form asp-action="SOIntakeDetails" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="CollegeCode" value="@Model.CollegeCode" />
                        <input type="hidden" name="FacultyCode" value="@Model.FacultyCode" />

                        <!-- Upload Section -->
                        <label class="form-label fw-semibold mb-2">
                            <i class="fas fa-file-upload me-1 text-info"></i> Upload RGUHS notification (PDF, Max 2MB)
                        </label>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <input type="file" class="form-control w-75" id="AllDocuments" name="AllDocuments" multiple />
                            @if (Model.isRguhsNotification == true)
                            {
                                <a asp-action="ViewDocument1" asp-route-collegeCode="@Model.CollegeCode" target="_blank" class="btn btn-outline-secondary btn-sm ms-3">
                                    <i class="fas fa-eye me-1"></i> View Uploaded file
                                </a>
                            }
                        </div>

                        <h4 class="fw-semibold mb-3">
                            <i class="fas fa-book text-primary me-1"></i> Course Details
                        </h4>

                        <div class="table-responsive mb-3">
                            <table class="table table-striped table-hover table-bordered align-middle" id="coursesTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Sl No</th>
                                        <th>Course Level</th>
                                        @* <th>Course Prefix</th> *@
                                        <th>Course Name</th>
                                        <th>RGUHS Intake</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.AHScourseIntakeViewModel.Count; i++)
                                    {
                                        var course = Model.AHScourseIntakeViewModel[i];
                                        <tr>
                                            <td>@(i + 1)</td>
                                            <td>@course.CourseLevel</td>
                                            @* <td>@course.CoursePrefix</td> *@
                                            <td>@course.CourseName</td>
                                            <td>@course.SanctionedIntake</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="fas fa-save me-1"></i> Submit
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <p class="text-success fst-italic">All set! Please select a faculty and college to view course details.</p>
                }
            </div>
        </div>

        <!-- Uploaded Colleges Card -->
        <div class="card bg-white rounded shadow-sm">
            <div class="card-body">
                <h2 class="fw-semibold mb-3">
                    <i class="fas fa-university text-success me-1"></i> List of the colleges that uploaded the RGUHS Affiliation document
                </h2>

                @if (Model.UploadedColleges != null && Model.UploadedColleges.Any())
                {
                    <div class="table-responsive">
                        <table id="collegesTable" class="table table-striped table-hover table-bordered nowrap" style="width:100%">
                            <thead class="table-light">
                                <tr>
                                    <th>S.No</th>
                                    <th>College Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int serial = 1;
                                    foreach (var college in Model.UploadedColleges)
                                    {
                                        if (college.DocumentAffiliation != null)
                                        {
                                            <tr>
                                                <td>@serial</td>
                                                <td>@college.CollegeName</td>
                                            </tr>
                                            serial++;
                                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted fst-italic">No colleges with documents uploaded for this faculty.</p>
                }
            </div>
        </div>

    </div>

    <!-- jQuery & DataTables JS -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <script>
        $(document).ready(function () {
            $('#coursesTable').DataTable({
                dom: 'Bfrtip',
                buttons: ['excelHtml5', 'pdfHtml5', 'print'],
                pageLength: 5,
                responsive: true,
                ordering: true,
                scrollY: "200px",
                scrollCollapse: true,
                paging: false,
                language: {
                    search: "_INPUT_",
                    searchPlaceholder: "Search courses..."
                }
            });
            $('#collegesTable').DataTable({
                dom: 'Bfrtip',
                buttons: ['copyHtml5', 'excelHtml5', 'csvHtml5', 'pdfHtml5', 'print'],
                scrollY: "400px",
                scrollCollapse: true,
                paging: true,
                pageLength: 10,
                responsive: true
            });
        });
    </script>
</body>
</html>
