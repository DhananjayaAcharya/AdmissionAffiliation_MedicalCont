@model SectionOfficerCourseWiseRguhsIntakeViewModel
@{
    ViewData["Title"] = "SO Rguhs Intake update";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    :root {
        --bg-main: #050816;
        --bg-gradient-start: #050816;
        --bg-gradient-end: #0b1220;
        --primary: #0ea5e9;
        --primary-soft: #38bdf8;
        --accent: #22c55e;
        --glass-bg: rgba(15, 23, 42, 0.78);
        --glass-border: rgba(148, 163, 184, 0.55);
        --glass-shadow-main: 0 18px 40px rgba(15, 23, 42, 0.6);
        --glass-shadow-soft: 0 1px 10px rgba(148, 163, 184, 0.5);
        --text-main: #e5e7eb;
        --text-muted: #9ca3af;
        --heading: #f9fafb;
        --table-header-gradient-start: #0ea5e9;
        --table-header-gradient-end: #22c55e;
        --input-bg: rgba(15, 23, 42, 0.92);
        --input-border: rgba(148, 163, 184, 0.7);
        --input-focus: #0ea5e9;
        --row-border: rgba(148, 163, 184, 0.35);
        --btn-gradient-start: #0ea5e9;
        --btn-gradient-end: #6366f1;
        --btn-shadow: rgba(59, 130, 246, 0.45);
    }

    body {
        min-height: 100vh;
        font-family: 'Segoe UI', Arial, sans-serif;
        margin: 0;
        color: var(--text-main);
        background: radial-gradient(circle at top left, #0f172a 0%, var(--bg-main) 40%, var(--bg-gradient-end) 100%);
    }

    .glass-box {
        background: var(--glass-bg);
        border-radius: 24px;
        box-shadow: var(--glass-shadow-main), var(--glass-shadow-soft);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1.6px solid var(--glass-border);
        padding: 1rem 1.2rem 2.1rem;
        margin-top: 4vh;
        max-width: 55vw;
        margin-left: auto;
        margin-right: auto;
        transition: box-shadow 0.2s, transform 0.16s;
    }

        .glass-box:hover {
            box-shadow: 0 22px 50px rgba(15, 23, 42, 0.8);
            transform: translateY(-1px);
        }

    .page-title {
        text-align: center;
        font-size: 28px;
        font-weight: 800;
        letter-spacing: 0.06em;
        color: var(--heading);
        padding-bottom: 10px;
    }

    a.back-link {
        text-decoration: none;
        color: var(--primary-soft);
        font-weight: 500;
        display: inline-block;
        margin-bottom: 8px;
    }

        a.back-link:hover {
            color: var(--primary);
            text-decoration: underline;
        }

    label {
        font-weight: 600;
        color: var(--text-muted);
        font-size: 15.5px;
        margin-bottom: 5px;
    }

    .form-control,
    .form-select {
        background: var(--input-bg) !important;
        border-radius: 11px;
        border: 1.3px solid var(--input-border);
        transition: border-color 0.17s ease, box-shadow 0.17s ease, background 0.17s ease;
        font-size: 15px;
        box-shadow: 0 2px 9px rgba(15, 23, 42, 0.6);
        margin-bottom: 8px;
        color: var(--text-main);
    }

        .form-control::placeholder {
            color: var(--text-muted);
        }

    #collegeSelect {
        width: 25vw;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: var(--input-focus);
        box-shadow: 0 0 0 1.7px rgba(14, 165, 233, 0.35);
        background: rgba(15, 23, 42, 0.98) !important;
        outline: none;
    }

    .table-responsive {
        overflow-x: auto;
        padding: 0;
        margin-bottom: 1.3rem;
    }

    #courseTable {
        margin-bottom: 0;
        background: rgba(15, 23, 42, 0.55);
        border-radius: 10px;
        overflow: hidden;
        border-collapse: separate;
        border-spacing: 0;
        width: 100%;
        text-align: center;
    }

        #courseTable thead {
            background: linear-gradient(90deg, var(--table-header-gradient-start) 0%, var(--table-header-gradient-end) 100%);
            position: sticky;
            top: 0;
            z-index: 2;
        }

        #courseTable th {
            font-size: 15.5px;
            font-weight: 700;
            color: #0b1220;
            padding: 11px 17px;
            background: transparent;
            border-bottom: 2.5px solid rgba(15, 23, 42, 0.15);
        }

        #courseTable td {
            font-size: 15px;
            color: var(--text-main);
            background: transparent;
            border-bottom: 1.4px solid var(--row-border);
            padding: 10px 14px;
            text-align: center;
        }

        #courseTable tbody {
            display: block;
            width: 100%;
            min-width: 320px;
            max-height: 340px;
            overflow-y: auto;
            overflow-x: auto;
            scrollbar-width: thin;
            scrollbar-color: rgba(148, 163, 184, 0.8) transparent;
        }

            #courseTable tbody::-webkit-scrollbar {
                width: 6px;
                height: 6px;
            }

            #courseTable tbody::-webkit-scrollbar-thumb {
                background: rgba(148, 163, 184, 0.9);
                border-radius: 999px;
            }

        #courseTable thead,
        #courseTable tr {
            display: table;
            width: 100%;
            table-layout: fixed;
        }

        #courseTable tbody tr:hover {
            background: radial-gradient(circle at left, rgba(14, 165, 233, 0.12), rgba(15, 23, 42, 0.1));
            cursor: pointer;
            transition: background 0.13s ease;
        }

    .btn-save {
        background: linear-gradient(90deg, var(--btn-gradient-start) 10%, var(--btn-gradient-end) 100%);
        border: none;
        padding: 13px 34px;
        border-radius: 15px;
        font-weight: 700;
        font-size: 16px;
        color: #f9fafb;
        letter-spacing: 0.04em;
        box-shadow: 0 6px 18px var(--btn-shadow);
        transition: background 0.22s ease, box-shadow 0.22s ease, transform 0.17s ease;
        margin-top: 12px;
    }

        .btn-save:hover {
            background: linear-gradient(91deg, #38bdf8 20%, #818cf8 90%);
            transform: translateY(-2px) scale(1.03);
        }

        .btn-save:active {
            transform: translateY(0) scale(0.98);
            box-shadow: 0 3px 10px rgba(30, 64, 175, 0.55);
        }

    .remarkInput {
        max-height: 70px;
        overflow-y: auto;
        resize: none;
        background: var(--input-bg);
        border-radius: 10px;
        border: 1.3px solid var(--input-border);
        color: var(--text-main);
    }

    @@media (max-width: 900px) {
        .glass-box {
            padding: 1.1rem 0.7rem 1.6rem;
            max-width: 90vw;
        }

        #courseTable tbody {
            max-height: 260px;
            width: 95vw;
            min-width: 200px;
        }

        #collegeSelect {
            width: 100%;
        }
    }

    @@media (max-width: 768px) {
        .row {
            display: block !important;
        }

        .col-md-4,
        .col-md-6 {
            width: 100%;
            display: block;
            margin-bottom: 12px;
        }

        #courseTable tbody {
            max-height: 200px;
            width: 96vw;
        }

        .btn-save {
            width: 100%;
            margin-top: 10px;
        }
    }

    @@media (max-width: 420px) {
        .page-title {
            font-size: 19px;
            padding-top: 8px;
        }

        .form-control,
        .form-select {
            font-size: 13px;
            padding: 7px 7px;
        }

        #courseTable td,
        #courseTable th {
            font-size: 11px;
            padding: 8px;
        }

        #courseTable tbody {
            max-height: 120px;
        }
    }
</style>

<div class="container py-2">
    <div class="glass-box">
        <div class="row mb-3 px-2">
            <div>
                <a class="back-link" href="@Url.Action("SODashboard", "SectionOfficer")">← Back to Dashboard</a>
                <h3 class="page-title">RGUHS Intake Management</h3>
            </div>

            <div class="col-md-4">
                <label>Faculty</label>
                <select id="facultySelect" class="form-select">
                    <option value="">Select Faculty</option>
                    @foreach (var f in Model.faculties)
                    {
                        <option value="@f.FacultyId" selected="@(f.FacultyId.ToString() == Model.SelectedFacultyCode ? "selected" : null)">
                            @f.FacultyName
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label>College</label>
                <select id="collegeSelect" class="form-select">
                    <option value="">Select College</option>
                    @if (!string.IsNullOrEmpty(Model.SelectedFacultyCode) && Model.collegeCourseIntakeDetails.Any())
                    {
                        foreach (var c in Model.collegeCourseIntakeDetails)
                        {
                            <option value="@c.CollegeCode">@c.CollegeName</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table" id="courseTable">
                <thead>
                    <tr>
                        <th style="width:30%;">Course</th>
                        <th style="width:20%;">RGUHS 2025-26</th>
                        <th style="width:20%;">RGUHS New Intake 2026-27</th>
                        <th style="width:30%;">Remarks</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <div class="d-flex justify-content-center">
            <button class="btn btn-save" id="saveBtn">Save Intake Updates</button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById("facultySelect").addEventListener("change", async function () {
        const facultyId = this.value;
        const collegeSelect = document.getElementById("collegeSelect");
        collegeSelect.innerHTML = "<option value=''>Select College</option>";

        const response = await fetch("@Url.Action("FetchCollegesByFaculty", "SectionOfficer")?facultyId=" + facultyId);
        const data = await response.json();

        data.forEach(d => {
            const opt = document.createElement("option");
            opt.value = d.value;
            opt.textContent = d.text;
            collegeSelect.appendChild(opt);
        });
    });

    document.getElementById("collegeSelect").addEventListener("change", async function () {
        const collegeCode = this.value;
        const tbody = document.querySelector("#courseTable tbody");
        tbody.innerHTML = "";

        const response = await fetch("@Url.Action("GetCoursesByCollegeForSOUpdate", "SectionOfficer")?collegeCode=" + collegeCode);
        const data = await response.json();

        data.forEach(c => {
            const row = document.createElement("tr");
            row.dataset.course = c.courseCode;
            const existingRemark = c.remarksForIntakeChange ?? "";
            row.innerHTML = `
                <td>${c.courseName}</td>
                <td>${c.rguhsExistingIntake}</td>
                <td>
                    <input type="number"
                           class="form-control newIntake"
                           value="${c.rguhsNewIntake ?? ''}"
                           style="max-width:98px;display:inline-block;text-align:center">
                </td>
                <td>
                    <div class="remarkBox" style="margin-top:5px; display:${existingRemark ? 'block' : 'none'};">
                        <textarea class="form-control remarkInput" placeholder="Enter remarks" name="Reason">${existingRemark}</textarea>
                    </div>
                </td>
            `;
            tbody.appendChild(row);
        });
    });

    document.addEventListener("input", function (e) {
        if (e.target.classList.contains("newIntake")) {
            const row = e.target.closest("tr");
            const remarkBox = row.querySelector(".remarkBox");
            const value = Number(e.target.value);

            if (value > 0) {
                remarkBox.style.display = "block";
            } else {
                remarkBox.style.display = "none";
                const remarkInput = row.querySelector(".remarkInput");
                if (remarkInput) {
                    remarkInput.value = "";
                }
            }
        }
    });

    document.getElementById("saveBtn").addEventListener("click", async function () {
        const collegeCode = document.getElementById("collegeSelect").value;
        const rows = document.querySelectorAll("#courseTable tbody tr");

        const updates = [];
        rows.forEach(row => {
            const intakeVal = row.querySelector(".newIntake").value;
            const remarkVal = row.querySelector(".remarkInput")?.value || "";
            const obj = {
                CollegeCode: collegeCode,
                CourseCode: row.dataset.course,
                NewIntake: intakeVal ? Number(intakeVal) : null
            };
            if (remarkVal.trim().length > 0) {
                obj.Reason = remarkVal.trim();
            }
            updates.push(obj);
        });

        const result = await fetch("@Url.Action("SOUpdateSaveNewRguhsIntake", "SectionOfficer")", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(updates)
        });

        if (result.ok) {
            alert("Intake Updated Successfully!");
        }
    });
</script>
