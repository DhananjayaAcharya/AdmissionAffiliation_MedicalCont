@model List<NursingExamResultViewModel>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    Layout = null;
    ViewData["Title"] = "Academic Performance";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
    int currentStep = 6;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RGUHS Portal</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>

    <style>
        :root {
            --navy: #0d1b3e;
            --navy-mid: #1a2f5f;
            --blue: #1d4ed8;
            --blue-light: #3b82f6;
            --gold: #c8a84b;
            --gold-pale: #f7f0dc;
            --surface: #f4f6fb;
            --card-bg: #ffffff;
            --border: #dde3f0;
            --text-main: #0d1b3e;
            --text-muted: #6b7a99;
            --danger: #dc2626;
            --success: #16a34a;
            --radius: 14px;
            --shadow-sm: 0 2px 8px rgba(13,27,62,.07);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--surface);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ===== HEADER ===== */
        .portal-header {
            background: var(--navy);
            padding: 0 2rem;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 12px rgba(0,0,0,.25);
            border-bottom: 2px solid var(--gold);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .brand-emblem {
            width: 38px;
            height: 38px;
            background: var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--navy);
            font-weight: 700;
        }

        .brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .brand-title {
            font-family: 'Playfair Display', serif;
            font-size: 1rem;
            font-weight: 700;
            color: #fff;
        }

        .brand-sub {
            font-size: .7rem;
            color: rgba(255,255,255,.6);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .header-meta {
            font-size: .78rem;
            color: rgba(255,255,255,.7);
            display: flex;
            align-items: center;
            gap: 18px;
        }

            .header-meta span {
                display: flex;
                align-items: center;
                gap: 5px;
            }

        /* ===== LAYOUT ===== */
        .page-shell {
            display: flex;
            flex: 1;
        }

        .sidebar-wrap {
            width: 260px;
            flex-shrink: 0;
            background: var(--navy-mid);
            min-height: calc(100vh - 64px);
            position: sticky;
            top: 64px;
            align-self: flex-start;
        }

        .content-area {
            flex: 1;
            padding: 2rem 2.5rem;
            max-width: 1000px;
            margin: 0 auto;
            width: 100%;
        }

        /* ===== PAGE TITLE ===== */
        .page-title-block {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 1.75rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--border);
        }

            .page-title-block h1 {
                font-family: 'Playfair Display', serif;
                font-size: 1.7rem;
                font-weight: 700;
                color: var(--navy);
            }

        .page-crumb {
            font-size: .78rem;
            color: var(--text-muted);
            margin-top: 4px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .page-crumb i {
                color: var(--gold);
            }

        /* ===== STEPPER ===== */
        .stepper-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.5rem 1.25rem;
            margin-bottom: 1.75rem;
            box-shadow: var(--shadow-sm);
        }

        .stepper-label {
            font-size: .68rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            margin-bottom: .75rem;
        }

        .stepper {
            display: flex;
            align-items: flex-start;
            overflow-x: auto;
            scrollbar-width: none;
            padding-bottom: 4px;
        }

            .stepper::-webkit-scrollbar {
                display: none;
            }

        .step-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
            min-width: 0;
            position: relative;
        }

            .step-item:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 14px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: var(--border);
                z-index: 0;
            }

            .step-item.completed:not(:last-child)::after {
                background: var(--success);
            }

        .step-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid var(--border);
            background: var(--card-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .7rem;
            font-weight: 700;
            color: var(--text-muted);
            position: relative;
            z-index: 1;
            transition: all .3s;
            flex-shrink: 0;
        }

        .step-item.active .step-dot {
            border-color: var(--blue);
            background: var(--blue);
            color: #fff;
            box-shadow: 0 0 0 4px rgba(29,78,216,.15);
        }

        .step-item.completed .step-dot {
            border-color: var(--success);
            background: var(--success);
            color: #fff;
        }

        .step-title {
            font-size: .65rem;
            font-weight: 500;
            color: var(--text-muted);
            text-align: center;
            margin-top: 6px;
            line-height: 1.3;
            max-width: 88px;
            word-break: break-word;
        }

        .step-item.active .step-title {
            color: var(--blue);
            font-weight: 600;
        }

        .step-item.completed .step-title {
            color: var(--success);
        }

        /* ===== PANEL ===== */
        .panel {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .panel-header {
            padding: .85rem 1.35rem;
            background: var(--navy);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .panel-header h5 {
                font-family: 'Playfair Display', serif;
                font-size: 1rem;
                font-weight: 700;
                color: #fff;
                margin: 0;
            }

            .panel-header i {
                color: var(--gold);
                font-size: 1.15rem;
            }

        /* ===== ALERTS ===== */
        .alert-custom {
            border-radius: 8px;
            padding: .65rem 1rem;
            font-size: .82rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 1rem;
        }

            .alert-custom.danger {
                background: #fef2f2;
                color: var(--danger);
                border: 1px solid #fecaca;
            }

        /* ===== PERFORMANCE TABLE ===== */
        .perf-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .85rem;
        }

            .perf-table thead th {
                background: #1e3a5f;
                color: #fff;
                font-size: .68rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .8px;
                padding: .75rem 1.1rem;
                white-space: nowrap;
                border-bottom: 2px solid var(--border);
            }

            .perf-table tbody td {
                padding: .6rem 1.1rem;
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }

            .perf-table tbody tr:last-child td {
                border-bottom: none;
            }

            .perf-table tbody tr:hover td {
                background: #f4f7ff;
            }

        .course-cell {
            font-weight: 700;
            color: var(--navy);
        }

        .year-badge {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 3px 10px;
            font-size: .75rem;
            font-weight: 600;
            color: var(--text-muted);
            display: inline-block;
        }

        .perf-input {
            font-family: 'DM Sans', sans-serif;
            font-size: .85rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: .45rem .65rem;
            color: var(--text-main);
            background: #fafbfd;
            width: 120px;
            text-align: center;
            transition: border-color .2s, box-shadow .2s;
        }

            .perf-input:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px rgba(29,78,216,.1);
                background: #fff;
                outline: none;
            }

            .perf-input[readonly] {
                background: var(--surface);
                color: var(--text-muted);
                cursor: default;
            }

        /* Percentage pill styling based on value */
        .pct-good {
            color: var(--success);
            font-weight: 700;
        }

        .pct-mid {
            color: #d97706;
            font-weight: 700;
        }

        .pct-low {
            color: var(--danger);
            font-weight: 700;
        }

        /* ===== PANEL FOOTER ===== */
        .panel-footer-bar {
            padding: 1rem 1.25rem;
            border-top: 1px solid var(--border);
            background: var(--surface);
            display: flex;
            justify-content: flex-end;
        }

        /* ===== BUTTONS ===== */
        .btn-official {
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .65rem 1.6rem;
            font-family: 'DM Sans', sans-serif;
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background .2s, transform .15s, box-shadow .2s;
            text-decoration: none;
        }

            .btn-official:hover {
                background: var(--blue);
                box-shadow: 0 4px 16px rgba(29,78,216,.25);
                transform: translateY(-1px);
                color: #fff;
            }

            .btn-official.success-btn {
                background: var(--success);
            }

                .btn-official.success-btn:hover {
                    background: #15803d;
                }

        .btn-official-outline {
            background: transparent;
            color: var(--navy);
            border: 1.5px solid var(--navy);
            border-radius: 8px;
            padding: .55rem 1.1rem;
            font-family: 'DM Sans', sans-serif;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all .2s;
            text-decoration: none;
        }

            .btn-official-outline:hover {
                background: var(--navy);
                color: #fff;
            }

        /* ===== NAV FOOTER ===== */
        .nav-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1.5rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--border);
        }

        /* ===== SUCCESS POPUP ===== */
        #successPopup {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(13,27,62,.92);
            backdrop-filter: blur(10px);
            z-index: 9999;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            animation: popIn .4s ease forwards;
            opacity: 0;
        }

        @@keyframes popIn {
            from {
                transform: scale(.85);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        .popup-card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 3rem 4rem;
            text-align: center;
            max-width: 520px;
            box-shadow: 0 24px 60px rgba(0,0,0,.4);
            border-top: 4px solid var(--gold);
        }

        .popup-icon {
            font-size: 3.5rem;
            color: var(--success);
            margin-bottom: 1rem;
            display: block;
        }

        .popup-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: .5rem;
        }

        .popup-msg {
            font-size: .9rem;
            color: var(--text-muted);
            margin-bottom: 1.5rem;
        }

        .popup-close {
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .65rem 2rem;
            font-size: .9rem;
            font-weight: 600;
            cursor: pointer;
            font-family: 'DM Sans', sans-serif;
            transition: background .2s;
        }

            .popup-close:hover {
                background: var(--blue);
            }

        /* Confetti */
        .confetti-piece {
            position: fixed;
            width: 8px;
            height: 8px;
            top: -10px;
            border-radius: 2px;
            pointer-events: none;
            z-index: 10000;
            animation: confettiFall linear forwards;
        }

        @@keyframes confettiFall {
            0% {
                transform: translateY(0) rotate(0deg);
                opacity: 1;
            }

            100% {
                transform: translateY(105vh) rotate(720deg);
                opacity: 0;
            }
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--surface);
        }

        ::-webkit-scrollbar-thumb {
            background: #c0c8db;
            border-radius: 3px;
        }

        /* ===== INFO BANNER ===== */
        .info-banner {
            background: var(--gold-pale);
            border: 1px solid #e0d0a0;
            border-radius: 10px;
            padding: .75rem 1.1rem;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: .8rem;
            color: #7c5e10;
            margin-bottom: 1.25rem;
        }

        @@media (max-width: 1100px) {
            .content-area {
                padding: 1.5rem 1.25rem;
            }

            .sidebar-wrap {
                display: none;
            }
        }

        @@media (max-width: 600px) {
            .portal-header .header-meta {
                display: none;
            }

            .perf-input {
                width: 90px;
            }
        }
    </style>
</head>
<body>

    <!-- SUCCESS POPUP -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successPopup" class="d-flex">
            <div class="popup-card">
                <i class="bi bi-patch-check-fill popup-icon"></i>
                <div class="popup-title">Submitted Successfully!</div>
                <div class="popup-msg">@TempData["SuccessMessage"]</div>
                <button class="popup-close" id="closePopupBtn">
                    <i class="bi bi-check2"></i> Done
                </button>
            </div>
        </div>
    }

    <!-- HEADER -->
    <header class="portal-header">
        <a href="#" class="brand">
            <div class="brand-emblem"><i class="bi bi-mortarboard-fill"></i></div>
            <div class="brand-text">
                <span class="brand-title">RGUHS Affiliation Portal</span>
                <span class="brand-sub">Rajiv Gandhi University of Health Sciences</span>
            </div>
        </a>
        <div class="header-meta">
            @using System.Text.RegularExpressions
            @{
                var collegeFullName = HttpContextAccessor.HttpContext.Session.GetString("CollegeName") ?? "";
                var collegeName = Regex.Replace(collegeFullName, @"[\s\-:]*[A-Za-z]*\d{3,}\s*$", "").Trim();
            }
            @if (!string.IsNullOrEmpty(collegeName))
            {
                <span><i class="bi bi-building"></i> @collegeName</span>
            }
            <span><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dd MMM yyyy")</span>
        </div>
    </header>

    <div class="page-shell">
        <main class="content-area">

            <!-- Page Title -->
            <div class="page-title-block">
                <div>
                    <h1>College Year-Wise Academic Performance</h1>
                    <div class="page-crumb">
                        <i class="bi bi-house-fill"></i> Home
                        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i> Admission Affiliation
                        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
                        <strong>Academic Performance</strong>
                    </div>
                </div>
                <span style="font-size:.72rem;color:var(--text-muted);background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:4px 12px;">
                    <i class="bi bi-shield-lock" style="color:var(--gold);"></i> Secure Session
                </span>
            </div>

            <!-- Alerts -->
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert-custom danger"><i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]</div>
            }

            <!-- STEPPER -->
            @{
                var stepTitles = new[] {
                        "Basic Institute Details", "Course Details", "Hospital Details",
                        "Designation Details", "Add College Faculty", "College Performance"
                        };
            }
            <div class="stepper-card">
                <div class="stepper-label">Application Progress — Step @currentStep of @stepTitles.Length</div>
                <div class="stepper">
                    @for (int i = 0; i < stepTitles.Length; i++)
                    {
                        var isActive = (currentStep == i + 1);
                        var isCompleted = (currentStep > i + 1);
                        var cls = isActive ? "active" : (isCompleted ? "completed" : "");
                        <div class="step-item @cls">
                            <div class="step-dot">
                                @if (isCompleted)
                                {
                                    <i class="bi bi-check-lg" style="font-size:.75rem;"></i>
                                }
                                else
                                {

                                    @(i + 1)
                                }
                            </div>
                            <span class="step-title">@stepTitles[i]</span>
                        </div>
                    }
                </div>
            </div>

            <!-- INFO BANNER -->
            <div class="info-banner">
                <i class="bi bi-info-circle-fill"></i>
                Enter <strong>Exam Appeared</strong> and <strong>Passed</strong> counts. The percentage is calculated automatically.
                Academic Year: <strong>2023–24</strong>.
            </div>

            <!-- PERFORMANCE FORM -->
            <form asp-action="Repo_ExamResults" method="post" id="examResultsForm" autocomplete="off">
                @Html.AntiForgeryToken()

                <div class="panel">
                    <div class="panel-header">
                        <i class="bi bi-bar-chart-line"></i>
                        <h5>Year-wise Exam Results</h5>
                    </div>

                    <div style="overflow-x:auto;">
                        <table class="perf-table">
                            <thead>
                                <tr>
                                    <th>slno</th>
                                    <th>Course</th>
                                    <th>Year</th>
                                    <th style="text-align:center;">Exam Appeared</th>
                                    <th style="text-align:center;">Passed</th>
                                    <th style="text-align:center;">Pass % (Auto)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Count; i++)
                                {
                                    <tr>
                                        <input type="hidden" asp-for="@Model[i].Course" />
                                        <input type="hidden" asp-for="@Model[i].Year" />
                                        <td style="font-weight:700;color:var(--text-muted);text-align:center;">@(i + 1)</td>
                                        <td class="course-cell">@Model[i].Course</td>
                                        <td><span class="year-badge">@Model[i].Year</span></td>
                                        <td style="text-align:center;">
                                            <input asp-for="@Model[i].ExamAppearedCount" type="number" min="0"
                                                   class="perf-input appeared" placeholder="0" />
                                        </td>
                                        <td style="text-align:center;">
                                            <input asp-for="@Model[i].PassedOutCount" type="number" min="0"
                                                   class="perf-input passed" placeholder="0" />
                                        </td>
                                        <td style="text-align:center;">
                                            <input asp-for="@Model[i].YearOfPercentage"
                                                   class="perf-input percentage" readonly placeholder="0.00" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="panel-footer-bar">
                        <button type="submit" class="btn-official success-btn">
                            <i class="bi bi-send-check"></i> Submit Results
                        </button>
                    </div>
                </div>

                <!-- Nav Footer -->
                <div class="nav-footer">
                    <a asp-action="Repo_FacultyDetails" class="btn-official-outline">
                        <i class="bi bi-arrow-left"></i> Previous
                    </a>
                    <span style="font-size:.75rem;color:var(--text-muted);">
                        <i class="bi bi-info-circle"></i> This is the final step. Submit to complete your application.
                    </span>
                    <button type="submit" class="btn-official success-btn">
                        <i class="bi bi-send-check"></i> Submit &amp; Finish
                    </button>
                </div>
            </form>

        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            /* ---- Percentage auto-calculation ---- */
            function calcPct(row) {
                const appeared = parseFloat(row.querySelector('.appeared').value) || 0;
                const passed   = parseFloat(row.querySelector('.passed').value)   || 0;
                const pctField = row.querySelector('.percentage');
                const pct = appeared > 0 ? ((passed / appeared) * 100).toFixed(2) : "0.00";
                pctField.value = pct;
                pctField.classList.remove('pct-good','pct-mid','pct-low');
                const p = parseFloat(pct);
                if (p >= 75) pctField.classList.add('pct-good');
                else if (p >= 50) pctField.classList.add('pct-mid');
                else pctField.classList.add('pct-low');
            }

            document.querySelectorAll('.appeared, .passed').forEach(input => {
                input.addEventListener('input', function () { calcPct(this.closest('tr')); });
            });

            /* ---- Success popup ---- */
            const popup   = document.getElementById('successPopup');
            const closeBtn = document.getElementById('closePopupBtn');
            if (!popup) return;

            popup.style.display = 'flex';

            let confettiInterval = setInterval(() => {
                for (let i = 0; i < 6; i++) {
                    const el = document.createElement('div');
                    el.classList.add('confetti-piece');
                    el.style.left = Math.random() * 100 + 'vw';
                    el.style.background = `hsl(${Math.random()*360},70%,60%)`;
                    el.style.animationDuration = (1.5 + Math.random() * 2.5) + 's';
                    document.body.appendChild(el);
                    el.addEventListener('animationend', () => el.remove());
                }
            }, 120);

            if (closeBtn) {
                closeBtn.addEventListener('click', () => {
                    popup.style.display = 'none';
                    clearInterval(confettiInterval);
                    document.querySelectorAll('.confetti-piece').forEach(el => el.remove());
                });
            }
        });
    </script>

</body>
</html>
