@model List<Nursing_YearwiseMaterialsDataViewModel>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    Layout = null;
    ViewData["Title"] = "Affiliated Year-wise Clinical Materials";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    int currentStep = 3;
    var parameters = ViewBag.ParametersList as List<string> ?? new List<string>();
    var uniqueParameters = Model
        .GroupBy(m => m.ParametersId)
        .Select(g => g.First())
        .ToList();
    var pivotData = ViewBag.PivotData as List<YearwisePivotRecord> ?? new List<YearwisePivotRecord>();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RGUHS Portal</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- jQuery -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.20.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>

    <style>
        /* ===== TOKENS ===== */
        :root {
            --navy: #0d1b3e;
            --navy-mid: #1a2f5f;
            --blue: #1d4ed8;
            --blue-light: #3b82f6;
            --gold: #c8a84b;
            --gold-pale: #f7f0dc;
            --surface: #f4f6fb;
            --card-bg: #ffffff;
            --border: #dde3f0;
            --text-main: #0d1b3e;
            --text-muted: #6b7a99;
            --danger: #dc2626;
            --success: #16a34a;
            --teal: #0f766e;
            --radius: 14px;
            --shadow-sm: 0 2px 8px rgba(13,27,62,.07);
            --shadow-md: 0 6px 24px rgba(13,27,62,.10);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--surface);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ===== HEADER ===== */
        .portal-header {
            background: var(--navy);
            color: #fff;
            padding: 0 2rem;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 12px rgba(0,0,0,.25);
            border-bottom: 2px solid var(--gold);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .brand-emblem {
            width: 38px;
            height: 38px;
            background: var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--navy);
            font-weight: 700;
        }

        .brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .brand-title {
            font-family: 'Playfair Display', serif;
            font-size: 1rem;
            font-weight: 700;
            color: #fff;
        }

        .brand-sub {
            font-size: .7rem;
            color: rgba(255,255,255,.6);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .header-meta {
            font-size: .78rem;
            color: rgba(255,255,255,.7);
            display: flex;
            align-items: center;
            gap: 18px;
        }

            .header-meta span {
                display: flex;
                align-items: center;
                gap: 5px;
            }

        /* ===== LAYOUT ===== */
        .page-shell {
            display: flex;
            flex: 1;
        }

        .sidebar-wrap {
            width: 260px;
            flex-shrink: 0;
            background: var(--navy-mid);
            min-height: calc(100vh - 64px);
            position: sticky;
            top: 64px;
            align-self: flex-start;
        }

        .content-area {
            flex: 1;
            padding: 2rem 2.5rem;
            max-width: 1400px;
            margin: 0 auto;
            width: 100%;
        }

        /* ===== PAGE TITLE ===== */
        .page-title-block {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 1.75rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--border);
        }

            .page-title-block h1 {
                font-family: 'Playfair Display', serif;
                font-size: 1.7rem;
                font-weight: 700;
                color: var(--navy);
            }

        .page-crumb {
            font-size: .78rem;
            color: var(--text-muted);
            margin-top: 4px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .page-crumb i {
                color: var(--gold);
            }

        /* ===== STEPPER ===== */
        .stepper-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.5rem 1.25rem;
            margin-bottom: 1.75rem;
            box-shadow: var(--shadow-sm);
        }

        .stepper-label {
            font-size: .68rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            margin-bottom: .75rem;
        }

        .stepper {
            display: flex;
            align-items: flex-start;
            overflow-x: auto;
            scrollbar-width: none;
            padding-bottom: 4px;
        }

            .stepper::-webkit-scrollbar {
                display: none;
            }

        .step-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
            min-width: 0;
            position: relative;
        }

            .step-item:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 14px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: var(--border);
                z-index: 0;
                transition: background .4s;
            }

            .step-item.completed:not(:last-child)::after {
                background: var(--success);
            }

        .step-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid var(--border);
            background: var(--card-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .7rem;
            font-weight: 700;
            color: var(--text-muted);
            position: relative;
            z-index: 1;
            transition: all .3s;
            flex-shrink: 0;
        }

        .step-item.active .step-dot {
            border-color: var(--blue);
            background: var(--blue);
            color: #fff;
            box-shadow: 0 0 0 4px rgba(29,78,216,.15);
        }

        .step-item.completed .step-dot {
            border-color: var(--success);
            background: var(--success);
            color: #fff;
        }

        .step-title {
            font-size: .65rem;
            font-weight: 500;
            color: var(--text-muted);
            text-align: center;
            margin-top: 6px;
            line-height: 1.3;
            max-width: 88px;
            word-break: break-word;
        }

        .step-item.active .step-title {
            color: var(--blue);
            font-weight: 600;
        }

        .step-item.completed .step-title {
            color: var(--success);
        }

        /* ===== PANEL ===== */
        .panel {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            margin-bottom: 1.5rem;
        }

        .panel-header {
            padding: .85rem 1.35rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .panel-header.navy {
                background: var(--navy);
            }

            .panel-header.teal {
                background: var(--teal);
            }

            .panel-header.slate {
                background: #334155;
            }

            .panel-header h5 {
                font-family: 'Playfair Display', serif;
                font-size: 1rem;
                font-weight: 700;
                color: #fff;
                margin: 0;
            }

            .panel-header i {
                color: var(--gold);
                font-size: 1.15rem;
            }

        .panel-body {
            padding: 1.5rem;
        }

        /* ===== FORM ===== */
        .form-label {
            font-size: .75rem;
            font-weight: 600;
            letter-spacing: .3px;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: .4rem;
        }

        .form-control, .form-select {
            font-family: 'DM Sans', sans-serif;
            font-size: .875rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: .55rem .85rem;
            color: var(--text-main);
            background: #fafbfd;
            transition: border-color .2s, box-shadow .2s;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px rgba(29,78,216,.1);
                background: #fff;
                outline: none;
            }

            .form-control::placeholder {
                color: #b0b9cc;
            }

        /* ===== SECTION DIVIDER ===== */
        .section-divider {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 1.25rem 0 1rem;
        }

            .section-divider span {
                font-size: .7rem;
                font-weight: 700;
                letter-spacing: 1.5px;
                text-transform: uppercase;
                color: var(--text-muted);
                white-space: nowrap;
            }

            .section-divider::before, .section-divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border);
            }

        /* ===== FILE UPLOAD ===== */
        .upload-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
        }

        .upload-field-label {
            font-size: .72rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: .4px;
            margin-bottom: .4rem;
        }

        .upload-box {
            border: 1.5px dashed var(--border);
            border-radius: 10px;
            padding: .75rem .85rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            cursor: pointer;
            transition: border-color .2s, background .2s;
            background: #fafbfd;
        }

            .upload-box:hover {
                border-color: var(--blue-light);
                background: #eff4ff;
            }

            .upload-box i {
                font-size: 1.3rem;
                color: var(--blue-light);
            }

            .upload-box .upload-label-txt {
                font-size: .72rem;
                color: var(--text-muted);
                text-align: center;
            }

            .upload-box .file-name {
                font-size: .68rem;
                color: var(--text-muted);
                word-break: break-all;
                text-align: center;
                font-style: italic;
            }

                .upload-box .file-name.has-file {
                    color: var(--blue);
                    font-style: normal;
                    font-weight: 600;
                }

        .hidden-file-input {
            display: none !important;
        }

        /* ===== BUTTONS ===== */
        .btn-official {
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .65rem 1.6rem;
            font-family: 'DM Sans', sans-serif;
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background .2s, transform .15s, box-shadow .2s;
            text-decoration: none;
        }

            .btn-official:hover {
                background: var(--blue);
                box-shadow: 0 4px 16px rgba(29,78,216,.25);
                transform: translateY(-1px);
                color: #fff;
            }

            .btn-official.success {
                background: var(--success);
            }

                .btn-official.success:hover {
                    background: #15803d;
                    box-shadow: 0 4px 16px rgba(22,163,74,.25);
                }

        .btn-official-outline {
            background: transparent;
            color: var(--navy);
            border: 1.5px solid var(--navy);
            border-radius: 8px;
            padding: .55rem 1.1rem;
            font-family: 'DM Sans', sans-serif;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all .2s;
            text-decoration: none;
        }

            .btn-official-outline:hover {
                background: var(--navy);
                color: #fff;
            }

        /* ===== HOSPITAL TYPE PILL ===== */
        .hospital-type-select-wrap {
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--gold-pale);
            border: 1px solid #e0d0a0;
            border-radius: 10px;
            padding: .75rem 1rem;
            margin-bottom: 1.25rem;
        }

            .hospital-type-select-wrap label {
                font-size: .78rem;
                font-weight: 700;
                color: var(--navy);
                white-space: nowrap;
                text-transform: uppercase;
                letter-spacing: .5px;
            }

            .hospital-type-select-wrap select {
                flex: 1;
                max-width: 300px;
            }

        /* ===== YEARWISE ENTRY TABLE ===== */
        .entry-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .82rem;
        }

            .entry-table thead th {
                background: #1e3a5f;
                color: #fff;
                font-size: .68rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .8px;
                padding: .7rem 1rem;
                white-space: nowrap;
                border-bottom: 2px solid var(--border);
            }

            .entry-table tbody td {
                padding: .55rem .85rem;
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }

            .entry-table tbody tr:hover td {
                background: #f4f7ff;
            }

            .entry-table tbody tr:last-child td {
                border-bottom: none;
            }

            .entry-table .param-name {
                font-weight: 600;
                color: var(--navy);
                font-size: .82rem;
            }

        .year-input {
            width: 90px;
        }

        /* ===== PIVOT TABLE (Read-only) ===== */
        .pivot-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .75rem;
            min-width: 900px;
        }

            .pivot-table th {
                background: #0f172a;
                color: #fff;
                font-size: .65rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .8px;
                padding: .6rem .85rem;
                white-space: nowrap;
                border: 1px solid #1e293b;
                text-align: center;
            }

            .pivot-table td {
                padding: .55rem .85rem;
                border: 1px solid var(--border);
                vertical-align: middle;
                text-align: center;
            }

            .pivot-table tbody tr:hover td {
                background: #f4f7ff;
            }

            .pivot-table .param-group-header {
                background: #f8fafc;
                font-weight: 700;
                text-align: center;
                letter-spacing: .5px;
                color: var(--navy);
            }

        .doc-btn {
            background: #eff4ff;
            color: var(--blue);
            border: 1px solid #c7d7fd;
            border-radius: 6px;
            padding: 3px 10px;
            font-size: .68rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            transition: all .18s;
        }

            .doc-btn:hover {
                background: var(--blue);
                color: #fff;
                border-color: var(--blue);
            }

        .doc-btn-missing {
            color: #c0c8db;
            font-size: .7rem;
        }

        .btn-delete {
            background: #fef2f2;
            color: var(--danger);
            border: 1px solid #fecaca;
            border-radius: 6px;
            padding: 4px 10px;
            font-size: .7rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            transition: all .18s;
        }

            .btn-delete:hover {
                background: var(--danger);
                color: #fff;
                border-color: var(--danger);
            }

        /* ===== NAV FOOTER ===== */
        .nav-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1.75rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--border);
        }

        /* ===== TABLE SCROLL ===== */
        .table-scroll-wrap {
            overflow-x: auto;
            max-height: 500px;
            overflow-y: auto;
        }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--surface);
        }

        ::-webkit-scrollbar-thumb {
            background: #c0c8db;
            border-radius: 3px;
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 1100px) {
            .content-area {
                padding: 1.5rem 1.25rem;
            }

            .sidebar-wrap {
                display: none;
            }

            .upload-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width: 600px) {
            .upload-grid {
                grid-template-columns: 1fr;
            }

            .portal-header .header-meta {
                display: none;
            }
        }

        /* ===== EMPTY STATE ===== */
        .empty-state {
            padding: 2.5rem;
            text-align: center;
            color: var(--text-muted);
        }

            .empty-state i {
                font-size: 2rem;
                margin-bottom: .5rem;
                display: block;
            }

            .empty-state p {
                font-size: .82rem;
            }
    </style>
</head>
<body>

    <!-- ===================== HEADER ===================== -->
    <header class="portal-header">
        <a href="#" class="brand">
            <div class="brand-emblem"><i class="bi bi-mortarboard-fill"></i></div>
            <div class="brand-text">
                <span class="brand-title">RGUHS Affiliation Portal</span>
                <span class="brand-sub">Rajiv Gandhi University of Health Sciences</span>
            </div>
        </a>
        <div class="header-meta">
            @using System.Text.RegularExpressions
            @{
                var collegeFullName = HttpContextAccessor.HttpContext.Session.GetString("CollegeName") ?? "";
                var collegeName = Regex.Replace(collegeFullName, @"[\s\-:]*[A-Za-z]*\d{3,}\s*$", "").Trim();
            }
            @if (!string.IsNullOrEmpty(collegeName))
            {
                <span><i class="bi bi-building"></i> @collegeName</span>
            }
            <span><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dd MMM yyyy")</span>
        </div>
    </header>

    <!-- ===================== BODY SHELL ===================== -->
    <div class="page-shell">


        <main class="content-area">

            <!-- Page Title -->
            <div class="page-title-block">
                <div>
                    <h1>Parent / Affiliated Hospital Detail</h1>
                    <div class="page-crumb">
                        <i class="bi bi-house-fill"></i> Home
                        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i> Admission Affiliation
                        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
                        <strong>Hospital &amp; Year-wise Materials</strong>
                    </div>
                </div>
                <span style="font-size:.72rem;color:var(--text-muted);background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:4px 12px;">
                    <i class="bi bi-shield-lock" style="color:var(--gold);"></i> Secure Session
                </span>
            </div>

            <!-- ===== STEPPER ===== -->
            @{
                var stepTitles = new[] {
                        "Basic Institute Details",
                        "Course Details",
                        "Hospital Details",
                        "Designation Details",
                        "Add College Faculty",
                        "College Performance"
                        };
            }
            <div class="stepper-card">
                <div class="stepper-label">Application Progress — Step @currentStep of @stepTitles.Length</div>
                <div class="stepper">
                    @for (int i = 0; i < stepTitles.Length; i++)
                    {
                        var isActive = (currentStep == i + 1);
                        var isCompleted = (currentStep > i + 1);
                        var cls = isActive ? "active" : (isCompleted ? "completed" : "");
                        <div class="step-item @cls">
                            <div class="step-dot">
                                @if (isCompleted)
                                {
                                    <i class="bi bi-check-lg" style="font-size:.75rem;"></i>
                                }
                                else
                                {

                                    @(i + 1)
                                }
                            </div>
                            <span class="step-title">@stepTitles[i]</span>
                        </div>
                    }
                </div>
            </div>

            <!-- ===================== MAIN FORM ===================== -->
            <form asp-action="Repo_Affiliated_YearwiseMaterials" method="post" enctype="multipart/form-data" id="mainForm" autocomplete="off">

                <!-- ===== HOSPITAL DETAILS PANEL ===== -->
                <div class="panel">
                    <div class="panel-header navy">
                        <i class="bi bi-hospital"></i>
                        <h5>Hospital Details</h5>
                    </div>
                    <div class="panel-body">

                        <!-- Hospital Type -->
                        <div class="hospital-type-select-wrap">
                            <i class="bi bi-building-fill-check" style="color:var(--gold);font-size:1.2rem;"></i>
                            <label for="HospitalType">Hospital Type</label>
                            @Html.DropDownList("HospitalType", ViewBag.HospitalTypes as List<SelectListItem>, "— Select Hospital Type —",
                            new { @class = "form-select", required = "required", id = "HospitalType" })
                        </div>

                        <!-- Row 1: Basic Info -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Hospital Name</label>
                                <input type="text" class="form-control" name="ParentHospitalName" placeholder="e.g. District Government Hospital" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Hospital Address</label>
                                <input type="text" class="form-control" name="ParentHospitalAddress" placeholder="Street, City, District" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Owner Name</label>
                                <input type="text" class="form-control" name="HospitalOwnerName" placeholder="Full Name of Owner / Trustee" />
                            </div>
                        </div>

                        <!-- Row 2: Beds -->
                        <div class="row g-3 mb-1">
                            <div class="col-md-3">
                                <label class="form-label">KPME Beds</label>
                                <input type="number" class="form-control" name="Kpmebeds" min="0" placeholder="0" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">PCB Beds</label>
                                <input type="number" class="form-control" name="PostBasicBeds" min="0" placeholder="0" />
                            </div>
                        </div>

                        <!-- Document Uploads -->
                        <div class="section-divider mt-4">
                            <i class="bi bi-paperclip" style="color:var(--gold);font-size:.85rem;"></i>
                            <span>Supporting Documents</span>
                        </div>

                        <div class="upload-grid">
                            <!-- KPME Beds Doc -->
                            <div>
                                <div class="upload-field-label">KPME Beds Document</div>
                                <div class="upload-box" onclick="this.querySelector('.hidden-file-input').click()">
                                    <i class="bi bi-cloud-upload"></i>
                                    <span class="upload-label-txt">Click to upload</span>
                                    <span class="file-name" id="ParentHospitalKpmebedsDocFileName">No file chosen</span>
                                    <input type="file" id="ParentHospitalKpmebedsDocFile" name="ParentHospitalKpmebedsDocFile" class="hidden-file-input" />
                                </div>
                            </div>
                            <!-- MOU Doc -->
                            <div>
                                <div class="upload-field-label">MOU Document</div>
                                <div class="upload-box" onclick="this.querySelector('.hidden-file-input').click()">
                                    <i class="bi bi-cloud-upload"></i>
                                    <span class="upload-label-txt">Click to upload</span>
                                    <span class="file-name" id="ParentHospitalMoudocFileName">No file chosen</span>
                                    <input type="file" id="ParentHospitalMoudocFile" name="ParentHospitalMoudocFile" class="hidden-file-input" />
                                </div>
                            </div>
                            <!-- Clinical Receipt Doc -->
                            <div>
                                <div class="upload-field-label">Clinical Receipt Document</div>
                                <div class="upload-box" onclick="this.querySelector('.hidden-file-input').click()">
                                    <i class="bi bi-cloud-upload"></i>
                                    <span class="upload-label-txt">Click to upload</span>
                                    <span class="file-name" id="ParentHospitalOwnerNameDocFileName">No file chosen</span>
                                    <input type="file" id="ParentHospitalOwnerNameDocFile" name="ParentHospitalOwnerNameDocFile" class="hidden-file-input" />
                                </div>
                            </div>
                            <!-- PCB Doc -->
                            <div>
                                <div class="upload-field-label">PCB Document</div>
                                <div class="upload-box" onclick="this.querySelector('.hidden-file-input').click()">
                                    <i class="bi bi-cloud-upload"></i>
                                    <span class="upload-label-txt">Click to upload</span>
                                    <span class="file-name" id="ParentHospitalPostBasicDocFileName">No file chosen</span>
                                    <input type="file" id="ParentHospitalPostBasicDocFile" name="ParentHospitalPostBasicDocFile" class="hidden-file-input" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ===== YEAR-WISE MATERIALS ENTRY ===== -->
                <div class="panel">
                    <div class="panel-header teal">
                        <i class="bi bi-bar-chart-steps"></i>
                        <h5>Year-wise Clinical Materials Entry</h5>
                    </div>
                    <div class="panel-body p-0">
                        <div class="table-scroll-wrap">
                            <table class="entry-table">
                                <thead>
                                    <tr>
                                        <th style="width:40%;text-align:left;padding-left:1.25rem;">Parameter</th>
                                        <th id="th-year1">Year 1</th>
                                        <th id="th-year2">Year 2</th>
                                        <th id="th-year3">Year 3</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < uniqueParameters.Count; i++)
                                    {
                                        var item = uniqueParameters[i];
                                        <tr>
                                            <td style="padding-left:1.25rem;">
                                                <span class="param-name">@item.ParametersName</span>
                                                <input type="hidden" name="[@i].ParametersId" value="@item.ParametersId" />
                                                <input type="hidden" name="[@i].ParametersName" value="@item.ParametersName" />
                                                <input type="hidden" name="[@i].CollegeCode" value="@item.CollegeCode" />
                                                <input type="hidden" name="[@i].FacultyCode" value="@item.FacultyCode" />
                                                <input type="hidden" name="[@i].HospitalType" value="" />
                                            </td>
                                            <td><input type="number" name="[@i].Year1" class="form-control year-input" min="0" placeholder="—" /></td>
                                            <td><input type="number" name="[@i].Year2" class="form-control year-input" min="0" placeholder="—" /></td>
                                            <td><input type="number" name="[@i].Year3" class="form-control year-input" min="0" placeholder="—" /></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div style="padding: 1rem 1.25rem; border-top: 1px solid var(--border); display:flex; justify-content:flex-end;">
                            <button type="submit" class="btn-official success">
                                <i class="bi bi-save2"></i> Save Details
                            </button>
                        </div>
                    </div>
                </div>

            </form>

            <!-- ===================== SAVED RECORDS TABLE ===================== -->
            <div class="panel">
                <div class="panel-header slate">
                    <i class="bi bi-table"></i>
                    <h5>Saved Year-wise Records</h5>
                    <span style="margin-left:auto;background:rgba(255,255,255,.15);border-radius:20px;padding:2px 12px;font-size:.72rem;color:#fff;font-weight:700;">
                        @pivotData.Count Rows
                    </span>
                </div>

                @if (!pivotData.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-inbox"></i>
                        <p>No records saved yet. Fill the form above to add hospital and year-wise data.</p>
                    </div>
                }
                else
                {
                    <div class="table-scroll-wrap">
                        <table class="pivot-table">
                            <thead>
                                <tr>
                                    <th rowspan="2" style="text-align:left;padding-left:1rem;">Hospital Type</th>
                                    @foreach (var param in parameters)
                                    {
                                        <th colspan="3" class="param-group-header" style="background:#1d4ed8;">@param</th>
                                    }
                                    <th rowspan="2">Hospital Name</th>
                                    <th rowspan="2">Address</th>
                                    <th rowspan="2">KPME Beds</th>
                                    <th rowspan="2">PCB Beds</th>
                                    <th rowspan="2">Owner</th>
                                    <th rowspan="2">MOU</th>
                                    <th rowspan="2">Owner Doc</th>
                                    <th rowspan="2">KPME Doc</th>
                                    <th rowspan="2">PCB Doc</th>
                                    <th rowspan="2">Action</th>
                                </tr>
                                <tr>
                                    @foreach (var param in parameters)
                                    {
                                        <th class="year1" style="background:#1e3a8a;">Yr 1</th>
                                        <th class="year2" style="background:#1e3a8a;">Yr 2</th>
                                        <th class="year3" style="background:#1e3a8a;">Yr 3</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in pivotData)
                                {
                                    if (row == null || row.Parameters == null) { continue; }
                                    <tr>
                                        <td style="font-weight:600;text-align:left;padding-left:1rem;">@row.HospitalType</td>

                                        @foreach (var param in parameters)
                                        {
                                            if (row.Parameters.ContainsKey(param) && row.Parameters[param] != null)
                                            {
                                                <td>@row.Parameters[param].Year1</td>
                                                <td>@row.Parameters[param].Year2</td>
                                                <td>@row.Parameters[param].Year3</td>
                                            }
                                            else
                                            {
                                                <td><span class="doc-btn-missing">—</span></td>
                                                <td><span class="doc-btn-missing">—</span></td>
                                                <td><span class="doc-btn-missing">—</span></td>
                                            }
                                        }

                                        <td>@(row.ParentHospitalName ?? "—")</td>
                                        <td>@(row.ParentHospitalAddress ?? "—")</td>
                                        <td>@(row.Kpmebeds ?? "—")</td>
                                        <td>@(row.PostBasicBeds ?? "—")</td>
                                        <td>@(row.HospitalOwnerName ?? "—")</td>

                                        <td>
                                            @if (row.ParentHospitalMoudocPresent == true)
                                            {
                                                <a class="doc-btn" target="_blank"
                                                   href="@Url.Action("DownloadYearwiseDocument", "MedicalRepository", new { id = row.Id, docType = "ParentHospitalMoudoc" })">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            }
                                            else
                                            {

                                                <span class="doc-btn-missing">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (row.ParentHospitalOwnerNameDocPresent == true)
                                            {
                                                <a class="doc-btn" target="_blank"
                                                   href="@Url.Action("DownloadYearwiseDocument", "MedicalRepository", new { id = row.Id, docType = "ParentHospitalOwnerNameDoc" })">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            }
                                            else
                                            {

                                                <span class="doc-btn-missing">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (row.ParentHospitalKpmebedsDocPresent == true)
                                            {
                                                <a class="doc-btn" target="_blank"
                                                   href="@Url.Action("DownloadYearwiseDocument", "MedicalRepository", new { id = row.Id, docType = "ParentHospitalKpmebedsDoc" })">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            }
                                            else
                                            {

                                                <span class="doc-btn-missing">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (row.ParentHospitalPostBasicDocPresent == true)
                                            {
                                                <a class="doc-btn" target="_blank"
                                                   href="@Url.Action("DownloadYearwiseDocument", "MedicalRepository", new { id = row.Id, docType = "ParentHospitalPostBasicDoc" })">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            }
                                            else
                                            {

                                                <span class="doc-btn-missing">—</span>
                                            }
                                        </td>

                                        <td>
                                            <form asp-action="DeleteYearwiseMaterial1" method="post"
                                                  onsubmit="return confirm('Delete this record? This cannot be undone.');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="parametersId" value="@row.Parameters.First().Key" />
                                                <input type="hidden" name="hospitalType" value="@row.HospitalType" />
                                                <button type="submit" class="btn-delete">
                                                    <i class="bi bi-trash3"></i> Delete
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <!-- ===== NAV FOOTER ===== -->
            <div class="nav-footer">
                <a asp-controller="Repo" asp-action="Repo_UGPG" class="btn-official-outline">
                    <i class="bi bi-arrow-left"></i> Previous
                </a>
                <span style="font-size:.75rem;color:var(--text-muted);">
                    <i class="bi bi-info-circle"></i> Year columns auto-fill with current year on load.
                </span>
                <a asp-controller="Repo" asp-action="Repo_ManageDesignationIntake" class="btn-official" style="text-decoration:none;">
                    Proceed to Next <i class="bi bi-arrow-right"></i>
                </a>
            </div>

        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // ---- Year columns: fill with actual years ----
            const currentYear = new Date().getFullYear();
            document.getElementById("th-year1").textContent = currentYear;
            document.getElementById("th-year2").textContent = currentYear - 1;
            document.getElementById("th-year3").textContent = currentYear - 2;
            document.querySelectorAll('.year1').forEach(el => el.textContent = "Yr " + currentYear);
            document.querySelectorAll('.year2').forEach(el => el.textContent = "Yr " + (currentYear - 1));
            document.querySelectorAll('.year3').forEach(el => el.textContent = "Yr " + (currentYear - 2));

            // ---- File upload label update ----
            document.querySelectorAll('.hidden-file-input').forEach(function (input) {
                input.addEventListener('change', function () {
                    const fileNameEl = document.getElementById(this.id + 'Name');
                    if (!fileNameEl) return;
                    const hasFile = this.files && this.files.length > 0;
                    fileNameEl.textContent = hasFile ? this.files[0].name : 'No file chosen';
                    fileNameEl.classList.toggle('has-file', hasFile);
                });
            });
        });
    </script>

</body>
</html>
