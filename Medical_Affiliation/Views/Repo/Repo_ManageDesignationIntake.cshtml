@model List<CollegeDesignationDetailsViewModel>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    Layout = null;
    ViewData["Title"] = "Designation Details";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
    int currentStep = 4;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RGUHS Portal</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- jQuery -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.20.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>

    <style>
        /* ===== TOKENS ===== */
        :root {
            --navy: #0d1b3e;
            --navy-mid: #1a2f5f;
            --blue: #1d4ed8;
            --blue-light: #3b82f6;
            --gold: #c8a84b;
            --gold-pale: #f7f0dc;
            --surface: #f4f6fb;
            --card-bg: #ffffff;
            --border: #dde3f0;
            --text-main: #0d1b3e;
            --text-muted: #6b7a99;
            --danger: #dc2626;
            --success: #16a34a;
            --radius: 14px;
            --shadow-sm: 0 2px 8px rgba(13,27,62,.07);
            --shadow-md: 0 6px 24px rgba(13,27,62,.10);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--surface);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ===== HEADER ===== */
        .portal-header {
            background: var(--navy);
            color: #fff;
            padding: 0 2rem;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 12px rgba(0,0,0,.25);
            border-bottom: 2px solid var(--gold);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .brand-emblem {
            width: 38px;
            height: 38px;
            background: var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--navy);
            font-weight: 700;
        }

        .brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .brand-title {
            font-family: 'Playfair Display', serif;
            font-size: 1rem;
            font-weight: 700;
            color: #fff;
        }

        .brand-sub {
            font-size: .7rem;
            color: rgba(255,255,255,.6);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .header-meta {
            font-size: .78rem;
            color: rgba(255,255,255,.7);
            display: flex;
            align-items: center;
            gap: 18px;
        }

            .header-meta span {
                display: flex;
                align-items: center;
                gap: 5px;
            }

        /* ===== LAYOUT ===== */
        .page-shell {
            display: flex;
            flex: 1;
        }

        .sidebar-wrap {
            width: 260px;
            flex-shrink: 0;
            background: var(--navy-mid);
            min-height: calc(100vh - 64px);
            position: sticky;
            top: 64px;
            align-self: flex-start;
        }

        .content-area {
            flex: 1;
            padding: 2rem 2.5rem;
            max-width: 960px;
            margin: 0 auto;
            width: 100%;
        }

        /* ===== PAGE TITLE ===== */
        .page-title-block {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 1.75rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--border);
        }

            .page-title-block h1 {
                font-family: 'Playfair Display', serif;
                font-size: 1.7rem;
                font-weight: 700;
                color: var(--navy);
            }

        .page-crumb {
            font-size: .78rem;
            color: var(--text-muted);
            margin-top: 4px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .page-crumb i {
                color: var(--gold);
            }

        /* ===== STEPPER ===== */
        .stepper-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.5rem 1.25rem;
            margin-bottom: 1.75rem;
            box-shadow: var(--shadow-sm);
        }

        .stepper-label {
            font-size: .68rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            margin-bottom: .75rem;
        }

        .stepper {
            display: flex;
            align-items: flex-start;
            overflow-x: auto;
            scrollbar-width: none;
            padding-bottom: 4px;
        }

            .stepper::-webkit-scrollbar {
                display: none;
            }

        .step-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
            min-width: 0;
            position: relative;
        }

            .step-item:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 14px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: var(--border);
                z-index: 0;
            }

            .step-item.completed:not(:last-child)::after {
                background: var(--success);
            }

        .step-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid var(--border);
            background: var(--card-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .7rem;
            font-weight: 700;
            color: var(--text-muted);
            position: relative;
            z-index: 1;
            transition: all .3s;
            flex-shrink: 0;
        }

        .step-item.active .step-dot {
            border-color: var(--blue);
            background: var(--blue);
            color: #fff;
            box-shadow: 0 0 0 4px rgba(29,78,216,.15);
        }

        .step-item.completed .step-dot {
            border-color: var(--success);
            background: var(--success);
            color: #fff;
        }

        .step-title {
            font-size: .65rem;
            font-weight: 500;
            color: var(--text-muted);
            text-align: center;
            margin-top: 6px;
            line-height: 1.3;
            max-width: 88px;
            word-break: break-word;
        }

        .step-item.active .step-title {
            color: var(--blue);
            font-weight: 600;
        }

        .step-item.completed .step-title {
            color: var(--success);
        }

        /* ===== PANEL ===== */
        .panel {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .panel-header {
            padding: .85rem 1.35rem;
            background: var(--navy);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .panel-header h5 {
                font-family: 'Playfair Display', serif;
                font-size: 1rem;
                font-weight: 700;
                color: #fff;
                margin: 0;
            }

            .panel-header i {
                color: var(--gold);
                font-size: 1.15rem;
            }

            .panel-header .record-pill {
                margin-left: auto;
                background: rgba(255,255,255,.15);
                border-radius: 20px;
                padding: 2px 12px;
                font-size: .72rem;
                color: #fff;
                font-weight: 700;
            }

        /* ===== DESIGNATION TABLE ===== */
        .desig-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .875rem;
        }

            .desig-table thead th {
                background: var(--surface);
                color: var(--text-muted);
                font-size: .68rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .8px;
                padding: .75rem 1.25rem;
                border-bottom: 2px solid var(--border);
            }

                .desig-table thead th:last-child {
                    text-align: center;
                }

            .desig-table tbody td {
                padding: .65rem 1.25rem;
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }

            .desig-table tbody tr:last-child td {
                border-bottom: none;
            }

            .desig-table tbody tr:hover td {
                background: #f4f7ff;
            }

        .desig-name {
            font-weight: 600;
            color: var(--navy);
            font-size: .875rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .desig-name::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: var(--gold);
                flex-shrink: 0;
            }

        .intake-input {
            font-family: 'DM Sans', sans-serif;
            font-size: .875rem;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            padding: .5rem .85rem;
            color: var(--text-main);
            background: #fafbfd;
            width: 140px;
            text-align: center;
            transition: border-color .2s, box-shadow .2s;
        }

            .intake-input:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px rgba(29,78,216,.1);
                background: #fff;
                outline: none;
            }

        /* Row number badge */
        .row-num {
            width: 24px;
            height: 24px;
            border-radius: 6px;
            background: var(--surface);
            border: 1px solid var(--border);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: .68rem;
            font-weight: 700;
            color: var(--text-muted);
            flex-shrink: 0;
        }

        /* ===== EMPTY STATE ===== */
        .empty-state {
            padding: 3rem;
            text-align: center;
            color: var(--text-muted);
        }

            .empty-state i {
                font-size: 2.5rem;
                margin-bottom: .75rem;
                display: block;
                color: #c0c8db;
            }

            .empty-state p {
                font-size: .85rem;
            }

        /* ===== BUTTONS ===== */
        .btn-official {
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .65rem 1.6rem;
            font-family: 'DM Sans', sans-serif;
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background .2s, transform .15s, box-shadow .2s;
            text-decoration: none;
        }

            .btn-official:hover {
                background: var(--blue);
                box-shadow: 0 4px 16px rgba(29,78,216,.25);
                transform: translateY(-1px);
                color: #fff;
            }

        .btn-official-outline {
            background: transparent;
            color: var(--navy);
            border: 1.5px solid var(--navy);
            border-radius: 8px;
            padding: .55rem 1.1rem;
            font-family: 'DM Sans', sans-serif;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all .2s;
            text-decoration: none;
        }

            .btn-official-outline:hover {
                background: var(--navy);
                color: #fff;
            }

        /* ===== NAV FOOTER ===== */
        .nav-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1.5rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--border);
        }

        /* ===== INFO BANNER ===== */
        .info-banner {
            background: var(--gold-pale);
            border: 1px solid #e0d0a0;
            border-radius: 10px;
            padding: .75rem 1.1rem;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: .8rem;
            color: #7c5e10;
            margin-bottom: 1.25rem;
        }

            .info-banner i {
                font-size: 1rem;
                flex-shrink: 0;
            }

        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--surface);
        }

        ::-webkit-scrollbar-thumb {
            background: #c0c8db;
            border-radius: 3px;
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 1100px) {
            .content-area {
                padding: 1.5rem 1.25rem;
            }

            .sidebar-wrap {
                display: none;
            }
        }

        @@media (max-width: 600px) {
            .portal-header .header-meta {
                display: none;
            }

            .intake-input {
                width: 100px;
            }
        }
    </style>
</head>
<body>

    <!-- ===================== HEADER ===================== -->
    <header class="portal-header">
        <a href="#" class="brand">
            <div class="brand-emblem"><i class="bi bi-mortarboard-fill"></i></div>
            <div class="brand-text">
                <span class="brand-title">RGUHS Affiliation Portal</span>
                <span class="brand-sub">Rajiv Gandhi University of Health Sciences</span>
            </div>
        </a>
        <div class="header-meta">
            @using System.Text.RegularExpressions
            @{
                var collegeFullName = HttpContextAccessor.HttpContext.Session.GetString("CollegeName") ?? "";
                var collegeName = Regex.Replace(collegeFullName, @"[\s\-:]*[A-Za-z]*\d{3,}\s*$", "").Trim();
            }
            @if (!string.IsNullOrEmpty(collegeName))
            {
                <span><i class="bi bi-building"></i> @collegeName</span>
            }
            <span><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dd MMM yyyy")</span>
        </div>
    </header>

    <!-- ===================== BODY SHELL ===================== -->
    <div class="page-shell">

        <main class="content-area">

            <!-- Page Title -->
            <div class="page-title-block">
                <div>
                    <h1>Designation Details</h1>
                    <div class="page-crumb">
                        <i class="bi bi-house-fill"></i> Home
                        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i> Admission Affiliation
                        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
                        <strong>Designation Intake</strong>
                    </div>
                </div>
                <span style="font-size:.72rem;color:var(--text-muted);background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:4px 12px;">
                    <i class="bi bi-shield-lock" style="color:var(--gold);"></i> Secure Session
                </span>
            </div>

            <!-- ===== STEPPER ===== -->
            @{
                var stepTitles = new[] {
                        "Basic Institute Details",
                        "Course Details",
                        "Clinical Material Details",
                        "Designation Details",
                        "Add College Faculty",
                        "College Performance"
                        };
            }
            <div class="stepper-card">
                <div class="stepper-label">Application Progress — Step @currentStep of @stepTitles.Length</div>
                <div class="stepper">
                    @for (int i = 0; i < stepTitles.Length; i++)
                    {
                        var isActive = (currentStep == i + 1);
                        var isCompleted = (currentStep > i + 1);
                        var cls = isActive ? "active" : (isCompleted ? "completed" : "");
                        <div class="step-item @cls">
                            <div class="step-dot">
                                @if (isCompleted)
                                {
                                    <i class="bi bi-check-lg" style="font-size:.75rem;"></i>
                                }
                                else
                                {

                                    @(i + 1)
                                }
                            </div>
                            <span class="step-title">@stepTitles[i]</span>
                        </div>
                    }
                </div>
            </div>

            <!-- ===== INFO BANNER ===== -->
            <div class="info-banner">
                <i class="bi bi-info-circle-fill"></i>
                Enter the <strong>Present Intake</strong> count for each designation below. All fields are required. Values must be 0 or greater.
            </div>

            <!-- ===== DESIGNATION FORM ===== -->
            <form asp-action="Repo_ManageDesignationIntake" method="post" id="designationForm" autocomplete="off">
                @Html.AntiForgeryToken()

                <div class="panel">
                    <div class="panel-header">
                        <i class="bi bi-person-badge"></i>
                        <h5>Faculty Designation Intake</h5>
                        <span class="record-pill">@Model.Count Designations</span>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="empty-state">
                            <i class="bi bi-person-x"></i>
                            <p>No designation records found.<br />Please contact your administrator.</p>
                        </div>
                    }
                    else
                    {
                        <table class="desig-table">
                            <thead>
                                <tr>
                                    <th style="width:48px;">#</th>
                                    <th>Designation</th>
                                    <th style="text-align:center;">Present Intake</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            <span class="row-num">@(i + 1)</span>
                                        </td>
                                        <td>
                                            <span class="desig-name">@Model[i].Designation</span>
                                            <input type="hidden" name="[@i].DesignationCode" value="@Model[i].DesignationCode" />
                                            <input type="hidden" name="[@i].Designation" value="@Model[i].Designation" />
                                        </td>
                                        <td style="text-align:center;">
                                            <input type="number"
                                                   name="[@i].PresentIntake"
                                                   value="@Model[i].PresentIntake"
                                                   class="intake-input"
                                                   min="0"
                                                   required
                                                   placeholder="0" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <!-- Panel Footer with Save -->
                        <div style="padding: 1rem 1.25rem; border-top: 1px solid var(--border); display:flex; justify-content:flex-end; background:var(--surface);">
                            <button type="submit" class="btn-official">
                                <i class="bi bi-save2"></i> Save &amp; Proceed
                            </button>
                        </div>
                    }
                </div>

                <!-- ===== NAV FOOTER ===== -->
                <div class="nav-footer">
                    <a asp-controller="Repo" asp-action="Repo_Affiliated_YearwiseMaterials" class="btn-official-outline">
                        <i class="bi bi-arrow-left"></i> Previous
                    </a>
                    <span style="font-size:.75rem;color:var(--text-muted);">
                        <i class="bi bi-info-circle"></i> All intake values are mandatory.
                    </span>
                    <button type="submit" class="btn-official">
                        <i class="bi bi-save2"></i> Save &amp; Proceed <i class="bi bi-arrow-right"></i>
                    </button>
                </div>

            </form>

        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
