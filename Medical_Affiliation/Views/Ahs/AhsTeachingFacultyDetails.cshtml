@inject IHttpContextAccessor HttpContextAccessor
@model AhsTeachingFactultyDetails
@{
    ViewData["Title"] = "AHS Teaching Faculty Details";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
}
<style>
    .navbar-container {
        display: flex;
        justify-content: center;
        gap: 5rem;
        padding: 31px 6px;
        background: white;
        align-items: center;
        margin-left: 13rem;
        width: 97%;
    }

    .container {
        margin-left: 12rem;
    }
</style>
<div class="navbar-container">
    <div style="width: 80%; text-align: center;">
        <h2 class="text-3xl fw-bold text-indigo-900 mb-3">Welcome, @Model.CollegeName</h2>


    </div>
    <form asp-controller="Collegelogin" asp-action="Logout" class="flex justify-content-between fade-in" method="post" class="mb-0">
        @* <p class="text-gray-700 text-lg d-inline"><i class="fas fa-map-marker-alt mr-2 icon-color "></i> @Model.CollegeAddress</p> *@
        @Html.AntiForgeryToken()
        <button type="submit" class="btn text-danger btn-outline-danger py-2 px-3 rounded-xl hover-scale shadow-custom">
            <i class="fas fa-sign-out-alt mr-2 icon-color"></i> Logout
        </button>
    </form>
</div>
<div class="container mt-4">
    @if (!string.IsNullOrEmpty(facultyCode))
    {
        @await Component.InvokeAsync("Sidebar")
    }
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-primary text-white py-3 rounded-top-4">
            <h4 class="mb-0 text-center">AHS Teaching Faculty Details</h4>
        </div>

        <form asp-action="AhsTrainingFacultyDetails" method="post" enctype="multipart/form-data" class="p-4">
            <input type="hidden" asp-for="CollegeCode" />
            <input type="hidden" asp-for="CollegeName" />

            <div class="row g-4">
                <!-- Left Column -->
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="TeachingFacultyName" class="form-label fw-semibold">Teaching Faculty Name</label>
                        <input asp-for="TeachingFacultyName" class="form-control" placeholder="Enter full name" />
                        <span asp-validation-for="TeachingFacultyName" class="text-danger small"></span>
                    </div>

                    

                    <div class="mb-3">
                        <label asp-for="AadharNumber" class="form-label fw-semibold">Aadhar Number</label>
                        <input asp-for="AadharNumber" class="form-control" placeholder="Enter Aadhar number" />
                        <span asp-validation-for="AadharNumber" class="text-danger small"></span>
                    </div>


                    <div class="mb-3">
                        <label asp-for="PanNumber" class="form-label fw-semibold">Pan Number</label>
                        <input asp-for="PanNumber" class="form-control" placeholder="Enter PAN number" />
                        <span asp-validation-for="PanNumber" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="selectedFacultyDepartment" class="form-label fw-semibold">Department</label>
                        @Html.DropDownListFor(m => m.selectedFacultyDepartment, Model.FacultyDepartment, "-- Select Department --", new { @class = "form-select" })
                        <span asp-validation-for="selectedFacultyDepartment" class="text-danger small"></span>
                    </div>

                    <div class="mb-3 ">
                        <label asp-for="Form16_bankStatement" class="form-label fw-semibold">Upload Form-16 / Bank Statement</label>
                        <div class="d-flex flex-row gap-2">
                        <input asp-for="Form16_bankStatement" type="file" id="form16Input" accept=".pdf" class="form-control d-none" style="width: 70%" />
                        <button type="button" class="btn btn-outline-primary" id="uploadForm16Btn">Upload File</button>
                        <span asp-validation-for="Form16_bankStatement" class="text-danger small"></span>

                        @if (Model.HasForm16File)
                        {
                            <a asp-action="GetForm16_BankStatement" asp-route-collegeCode="@Model.CollegeCode" target="_blank" class="btn btn-outline-secondary btn-sm">
                                View File
                            </a>
                        }
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UgUniversityName" class="form-label fw-semibold">UG University Name</label>
                        <input asp-for="UgUniversityName" class="form-control" placeholder="Enter UG University name" />
                        <span asp-validation-for="UgUniversityName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PgUniverstityName" class="form-label fw-semibold">PG University Name</label>
                        <input asp-for="PgUniverstityName" class="form-control" placeholder="Enter PG University name" />
                        <span asp-validation-for="PgUniverstityName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TeachingExpAfterUg" class="form-label fw-semibold">Teaching Experience After Ug</label>
                        <input asp-for="TeachingExpAfterUg" class="form-control" placeholder="e.g. 3 years 6 months" />
                        <span asp-validation-for="TeachingExpAfterUg" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DateOfJoining" class="form-label fw-semibold">Date Of Joining</label>
                        <input asp-for="DateOfJoining" type="date" class="form-control" />
                        <span asp-validation-for="DateOfJoining" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="DateOfBirth" class="form-label fw-semibold">Date Of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                    </div>


                    <div class="mb-3 ">
                        <label asp-for="AadharFile" class="form-label fw-semibold">Upload Aadhar (PDF)</label>
                        <div class="d-flex gap-3">
                        <input asp-for="AadharFile" type="file" accept=".pdf" class="form-control d-none" id="adharFile"/>
                        <span asp-validation-for="AadharFile" class="text-danger small"></span>
                        <button type="button" class="btn btn-outline-primary" id="adharBtn">Upload File</button>

                        @if (Model.HasAdharFile)
                        {
                            <a asp-action="GetAdharCard" asp-route-collegeCode="@Model.CollegeCode" target="_blank" class="btn btn-outline-secondary btn-sm">
                                View File
                            </a>
                        }
                        </div>

                    </div>

                    <div class="mb-3">
                        <label asp-for="PanFile" class="form-label fw-semibold">Upload PAN (PDF)</label>
                        <div class="d-flex gap-3">
                        <input asp-for="PanFile" type="file" accept=".pdf" class="form-control d-none" id="panFile" />
                        <span asp-validation-for="PanFile" class="text-danger small"></span>
                        <button class="btn btn-outline-primary" id="panBtn">Upload file</button>

                            @if (Model.HasPanFile)
                            {
                                <a asp-action="GetPanCard" asp-route-collegeCode="@Model.CollegeCode" target="_blank" class="btn btn-outline-secondary btn-sm">
                                    View File
                                </a>
                            }
                        </div>
                    </div>
                    

                    <div class="mb-3">
                        <label asp-for="selectedFacultyDesignation" class="form-label fw-semibold">Designation</label>
                        @Html.DropDownListFor(m => m.selectedFacultyDesignation, Model.FacultyDesignation, "-- Select Designation --", new { @class = "form-select" })
                        <span asp-validation-for="selectedFacultyDesignation" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Qualification" class="form-label fw-semibold"></label>
                        <input asp-for="Qualification" class="form-control" placeholder="Enter qualification" />
                        <span asp-validation-for="Qualification" class="text-danger small"></span>
                    </div>

                    @* <div class="row"> *@
                        <div class="mb-3">
                            <label asp-for="selectedUgYear" class="form-label fw-semibold">UG Passing Year</label>
                            @Html.DropDownListFor(m => m.selectedUgYear, Model.UGPassingYearList, "-- Select Year --", new { @class = "form-select" })
                        <span asp-validation-for="selectedUgYear" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="selectedPgYear" class="form-label fw-semibold">PG Passing Year</label>
                            @Html.DropDownListFor(m => m.selectedPgYear, Model.PGPassingYearList, "-- Select Year --", new { @class = "form-select" })
                            <span asp-validation-for="selectedPgYear" class="text-danger small"></span>
                        </div>
                    @* </div> *@


                    <div class="mb-5">
                        <label asp-for="TeachingExpAfterPg" class="form-label fw-semibold">Teaching Experience After Pg</label>
                        <input asp-for="TeachingExpAfterPg" class="form-control" placeholder="e.g. 2 years 4 months" />
                        <span asp-validation-for="TeachingExpAfterPg" class="text-danger small"></span>
                    </div>


                    <div class="d-flex align-items-center mb-3">
                        <label for="pgGuide" class="fw-semibold me-3 mb-0">Recognized PG Guide</label>
                        <input asp-for="RecognizedPgGuide" class="form-check-input" type="checkbox" id="pgGuide" />
                    </div>

                </div>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-success px-4 py-2 shadow-sm">Save Faculty Details</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            // Trigger hidden file input
            $('#uploadForm16Btn').click(function () {
                $('#form16Input').click();
            });
            $('#adharBtn').click(function () {
                $('#adharFile').click();
            });

            $('#panBtn').click(function () {
                $('#panFile').click();
            });
        });
        var message = '@TempData["facDetails"]';
        if (message) {
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: message,
                confirmButtonColor: '#3085d6',
                confirmButtonText: 'OK'
            });
        }
    </script>
}
