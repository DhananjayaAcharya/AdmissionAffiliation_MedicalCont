@model Medical_Affiliation.Models.NonTeachingStaffSectionVM

<div class="general-body">
    <div class="section-block">
        <div class="section-header-block mb-3">
            <div class="section-title-text department-badge">
                <i class="bi bi-person-badge"></i>
                Non-Teaching Staff Details
            </div>
        </div>

        @if (Model != null && Model.Staffs != null && Model.Staffs.Any())
        {
            <div class="data-table-wrapper">
                <table class="table data-table align-middle">
                    <thead>
                        <tr>
                            <th>Staff Name</th>
                            <th>Designation</th>
                            <th class="text-center">PF</th>
                            <th class="text-center">ESI</th>
                            <th class="text-center">Service Register</th>
                            <th class="text-center">Salary Register</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var staff in Model.Staffs)
                        {
                            <tr>
                                <td>@staff.StaffName</td>
                                <td>@staff.Designation</td>
                                <td class="text-center">
                                    @(staff.PfProvided ? "Yes" : "No")
                                </td>
                                <td class="text-center">
                                    @(staff.EsiProvided ? "Yes" : "No")
                                </td>
                                <td class="text-center">
                                    @(staff.ServiceRegisterMaintained ? "Yes" : "No")
                                </td>
                                <td class="text-center">
                                    @(staff.SalaryAcquaintanceRegister ? "Yes" : "No")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No non-teaching staff details available.</p>
            </div>
        }
    </div>
</div>
