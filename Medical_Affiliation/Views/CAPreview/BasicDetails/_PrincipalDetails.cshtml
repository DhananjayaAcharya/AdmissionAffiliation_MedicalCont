@model InstituionBasicDetailsDisplayVM

<div class="general-body">
    <div class="section-block">
        <div class="section-header-block mb-3">
            <div class="section-title-text department-badge">
                <i class="bi bi-person-workspace"></i>
                Principal Details
            </div>
        </div>

        @if (Model != null)
        {
            <div class="data-table-wrapper">
                <table class="table data-table align-middle">
                    <tbody>
                        <tr>
                            <th>Name</th>
                            <td>@Model.PrincipalDetailDisplayVM.PrincipalName</td>
                        </tr>
                        <tr>
                            <th>Qualification</th>
                            <td>@Model.PrincipalDetailDisplayVM.PrincipalQualification</td>
                        </tr>
                        <tr>
                            <th>Qualification Date</th>
                            <td>@Model.PrincipalDetailDisplayVM.PrincipalQualificationDate</td>
                        </tr>
                        <tr>
                            <th>University</th>
                            <td>@Model.PrincipalDetailDisplayVM.PrincipalUniversity</td>
                        </tr>
                        <tr>
                            <th>State Council Number</th>
                            <td>@Model.PrincipalDetailDisplayVM.PrincipalStateCouncilNumber</td>
                        </tr>
                        <tr>
                            <th>Recognized by MCI</th>
                            <td>@Model.PrincipalDetailDisplayVM.RecognizedByMci</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No Principal details available.</p>
            </div>
        }
    </div>
</div>
