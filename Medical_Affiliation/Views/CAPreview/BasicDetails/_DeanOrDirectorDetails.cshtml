@model InstituionBasicDetailsDisplayVM

<div class="general-body">
    <div class="section-block">
        <div class="section-header-block mb-3">
            <div class="section-title-text department-badge">
                <i class="bi bi-person-badge"></i>
                Dean / Director Details
            </div>
        </div>

        @if (Model != null)
        {
            <div class="data-table-wrapper">
                <table class="table data-table align-middle">
                    <tbody>
                        <tr>
                            <th>Name</th>
                            <td>@Model.DeanOrDirectorDetailDisplayVM.DeanOrDirectorName</td>
                        </tr>
                        <tr>
                            <th>Qualification</th>
                            <td>@Model.DeanOrDirectorDetailDisplayVM.DeanQualification</td>
                        </tr>
                        <tr>
                            <th>Qualification Date</th>
                            <td>@Model.DeanOrDirectorDetailDisplayVM.DeanQualificationDate</td>
                        </tr>
                        <tr>
                            <th>University</th>
                            <td>@Model.DeanOrDirectorDetailDisplayVM.DeanUniversity</td>
                        </tr>
                        <tr>
                            <th>State Council Number</th>
                            <td>@Model.DeanOrDirectorDetailDisplayVM.DeanStateCouncilNumber</td>
                        </tr>
                        <tr>
                            <th>Recognized by MCI</th>
                            <td>@Model.DeanOrDirectorDetailDisplayVM.RecognizedByMci</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>No Dean / Director details available.</p>
            </div>
        }
    </div>
</div>
