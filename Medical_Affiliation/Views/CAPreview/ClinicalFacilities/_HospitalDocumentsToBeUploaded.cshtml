@model List<HospitalDocumentsToBeUploadedDisplayViewModel>

<div class="general-body">
    <div class="section-block">

        <div class="section-header-block">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <div class="section-title-text department-badge">
                        <i class="bi bi-file-earmark-medical"></i>
                        Hospital Documents
                    </div>
                    <p class="section-description">
                        Uploaded documents and current status
                    </p>
                </div>

                @if (Model != null && Model.Any())
                {
                    <span class="count-badge">
                        @Model.Count documents
                    </span>
                }
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="data-table-wrapper">
                <table class="table data-table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Hospital</th>
                            <th class="text-end">Total Beds</th>
                            <th>Document</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in Model)
                        {
                            <tr>
                                <td class="fw-semibold text-dark">
                                    @doc.HospitalName
                                </td>

                                <td class="text-end">
                                    @doc.TotalBeds
                                </td>

                                <td>
                                    @doc.DocumentName
                                </td>

                                <td class="text-center">
                                    @if (doc.DocumentExists)
                                    {
                                        <span class="status-badge-maintained">
                                            ✓ Uploaded
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge-not-maintained">
                                            ✗ Pending
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-file-earmark-x"></i>
                <p class="mb-0">No hospital documents available.</p>
            </div>
        }

    </div>
</div>

