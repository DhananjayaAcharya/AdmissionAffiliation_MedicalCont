@model AffiliationPaymentViewModel

<style>
    .payment-section {
        background: linear-gradient(135deg, #fef3c7 0%, #fff7ed 100%);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(245, 158, 11, 0.15);
        overflow: hidden;
        border: 1px solid rgba(245, 158, 11, 0.2);
        margin-bottom: 2rem;
    }

    .payment-header {
        /* background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); */
        padding: 0.8rem 1rem;
    }

    .payment-title {
        color: white;
        font-size: 1.3rem;
        font-weight: 700;
    }

    .payment-body {
        padding: 2rem;
        background: white;
    }

    .payment-block {
        background: linear-gradient(135deg, #fffbeb 0%, #fefce8 100%);
        border-radius: 16px;
        padding: 1.5rem;
        border: 1px solid #fde68a;
        margin-bottom: 1.5rem;
    }

    .payment-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        color: #92400e;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .payment-value {
        font-size: 1rem;
        font-weight: 600;
        color: #1f2937;
    }

    .amount-highlight {
        font-size: 1.4rem;
        font-weight: 700;
        color: #059669;
    }

    .download-btn {
        background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .empty-state {
        text-align: center;
        padding: 2rem;
        color: #9ca3af;
        border: 2px dashed #e5e7eb;
        border-radius: 12px;
    }
</style>
<link rel="stylesheet" href="~/css/preview.css" asp-append-version="true" />

<div class="academic-section">

    <!-- HEADER -->
    <div class="academic-header d-flex justify-content-between align-items-center">
        <h2 class="academic-title academic-badge">Payment Details</h2>

        <a class="edit-button"
               href="@Url.Action("AffiliationPayment", "Payment")">
            <i class="bi bi-pencil-square"></i>
            Edit
        </a>
    </div>

    <div class="payment-body">

        @if (Model != null && Model.Id > 0)
        {
            <div class="payment-block">

                <div class="row g-4">

                    <!-- Amount -->
                    <div class="col-md-4">
                        <div class="payment-label">Amount Paid</div>
                        <div class="amount-highlight">₹ @Model.Amount</div>
                    </div>

                    <!-- Date -->
                    <div class="col-md-4">
                        <div class="payment-label">Payment Date</div>
                        <div class="payment-value">
                            @Model.PaymentDateDisplay
                        </div>
                    </div>

                    <!-- Transaction -->
                    <div class="col-md-4">
                        <div class="payment-label">Transaction Ref No</div>
                        <div class="payment-value">
                            @Model.TransactionReferenceNo
                        </div>
                    </div>

                </div>

                <hr class="my-4" />

                <!-- Document -->
                <div>
                    <div class="payment-label">Supporting Document</div>

                    @if (!string.IsNullOrEmpty(Model.SupportingDocument))
                    {
                        <a href="@Url.Action("ViewFile", "AffiliationPayment", new { path = Model.SupportingDocument })"
                               target="_blank"
                               class="download-btn">
                            <i class="bi bi-file-earmark-pdf"></i>
                            View Document
                        </a>
                    }
                    else
                    {
                        <span class="text-muted fst-italic">
                            No document uploaded
                        </span>
                    }
                </div>

            </div>
        }
        else
        {
            <!-- EMPTY -->
            <div class="empty-state">
                <i class="bi bi-wallet2" style="font-size:2rem;"></i>
                <p class="mt-2">No payment details available.</p>
            </div>
        }

    </div>

</div>