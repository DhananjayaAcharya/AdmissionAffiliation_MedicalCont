@model MedicalLibraryDisplayViewModel

<!-- ===================== LIBRARY BUILDING DETAILS ===================== -->

<div class="general-body">
    <div class="section-block">

        <!-- HEADER -->
        <div class="section-header-block mb-3">
            <div class="section-title-text section-badge">
                <i class="bi bi-building"></i>
                Library Building
            </div>

            <p class="section-description">
                Physical infrastructure details of the library building
            </p>
        </div>

        <div class="data-table-wrapper">
            <table class="table data-table align-middle">
                <thead>
                    <tr>
                        <th>Detail</th>
                        <th class="text-center">Information</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        <tr>
                            <td>Independent Library Building</td>
                            <td class="text-center">
                                @if (Model.LibraryBuildingVM.IsIndependent)
                                {
                                    <span class="status-badge-maintained">Yes</span>
                                }
                                else
                                {
                                    <span class="status-badge-not-maintained">No</span>
                                }
                            </td>
                        </tr>

                        <tr>
                            <td>Total Area (Sq. Mtrs)</td>
                            <td class="text-center">
                                @if (Model.LibraryBuildingVM.AreaSqMtrs > 0)
                                {
                                    <span class="status-badge-maintained">
                                        @Model.LibraryBuildingVM.AreaSqMtrs Sq. Mtrs
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">Not Provided</span>
                                }
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="text-center text-muted">
                                Library building details not available
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>
