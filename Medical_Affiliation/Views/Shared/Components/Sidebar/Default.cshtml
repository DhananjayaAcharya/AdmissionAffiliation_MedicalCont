@model SidebarViewModel
@inject IHttpContextAccessor HttpContextAccessor
@{
    var isSubmitDisplayString = HttpContextAccessor.HttpContext.Session.GetString("IsSubmitDisplay");
    var ugCourse = HttpContextAccessor.HttpContext.Session.GetString("UgCourse");
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    var collegecode = HttpContextAccessor.HttpContext.Session.GetString("CollegeCode");
    bool isSubmitDisplay = false;
    var showNodalOfficer = HttpContextAccessor.HttpContext.Session.GetString("ShowNodalOfficer");
    var showIntakeDetails = HttpContextAccessor.HttpContext.Session.GetString("ShowIntakeDetails");
    var showRepository = HttpContextAccessor.HttpContext.Session.GetString("ShowRepository");
    var sidebarActionMethod = HttpContextAccessor.HttpContext.Session.GetString("sidebarActionMethod");
    var sidebarController = HttpContextAccessor.HttpContext.Session.GetString("sidebarController");

    if (!string.IsNullOrEmpty(isSubmitDisplayString))
    {
        bool.TryParse(isSubmitDisplayString, out isSubmitDisplay);
    }

    // Helper to check active link (optional improvement)
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<style>
    :root {
        --sidebar-bg: #0f1e3a; /* deep navy */
        --sidebar-accent: #097969; /* teal accent */
        --sidebar-text: #e0f0ff;
        --sidebar-hover: #1a355c;
        --sidebar-active: #097969;
        --sidebar-border: rgba(255,255,255,0.08);
        --header-height-lg: 15vh;
    }

    .sidebar {
        position: fixed;
        top: var(--header-height, 100px);
        left: 0;
        width: 280px;
        height: calc(100vh - var(--header-height));
        background: var(--sidebar-bg);
        color: var(--sidebar-text);
        box-shadow: 2px 0 20px rgba(0,0,0,0.35);
        padding: 1.5rem 1rem;
        display: flex;
        flex-direction: column;
        z-index: 900;
        overflow-y: auto;
        border-right: 1px solid var(--sidebar-border);
        transition: width 0.3s ease;
    }

    .sidebar-header {
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1.2rem;
        border-bottom: 1px solid var(--sidebar-border);
    }

        .sidebar-header h4 {
            font-size: 1.35rem;
            font-weight: 700;
            margin: 0;
            color: white;
            letter-spacing: 0.5px;
        }

    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sidebar-item {
        margin-bottom: 0.35rem;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        padding: 0.85rem 1.2rem;
        color: var(--sidebar-text);
        text-decoration: none;
        border-radius: 8px;
        font-weight: 500;
        font-size: 0.98rem;
        transition: all 0.25s ease;
    }

        .sidebar-link i {
            margin-right: 12px;
            font-size: 1.15rem;
            width: 24px;
            text-align: center;
        }

        .sidebar-link:hover {
            background: var(--sidebar-hover);
            color: white;
            transform: translateX(4px);
        }

        .sidebar-link.active {
            background: var(--sidebar-active);
            color: white;
            font-weight: 600;
        }

    .sidebar-footer {
        margin-top: auto;
        padding-top: 1.5rem;
        border-top: 1px solid var(--sidebar-border);
    }

    .sidebar-btn-password {
        width: 100%;
        background: rgba(9,121,105,0.15);
        border: 1px solid var(--sidebar-accent);
        color: var(--sidebar-accent);
        font-weight: 600;
        padding: 0.75rem;
        border-radius: 8px;
        transition: all 0.3s;
    }

        .sidebar-btn-password:hover {
            background: var(--sidebar-accent);
            color: white;
        }

    /* Mobile / responsive */
    @@media (max-width: 991px) {
        .sidebar {
            position: relative;
            width: 100%;
            height: auto;
            top: 0;
            left: 0;
            box-shadow: none;
            border-right: none;
            border-bottom: 1px solid var(--sidebar-border);
            padding: 1.2rem;
        }
    }

    @@media (max-width: 1200px) {
        .sidebar {
            width: 240px;
        }

        .sidebar-link {
            font-size: 0.95rem;
            padding: 0.75rem 1rem;
        }
    }

    @@media (min-width: 1024px) {
        .sidebar {
            height: calc(100vh - var(--header-height-lg));
            overflow-y: auto;
        }
        .sidebar::-webkit-scrollbar{
            display: none;
        }
    }

    .sidebar .dropdown-menu {
        position: static !important;
        display: block;
        margin-left: 10px;
        background: transparent;
        border: none;
    }

    .sidebar .dropdown-item {
        color: #e0f0ff;
        padding-left: 20px;
    }

        .sidebar .dropdown-item:hover {
            background: #1a355c;
        }

    .d-none {
        display: none !important;
    }

    splay: none;
    }
</style>

