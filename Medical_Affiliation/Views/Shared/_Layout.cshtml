@inject IHttpContextAccessor HttpContextAccessor
@{
    var facultyCode = HttpContextAccessor.HttpContext?.Session?.GetString("FacultyCode");
    var facultyIntCode = string.IsNullOrEmpty(facultyCode) ? 0 : Convert.ToInt64(facultyCode);
    var CollegeName = HttpContextAccessor.HttpContext?.Session?.GetString("CollegeName");
    var CollegeCode = HttpContextAccessor.HttpContext?.Session?.GetString("CollegeCode");
    var logoutController = HttpContextAccessor.HttpContext?.Session?.GetString("logoutController");
    var typeOfAffiliationList = ViewData["TypeOfAffiliationList"] as List<SelectListItem>;
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
}
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
<!DOCTYPE html>
<html lang="@Thread.CurrentThread.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"]) - RGUHS Admission Affiliation</title>

    <!-- Bootstrap 5.3.8 (latest as of Feb 2026) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-M7i8m4v1m4g3y0vZ5p5o5l5f5g5h5i5j5k5l5m5n5o5p5q5r5s5t5u5v5w5x5y5z5"
          crossorigin="anonymous">

    <link rel="stylesheet" href="~/css/site.css" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
          integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- DataTables 2.3.7 (latest stable) -->
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.1.2/css/buttons.bootstrap5.min.css" />

    <!-- SweetAlert2 11.26.18 (latest patch Feb 2026) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.min.css" />

</head>
<body>
    <div class="page-wrapper">
        <header class="modern-header">
            <div class="modern-header-inner">
                <div class="brand-block">
                    <img src="~/images/newLogo.jpeg" id="signupLogo" alt="University Logo" />
                    <div>
                        <div class="brand-title">@Localizer["UniversityTitle"]</div>
                        <div class="brand-subtitle">@Localizer["UniversityAddress"]</div>
                    </div>
                </div>

                <div class="header-center">
                    <div class="page-title">@ViewData["Title"]</div>
                    <div class="page-subtitle">@Localizer["UniversityTitle"]</div>
                    @if (!string.IsNullOrEmpty(CollegeCode) && !string.IsNullOrEmpty(CollegeName))
                    {
                        <div class="college-info">
                            <i class="fas fa-university"></i>
                            <span>@CollegeName</span>
                        </div>
                    }
                </div>

                <div class="header-actions">
                    <div class="language-switcher">
                        <select id="languageSelect" onchange="changeLanguage()" aria-label="@Localizer["SelectLanguage"]">
                            <option value="en" selected="@(Thread.CurrentThread.CurrentUICulture.Name == "en")">English</option>
                            <option value="kn" selected="@(Thread.CurrentThread.CurrentUICulture.Name == "kn")">ಕನ್ನಡ (Kannada)</option>
                        </select>
                    </div>
                    @if (facultyIntCode != 0)
                    {
                        <form asp-controller="CollegeLogin" asp-action="Logout" method="post" class="mb-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn logout-btn">
                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                            </button>
                        </form>
                    }
                    <span class="chip">University Portal</span>
                </div>
            </div>

            @if (string.IsNullOrEmpty(facultyCode))
            {
                <div class="navbar-wrap">
                    <div class="container">
                        <ul class="navbar-nav flex-row gap-4 justify-content-center">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Home")">@Localizer["Nav_Home"]</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="loginDropdown" data-bs-toggle="dropdown" role="button" aria-expanded="false">
                                    @Localizer["Nav_Login"]
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="@Url.Action("Login", "Login")">@Localizer["Nav_Login_College"]</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("UniversityLogin", "Admin")">@Localizer["Nav_Login_University"]</a></li>
                                    <li>
                                        <a class="dropdown-item d-flex align-items-center" href="@Url.Action("Auth", "LICInspection")">
                                            <i class="fas fa-user-graduate me-2 text-primary"></i>
                                            RGUHS Assignment
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                </div>
            }
        </header>

        <div class="page-shell">
            <aside class="modern-sidebar">
                <div class="sidebar-header">
                    <h2>Portal menu</h2>
                    <p>Quick access to core pages and login actions.</p>
                </div>
                <div class="sidebar-links">
                    <a class="sidebar-link" href="@Url.Action("Index", "Home")">
                        <i class="fas fa-home"></i>
                        Home
                    </a>
                    <a class="sidebar-link" href="@Url.Action("Login", "Login")">
                        <i class="fas fa-university"></i>
                        College login
                    </a>
                    <a class="sidebar-link" href="@Url.Action("UniversityLogin", "Admin")">
                        <i class="fas fa-user-shield"></i>
                        University login
                    </a>
                    <a class="sidebar-link" href="@Url.Action("Auth", "LICInspection")">
                        <i class="fas fa-user-graduate"></i>
                        RGUHS assignment
                    </a>
                </div>
                <div class="sidebar-footer">
                    <strong>Status</strong>
                    <div>@(facultyIntCode != 0 ? CollegeName : "Guest user")</div>
                </div>
            </aside>

            <section class="page-content">
                <main>
                    <div class="container-fluid">
                        @RenderBody()
                        @RenderSection("Styles", required: false)
                    </div>
                </main>
            </section>
        </div>

        <footer>
            <div class="container-fluid">
                <p>@Localizer["FooterText"]</p>
                <p>
                    <a href="mailto:support@rguhs.ac.in">@Localizer["Nav_ContactSupp"]</a>
                    |
                    <a href="/Home/Privacy">@Localizer["Nav_Privacy"]</a>
                </p>
            </div>
        </footer>
    </div>

    <!-- Scripts (updated versions) -->
    <script src="https://code.jquery.com/jquery-4.0.0.min.js"
            integrity="sha256-..." crossorigin="anonymous"></script> <!-- Replace integrity after testing -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-..." crossorigin="anonymous"></script>

    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.1.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.1.2/js/buttons.print.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.18/dist/sweetalert2.all.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/language.js" asp-append-version="true"></script>

    <input type="hidden" id="languageErrorTitle" value="@Localizer["ErrorTitle"]" />
    <input type="hidden" id="languageErrorMessage" value="@Localizer["LanguageChangeError"]" />
    <input type="hidden" id="languageOK" value="@Localizer["OK"]" />
    <input type="hidden" id="setLanguageUrl" value="@Url.Action("SetLanguage", "Home")" />

    @RenderSection("Scripts", required: false)
</body>
</html>

