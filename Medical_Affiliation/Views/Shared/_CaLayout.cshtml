@* Views/Shared/_CaLayout.cshtml *@
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Continuous Affiliation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />


    <style>
        html, body {
            margin: 0;
            padding: 0;
            min-height: 100%;
            background: #f4f7fb;
            color: #1f2937;
            font-family: 'Segoe UI', 'Arial', sans-serif;
        }

        .page-wrapper {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .ca-shell {
            display: flex;
            min-height: 100vh;
            background: #f4f7fb;
        }

        .ca-main {
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
            background: #f4f7fb;
        }

        .ca-body {
            flex: 1;
            min-width: 0;
            background: #f4f7fb;
            overflow-y: auto;
            padding: 1.5rem;
        }

        .ca-topbar {
            background: linear-gradient(90deg, #0d47a1 0%, #0f5bb7 100%);
            color: #fff;
            border-bottom: 1px solid rgba(255,255,255,0.14);
            padding: 1rem 1.25rem;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .ca-topbar-left {
            display: flex;
            align-items: center;
            gap: 0.9rem;
            min-width: 260px;
        }

        .ca-logo {
            width: 56px;
            height: 56px;
            object-fit: contain;
            background: #fff;
            border-radius: 18px;
            padding: 0.35rem;
        }

        .ca-topbar-title h4 {
            margin: 0;
            color: #fff;
            font-weight: 700;
        }

        .ca-topbar-title p {
            margin: 0.2rem 0 0;
            color: rgba(255,255,255,0.86);
            font-size: 0.92rem;
        }

        .ca-pill {
            background: rgba(255,255,255,0.16);
            border: 1px solid rgba(255,255,255,0.22);
            border-radius: 999px;
            padding: 0.5rem 0.85rem;
            font-weight: 600;
            color: #fff;
        }

        @@media (max-width: 991px) {
            .ca-topbar {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>

    <link rel="stylesheet" href="~/css/common-form.css" />
</head>
<body>

    @* ── Include your existing top header here ── *@
    @* Example: @await Html.PartialAsync("_Header") *@

    <div class="ca-shell">
        @await Html.PartialAsync("_ContinuousAffiliationSidebar")
        <div class="ca-main">
            <header class="ca-topbar">
                <div class="ca-topbar-left">
                    <img src="~/images/newLogo.jpeg" class="ca-logo" alt="University Logo" />
                    <div class="ca-topbar-title">
                        <h4>@ViewData["Title"]</h4>
                        <p>Continuous Affiliation Portal</p>
                    </div>
                </div>
                <span class="ca-pill">University Portal</span>
            </header>
            <main class="ca-body">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
