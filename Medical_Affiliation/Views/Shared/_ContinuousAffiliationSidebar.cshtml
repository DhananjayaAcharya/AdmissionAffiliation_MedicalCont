        display: flex;
        justify-content: space-between;
        padding: 8px 16px;
        text-decoration: none;
        color: #333;
    }

        .step-item.active {
            background: #e6f0ff;
            font-weight: bold;
        } */

    .tick {
        color: green;
    }

