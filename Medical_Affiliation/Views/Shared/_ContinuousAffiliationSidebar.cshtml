@* Views/Shared/_ContinuousAffiliationSidebar.cshtml *@
@inject IHttpContextAccessor HttpContextAccessor

@{
    var level = HttpContextAccessor.HttpContext.Session.GetString("CourseLevel") ?? "UG";
    var doneRaw = HttpContextAccessor.HttpContext.Session.GetString("CA_Done") ?? "";
    var doneSteps = doneRaw.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
    var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAct = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    // ── Step definition ───────────────────────────────────────────────────
    // Flat list — Physical Facilities sub-items are shown as individual steps
    var allSteps = new List<dynamic>
    {
        // ================= BASIC DETAILS =================
        new { Key="Institution", Label="Institution Details", Group="Basic Details", Ctrl="ContinuesAffiliation_Facultybased", Act="Institution_Details" },
        new { Key="TrustDetails", Label="Trust Details", Group="Basic Details", Ctrl="ContinuesAffiliation_Facultybased", Act="aff_institutedetails" },
        new { Key="TrustMemberDetails", Label="Trust Member Details", Group="Basic Details", Ctrl="ContinuesAffiliation_Facultybased", Act="Aff_TrustMemberDetails" },

        // 👇 CONDITIONAL STEP
        // MBBS only for UG
        // we will add below dynamically

        new { Key="DeanDetails", Label="Dean / Director Details", Group="Basic Details", Ctrl="ContinuesAffiliation_Facultybased", Act="Dean_DirectorDetails" },
        new { Key="PrincipalDetails", Label="Principal Details", Group="Basic Details", Ctrl="ContinuesAffiliation_Facultybased", Act="Aff_PrincipalDetails" },

        // ================= PHYSICAL INFRASTRUCTURE =================
        new { Key="LandBuilding", Label="Land & Building", Group="Physical Infrastructure", Ctrl="Medical_ContinuousAffiliation", Act="Medical_LandBuildingdetails" },
        new { Key="SkillsLab", Label="Classroom & Laboratory", Group="Physical Infrastructure", Ctrl="Medical_ContinuousAffiliation", Act="Medical_SkillsLaboratory" },
        new { Key="Equipment", Label="Equipment Details", Group="Physical Infrastructure", Ctrl="Medical_ContinuousAffiliation", Act="Medical_EquimentDetails" },
        new { Key="ClinicalFacilities", Label="Clinical Facilities", Group="Physical Infrastructure", Ctrl="ContinuationAffiliationClinicalFacilities", Act="ClinicalFacilities" },
        new { Key="Vehicle", Label="Vehicle Details", Group="Physical Infrastructure", Ctrl="Aff_AHS_ContinousApplication", Act="CA_VehicleDetails" },
        new { Key="BedDistribution", Label="Bed Distribution", Group="Physical Infrastructure", Ctrl="ContinuesAffiliation_Facultybased", Act="MedicalUGBedDistribution" },


        // ================= ACADEMIC & ADMIN =================v v  v
        new { Key="AcademicMatters", Label="Academic Matters", Group="Academic & Admin", Ctrl="CA_Aff_AcademicMatters", Act="AcademicMatters" },
        new { Key="Finance", Label="Financial Details", Group="Academic & Admin", Ctrl="Aff_CA_Med_FinanceDetails", Act="Med_CA_AccountAndFeeDetails" },
        new { Key="StaffDetails", Label="Staff Details", Group="Academic & Admin", Ctrl="CA_Med_StaffDetails", Act="CA_Med_StaffDetails" },

        // ================= RESEARCH & LIBRARY =================
        new { Key="Research", Label="Research & Publications", Group="Research & Library", Ctrl="CA_Med_ResearchPublications", Act="CA_Med_ResearchPublicationsDetails" },
        new { Key="Library", Label="Library Details", Group="Research & Library", Ctrl="Aff_CA_MedicalLibrary", Act="Aff_CA_Medical_LibraryDetails" },
        new { Key="LibraryServices", Label="Library Services", Group="Research & Library", Ctrl="CA_Aff_MedicalLibrary", Act="MedicalLibrary" },

        // ================= STUDENT & STAFF =================
        new { Key="TeachingStaff", Label="Teaching Staff Dept Wise", Group="Human Resources", Ctrl="ContinuesAffiliation_Facultybased", Act="TeachingStaffDepartmentWise" },
        new { Key="NonTeachingStaff", Label="Non-Teaching Staff Dept Wise", Group="Human Resources", Ctrl="ContinuesAffiliation_Facultybased", Act="NonTeachingStaffDepartmentwise" },
        new { Key="FacultyDetails", Label="Faculty Details", Group="Human Resources", Ctrl="FacultyDetails", Act="Repo_FacultyDetails" },

        // ================= STUDENT AMENITIES =================
        new { Key="Hostel", Label="Hostel Details", Group="Student Amenities", Ctrl="ContinuesAffiliation_Facultybased", Act="Aff_HostelDetails" },
        
        // ================= STUDENT AMENITIES =================
        new { Key="IntakeDetails", Label="Intake Details", Group="Intake Details", Ctrl="ContinuousAffiliationIncreaseintake", Act="IncreaseIntake" },
        
        // ================= FINAL =================
        new { Key="DepartmentUnits", Label="Department / Units", Group="Final Submission", Ctrl="Medical_ContinuousAffiliation", Act="Medical_DepartmentOfficesAndEducationalUnit" },
        new { Key="PaymentDetails", Label="Department / Units", Group="Final Submission", Ctrl="Medical_ContinuousAffiliation", Act="Medical_DepartmentOfficesAndEducationalUnit" },

        new { Key="PreviewMode", Label="Preview", Group="Final Submission", Ctrl="CAPreview", Act="Preview" },
    };

    // ✅ Add MBBS ONLY for UG
    if (level == "UG")
    {
        allSteps.Insert(3, new
        {
            Key = "MBBSDetails",
            Label = "MBBS Details",
            Group = "Basic Details",
            Ctrl = "ContinuesAffiliation_Facultybased",
            Act = "Details_Of_MBBS"
        });
    }

    // ✅ Add PG-specific steps
    if (level == "PG")
    {
        var pgSteps = new[]
        {
            // new
            // {
            //     Key = "PgCoursesOffered",
            //     Label = "Courses Offered",
            //     Group = "PG Details",
            //     Ctrl = "AffiliationPgCourse",
            //     Act = "PgCourses"
            // },
            new
            {
                Key = "PgCourses",
                Label = "PG Course Details",
                Group = "PG Details",
                Ctrl = "AffiliationPgCourse",
                Act = "PgCourses"
            },
            new
            {
                Key = "PgAssociatedInstitutions",
                Label = "Associated Institutions",
                Group = "PG Details",
                Ctrl = "AffiliationSS",
                Act = "AssociatedInstitutions"
            }
        };

        // 👉 Find last index of "Basic Details"
        var lastBasicIndex = allSteps
            .Select((step, index) => new { step, index })
            .Where(x => x.step.Group == "Basic Details")
            .Select(x => x.index)
            .LastOrDefault();

        // 👉 Insert AFTER Basic Details
        allSteps.InsertRange(lastBasicIndex + 1, pgSteps);
    }

    void InsertAfterBasicDetails(dynamic[] newSteps)
    {
        var lastBasicIndex = allSteps
            .Select((step, index) => new { step, index })
            .Where(x => x.step.Group == "Basic Details")
            .Select(x => x.index)
            .LastOrDefault();

        if (lastBasicIndex >= 0)
            allSteps.InsertRange(lastBasicIndex + 1, newSteps);
    }

    // ✅ SS Specific - Added your new tab "SS Courses Applied"
    if (level == "SS")
    {
        var ssSteps = new[]
        {
            new { Key = "SsCoursesOffered",        Label = "Courses Offered",                  Group = "SS Details", Ctrl = "AffiliationSS", Act = "CoursesOffered" },
            // new { Key = "SsCourseDetails",         Label = "Super Specialty Course Details",   Group = "SS Details", Ctrl = "AffiliationSS", Act = "SsCourses" },
            new { Key = "SsAssociatedInstitutions", Label = "Associated Institutions",         Group = "SS Details", Ctrl = "AffiliationSS", Act = "AssociatedInstitutions" },

            // ✅ NEW TAB YOU REQUESTED
            new { Key = "SsCoursesApplied",        Label = "SS Courses Applied",               Group = "SS Details",
                  Ctrl = "Aff_CA_SS_CoursesAppliedSS",
                  Act = "CA_SS_CoursesApplied" }
        };
        InsertAfterBasicDetails(ssSteps);
    }

    int total = allSteps.Count;
    int done = allSteps.Count(s => doneSteps.Contains(s.Key));
    int pct = total > 0 ? (int)Math.Round((double)done / total * 100) : 0;

    // Track which group label we last printed (for group headers)
    string lastGroup = "";
}
<link rel="stylesheet" href="~/css/common-form.css" />

<style>
    @@import url('https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap');

    /* ══════════════════════════════
                   CA SIDEBAR
                ══════════════════════════════ */
    .ca-sb {
        width: 265px;
        min-height: 100vh;
        background: linear-gradient(180deg, #0f2545 0%, #162e55 100%);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        font-family: 'DM Sans', sans-serif;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        box-shadow: 2px 0 16px rgba(0,0,0,0.25);
    }

        .ca-sb::-webkit-scrollbar {
            width: 3px;
        }

        .ca-sb::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.1);
            border-radius: 99px;
        }

    /* Brand */
    .ca-sb-top {
        padding: 20px 18px 14px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
    }

    .ca-sb-title {
        font-family: 'EB Garamond', serif;
        font-size: 1.1rem;
        color: #fff;
        font-weight: 500;
    }

    .ca-sb-subtitle {
        font-size: 0.6rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #d4a84b;
        margin-top: 3px;
    }

    /* Level pill */
    .ca-sb-level-row {
        padding: 12px 18px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
    }

    .ca-sb-level-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(184,136,42,0.14);
        border: 1px solid rgba(184,136,42,0.3);
        border-radius: 5px;
        padding: 5px 13px;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        color: #d4a84b;
        text-transform: uppercase;
    }

    /* Progress */
    .ca-sb-prog {
        padding: 14px 18px 12px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
    }

    .ca-sb-prog-top {
        display: flex;
        justify-content: space-between;
        margin-bottom: 6px;
    }

    .ca-sb-prog-lbl {
        font-size: 0.58rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.3);
    }

    .ca-sb-prog-pct {
        font-size: 0.68rem;
        font-weight: 700;
        color: #d4a84b;
    }

    .ca-sb-track {
        height: 4px;
        background: rgba(255,255,255,0.08);
        border-radius: 99px;
        overflow: hidden;
    }

    .ca-sb-fill {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg, #b8882a, #d4a84b);
        transition: width 0.4s ease;
    }

    .ca-sb-prog-note {
        font-size: 0.58rem;
        color: rgba(255,255,255,0.25);
        text-align: right;
        margin-top: 4px;
    }

    /* Nav */
    .ca-sb-nav {
        flex: 1;
        list-style: none;
        padding: 6px 0 16px;
        margin: 0;
        overflow-y: auto;
    }

        .ca-sb-nav::-webkit-scrollbar {
            width: 3px;
        }

        .ca-sb-nav::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.08);
            border-radius: 99px;
        }

    /* Group label (e.g. "Physical Facilities") */
    .ca-sb-group-label {
        font-size: 0.57rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.22);
        padding: 12px 18px 4px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .ca-sb-group-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255,255,255,0.07);
        }

    /* Step link */
    .ca-sb-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 7px 18px;
        text-decoration: none;
        color: rgba(255,255,255,0.5);
        font-size: 0.78rem;
        font-weight: 500;
        transition: background 0.15s, color 0.15s;
        border-left: 3px solid transparent;
    }

        .ca-sb-link:hover {
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.82);
            text-decoration: none;
        }

        .ca-sb-link.is-active {
            background: rgba(184,136,42,0.12);
            border-left-color: #d4a84b;
            color: #fff;
            font-weight: 600;
            padding-left: 15px;
        }

        /* Indented sub-steps (Physical Facilities items) */
        .ca-sb-link.is-sub {
            padding-left: 32px;
            font-size: 0.75rem;
        }

            .ca-sb-link.is-sub.is-active {
                padding-left: 29px;
            }

    /* Step dot */
    .ca-dot {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.58rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .ca-dot-done {
        background: #1a6b3a;
        color: #fff;
    }

    .ca-dot-current {
        background: linear-gradient(135deg,#b8882a,#d4a84b);
        color: #fff;
        box-shadow: 0 0 0 3px rgba(212,168,75,0.18);
    }

    .ca-dot-pending {
        background: rgba(255,255,255,0.07);
        border: 1.5px solid rgba(255,255,255,0.14);
        color: rgba(255,255,255,0.22);
    }

    .ca-sb-check {
        font-size: 0.6rem;
        color: #2e8b57;
        margin-left: auto;
    }

    /* Footer */
    .ca-sb-footer {
        padding: 12px 18px;
        border-top: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
    }

    .ca-sb-back {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.7rem;
        color: rgba(255,255,255,0.3);
        text-decoration: none;
        transition: color 0.15s;
    }

        .ca-sb-back:hover {
            color: #d4a84b;
            text-decoration: none;
        }

    /* SS Coming Soon overlay */
    .ca-ss-coming {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 30px 18px;
        text-align: center;
        color: rgba(255,255,255,0.3);
        gap: 10px;
    }

    .ca-ss-coming-icon {
        font-size: 2.2rem;
        opacity: 0.35;
    }

    .ca-ss-coming-title {
        font-size: 0.85rem;
        font-weight: 600;
        color: rgba(255,255,255,0.45);
    }

    .ca-ss-coming-desc {
        font-size: 0.72rem;
        line-height: 1.5;
    }

    .ca-ss-badge {
        display: inline-block;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 99px;
        padding: 4px 14px;
        font-size: 0.62rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.3);
        margin-top: 4px;
    }

    .btn-logout {
        background: transparent;
        border: 1px solid rgba(255,255,255,.35);
        color: rgba(255,255,255,.85);
        border-radius: 7px;
        padding: 5px 14px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'DM Sans', sans-serif;
    }

        .btn-logout:hover {
            background: var(--danger);
            border-color: var(--danger);
            color: #fff;
        }

</style>

<aside class="ca-sb">

    

    <!-- Brand -->
    <div class="ca-sb-top">
        <div class="ca-sb-title">Continuous Affiliation</div>
        <div class="ca-sb-subtitle">Faculty-Based Module</div>
    </div>

    <!-- Level pill -->
    <div class="ca-sb-level-row">
        <span class="ca-sb-level-pill">
            <i class="bi bi-mortarboard-fill"></i>
            @level Programme
        </span>
    </div>

    
    <!-- Progress bar (UG and PG and SS) -->
    <div class="ca-sb-prog">
        <div class="ca-sb-prog-top">
            <span class="ca-sb-prog-lbl">Completion</span>
            <span class="ca-sb-prog-pct">@pct%</span>
        </div>
        <div class="ca-sb-track">
            <div class="ca-sb-fill" style="width:@pct%"></div>
        </div>
        <div class="ca-sb-prog-note">@done of @total steps completed</div>
    </div>

    <!-- Step list (flat) -->
    <ul class="ca-sb-nav">
        @{
            int stepNum = 0;
            lastGroup = "";
        }

        @foreach (var s in allSteps)
        {
            stepNum++;
            bool isDone = doneSteps.Contains(s.Key);
            bool isCurrent = string.Equals(currentCtrl, s.Ctrl, StringComparison.OrdinalIgnoreCase)
            && string.Equals(currentAct, s.Act, StringComparison.OrdinalIgnoreCase);
            bool isSub = !string.IsNullOrEmpty(s.Group);

            // Print group header when group changes
            if (!string.IsNullOrEmpty(s.Group) && s.Group != lastGroup)
            {
                lastGroup = s.Group;
                <li>
                    <div class="ca-sb-group-label">@s.Group</div>
                </li>
            }
            else if (string.IsNullOrEmpty(s.Group))
            {
                lastGroup = "";
            }

            string dotCls = isCurrent ? "ca-dot ca-dot-current"
            : isDone ? "ca-dot ca-dot-done"
            : "ca-dot ca-dot-pending";

            string linkCls = "ca-sb-link"
            + (isSub ? " is-sub" : "")
            + (isCurrent ? " is-active" : "");

            <li>
                <a asp-controller="@s.Ctrl" asp-action="@s.Act" class="@linkCls">
                    <div class="@dotCls">
                        @if (isDone)
                        {
                            <text>&#10003;</text>
                        }
                        else
                        {

                            @stepNum
                        }
                    </div>
                    <span style="flex:1; line-height:1.3;">@s.Label</span>
                    @if (isDone && !isCurrent)
                    {
                        <span class="ca-sb-check">&#10003;</span>
                    }
                </a>
            </li>
        }
    </ul>
  

    <!-- Footer -->
    <div class="ca-sb-footer">
        <div style="text-align: center;">
            <a asp-action="Dashboard" asp-controller="Collegelogin" style="font-size: .8rem; color: white; text-decoration: none; padding: 5px;"> Back To Dashboard</a>
        </div>

        
    </div>

</aside>
