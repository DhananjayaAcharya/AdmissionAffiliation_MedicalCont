</style>

<aside class="ca-sb">

    <!-- Brand -->
    <div class="ca-sb-top">
        @* <div class="ca-sb-title">@collegeName</div> *@
        <div class="ca-sb-title">College Details</div>
        @* <div class="ca-sb-subtitle">Faculty-Based Module</div> *@
    </div>

    <!-- Level pill -->
    @* <div class="ca-sb-level-row">
        <span class="ca-sb-level-pill">
            <i class="bi bi-mortarboard-fill"></i>
            @level Programme
        </span>
    </div> *@

    
    <!-- Progress bar (UG and PG and SS) -->
    <div class="ca-sb-prog">
        <div class="ca-sb-prog-top">
            <span class="ca-sb-prog-lbl">Completion</span>
            <span class="ca-sb-prog-pct">@pct%</span>
        </div>
        <div class="ca-sb-track">
            <div class="ca-sb-fill" style="width:@pct%"></div>
        </div>
        <div class="ca-sb-prog-note">@done of @total steps completed</div>
    </div>

    <!-- Step list (flat) -->
    <div class="accordion-container">
        @foreach (var group in groupedSteps)
        {
            var groupId = group.Key.Replace(" ", "");

            <div class="accordion-item">
                <!-- Accordion Header -->
                <div class="accordion-header tab-header"
                     data-tab="@groupId"
                     onclick="toggleAccordion('@groupId')">
                    <span>@group.Key</span>
                    <i class="bi bi-chevron-down toggle-icon"></i>
                </div>

                <!-- Accordion Content -->
                <div class="accordion-content tab-content"
                     id="content-@groupId"
                     data-tab-content="@groupId">
                    @foreach (var step in group)
                    {
                        var isActive = currentCtrl == step.Ctrl && currentAct == step.Act;
                        var isDone = doneSteps.Contains(step.Key);

                        string dotCls = isActive ? "ca-dot ca-dot-current"
                            : isDone ? "ca-dot ca-dot-done"
                            : "ca-dot ca-dot-pending";

                        string linkCls = "ca-sb-link"
                            + (isActive ? " is-active" : "");

                        <a href="@Url.Action(step.Act, step.Ctrl)" class="@linkCls">

                            <div class="@dotCls">
                                @if (isDone)
                                {
                                    <text>&#10003;</text>
                                }
                            </div>

                            <span style="flex:1;">@step.Label</span>

                            @if (isDone && !isActive)
                            {
                                <span class="ca-sb-check">&#10003;</span>
                            }
                        </a>
                    }
                </div>
            </div>
        }
    </div>


    <!-- Footer -->
    <div class="ca-sb-footer">
        <div style="text-align: center;">
            <a asp-action="Dashboard" asp-controller="Collegelogin" style="font-size: .8rem; color: white; text-decoration: none; padding: 5px;"> Back To Dashboard</a>
        </div>
    </div>

</aside>

<script>
    
    function toggleAccordion(groupId) {

        const currentContent = document.querySelector(`[data-tab-content="${groupId}"]`);
        const currentHeader = document.querySelector(`[data-tab="${groupId}"]`);

        const isOpen = currentHeader.classList.contains("active-tab");

        const allContents = document.querySelectorAll(".tab-content");
        const allHeaders = document.querySelectorAll(".tab-header");

        // Close all
        allContents.forEach(c => c.style.maxHeight = null);
        allHeaders.forEach(h => h.classList.remove("active-tab"));

        // If it was already open → close only
        if (isOpen) {
            sessionStorage.removeItem("activeTab");
            return;
        }

        // Otherwise open it
        sessionStorage.setItem("activeTab", groupId);

        if (currentContent) {
            currentContent.style.maxHeight = currentContent.scrollHeight + "px";
        }

        if (currentHeader) {
            currentHeader.classList.add("active-tab");
        }
    }

    // Auto-open active group
    window.onload = function () {

    let activeTab = sessionStorage.getItem("activeTab");

    // fallback → detect active step
    if (!activeTab) {
        const activeLink = document.querySelector(".ca-sb-link.is-active");
        if (activeLink) {
            const parent = activeLink.closest(".tab-content");
            if (parent) {
                activeTab = parent.getAttribute("data-tab-content");
            }
        }
    }

    if (activeTab) {
        toggleAccordion(activeTab);
    }
};
</script>