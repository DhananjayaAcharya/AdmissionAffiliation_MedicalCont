@* Views/Shared/_ContinuousAffiliationSidebar.cshtml *@
@using Medical_Affiliation.DATA
@inject IHttpContextAccessor HttpContextAccessor
@inject ApplicationDbContext _context   // ✅ ADD
@using System.Text.Json;
@using Microsoft.EntityFrameworkCore;

@{
    var collegeCode = HttpContextAccessor.HttpContext.Session.GetString("CollegeCode");
    var collegeName = HttpContextAccessor.HttpContext.Session.GetString("CollegeName");
    var facultyCode = Context.Session.GetString("FacultyCode");
    var levels = await (
        from ai in _context.AcademicIntakes
        join mc in _context.MstCourses
            on ai.Courses equals mc.CourseCode.ToString()
        where ai.CollegeCode == collegeCode
              && ai.FacultyCode == facultyCode
        select mc.CourseLevel
    ).Distinct().ToListAsync();



    // fallback from AcademicIntake
    if (!levels.Any())
    {
        levels = await (
            from ai in _context.AcademicIntakes
            join cm in _context.MstCourses
                on ai.Courses equals cm.CourseCode.ToString()
            where ai.CollegeCode == collegeCode && ai.Ay2026TotalIntake > 0
                  && !string.IsNullOrEmpty(ai.Courses)
            select cm.CourseLevel
        )
        .Distinct()
        .ToListAsync();
    }



    var doneSteps = _context.CaProgresses
    .Where(x => x.CollegeCode == collegeCode &&
                levels.Contains(x.CourseLevel.Trim().ToUpper()) &&
                x.IsCompleted == true)
    .Select(x => x.StepKey)
    .ToList();

    var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAct = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    // ── Step definition ───────────────────────────────────────────────────
    // Flat list — Physical Facilities sub-items are shown as individual steps
    var allSteps = new List<StepItem>
    {
        // ================= BASIC DETAILS =================
        new StepItem{ Key="Institution", Label="Institution Details", Group="Basic Details", Ctrl="ContinuesAffiliation_Facultybased", Act="Institution_Details" },
        new StepItem{ Key="TrustDetails", Label="Trust Details", Group="Basic Details", Ctrl="ContinuesAffiliation_Facultybased", Act="Aff_InstituteDetails" },
        new StepItem{ Key="TrustMemberDetails", Label="Trust Member Details", Group="Basic Details", Ctrl="ContinuesAffiliation_Facultybased", Act="Aff_TrustMemberDetails" },

        // 👇 CONDITIONAL STEP
        // MBBS only for UG
        // we will add below dynamically
         // new { Key="FacultyDetails", Label="Faculty Details", Group="Basic Details", Ctrl="FacultyDetails", Act="Repo_FacultyDetails" },
        new StepItem{ Key="DeanDetails", Label="Dean / Director Details", Group="Basic Details", Ctrl="ContinuesAffiliation_Facultybased", Act="Dean_DirectorDetails" },
        new StepItem{ Key="PrincipalDetails", Label="Principal Details", Group="Basic Details", Ctrl="ContinuesAffiliation_Facultybased", Act="Aff_PrincipalDetails" },

        // ================= STUDENT AMENITIES =================
        new StepItem{ Key="IntakeDetails", Label="Course-wise Intake Details", Group="Intake Details", Ctrl="ContinuousAffiliationIncreaseintake", Act="IncreaseIntake" },
        new StepItem{ Key = "SsCoursesOffered", Label = "Courses Offered",   Group = "Intake Details", Ctrl = "AffiliationSS", Act = "CoursesOffered", Levels = new List<string>{ "SS" } },


        // ================= PHYSICAL INFRASTRUCTURE =================
        // new StepItem{ Key="LandBuilding", Label="Land & Building", Group="Physical Infrastructure", Ctrl="Medical_ContinuousAffiliation", Act="Medical_LandBuildingdetails" },
        // new StepItem{ Key="SkillsLab", Label="Classroom & Laboratory", Group="Physical Infrastructure", Ctrl="Medical_ContinuousAffiliation", Act="Medical_SkillsLaboratory" },
        // new StepItem{ Key="EquipmentDetails", Label="Equipment Details", Group="Physical Infrastructure", Ctrl="Medical_ContinuousAffiliation", Act="Medical_EquimentDetails" },
        new StepItem{ Key="EquipmentMaster", Label="Additional Equipment Details", Group="Physical Infrastructure", Ctrl="Medical_ContinuousAffiliation", Act="Medical_EquipmentMaster" },
        new StepItem{ Key="ClinicalFacilities", Label="Clinical Facilities", Group="Physical Infrastructure", Ctrl="ContinuationAffiliationClinicalFacilities", Act="ClinicalFacilities" },
        // new StepItem{ Key="Vehicle", Label="Vehicle Details", Group="Physical Infrastructure", Ctrl="Aff_AHS_ContinousApplication", Act="CA_VehicleDetails" },
        new StepItem{ Key="BedDistribution", Label="Bed Distribution", Group="Physical Infrastructure", Ctrl="ContinuesAffiliation_Facultybased", Act="MedicalUGBedDistribution" },
        // new StepItem{ Key="ChairDistribution", Label="Chair Distribution", Group="Physical Infrastructure", Ctrl="PhysicalInfrastructure", Act="ChairDistribution" },
        // new StepItem{ Key="DepartmentUnits", Label="Department / Units", Group="Physical Infrastructure", Ctrl="Medical_ContinuousAffiliation", Act="Medical_DepartmentOfficesAndEducationalUnit" },
        new StepItem{ Key="DepartmentUnits", Label="Department / Clinics/ Labs", Group="Physical Infrastructure", Ctrl="Medical_ContinuousAffiliation", Act="Medical_DepartmentOfficesAndEducationalUnit" },
        new StepItem{ Key="Hostel", Label="Hostel Details", Group="Physical Infrastructure", Ctrl="ContinuesAffiliation_Facultybased", Act="Aff_HostelDetails" },
        new StepItem{ Key = "AssociatedInstitutions", Label = "Associated Institutions",   Group = "Physical Infrastructure", Ctrl = "AffiliationSS", Act = "AssociatedInstitutions" },



        // ================= ACADEMIC & ADMIN =================v v  v 
        new StepItem{ Key="AcademicMatters", Label="UG Academic Performance", Group="Academic & Admin", Ctrl="CA_Aff_AcademicMatters", Act="AcademicMatters" },
        new StepItem{ Key="PGAcademicMatters", Label="PG Academic Performance", Group="Academic & Admin", Ctrl="CA_Aff_AcademicMatters", Act="AcademicMattersPG", Levels = new List<string>{ "PG" } },
        new StepItem{ Key="Finance", Label="Financial Details", Group="Academic & Admin", Ctrl="Aff_CA_Med_FinanceDetails", Act="Med_CA_AccountAndFeeDetails" },
        new StepItem{ Key="StaffDetails", Label="Staff Particular Details", Group="Academic & Admin", Ctrl="CA_Med_StaffDetails", Act="CA_Med_StaffDetails" },

        // ================= RESEARCH & LIBRARY =================
        new StepItem{ Key="LibraryServices", Label="Library Services", Group="Research & Library", Ctrl="CA_Aff_MedicalLibrary", Act="MedicalLibrary" },
        new StepItem{ Key="Research", Label="Research & Publications", Group="Research & Library", Ctrl="CA_Med_ResearchPublications", Act="CA_Med_ResearchPublicationsDetails" },
        new StepItem{ Key="Library", Label="Library Details", Group="Research & Library", Ctrl="Aff_CA_MedicalLibrary", Act="Aff_CA_Medical_LibraryDetails" },

        // ================= STUDENT & STAFF =================
        new StepItem{ Key="FacultyDetails", Label="Faculty Details", Group="Human Resources", Ctrl="FacultyDetails", Act="Repo_FacultyDetails" },
        // new StepItem{ Key="TeachingStaff", Label="Teaching Staff Dept Wise", Group="Human Resources", Ctrl="ContinuesAffiliation_Facultybased", Act="TeachingStaffDepartmentWise" },
        new StepItem{ Key="NonTeachingStaff", Label="Non-Teaching Staff Dept Wise", Group="Human Resources", Ctrl="ContinuesAffiliation_Facultybased", Act="NonTeachingStaffDepartmentwise" },


        // ================= STUDENT AMENITIES =================
        // new StepItem{ Key="Hostel", Label="Hostel Details", Group="Student Amenities", Ctrl="ContinuesAffiliation_Facultybased", Act="Aff_HostelDetails" },

        // new { Key="PaymentDetails", Label="Affiliation Payment", Group="Final Submission", Ctrl="AffiliationPayment", Act="Payment" },
        // new { Key="Declaration", Label="Declaration", Group="Final Submission", Ctrl="AffiliationDeclaration", Act="Declaration" },

        new StepItem{ Key="PreviewMode", Label="Preview", Group="Final Preview", Ctrl="CAPreview", Act="Preview" },
    };

    // ======================================================
    // SKILLS / LAB STEP BASED ON FACULTY
    // ======================================================

    var skillsIndex = allSteps.FindIndex(x => x.Key == "EquipmentMaster");

    if (skillsIndex < 0)
    {
        skillsIndex = allSteps.Count;
    }

    if (facultyCode == "2")
    {
        // Dental
        allSteps.Insert(skillsIndex,

            new StepItem
            {
                Key = "DentalSkillsLab",
                Label = "Classroom & Laboratory",
                Group = "Physical Infrastructure",
                Ctrl = "PhysicalInfrastructure",
                Act = "DentalSkillsLaboratory"
            });
    }
    else
    {
        // Medical / Others
        allSteps.Insert(skillsIndex,

            new StepItem
            {
                Key = "SkillsLab",
                Label = "Classroom & Laboratory",
                Group = "Physical Infrastructure",
                Ctrl = "Medical_ContinuousAffiliation",
                Act = "Medical_SkillsLaboratory"
            });
    }

    // ======================================================
    // VEHICLE POSITION FOR DENTAL
    // ======================================================

    if (facultyCode == "2")
    {
        // place after Additional Equipment Details
        var vehicleIndex = allSteps.FindIndex(x => x.Key == "EquipmentMaster");

        if (vehicleIndex >= 0)
        {
            allSteps.Insert(vehicleIndex + 1, new StepItem
            {
                Key = "Vehicle",
                Label = "Vehicle Details",
                Group = "Physical Infrastructure",
                Ctrl = "Aff_AHS_ContinousApplication",
                Act = "CA_VehicleDetails"
            });
        }
    }
    else
    {
        // existing order for all other faculties
        allSteps.Add(new StepItem
        {
            Key = "Vehicle",
            Label = "Vehicle Details",
            Group = "Physical Infrastructure",
            Ctrl = "Aff_AHS_ContinousApplication",
            Act = "CA_VehicleDetails"
        });
    }

    // ======================================================
    // LAND & BUILDING STEP BASED ON FACULTY
    // ======================================================

    int insertIndex = -1;

    if (facultyCode == "2")
    {
        insertIndex = allSteps.FindIndex(x => x.Key == "DentalSkillsLab");
    }
    else
    {
        insertIndex = allSteps.FindIndex(x => x.Key == "SkillsLab");
    }

    if (insertIndex < 0)
    {
        insertIndex = allSteps.Count;
    }

    if (facultyCode == "2")
    {
        // Dental
        allSteps.Insert(insertIndex,

            new StepItem
            {
                Key = "LandBuilding",
                Label = "Land & Building",
                Group = "Physical Infrastructure",
                Ctrl = "PhysicalInfrastructure",
                Act = "DentalCollegeLandBuildingDetail"
            });
    }
    else
    {
        // Medical / Others
        allSteps.Insert(insertIndex,

            new StepItem
            {
                Key = "LandBuilding",
                Label = "Land & Building",
                Group = "Physical Infrastructure",
                Ctrl = "Medical_ContinuousAffiliation",
                Act = "Medical_LandBuildingdetails"
            });
    }

    var nonTeachingIndex = allSteps.FindIndex(x => x.Key == "NonTeachingStaff");

    if (nonTeachingIndex < 0)
    {
        nonTeachingIndex = allSteps.Count;
    }

    if (facultyCode == "2")
    {
        allSteps.Insert(nonTeachingIndex, new StepItem
        {
            Key = "TeachingStaff",
            Label = "Teaching Staff Dept Wise",
            Group = "Human Resources",
            Ctrl = "Dental",
            Act = "TeachingStaffDepartmentWise"
        });
    }
    else
    {
        allSteps.Insert(nonTeachingIndex, new StepItem
        {
            Key = "TeachingStaff",
            Label = "Teaching Staff Dept Wise",
            Group = "Human Resources",
            Ctrl = "ContinuesAffiliation_Facultybased",
            Act = "TeachingStaffDepartmentWise"
        });
    }

    var equipmentIndex = allSteps.FindIndex(x => x.Key == "EquipmentMaster");

    if (equipmentIndex < 0)
    {
        equipmentIndex = allSteps.Count;
    }

    if (facultyCode == "2")
    {
        // Dental
        allSteps.Insert(equipmentIndex,

            new StepItem
            {
                Key = "DentalEquipmentDetails",
                Label = "Equipment List",
                Group = "Physical Infrastructure",
                Ctrl = "Dental",
                Act = "EquipmentList"
            });
    }
    else
    {
        // Medical / Others
        allSteps.Insert(equipmentIndex,

            new StepItem
            {
                Key = "EquipmentDetails",
                Label = "Equipment Details",
                Group = "Physical Infrastructure",
                Ctrl = "Medical_ContinuousAffiliation",
                Act = "Medical_EquimentDetails"
            });
    }
    // ✅ Add MBBS ONLY for UG
    if (levels.Contains("UG") && facultyCode == "1")
    {
        allSteps.Insert(1, new StepItem
        {
            Key = "MBBSDetails",
            Label = "UG Course Details",
            Group = "Intake Details",
            Ctrl = "ContinuesAffiliation_Facultybased",
            Act = "Details_Of_MBBS"
        });
    }
    else if (levels.Contains("UG") && facultyCode == "2")
    {
        allSteps.Insert(1, new StepItem
        {
            Key = "BDSDetails",
            Label = "UG Course Details",
            Group = "Intake Details",
            Ctrl = "ContinuesAffiliation_Facultybased",
            Act = "Ug_Course_Details"
        });
    }

    if (facultyCode == "2")
    {
        var intakeIndex = allSteps.FindIndex(x => x.Key == "IntakeDetails");

        if (intakeIndex >= 0)
        {
            allSteps.Insert(intakeIndex + 1, new StepItem
            {
                Key = "DentalFacultyDetails",
                Label = "Faculty Repository",
                Group = "Intake Details",
                Ctrl = "DentalRepository",
                Act = "TeachingFacultyDetails"
            });
        }
    }

    // ✅ Add PG-specific steps
    if (levels.Contains("PG"))
    {
        var pgSteps = new List<StepItem>
        {
            // new
            // {
            //     Key = "PgCoursesOffered",
            //     Label = "Courses Offered",
            //     Group = "PG Details",
            //     Ctrl = "AffiliationPgCourse",
            //     Act = "PgCourses"
            // },
            new StepItem
            {
                Key = "PgCourses",
                Label = "PG Course Details",
                Group = "Intake Details",
                Ctrl = "AffiliationPgCourse",
                Act = "PgCourses",
            },
        };

        // 👉 Find last index of "Basic Details"
        var lastBasicIndex = allSteps
            .Select((step, index) => new { step, index })
            .Where(x => x.step.Group == "Basic Details")
            .Select(x => x.index)
            .LastOrDefault();

        // 👉 Insert AFTER Basic Details
        allSteps.InsertRange(lastBasicIndex + 1, pgSteps);
    }

    void InsertAfterBasicDetails(List<StepItem> newSteps)
    {
        var lastBasicIndex = allSteps
            .Select((step, index) => new { step, index })
            .Where(x => x.step.Group == "Basic Details")
            .Select(x => x.index)
            .LastOrDefault();

        if (lastBasicIndex >= 0)
            allSteps.InsertRange(lastBasicIndex + 1, newSteps);
    }

    // ✅ SS Specific - Added your new tab "SS Courses Applied"
    if (levels.Contains("SS"))
    {
        var ssSteps = new List<StepItem>
        {
            // new { Key = "SsCourseDetails",         Label = "Super Specialty Course Details",   Group = "SS Details", Ctrl = "AffiliationSS", Act = "SsCourses" },
            // new StepItem{ Key = "SsAssociatedInstitutions", Label = "Associated Institutions",         Group = "SS Details", Ctrl = "AffiliationSS", Act = "AssociatedInstitutions" },

            // ✅ NEW TAB YOU REQUESTED
            new StepItem{ Key = "SsCoursesApplied",        Label = "SS Course Details",               Group = "Intake Details",
                  Ctrl = "Aff_CA_SS_CoursesAppliedSS",
                  Act = "CA_SS_CoursesApplied" }
        };
        InsertAfterBasicDetails(ssSteps);
    }



    // 🔥 Exclude IntakeDetails from progress
    var progressSteps = allSteps
    .Where(s => s.Key != "IntakeDetails")
    .ToList();

    int total = progressSteps.Count;
    int done = progressSteps.Count(s => doneSteps.Contains(s.Key));
    int pct = total > 0 ? (int)Math.Round((double)done / total * 100) : 0;

    // int total = allSteps.Count;
    // int done = allSteps.Count(s => doneSteps.Contains(s.Key));
    // int pct = total > 0 ? (int)Math.Round((double)done / total * 100) : 0;

    // Track which group label we last printed (for group headers)
    string lastGroup = "";

    allSteps = allSteps
    .Where(step =>
        step.Levels == null || step.Levels.Count == 0   // ✅ default (UG/common)
        || step.Levels.Any(l => levels.Contains(l))     // PG / SS match
    )
    .ToList();

    if (facultyCode == "2")
    {
        // Insert Chair Distribution after Classroom & Laboratory
        var chairIndex = allSteps.FindIndex(x => x.Key == "DentalSkillsLab");

        if (chairIndex >= 0)
        {
            allSteps.Insert(chairIndex + 1, new StepItem
            {
                Key = "ChairDistribution",
                Label = "Chair Distribution",
                Group = "Physical Infrastructure",
                Ctrl = "PhysicalInfrastructure",
                Act = "ChairDistribution"
            });
        }
    }

    // skipped for Dental
    if (facultyCode == "2")
    {
        allSteps = allSteps
            .Where(x => x.Key != "AssociatedInstitutions")
            .ToList();
    }

    // ======================================================
    // FINAL ORDER FIX FOR DENTAL
    // ======================================================

    if (facultyCode == "2")
    {
        var physicalOrder = new List<string>
        {
            "ClinicalFacilities",
            "LandBuilding",
            "DentalSkillsLab",
            "ChairDistribution",
            "BedDistribution",
            "Hostel",
            "DepartmentUnits",
            "DentalEquipmentDetails",
            "EquipmentMaster",
            "Vehicle"
        };

        var physicalSteps = allSteps
            .Where(x => x.Group == "Physical Infrastructure")
            .ToList();

        var orderedPhysicalSteps = physicalOrder
            .Select(key => physicalSteps.FirstOrDefault(x => x.Key == key))
            .Where(x => x != null)
            .ToList();

        // Remaining physical infra steps (if any)
        var remainingPhysicalSteps = physicalSteps
            .Where(x => !physicalOrder.Contains(x.Key))
            .ToList();

        // Remove all physical infra steps
        allSteps.RemoveAll(x => x.Group == "Physical Infrastructure");

        // Find where Physical Infrastructure section originally started
        var insertAt = allSteps.FindIndex(x => x.Group != "Basic Details"
                                            && x.Group != "Intake Details");

        if (insertAt < 0)
        {
            insertAt = allSteps.Count;
        }

        // Reinsert in exact order
        allSteps.InsertRange(insertAt,
            orderedPhysicalSteps.Concat(remainingPhysicalSteps));
    }


    // ======================================================
    // DENTAL - FINAL ORDER FOR INTAKE/BASIC DETAILS
    // ======================================================

    if (facultyCode == "2")
    {
        // Move Course-wise Intake Details to Basic Details and make it first
        var intakeStep = allSteps.FirstOrDefault(x => x.Key == "IntakeDetails");

        if (intakeStep != null)
        {
            allSteps.Remove(intakeStep);

            intakeStep.Group = "Basic Details";

            allSteps.Insert(0, intakeStep);
        }

        // Keep UG/PG/SS/Faculty Repository under Intake Details
        var intakeOrder = new List<string>
        {
            "BDSDetails",
            "PgCourses",
            "SsCoursesApplied",
            "DentalFacultyDetails"
        };

        var intakeSteps = allSteps
            .Where(x => x.Group == "Intake Details")
            .ToList();

        var orderedIntakeSteps = intakeOrder
            .Select(key => intakeSteps.FirstOrDefault(x => x.Key == key))
            .Where(x => x != null)
            .ToList();

        var remainingIntakeSteps = intakeSteps
            .Where(x => !intakeOrder.Contains(x.Key))
            .ToList();

        allSteps.RemoveAll(x => x.Group == "Intake Details");

        var basicLastIndex = allSteps
            .Select((step, index) => new { step, index })
            .Where(x => x.step.Group == "Basic Details")
            .Select(x => x.index)
            .LastOrDefault();

        allSteps.InsertRange(
            basicLastIndex + 1,
            orderedIntakeSteps.Concat(remainingIntakeSteps)
        );
    }

    var groupedSteps = allSteps
            .GroupBy(s => s.Group)
            .ToList();



}
<link rel="stylesheet" href="~/css/common-form.css" />

<style>
    @@import url('https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap');

    /* ══════════════════════════════
                   CA SIDEBAR
                ══════════════════════════════ */
    .ca-sb {
        width: 18vw;
        min-height: 100vh;
        background: #ffffff;
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        font-family: 'DM Sans', sans-serif;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        border-right: 1px solid #e2e8f0;
    }

        .ca-sb::-webkit-scrollbar {
            width: 6px;
        }

        .ca-sb::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

    /* Brand */
    .ca-sb-top {
        padding: 20px 18px 14px;
        border-bottom: 1px solid #e2e8f0;
        flex-shrink: 0;
    }

    .ca-sb-title {
        font-family: 'EB Garamond', serif;
        font-size: 1.1rem;
        color: #0f172a;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .ca-sb-subtitle {
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #64748b;
        margin-top: 4px;
    }

    /* Level pill */
    .ca-sb-level-row {
        padding: 12px 18px;
        border-bottom: 1px solid #e2e8f0;
        flex-shrink: 0;
    }

    .ca-sb-level-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 8px;
        padding: 5px 14px;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        color: #0d47a1;
        text-transform: uppercase;
    }

    /* Progress */
    .ca-sb-prog {
        padding: 14px 18px 12px;
        border-bottom: 1px solid #e2e8f0;
        flex-shrink: 0;
        background: #f8fafc;
    }

    .ca-sb-prog-top {
        display: flex;
        justify-content: space-between;
        margin-bottom: 6px;
    }

    .ca-sb-prog-lbl {
        font-size: 0.58rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #64748b;
    }

    .ca-sb-prog-pct {
        font-size: 0.68rem;
        font-weight: 700;
        color: #0d47a1;
    }

    .ca-sb-track {
        height: 4px;
        background: #e2e8f0;
        border-radius: 999px;
        overflow: hidden;
    }

    .ca-sb-fill {
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #0d47a1, #1976d2);
        transition: width 0.4s ease;
    }

    .ca-sb-prog-note {
        font-size: 0.58rem;
        color: #94a3b8;
        text-align: right;
        margin-top: 4px;
    }

    /* Nav */
    .ca-sb-nav {
        flex: 1;
        list-style: none;
        padding: 8px 0 16px;
        margin: 0;
        overflow-y: auto;
    }

        .ca-sb-nav::-webkit-scrollbar {
            width: 6px;
        }

        .ca-sb-nav::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

    /* Group label (e.g. "Physical Facilities") */
    .ca-sb-group-label {
        font-size: 0.57rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #64748b;
        padding: 12px 18px 4px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .ca-sb-group-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }

    /* Step link */
    .ca-sb-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 14px;
        text-decoration: none;
        color: #334155;
        font-size: 0.82rem;
        font-weight: 500;
        transition: background 0.15s, color 0.15s;
        border-left: 3px solid transparent;
    }

        .ca-sb-link:hover {
            background: #eff6ff;
            color: #0d47a1;
            text-decoration: none;
        }

        .ca-sb-link.is-active {
            background: #e0efff;
            border-left-color: #0d47a1;
            color: #0d47a1;
            font-weight: 700;
            padding-left: 11px;
        }

        .ca-sb-link.is-sub {
            padding-left: 32px;
            font-size: 0.77rem;
        }

            .ca-sb-link.is-sub.is-active {
                padding-left: 29px;
            }

    /* Step dot */
    .ca-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.58rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .ca-dot-done {
        background: #047857;
        color: #fff;
    }

    .ca-dot-current {
        background: #0d47a1;
        color: #fff;
        box-shadow: 0 0 0 3px rgba(13, 71, 161, 0.2);
    }

    .ca-dot-pending {
        background: #f1f5f9;
        border: 1.5px solid #cbd5e1;
        color: #94a3b8;
    }

    .ca-sb-check {
        font-size: 0.6rem;
        color: #047857;
        margin-left: auto;
    }

    /* Footer */
    .ca-sb-footer {
        padding: 12px 18px;
        border-top: 1px solid #e2e8f0;
        flex-shrink: 0;
        background: #f8fafc;
    }

    .ca-sb-back {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.74rem;
        color: #475569;
        text-decoration: none;
        transition: color 0.15s;
    }

        .ca-sb-back:hover {
            color: #0d47a1;
            text-decoration: none;
        }

    .btn-logout {
        background: transparent;
        border: 1px solid #0d47a1;
        color: #0d47a1;
        border-radius: 7px;
        padding: 6px 14px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer;
        transition: all .2s;
        font-family: 'DM Sans', sans-serif;
    }

        .btn-logout:hover {
            background: #0d47a1;
            color: #fff;
        }

    .accordion-container {
        width: 100%;
    }

    .accordion-item {
        background: transparent;
        border-bottom: 1px solid #e2e8f0;
