        }


    .accordion-container {
        width: 100%;
    }

    .accordion-item {
        /* border-bottom: 1px solid #eee; */

        background: linear-gradient(180deg, #0f2545 0%, #162e55 100%);
    }

    .accordion-header {
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: .5px;
        /* text-transform: uppercase; */
        color: rgba(255,255,255,0.22);
        padding: 12px 18px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* .accordion-header::after {
        content: '';
        flex: 1;
        height: 1px;
        background: rgba(255,255,255,0.07);
    } */
