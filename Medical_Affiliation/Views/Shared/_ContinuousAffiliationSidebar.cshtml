        font-family: 'EB Garamond', serif;
        font-size: 1.1rem;
        color: #fff;
        font-weight: 500;
        letter-spacing: 1px;
    }

    .ca-sb-subtitle {
        font-size: 0.6rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #d4a84b;
        margin-top: 3px;
    }

    /* Level pill */
