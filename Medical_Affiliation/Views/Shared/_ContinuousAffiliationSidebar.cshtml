        padding: 14px 18px 12px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
    }

    .ca-sb-prog-top {
        display: flex;
        justify-content: space-between;
        margin-bottom: 6px;
    }

    .ca-sb-prog-lbl {
        font-size: 0.58rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.3);
    }

    .ca-sb-prog-pct {
        font-size: 0.68rem;
        font-weight: 700;
        color: #d4a84b;
    }

    .ca-sb-track {
        height: 4px;
        background: rgba(255,255,255,0.08);
        border-radius: 99px;
        overflow: hidden;
    }

    .ca-sb-fill {
        height: 100%;
        border-radius: 99px;
        background: linear-gradient(90deg, #b8882a, #d4a84b);
        transition: width 0.4s ease;
    }

    .ca-sb-prog-note {
        font-size: 0.58rem;
        color: rgba(255,255,255,0.25);
        text-align: right;
        margin-top: 4px;
    }

    /* Nav */
    .ca-sb-nav {
        flex: 1;
        list-style: none;
        padding: 6px 0 16px;
        margin: 0;
        overflow-y: auto;
    }

        .ca-sb-nav::-webkit-scrollbar {
            width: 3px;
        }

        .ca-sb-nav::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.08);
            border-radius: 99px;
        }

    /* Group label (e.g. "Physical Facilities") */
    .ca-sb-group-label {
        font-size: 0.57rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.22);
        padding: 12px 18px 4px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .ca-sb-group-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255,255,255,0.07);
        }

    /* Step link */
    .ca-sb-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 7px 10px;
        text-decoration: none;
        color: rgba(255,255,255,0.5);
        font-size: 0.78rem;
        font-weight: 500;
        transition: background 0.15s, color 0.15s;
        border-left: 3px solid transparent;
    }

        .ca-sb-link:hover {
            background: rgba(255,255,255,0.05);
            color: rgba(255,255,255,0.82);
            text-decoration: none;
        }

        .ca-sb-link.is-active {
            background: rgba(184,136,42,0.12);
            border-left-color: #d4a84b;
            color: #fff;
