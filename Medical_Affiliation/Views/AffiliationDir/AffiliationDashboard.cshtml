@model FacultyAndCollege
@{
    ViewBag.Title = "College Course Intake Details";
    var totalColleges = ViewBag.TotalColleges;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <!-- Bootstrap CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <style>
        *{
            font-weight: 400 !important;
        }
        body {
            font-family: 'Poppins', system-ui, Segoe UI, sans-serif;
            /* background:
                radial-gradient(900px 600px at 10% 10%, rgba(255,255,255,0.22), transparent 65%),
                radial-gradient(900px 400px at 95% 90%, rgba(111,192,255,0.10), transparent 65%),
                linear-gradient(135deg, #2a67b4 0%, #1b4e8f 100%); */
            min-height: 100vh;
            color: #fff !important;
        }

        .glass-card {
            background: linear-gradient(135deg, rgba(68,87,151,0.37) 10%, rgba(255,255,255,0.13) 85%);
            border-radius: 18px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.18);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,0.20);
            padding: 22px 22px 18px 22px;
            color: #fff;
            width: 75vw;
        }

        #intakeTable {
            width: 100%;
            border-collapse: separate;
            table-layout: fixed;
        }

            #intakeTable thead, #intakeTable tbody {
                display: block;
                width: 100%;
            }

            #intakeTable tbody {
                max-height: 45vh;
                overflow-y: auto;
                display: block;
                width: 100%;
            }

            #intakeTable th, #intakeTable td {
                width: 24%; 
                box-sizing: border-box;
            }


        .form-select, .form-control {
            background: rgba(255,255,255,0.21) !important;
            border-radius: 8px !important;
            color: #f7f7f7 !important;
            font-weight: 500;
        }

            .form-select option, .form-control option {
                background: #12385c !important; 
                color: #f4f4f4 !important;
                font-weight: 500;
            }

            .form-select:focus, .form-control:focus {
                box-shadow: 0 0 8px #4fc3f7;
                border: 1px solid #4fc3f7 !important;
                background: rgba(255,255,255,0.21) !important;
                border-radius: 8px !important;
                color: #f7f7f7 !important;
                font-weight: 500;
            }

        label {
            color: #fff;
            font-size: 18px;
            font-weight: 500 !important;
        }

        .table-glass {
            background: rgba(86,122,203,0.19) !important; 
            color: #f7f7f7 !important;
        }

        .table th{
            font-size: 18px;
            font-weight: 500 !important;
        }

        .table th, .table td {
            color: #fff !important;
            background: transparent !important;
        }


        .dataTables_wrapper .dataTables_filter label,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_length label {
            color: #fff !important;
        }

        .dataTables_wrapper .dt-button {
            color: #12385c !important;
            background: #fff !important;
            border-radius: 8px !important;
            border: none !important;
            margin-right: 6px;
        }

        #intakeTableFilters .form-control {
            width: 100%;
            padding: 6px 12px;
            border-radius: 8px;
            border: 1px solid #4fc3f7;
            background: rgba(255,255,255,0.21);
            color: #12385c;
            font-weight: 500;
            box-shadow: 0 0 4px #4fc3f726;
            margin-bottom: 0; 
        }

        #intakeTableFilters .form-control::placeholder {
            color: #5998cc;
            opacity: 0.9;
        }

        .intakeSummaryhide{
            display: none;
        }


        #intakeSummary{
            font-size: 14px;
            font-weight: 500;
        }

        .intakeSummaryDisplay{
            display: flex !important;
            flex-direction: row !important;
            gap: 2em !important;
            /* align-items: flex-end; */
            justify-content: flex-end;
            padding: .5em;
        }

        #intakeTableFilters .form-control:focus {
            background: rgba(255,255,255,0.29);
            box-shadow: 0 0 8px #4fc3f784;
            border-color: #2a67b4;
            color: #12385c;
        }

        @@media (max-width: 600px) {
            .row.g-3.align-items-end > [class^='col-'] {
                flex: 0 0 100%;
                max-width: 100%;
            }

            .glass-card {
                padding: 5vw 4vw;
            }

            label {
                font-size: 15px;
            }
        }


        @@media (max-width: 768px) {
            .glass-card {
                padding: 8px 25px !important;
                border-radius: 8px !important;
                width: 65vw !important;
            }

            .clg{
                margin-bottom: 1em !important;
            }
            .table-responsive {
                font-size: 13px;
                overflow-x: auto !important;
            }
            #intakeTable thead, #intakeTable tbody, #intakeTable th, #intakeTable td {
                display: table-row-group !important;
                width: auto !important;
            }
            #intakeTable {
                table-layout: auto !important;
                min-width: 520px;
            }
        }


        @@media (max-width: 600px) {
            .glass-card { margin-top: 9vw; padding: 12px; }
            .table-responsive { font-size: 13px; }
        }

        @@media(min-width: 1400px){
            .container {
                max-width: 100vw !important;
            }
            .glass-card{
                max-width: 85vw !important;
            }

            #statsContent {
                display: flex !important;
                flex-direction: row !important;
                gap: 2em !important;
            }
            .form-select{
                padding: .375rem 1.5rem .375rem .75rem;
            }

            
        }

        @@media (max-width: 1450px) {
            
            .glass-card {
                padding: 10px 13px 2px;

            }

            #intakeSummary {
                font-size: 14px;
            }

            .form-select option:hover, .form-control option:hover {
                background: #f4f4f4 !important; 
                color: #12385c !important;
                font-weight: 500;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-9 col-md-9">
                <h2 class="text-center text-white clg">College-Wise Course-Wise Intake Details</h2>
                <div class="glass-card shadow">
                        <form id="filterForm" autocomplete="off">
                            <div class="row g-3 align-items-end">
                                <div class="col-md-3 col-12">
                                    <label for="FacultyId" class="form-label">Faculty</label>
                                    <select asp-for="FacultyId" asp-items="Model.FacultyList" class="form-select" id="FacultyId"></select>
                                </div>
                                <div class="col-md-3 col-12">
                                    <label for="CollegeCode" class="form-label">College</label>
                                    <select asp-for="CollegeCode" asp-items="Model.CollegeList" class="form-select" id="CollegeCode">
                                        <option value="" selected>-- Select College --</option>
                                    </select>
                                </div>
                                <div class="col-md-3 col-12">
                                    <label for="CourseLevel" class="form-label">Course Level</label>
                                    <select asp-for="CourseLevel" asp-items="Model.CourseList" class="form-select" id="CourseLevel">
                                        <option value="" selected>-- Select Course Level --</option>
                                    </select>
                                </div>
                                <div class="col-md-3 col-12">
                                    <label for="CourseName" class="form-label">Subject</label>
                                    <select asp-for="CourseName" asp-items="Model.CoursesData" class="form-select" id="SubjectName"></select>
                                </div>

                            </div>
                        </form>

                        <div id="statsSummary" class="mt-3 p-3 rounded"
                             style="background: rgba(255,255,255,0.18); color:white; display:none;">
                            @* <h5 class="mb-2">Summary</h5> *@
                            <div id="statsContent"></div>
                        </div>

                        <!-- Intake Table -->
                        <div id="intakeDetails" class="table-responsive mt-4"></div>
                        <div id="intakeSummary" class="text-white intakeSummaryhide" style=""> </div>
                    </div>
        </div>
    </div>
</div>
    <!-- jQuery (required for DataTables) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- DataTables CSS & JS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <!-- DataTables Buttons for Export -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
    <!-- For PDF export -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <!-- For Excel export -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

<!-- Vanilla JS for dropdown logic -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {

            const facultySelect = document.getElementById("FacultyId");
            const collegeSelect = document.getElementById("CollegeCode");
            const courseSelect = document.getElementById("CourseLevel");
            const subjectSelect = document.getElementById("SubjectName");
            const intakeTableDiv = document.getElementById("intakeDetails");

            // Helper: fill dropdown
            function fillSelect(select, placeholder, items, includeAll = true) {
                select.innerHTML = `<option value="" selected>${placeholder}</option>`;
                if (includeAll) select.innerHTML += `<option value="All">All</option>`;
                items.forEach(item => {
                    const opt = document.createElement("option");
                    opt.value = item.value ?? item.Value;
                    opt.text = item.text ?? item.Text;
                    select.appendChild(opt);
                });
            }

            facultySelect.addEventListener("change", async () => {

                const url = `@Url.Action("GetCollegesForFaculty", "AffiliationDir")?facultyId=${encodeURIComponent(facultySelect.value)}`;

                const response = await fetch(url);
                const data = await response.json();

                fillSelect(collegeSelect, "-- Select College --", data);
                fillSelect(courseSelect, "-- Select Course Level --", [], false);
                fillSelect(subjectSelect, "-- Select Subject --", [], false);
                intakeTableDiv.innerHTML = "";
                updateStats();
            });

            collegeSelect.addEventListener("change", async () => {

                const url = `@Url.Action("GetCoursesForCollege", "AffiliationDir")?collegeId=${encodeURIComponent(collegeSelect.value)}`;

                const response = await fetch(url);
                const data = await response.json();

                fillSelect(courseSelect, "-- Select Course Level --", data);
                fillSelect(subjectSelect, "-- Select Subject --", [], false);
                intakeTableDiv.innerHTML = "";
                updateStats();

            });

            courseSelect.addEventListener("change", async () => {

                const url = `@Url.Action("GetSubjectsForCourses", "AffiliationDir")?courseId=${encodeURIComponent(courseSelect.value)}&facultyId=${encodeURIComponent(facultySelect.value)}&CollegeCode=${encodeURIComponent(collegeSelect.value)}`;

                const response = await fetch(url);
                const data = await response.json();

                fillSelect(subjectSelect, "-- Select Subject --", data);
                // intakeTableDiv.innerHTML = "";
                updateStats();
                runIntakeQuery();

            });

            subjectSelect.addEventListener("change", () => {
                updateStats();
                runIntakeQuery();
            });
            

            async function updateStats() {
                const facultyId = facultySelect.value || "All";
                const collegeId = collegeSelect.value || "All";
                const courseLevel = courseSelect.value || "All";
                const subject = subjectSelect.value || "All";

                const url = `@Url.Action("GetStats", "AffiliationDir")?facultyId=${facultyId}&collegeId=${collegeId}&courseLevel=${courseLevel}&subject=${subject}`;

                const response = await fetch(url);
                const stats = await response.json();
                let statsSummary = document.getElementById("statsSummary");
                statsSummary.style.display = "none";


                document.getElementById("statsContent").innerHTML = `
                        <div><strong>Faculties:</strong> ${stats.faculties}</div>
                        <div><strong>Colleges:</strong> ${stats.colleges}</div>
                        <div><strong>Courses:</strong> ${stats.courses}</div>
                        <div><strong>Subjects:</strong> ${stats.subjects}</div>
                    `;
            }

            async function runIntakeQuery() {

                const facultyId = facultySelect.value;
                const collegeId = collegeSelect.value;
                const courseLevel = courseSelect.value;
                const subject = subjectSelect.value;

                const url = `@Url.Action("GetIntakeDetails", "AffiliationDir")?facultyId=${encodeURIComponent(facultyId)}&collegeId=${encodeURIComponent(collegeId)}&courseLevel=${encodeURIComponent(courseLevel)}&subject=${encodeURIComponent(subject)}`;

                const response = await fetch(url);
                const data = await response.json();

                if (!data.intakeDetails || data.intakeDetails.length === 0) {
                    intakeTableDiv.innerHTML = '<div class="text-center text-white">No intake data for this selection.</div>';
                    document.getElementById("intakeSummary").style.display = "none";
                    return;
                }

                const rows = data.intakeDetails.map(row => `
                    <tr>
                        <td>${row.collegeName ?? ''}</td>
                        <td>${row.courseName ?? ''}</td>
                        <td>${row.rgushSintake ?? ''}</td>
                        <td>${row.presentintake ?? ''}</td>
                    </tr>
                `).join('');

                intakeTableDiv.innerHTML = `
                    <table id="intakeTable" class="table table-glass table-bordered" style="width:100%; table-layout:fixed;">
                        <thead>
                            <tr>
                                <th>College Name</th>
                                <th>Course Name</th>
                                <th>RGUHS Data</th>
                                <th>College Data</th>
                            </tr>
                        </thead>
                        <tbody>${rows}</tbody>
                    </table>
                `;

                if (window.intakeTableInstance) {
                    window.intakeTableInstance.destroy();
                }

                window.intakeTableInstance = new DataTable("#intakeTable", {
                    dom: "Bfrtip",
                    buttons: ["excelHtml5", "pdfHtml5", "print"],
                    scrollY: "50vh",
                    scrollCollapse: true,
                    paging: false,
                    order: [[0, "asc"]],
                    responsive: true
                });

                const totalCourses = data.intakeDetails.length;

                const totalExisting = data.intakeDetails.reduce((sum, row) => sum + (parseInt(row.rgushSintake) || 0), 0);
                const totalPresent = data.intakeDetails.reduce((sum, row) => sum + (parseInt(row.presentintake) || 0), 0);
                let totalClg = data.totalColleges;

                const summaryDiv = document.getElementById("intakeSummary");

                summaryDiv.classList.add("intakeSummaryDisplay");

                summaryDiv.innerHTML = `
                    <div><strong>Total Colleges:</strong> ${totalClg}</div>
                    <div><strong>Total Courses:</strong> ${totalCourses}</div>
                    <div><strong>Total RGUHS Intake Data:</strong> ${totalExisting}</div>
                    <div><strong>Total College Intake Data:</strong> ${totalPresent}</div>
                `;
            }


        });
    </script>
</body>
</html>
