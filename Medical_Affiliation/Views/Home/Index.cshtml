        <!-- About Section -->
        <section id="about" class="about section">
            <div class="container">
                <div class="row gy-4">
                    <div class="col-lg-6 order-1 order-lg-2" data-aos="fade-up" data-aos-delay="100">
                        <img src="@Url.Content("~/img/trainers/11.jpg")" class="img-fluid" alt="">
                    </div>

                    <div class="col-lg-6 order-2 order-lg-1 content" data-aos="fade-up" data-aos-delay="200">
                        <h3>@Localizer["Index1"]</h3>
                        <p class="fst-italic">@Localizer["Index2"]</p>
                        <ul>
                            <li><i class="bi bi-check-circle-fill text-success me-2"></i>@Localizer["Index3"]</li>
                            <li><i class="bi bi-check-circle-fill text-success me-2"></i>@Localizer["Index4"]</li>
                            <li><i class="bi bi-check-circle-fill text-success me-2"></i>@Localizer["Index5"]</li>
                        </ul>

                        <a href="http://www.rguhs.ac.in/index.html" class="read-more"><span>@Localizer["Index6"]</span><i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Trainers Index Section -->
        <section id="trainers-index" class="section trainers-index">
            <div class="container">
                <div class="row">
                    <div class="col-lg-4 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="100">
                        <div class="member">
                            <img src="@Url.Content("~/img/trainers/data.jpg")" class="img-fluid" alt="">
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="200">
                        <div class="member">
                            <img src="@Url.Content("~/img/trainers/1756455672299.jpg")" class="img-fluid" alt="">
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6 d-flex" data-aos="fade-up" data-aos-delay="300">
                        <div class="member">
                            <img src="@Url.Content("~/img/trainers/data.jpg")" class="img-fluid" alt="">
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <!-- Scroll Top -->
    <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center">
        <i class="bi bi-arrow-up-short"></i>
    </a>

    <!-- Preloader -->
    @* <div id="preloader"></div> *@
    <input type="hidden" id="languageErrorTitle" value="@Localizer["ErrorTitle"]" />
    <input type="hidden" id="languageErrorMessage" value="@Localizer["LanguageChangeError"]" />
    <input type="hidden" id="languageOK" value="@Localizer["OK"]" />
    <input type="hidden" id="setLanguageUrl" value="@Url.Action("SetLanguage", "Home")" />

    <!-- Vendor JS Files -->
    <script src="@Url.Content("~/vendor/bootstrap/js/bootstrap.js")"></script>
    <script src="@Url.Content("~/vendor/php-email-form/validate.js")"></script>
    <script src="@Url.Content("~/vendor/aos/aos.js")"></script>
    <script src="@Url.Content("~/vendor/glightbox/js/glightbox.min.js")"></script>
    <script src="@Url.Content("~/vendor/purecounter/purecounter_vanilla.js")"></script>
    <script src="@Url.Content("~/vendor/swiper/swiper-bundle.min.js")"></script>

    <!-- Main JS File -->
    <script src="@Url.Content("~/js/main.js")"></script>
    <script src="~/js/language.js" asp-append-version="true"></script>
</body>

</html>
