@inject IHttpContextAccessor HttpContextAccessor
@RenderSection("script", required: false)

@{
    ViewData["Title"] = "Dashboard";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    var typeOfAffiliationList = ViewData["TypeOfAffiliationList"] as List<SelectListItem>;
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    :root {
        --header-height: 140px;
        --footer-height: 0px;
    }

    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
        background: #f7f8fa;
        font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
        color: #333;
    }

    .main-content {
        padding: 2.5rem;
        max-width: 1200px;
        margin: var(--header-height) auto 0 auto;
    }

    .dashboard-card {
        background: #fff;
        padding: 2rem;
        border-radius: 1rem;
        text-align: center;
        box-shadow: 0 3px 32px rgba(44, 62, 80, .11), 0 1.5px 6px rgba(44,62,80,.05);
        margin-bottom: 2rem;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
        }

        .dashboard-card h2 {
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: #146c43;
        }

    .info-box {
        font-size: 1.1rem;
        margin-bottom: 1rem;
        color: #555;
    }

    .btn-primary {
        border-radius: 30px;
        padding: 0.6rem 1.7rem;
        font-size: 1.13rem;
        font-weight: 600;
        background: linear-gradient(90deg, #146c43 50%, #20c997 100%);
        border: none;
        color: #fff;
        box-shadow: 0 2px 8px rgba(20, 108, 67, 0.08);
        transition: background 0.3s, box-shadow 0.3s;
    }

        .btn-primary:hover, .btn-primary:focus {
            background: linear-gradient(90deg, #20c997 50%, #146c43 100%);
            box-shadow: 0 5px 15px rgba(20, 108, 67, 0.18);
        }

    .logout-btn {
        display: inline-block;
        border-radius: 30px;
        padding: 0.6rem 1.7rem;
        font-weight: 600;
        font-size: 1.1rem;
        background-color: #dc3545;
        color: #fff;
        transition: background 0.3s ease, box-shadow 0.3s ease;
    }

        .logout-btn:hover {
            background-color: #c82333;
            box-shadow: 0 5px 15px rgba(220, 53, 69, 0.2);
        }

    @@media (max-width: 991px) {
        .main-content {
            padding: 1.5rem;
            margin-top: 100px;
        }

        .dashboard-card {
            padding: 1.5rem;
        }
    }
</style>

