@if (!string.IsNullOrEmpty(facultyCode))
{
    @await Component.InvokeAsync("Sidebar")
}




<div class="nodal-container">
    <div class="container my-4">
        <div class="row">
            <div class="col">
                <form asp-controller="Login" asp-action="Login" method="post" class="m-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="fw-bold mb-0 text-center flex-grow-1">
                            @HttpContextAccessor.HttpContext.Session.GetString("CollegeName")
                        </h3>

                        <button type="submit" class="btn btn-outline-danger">
                            Logout
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <h2 class="mb-4">Nodal Officer Details</h2>
    <form id="nodalOfficerForm" asp-action="NodalOfficerDetails" method="post">
        <div class="mb-3">
            <label class="form-label">Faculty</label>
            @Html.DropDownListFor(m => m.FacultyCode, Model.FacultyList, "-- Select Faculty --", new { @class = "form-select", @disabled = "disabled" })
            @Html.HiddenFor(m => m.FacultyCode)
        </div>

        <div class="mb-3">
            <label class="form-label">College</label>
            @Html.DropDownListFor(m => m.CollegeCode, Model.CollegeList, "-- Select College --", new { @class = "form-select", @disabled = "disabled" })
            @Html.HiddenFor(m => m.CollegeCode)
        </div>
        <div class="mb-3">
            <label for="NodalOfficerName" class="form-label">Nodal Officer Name</label>
            @Html.TextBoxFor(m => m.NodalOfficerName, new { @class = "form-control", placeholder = "Enter Nodal Officer Name", id = "NodalOfficerName" })
        </div>
        <div class="mb-3">
            <label for="PhoneNumber" class="form-label">Mobile Number</label>
            @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control", placeholder = "Enter Mobile Number", id = "PhoneNumber" })
        </div>
        <div class="mb-3">
            <label for="EmailId" class="form-label">Email Id</label>
            @Html.TextBoxFor(m => m.EmailId, new { @class = "form-control", placeholder = "Enter Email Id", type = "email", id = "EmailId" })
        </div>
        
        <div>
            <label class="form-label">Initiatives List</label><br />
            <div class="card" style="padding: 10px; border-radius: 10px">
                <div class="form-check">
                    <input type="checkbox" id="allInitiatives" class="form-check-input" />
                    <label for="selectAll" class="form-check-label fw-bold">Select All</label>
                </div>
                <hr />
                @for (int i = 0; i < Model.InitiativeList.Count; i++)
                {
                    <div class="form-check">
                        <input asp-for="InitiativeList[i].IsSelected" class="form-check-input initiative-checkbox" type="checkbox" value="true" />
                        <input type="hidden" asp-for="InitiativeList[i].Id" />
                        <label class="form-check-label">
                            @Model.InitiativeList[i].Name
                        </label>
                    </div>
                }
            </div>
        </div>
        <div class="mb-3" style="text-align: center">
            <button type="submit" class="btn btn-primary">Save</button>
        </div>
    </form>
</div>



<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- SweetAlert2 JS -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    $(document).ready(function () {
        // ✅ Client-side validation before form submit

        $("#nodalOfficerForm").submit(function (e) {
            let name = $("#NodalOfficerName").val().trim();
            let phone = $("#PhoneNumber").val().trim();
            let email = $("#EmailId").val().trim();

            if (name === "") {
                Swal.fire("Validation Error", "Please enter Nodal Officer Name", "error");
                return false;
            }
            if (!/^\d{10}$/.test(phone)) {
                Swal.fire("Validation Error", "Please enter a valid 10-digit Mobile Number", "error");
                return false;
            }
            if (email === "") {
                Swal.fire("Validation Error", "Please enter Email Id", "error");
                return false;
            }
            return true; // allow form to submit
        });
        $("#allInitiatives").on("change", function () {
            $(".initiative-checkbox").prop("checked", $(this).prop("checked"));
        });

        $(".initiative-checkbox").on("change", function () {
            if (!$(this).prop("checked")) {
                $("#allInitiatives").prop("checked", false);
            } else if ($(".initiative-checkbox:checked").length === $(".initiative-checkbox").length) {
                $("#allInitiatives").prop("checked", true);
            }
        })

        // ✅ Show server-side SweetAlert (after redirect)
    @if (TempData["SuccessMessage"] != null)
    {
        <text>
                Swal.fire({
                    icon: "success",
                    title: "Success",
                    text: "@TempData["SuccessMessage"]",
                    confirmButtonColor: "#3085d6"
                });
        </text>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <text>
                Swal.fire({
                    icon: "error",
                    title: "Error",
                    text: "@TempData["ErrorMessage"]",
                    confirmButtonColor: "#d33"
                });
        </text>
    }
        });
</script>
