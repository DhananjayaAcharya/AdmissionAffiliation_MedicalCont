@model NodalOfficerReportData1

@{
    ViewData["Title"] = "Nodal Officer Report";
}
<link rel="stylesheet" 
      href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
<link rel="stylesheet" 
      href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" />


<nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
    <div class="container">

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a asp-controller="Admin" asp-action="AdminDashboard" class="sidebar-btn btn btn-light d-block">
                        🏠 Home
                    </a>
                </li>
            </ul>
            @* <form asp-controller="Admin" asp-action="AdminLogin" method="post" class="mb-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Logout</button>
            </form> *@
        </div>
    </div>
</nav>

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Nodal Officer Report</h3>
        </div>
        <div class="card-body">
        <form method="post" asp-action="NodalOfficerReport" id="reportForm">
    @Html.AntiForgeryToken()
    <div class="row g-3">
                    <div class="col-md-4">
                        <label for="Faculty" class="form-label fw-bold">
                            <i class="fas fa-user-tie me-2"></i>Faculty <span class="text-danger">*</span>
                        </label>
                        @Html.DropDownListFor(m => m.SelectedFaculty, Model.FacultyList, "Select Faculty", new { @class = "form-select select2", @id = "Faculty", required = true })
                        @Html.ValidationMessageFor(m => m.SelectedFaculty, "", new { @class = "text-danger" })
                    </div>

                    <!-- College Name -->
                    <!-- College Name -->
                    <div class="col-md-4">
                        <label for="dropCollege" class="form-label fw-bold">
                            <i class="fas fa-building me-2"></i>College Name <span class="text-danger">*</span>
                        </label>
                        @Html.DropDownListFor(m => m.SelectedCollege, Model.CollegeList, new { @class = "form-select select2", @id = "dropCollege", required = true })
                        @Html.ValidationMessageFor(m => m.SelectedCollege, "", new { @class = "text-danger" })
                    </div>

            </div>

                <div class="text-center mt-3">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-search"></i> Fetch Report
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.NodalOfficerReport != null && Model.NodalOfficerReport.Any())
    {
        <div class="card shadow-lg border-0 rounded-3 mt-4">
            <div class="card-body">
                <div class="table-responsive">
                    <table id="reportTable" class="table table-striped table-bordered display nowrap" style="width:100%">
                        <thead class="table-dark">
                            <tr>
                                <th>Sl No</th>
                                <th>Faculty</th>
                                <th>College Name</th>
                                <th>Initiative</th>
                                <th>Nodal Officer Name</th>
                                <th>Mobile</th>
                                <th>Email</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int i = 1;
                            }
                            @foreach (var item in Model.NodalOfficerReport)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td>@item.FacultyName</td>
                                    <td>@item.CollegeName</td>
                                    <td>@item.Initiative</td>
                                    <td>@item.NodalOfficerName</td>
                                    <td>@item.PhoneNumber</td>
                                    <td>@item.EmailId</td>
                                </tr>
                                i = i + 1;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
@Html.Hidden("MyURL", @Url.Action("BindCollegeBasedOnFaculty", "Admin"))
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

<script>
    $(document).ready(function () {
         const logoUrl = 'data:image/jpeg;base64,';
            const backlogo = 'data:image/jpeg;base64,';

        // Initialize DataTable
        $('#reportTable').DataTable({
           dom: 'Bfrtip',
                buttons: [
                    {
                        extend: 'pdfHtml5',
                        text: 'PDF',
                        filename: 'Nodal Officer Detailed Reports',
                        customize: function (doc) {
                            // Set PDF to landscape orientation
                            doc.pageOrientation = 'portrait';

                            // Remove default header
                            doc.content.splice(0, 1);
                            doc.pageMargins = [20, 30, 20, 70]; // Bottom margin increased for footer

                            doc.background = function (currentPage, pageSize) {
                                const images = [];
                                const logoWidth = 80;
                                const logoHeight = 80;
                                const stepX = 120;
                                const stepY = 100;

                                for (let y = 0; y < pageSize.height; y += stepY) {
                                    for (let x = 0; x < pageSize.width; x += stepX) {
                                        images.push({
                                            image: logoUrl,
                                            width: logoWidth,
                                            height: logoHeight,
                                            opacity: 0.25,
                                            absolutePosition: { x: x, y: y }
                                        });
                                    }
                                }

                                return images;
                            };

                            doc.content.unshift({
                                table: {
                                    widths: ['auto', '*'], // Two columns: one for the logo, one for the text
                                    body: [
                                        [
                                            {
                                                image: backlogo,
                                                width: 100,
                                                height: 80,
                                                alignment: 'left',
                                                margin: [20, 0, 0, 0] // Add margin for spacing
                                            },
                                            {
                                                text: 'Rajiv Gandhi University of Health Sciences, Karnataka\n4th \'T\' Block, Jayanagar, Bangalore - 560 041',
                                                fontSize: 18,
                                                bold: true,
                                                alignment: 'left', // Align text to the left
                                                margin: [20, 20, 0, 0] // Add margin for spacing
                                            }
                                        ],
                                       
                               
                                        [
                                            {
                                                text: 'Nodal Officer Detailed Reports',
                                                fontSize: 18,
                                                bold: true,
                                                decoration: 'underline',
                                                alignment: 'center',
                                                colSpan: 2 // Span across both columns
                                            },
                                            {} // Empty cell for the second column
                                        ],
                                    ]
                                },
                                layout: {
                                    hLineWidth: function (i, node) {
                                        // Draw horizontal lines only for the first and last rows
                                        if (i === 0 || i === node.table.body.length - 1) {
                                            return 2; // Top and bottom borders
                                        }
                                        return 0; // No horizontal lines for other rows
                                    },
                                    vLineWidth: function () { return 0; },
                                    hLineColor: function (i, node) {
                                        return (i === 0 || i === node.table.body.length - 1) ? '#000000' : null; // Black for top and bottom
                                    },
                                    paddingLeft: function () { return 10; },
                                    paddingRight: function () { return 10; },
                                    paddingTop: function () { return 5; },
                                    paddingBottom: function () { return 5; }
                                },
                                margin: [0, 0, 0, 10] // Margin below the table
                            });


                            doc.styles.tableHeader.color = 'black';
                            doc.styles.tableHeader.fillColor = '#F0F0F0';
                            doc.styles.tableBodyOdd.fillColor = '#FFFFFF';
                            doc.styles.tableBodyEven.fillColor = null;


                            // Function to format date and time
                            function formatDateTime(date) {
                                var day = date.getDate().toString().padStart(2, '0');
                                var month = (date.getMonth() + 1).toString().padStart(2, '0');
                                var year = date.getFullYear();
                                var hours = date.getHours().toString().padStart(2, '0');
                                var minutes = date.getMinutes().toString().padStart(2, '0');
                                return day + '/' + month + '/' + year + ' ' + hours + ':' + minutes;
                            }

                            // Customize footer
                            doc.footer = function (page, pages) {
                                return {
                                    columns: [
                                        {
                                            alignment: 'left',
                                            margin: [20, 0, 0, 0],
                                            text: 'Downloaded on: ' + formatDateTime(new Date())
                                        },
                                        {
                                            alignment: 'right',
                                            margin: [0, 0, 20, 0],
                                            text: 'Page ' + page.toString() + ' of ' + pages.toString()
                                        }
                                    ],
                                    margin: [20, 10, 20, 10]
                                };
                            };

                            // Simplified table layout
                            var tableLayout = {
                                hLineWidth: function (i) { return 0.5; },
                                vLineWidth: function (i) { return 0.5; },
                                hLineColor: function () { return '#aaa'; },
                                vLineColor: function () { return '#aaa'; },
                                paddingLeft: function () { return 1; },
                                paddingRight: function () { return 1; },
                                paddingTop: function () { return 5; },
                                paddingBottom: function () { return 5; },
                                fillColor: function (row) { return (row % 2 === 0) ? '#FFFFFF' : null; },
                                pageBreak: 'auto',
                                tableWidth: 'auto',
                                margin: [0, 10, 0, 10]
                            };

                            doc.defaultStyle.fontSize = 10;
                            doc.defaultStyle.alignment = 'left';
                            doc.pageMargins = [20, 30, 20, 30]; // Adjust margins as needed

                            // Define column widths if necessary
                            if (doc.content[1].table && doc.content[1].table.body) {
                                doc.content[1].table.widths = ['5%', '15%', '25%','12%' ,'12%', '12%', '20%'];
                            }

                            doc.content[1].layout = tableLayout;

                            // Calculate current content height
                            let currentContentHeight = 0;
                            doc.content.forEach(item => {
                                if (item.table) {
                                    currentContentHeight += item.table.body.length * 10; // Approximate height per row
                                }
                            });

                         


                        }



                    },
                    'excelHtml5',
                    'csvHtml5',
                    'print'
                ],
                "pageLength": 10,
                "lengthMenu": [10, 25, 50, 75, 100]
        });

    $('#Faculty').on('change', function () {
        // debugger
          var facultyId = $(this).val();
          var $collegeSelect = $('#dropCollege');
          var $loading = $('<span class="spinner-border spinner-border-sm ms-2" role="status" aria-hidden="true"></span>');

          $collegeSelect.prop('disabled', true).after($loading);
          $collegeSelect.empty();

          if (!facultyId) {
              $collegeSelect.prop('disabled', false);
              $loading.remove();
              return;
          }

          $.ajax({
              url: $('#MyURL').val(),
              type: 'POST',
              data: {
                  _RequestVerificationToken: $('input[name="_RequestVerificationToken"]').val(),
                  Faculty: facultyId
              },
              success: function (data) {
                  if (data && Array.isArray(data)) {
                      $.each(data, function (i, item) {
                          $collegeSelect.append($('<option>', {
                              value: item.Value || item.value,
                              text: item.Text || item.text
                          }));
                      });
                  } else {
                      alert('No colleges found for the selected faculty.');
                  }
              },
              error: function (xhr, status, error) {
                  alert('Error loading colleges: ' + (xhr.responseText || error));
              },
              complete: function () {
                  $collegeSelect.prop('disabled', false);
                  $loading.remove();
              }
          });
      });
    });
</script>
