/@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard";
    var faculties = ViewBag.Faculties;
    var username = ViewBag.UserName as string ?? "Administrator";
    var IsAdmin = ViewBag.IsAdmin ?? true;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RGUHS Admin Portal</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Sora:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

    <style>
        :root {
            --navy: #0b1e3d;
            --navy-mid: #122648;
            --navy-light: #1a3560;
            --gold: #c9973a;
            --gold-light: #e2b460;
            --teal: #0e8a73;
            --teal-light: #12a98d;
            --surface: #f0f4f9;
            --card: #ffffff;
            --text-main: #0d1b2a;
            --text-muted: #6b7a8d;
            --border: #dde3ee;
            --shadow-sm: 0 2px 8px rgba(11,30,61,.07);
            --shadow-md: 0 6px 24px rgba(11,30,61,.11);
            --shadow-lg: 0 12px 40px rgba(11,30,61,.15);
            --radius: 14px;
            --sidebar-w: 272px;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--surface);
            color: var(--text-main);
            min-height: 100vh;
        }

        /* ── TOP HEADER ─────────────────────────────────────────── */
        .site-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 64px;
            background: var(--navy);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem 0 calc(var(--sidebar-w) + 1.5rem);
            z-index: 1100;
            box-shadow: 0 2px 16px rgba(0,0,0,.35);
            gap: 1rem;
        }

        .header-logo-area {
            position: absolute;
            left: 0;
            top: 0;
            width: var(--sidebar-w);
            height: 64px;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0 1.4rem;
            background: linear-gradient(135deg, #0d2554 0%, #0b1e3d 100%);
            border-right: 1px solid rgba(255,255,255,.07);
        }

        .logo-emblem {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: .85rem;
            color: var(--navy);
            letter-spacing: .03em;
            flex-shrink: 0;
            box-shadow: 0 3px 10px rgba(201,151,58,.4);
        }

        .logo-text {
            line-height: 1.2;
        }

        .logo-title {
            font-family: 'Sora', sans-serif;
            font-weight: 700;
            font-size: .78rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: #fff;
        }

        .logo-sub {
            font-size: .65rem;
            color: rgba(255,255,255,.45);
            letter-spacing: .04em;
            text-transform: uppercase;
        }

        .header-breadcrumb {
            font-size: .78rem;
            color: rgba(255,255,255,.45);
            letter-spacing: .05em;
            text-transform: uppercase;
        }

            .header-breadcrumb span {
                color: var(--gold-light);
                font-weight: 600;
            }

        .header-right {
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .header-badge {
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
            border-radius: 8px;
            padding: .3rem .75rem;
            font-size: .78rem;
            color: rgba(255,255,255,.75);
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .header-badge i {
                color: var(--gold-light);
            }

        .header-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--teal) 0%, var(--teal-light) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: .8rem;
            border: 2px solid rgba(255,255,255,.15);
        }

        .mobile-toggle {
            display: none;
            background: none;
            border: none;
            color: white;
            font-size: 1.4rem;
            cursor: pointer;
            padding: .3rem;
        }

        /* ── SIDEBAR ─────────────────────────────────────────────── */
        .sidebar {
            position: fixed;
            top: 64px;
            left: 0;
            width: var(--sidebar-w);
            height: calc(100vh - 64px);
            background: linear-gradient(180deg, #0d2554 0%, var(--navy) 100%);
            overflow-y: auto;
            overflow-x: hidden;
            z-index: 1000;
            transition: transform .3s cubic-bezier(.4,0,.2,1);
            border-right: 1px solid rgba(255,255,255,.06);
        }

            .sidebar::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar::-webkit-scrollbar-track {
                background: transparent;
            }

            .sidebar::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,.15);
                border-radius: 4px;
            }

        .sidebar-section-label {
            padding: 1.5rem 1.4rem .5rem;
            font-size: .65rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: rgba(255,255,255,.28);
        }

        .sidebar-nav {
            padding: 0 .75rem 1.5rem;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: .72rem 1rem;
            border-radius: 9px;
            color: rgba(255,255,255,.62);
            text-decoration: none;
            font-size: .875rem;
            font-weight: 500;
            transition: all .22s ease;
            margin-bottom: 2px;
            position: relative;
        }

            .sidebar-link:hover {
                background: rgba(255,255,255,.07);
                color: rgba(255,255,255,.92);
            }

            .sidebar-link.active {
                background: linear-gradient(90deg, rgba(201,151,58,.18) 0%, rgba(201,151,58,.06) 100%);
                color: var(--gold-light);
                border: 1px solid rgba(201,151,58,.2);
            }

                .sidebar-link.active::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 20%;
                    bottom: 20%;
                    width: 3px;
                    border-radius: 0 3px 3px 0;
                    background: var(--gold);
                }

            .sidebar-link i {
                font-size: 1.1rem;
                width: 20px;
                text-align: center;
                flex-shrink: 0;
                opacity: .85;
            }

        .sidebar-divider {
            height: 1px;
            background: rgba(255,255,255,.07);
            margin: .5rem .75rem;
        }

        .sidebar-link.logout {
            color: rgba(255,120,100,.65);
        }

            .sidebar-link.logout:hover {
                background: rgba(255,80,60,.08);
                color: rgba(255,120,100,.9);
            }

        /* ── MAIN ────────────────────────────────────────────────── */
        .main {
            margin-left: var(--sidebar-w);
            margin-top: 64px;
            padding: 2rem 2rem 3rem;
            min-height: calc(100vh - 64px);
            transition: margin-left .3s;
        }

        /* ── WELCOME BANNER ──────────────────────────────────────── */
        .welcome-banner {
            background: linear-gradient(130deg, var(--navy) 0%, #163b7a 55%, #0e5c6e 100%);
            border-radius: var(--radius);
            padding: 2rem 2.2rem;
            margin-bottom: 1.8rem;
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }

            .welcome-banner::before {
                content: '';
                position: absolute;
                top: -40px;
                right: -40px;
                width: 220px;
                height: 220px;
                border-radius: 50%;
                background: rgba(201,151,58,.08);
                pointer-events: none;
            }

            .welcome-banner::after {
                content: '';
                position: absolute;
                bottom: -60px;
                right: 80px;
                width: 160px;
                height: 160px;
                border-radius: 50%;
                background: rgba(14,138,115,.1);
                pointer-events: none;
            }

        .welcome-title {
            font-family: 'Sora', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: .3rem;
        }

            .welcome-title strong {
                color: var(--gold-light);
            }

        .welcome-sub {
            font-size: .87rem;
            color: rgba(255,255,255,.55);
        }

        .btn-manage {
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.2);
            color: #fff;
            border-radius: 9px;
            padding: .6rem 1.3rem;
            font-size: .85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all .25s;
            white-space: nowrap;
            backdrop-filter: blur(6px);
        }

            .btn-manage:hover {
                background: rgba(201,151,58,.25);
                border-color: var(--gold);
                color: var(--gold-light);
                transform: translateY(-2px);
            }

        /* ── STAT CARDS ──────────────────────────────────────────── */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.1rem;
            margin-bottom: 1.8rem;
        }

        .stat-card {
            background: var(--card);
            border-radius: var(--radius);
            padding: 1.4rem 1.5rem;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 1rem;
            transition: transform .25s, box-shadow .25s;
            position: relative;
            overflow: hidden;
        }

            .stat-card::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                border-radius: var(--radius) var(--radius) 0 0;
            }

            .stat-card.blue::after {
                background: linear-gradient(90deg, #1a5fd4, #3b8ef0);
            }

            .stat-card.green::after {
                background: linear-gradient(90deg, var(--teal), var(--teal-light));
            }

            .stat-card.amber::after {
                background: linear-gradient(90deg, #d97706, #f59e0b);
            }

            .stat-card.gold::after {
                background: linear-gradient(90deg, var(--gold), var(--gold-light));
            }

            .stat-card:hover {
                transform: translateY(-4px);
                box-shadow: var(--shadow-md);
            }

        .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.35rem;
            flex-shrink: 0;
        }

        .stat-card.blue .stat-icon {
            background: #e8f0fd;
            color: #1a5fd4;
        }

        .stat-card.green .stat-icon {
            background: #e6f7f3;
            color: var(--teal);
        }

        .stat-card.amber .stat-icon {
            background: #fef3e2;
            color: #d97706;
        }

        .stat-card.gold .stat-icon {
            background: #fdf3e0;
            color: var(--gold);
        }

        .stat-value {
            font-family: 'Sora', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            line-height: 1;
            margin-bottom: 3px;
        }

        .stat-label {
            font-size: .78rem;
            font-weight: 500;
            color: var(--text-muted);
            letter-spacing: .02em;
        }

        /* ── ACTION PANELS ───────────────────────────────────────── */
        .action-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.4rem;
        }

        .action-panel {
            background: var(--card);
            border-radius: var(--radius);
            padding: 1.6rem;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
        }

        .panel-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 1.2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--border);
        }

        .panel-icon {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }

            .panel-icon.navy {
                background: #e4ecfa;
                color: var(--navy);
            }

            .panel-icon.teal {
                background: #e4f7f2;
                color: var(--teal);
            }

        .panel-title {
            font-weight: 700;
            font-size: .92rem;
            color: var(--text-main);
            letter-spacing: .01em;
        }

        .action-btn {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: .75rem 1rem;
            border-radius: 9px;
            background: #f7f9fc;
            border: 1px solid var(--border);
            color: var(--text-main);
            font-size: .855rem;
            font-weight: 500;
            text-decoration: none;
            transition: all .22s;
            margin-bottom: .5rem;
        }

            .action-btn:last-child {
                margin-bottom: 0;
            }

            .action-btn i {
                width: 32px;
                height: 32px;
                border-radius: 8px;
                background: #edf1f8;
                color: var(--navy-light);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1rem;
                flex-shrink: 0;
                transition: all .22s;
            }

            .action-btn:hover {
                background: var(--navy);
                border-color: var(--navy);
                color: #fff;
                transform: translateX(4px);
                box-shadow: var(--shadow-md);
            }

                .action-btn:hover i {
                    background: rgba(255,255,255,.15);
                    color: var(--gold-light);
                }

        /* ── MODAL ───────────────────────────────────────────────── */
        .modal-content {
            border: none;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 24px 64px rgba(0,0,0,.18);
        }

        .modal-header {
            background: linear-gradient(130deg, var(--navy) 0%, #163b7a 100%);
            color: white;
            padding: 1.2rem 1.6rem;
            border-bottom: none;
        }

        .modal-title {
            font-weight: 700;
            font-size: .97rem;
        }

        .btn-close {
            filter: invert(1) brightness(2);
        }

        .modal-body {
            padding: 1.4rem 1.6rem;
        }

        .table th {
            font-size: .75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: var(--text-muted);
            background: #f6f8fc;
            border-bottom: 2px solid var(--border);
        }

        .table td {
            vertical-align: middle;
            font-size: .875rem;
        }

        .form-check-input:checked {
            background-color: var(--teal);
            border-color: var(--teal);
        }

        /* ── RESPONSIVE ──────────────────────────────────────────── */
        @@media (max-width: 1200px) {
            .stat-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 992px) {
            .sidebar {
                transform: translateX(-100%);
            }

                .sidebar.open {
                    transform: translateX(0);
                }

            .main {
                margin-left: 0;
            }

            .site-header {
                padding-left: 4.5rem;
            }

            .mobile-toggle {
                display: block;
            }

            .action-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 640px) {
            .stat-grid {
                grid-template-columns: 1fr 1fr;
            }

            .welcome-title {
                font-size: 1.15rem;
            }

            .main {
                padding: 1.2rem 1rem;
            }
        }

        /* ── FADE-IN ANIMATION ───────────────────────────────────── */
        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(14px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .welcome-banner {
            animation: fadeUp .4s ease both;
        }

        .stat-card:nth-child(1) {
            animation: fadeUp .4s .05s ease both;
        }

        .stat-card:nth-child(2) {
            animation: fadeUp .4s .10s ease both;
        }

        .stat-card:nth-child(3) {
            animation: fadeUp .4s .15s ease both;
        }

        .stat-card:nth-child(4) {
            animation: fadeUp .4s .20s ease both;
        }

        .action-panel:nth-child(1) {
            animation: fadeUp .4s .25s ease both;
        }

        .action-panel:nth-child(2) {
            animation: fadeUp .4s .30s ease both;
        }
    </style>
</head>
<body>

    <!-- ╔═══════════════════════════════════════════╗ -->
    <!-- ║              GLOBAL HEADER                ║ -->
    <!-- ╚═══════════════════════════════════════════╝ -->
    <header class="site-header">
        <!-- Logo locked in sidebar column -->
        <div class="header-logo-area">
            <div class="logo-emblem">RGU</div>
            <div class="logo-text">
                <div class="logo-title">RGUHS Portal</div>
                <div class="logo-sub">Admin Management System</div>
            </div>
        </div>

        <!-- Mobile toggle -->
        <button class="mobile-toggle" id="sidebarToggle" aria-label="Open sidebar">
            <i class="bi bi-list"></i>
        </button>

        <!-- Breadcrumb -->
        <div class="header-breadcrumb d-none d-md-block">
            Admin Console &nbsp;/&nbsp; <span>Dashboard</span>
        </div>

        <div class="ms-auto header-right">
            <div class="header-badge">
                <i class="bi bi-shield-check-fill"></i>
                @(IsAdmin ? "Super Admin" : "Operator")
            </div>
            <div class="header-avatar">
                @(username?.Length > 0 ? username[0].ToString().ToUpper() : "A")
            </div>
        </div>
    </header>

    <!-- ╔═══════════════════════════════════════════╗ -->
    <!-- ║                 SIDEBAR                   ║ -->
    <!-- ╚═══════════════════════════════════════════╝ -->
    <aside class="sidebar" id="sidebar">
        <nav class="sidebar-nav">
            <div class="sidebar-section-label">Navigation</div>

            <a class="sidebar-link active" href="@Url.Action("Dashboard", "Admin")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a class="sidebar-link" href="@Url.Action("AddCollege", "Admin")">
                <i class="bi bi-building-add"></i> Add College
            </a>
            <a class="sidebar-link" href="@Url.Action("AddCourse", "Admin")">
                <i class="bi bi-journal-plus"></i> Add Course
            </a>
            <a class="sidebar-link" href="@Url.Action("NodalOfficersForAdmin", "Admin")">
                <i class="bi bi-person-badge-fill"></i> Nodal Officers
            </a>

            <div class="sidebar-divider"></div>
            <div class="sidebar-section-label">Reports</div>

            <a class="sidebar-link" href="@Url.Action("AdminDocumentReport", "Admin")">
                <i class="bi bi-file-earmark-check"></i> Document Reports
            </a>
            <a class="sidebar-link" href="@Url.Action("CollegeWiseReport", "Admin")">
                <i class="bi bi-building-check"></i> College Reports
            </a>
            <a class="sidebar-link" href="@Url.Action("UniversityDashboard", "Home")">
                <i class="bi bi-building-check"></i> Colleg-wise Medical UG Fcaulty List Reports
            </a>

            @if (IsAdmin)
            {
                <div class="sidebar-divider"></div>
                <div class="sidebar-section-label">Administration</div>
                <a class="sidebar-link" href="@Url.Action("ManageCollegeStatus", "Admin")">
                    <i class="bi bi-building-gear"></i> Manage College Status
                </a>
            }

            <div class="sidebar-divider" style="margin-top:auto;"></div>
            <form asp-controller="Admin"
                  asp-action="Logout"
                  method="post"
                  style="margin:0;">

                @Html.AntiForgeryToken()

                <button type="submit"
                        class="sidebar-link logout border-0 bg-transparent w-100 text-start">

                    <i class="bi bi-box-arrow-right"></i>
                    Sign Out
                </button>
            </form>
        </nav>
    </aside>

    <!-- ╔═══════════════════════════════════════════╗ -->
    <!-- ║               MAIN CONTENT                ║ -->
    <!-- ╚═══════════════════════════════════════════╝ -->
    <main class="main">

        <!-- Welcome Banner -->
        <div class="welcome-banner d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <div class="welcome-title">Welcome back, <strong>@username</strong></div>
                <div class="welcome-sub">Rajiv Gandhi University of Health Sciences &mdash; Administrative Portal</div>
            </div>
            @if (IsAdmin)
            {
                <button class="btn-manage" data-bs-toggle="modal" data-bs-target="#facultyModal">
                    <i class="bi bi-gear-fill"></i> Manage Faculties
                </button>
            }
        </div>

        <!-- Action Panels -->
        <div class="action-grid">

            <!-- Management -->
            <div class="action-panel">
                <div class="panel-header">
                    <div class="panel-icon navy"><i class="bi bi-sliders2"></i></div>
                    <div class="panel-title">Management Actions</div>
                </div>
                <a asp-action="AddCollege" class="action-btn"><i class="bi bi-building-add"></i> Add New College</a>
                <a asp-action="AddCourse" class="action-btn"><i class="bi bi-journal-plus"></i> Add Course to College</a>
              @*   <a asp-action="AddCourseToMstCourse" class="action-btn"><i class="bi bi-book"></i> Add to Course Master</a>
                <a asp-action="AddDepartmentToDepartmentMaster" class="action-btn"><i class="bi bi-diagram-3"></i> Add Department</a>
                <a asp-action="NodalOfficersForAdmin" class="action-btn"><i class="bi bi-person-badge-fill"></i> Manage Nodal Officers</a>
                <a asp-action="TabsToggle" class="action-btn"><i class="bi bi-layout-sidebar-inset"></i> Sidebar Settings</a> *@
            </div>

            <!-- Reports -->
            <div class="action-panel">
                <div class="panel-header">
                    <div class="panel-icon teal"><i class="bi bi-bar-chart-steps"></i></div>
                    <div class="panel-title">Reports &amp; Approvals</div>
                </div>
