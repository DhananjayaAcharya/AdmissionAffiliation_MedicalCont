@model AddCourseToMstCourseViewModel
<nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
    <div class="container">

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a asp-controller="Admin" asp-action="AdminDashboard" asp-route-username="@ViewBag.UserName" class="nav-link btn btn-outline-primary">
                        🏠 Home
                    </a>
                </li>
            </ul>
            <form asp-controller="Admin" asp-action="Logout" method="post" class="mb-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Logout</button>
            </form>
        </div>
    </div>
</nav>
<h4 class="mt-4">➕ Add New Course</h4>

<form asp-action="AddNewCourse" method="post">
    <div class="row mb-3">
        <div class="col-md-3">
            <label asp-for="NewCourse.FacultyCode" class="form-label">Faculty</label>
            <select asp-for="NewCourse.FacultyCode" asp-items="Model.Faculties" class="form-select">
                <option value="">-- Select Faculty --</option>
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="NewCourse.CourseLevel" class="form-label">Course Level</label>
            <select id="courseLevelSelect" asp-for="NewCourse.CourseLevel" asp-items="Model.CourseLevels" class="form-select">
                <option value="">-- Select Course Level --</option>
                <option value="__other__">➕ Other</option>
            </select>
            <input type="text" id="customCourseLevel" name="NewCourse.CourseLevel" class="form-control mt-2 d-none" placeholder="Enter new course level" />
        </div>
        <div class="col-md-3">
            <label asp-for="NewCourse.CoursePrefix" class="form-label">Course Prefix</label>
            <select id="coursePrefixSelect" asp-for="NewCourse.CoursePrefix" asp-items="Model.CoursePrefixList" class="form-select">
                <option value="">-- Select Course Prefix --</option>
                <option value="__other__">➕ Other</option>
            </select>
            <input type="text" id="customCoursePrefix" name="NewCourse.CoursePrefix" class="form-control mt-2 d-none" placeholder="Enter new prefix" />
        </div>
        <div class="col-md-4">
            <label asp-for="NewCourse.CourseName" class="form-label">Course Name</label>
            <input asp-for="NewCourse.CourseName" class="form-control" />
        </div>
    </div>

    @* <div class="row mb-3">
        <div class="col-md-12">
            <label asp-for="NewCourse.SubjectName" class="form-label"></label>
            <input asp-for="NewCourse.SubjectName" class="form-control" />
        </div>
    </div> *@

    <button type="submit" class="btn btn-success">Add Course</button>
</form>

<hr />

<form asp-action="AddCourseToMstCourse" method="get" class="mt-3">
    <div class="mb-3">
        <label asp-for="SelectedFacultyCode" class="form-label"></label>
        <select asp-for="SelectedFacultyCode" asp-items="Model.Faculties"
                class="form-select" onchange="this.form.submit()">
            <option value="">-- Select Faculty --</option>
        </select>
    </div>
</form>

@if (Model.Courses.Any())
{
    <div class="table-responsive mt-4">
        <table id="coursesTable" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Course Code</th>
                    <th>Course Name</th>
                    <th>Faculty Code</th>
                    <th>Course Level</th>
                    <th>Course Prefix</th>
                    <th>Subject Name</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model.Courses)
                {
                    <tr>
                        <td>@course.CourseCode</td>
                        <td>@course.CourseName</td>
                        <td>@course.FacultyCode</td>
                        <td>@course.CourseLevel</td>
                        <td>@course.CoursePrefix</td>
                        <td>@course.SubjectName</td>
                        <td class="d-flex gap-2">
                            <!-- Edit Button -->
                            <button type="button"
                                    class="btn btn-sm btn-warning edit-btn"
                                    data-id="@course.Id"
                                    data-coursecode="@course.CourseCode"
                                    data-coursename="@course.CourseName"
                                    data-facultycode="@course.FacultyCode"
                                    data-courselevel="@course.CourseLevel"
                                    data-courseprefix="@course.CoursePrefix"
                                    data-subjectname="@course.SubjectName">
                                ✏️ Edit
                            </button>

                            <!-- Delete Button -->
                            <form asp-action="DeleteCourseInMstCourse" method="post" asp-route-id="@course.Id" onsubmit="return confirm('Are you sure you want to delete this course?');">
                                <button type="submit" class="btn btn-sm btn-danger">🗑️ Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Edit Modal -->
<div class="modal fade" id="editCourseModal" tabindex="-1" aria-labelledby="editCourseLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="editCourseForm" asp-action="UpdateCourse" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="editCourseLabel">Edit Course</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body row g-3">
                    <input type="hidden" name="Id" id="edit_Id" />

                    <div class="col-md-4">
                        <label class="form-label">Course Code</label>
                        <input type="text" name="CourseCode" id="edit_CourseCode" class="form-control" readonly />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Course Name</label>
                        <input type="text" name="CourseName" id="edit_CourseName" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Faculty Code</label>
                        <input type="text" name="FacultyCode" id="edit_FacultyCode" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Course Level</label>
                        <input type="text" name="CourseLevel" id="edit_CourseLevel" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Course Prefix</label>
                        <input type="text" name="CoursePrefix" id="edit_CoursePrefix" class="form-control" />
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Subject Name</label>
                        <input type="text" name="SubjectName" id="edit_SubjectName" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">💾 Save Changes</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    $(document).ready(function () {
        $('#coursesTable').DataTable({
            paging: true,
            searching: true,
            ordering: true,
            scrollY: "400px",
            scrollCollapse: true,
            info: true
        });

        $(document).on("click", ".edit-btn", function () {
            $("#edit_Id").val($(this).data("id"));
            $("#edit_CourseCode").val($(this).data("coursecode"));
            $("#edit_CourseName").val($(this).data("coursename"));
            $("#edit_FacultyCode").val($(this).data("facultycode"));
            $("#edit_CourseLevel").val($(this).data("courselevel"));
            $("#edit_CoursePrefix").val($(this).data("courseprefix"));
            $("#edit_SubjectName").val($(this).data("subjectname"));

            $("#editCourseModal").modal("show");
        });
        $(document).on("change", "#courseLevelSelect", function () {
            if ($(this).val() === "__other__") {
                $("#courseLevelSelect").attr("disabled", true); // disable select
                $("#customCourseLevel").removeClass("d-none").val("").attr("disabled", false).focus();
            } else {
                $("#customCourseLevel").addClass("d-none").attr("disabled", true);
            }
        });

        // Handle Course Prefix "Other"
        $(document).on("change", "#coursePrefixSelect", function () {
            if ($(this).val() === "__other__") {
                $("#coursePrefixSelect").attr("disabled", true); // disable select
                $("#customCoursePrefix").removeClass("d-none").val("").attr("disabled", false).focus();
            } else {
                $("#customCoursePrefix").addClass("d-none").attr("disabled", true);
            }
        });
    });
</script>
