@model AddDepartmentToDepartmentMaster

<nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
    <div class="container">

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a asp-controller="Admin" asp-action="AdminDashboard" asp-route-username="@ViewBag.UserName" class="nav-link btn btn-outline-primary">
                        🏠 Home
                    </a>
                </li>
            </ul>
            <form asp-controller="Admin" asp-action="Logout" method="post" class="mb-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Logout</button>
            </form>
        </div>
    </div>
</nav>

<h4 class="mt-4">➕ Add New Department</h4>

<form asp-action="AddDepartmentToDepartmentMaster" method="post">
    <div class="row mb-3">
        <div class="col-md-4">
            <label asp-for="NewDepartment.FacultyCode" class="form-label">Faculty</label>
            <select asp-for="NewDepartment.FacultyCode" asp-items="Model.Faculties" class="form-select">
                <option value="">-- Select Faculty --</option>
            </select>
        </div>
        <div class="col-md-8">
            <label asp-for="NewDepartment.DepartmentName" class="form-label">Department Name</label>
            <input asp-for="NewDepartment.DepartmentName" class="form-control" />
        </div>
    </div>

    <button type="submit" class="btn btn-success">➕ Add Department</button>
</form>

<hr />

<form asp-action="AddDepartmentToDepartmentMaster" method="get" class="mt-3">
    <div class="mb-3">
        <label asp-for="SelectedFacultyCode" class="form-label">Select Faculty</label>
        <select asp-for="SelectedFacultyCode" asp-items="Model.Faculties" class="form-select" onchange="this.form.submit()">
            <option value="">-- Select Faculty --</option>
        </select>
    </div>
</form>

@if (Model.DepartmentMaster.Any())
{
    <div class="table-responsive mt-4">
        <table id="departmentTable" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Department Code</th>
                    <th>Department Name</th>
                    <th>Faculty</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.DepartmentMaster.Count; i++)
                {
                    <tr>
                        <td>@Model.DepartmentMaster[i].DepartmentCode</td>
                        <td>@Model.DepartmentMaster[i].DepartmentName</td>
                        <td>
                            @Model.Faculties.FirstOrDefault(f => f.Value == Model.DepartmentMaster[i].FacultyCode.ToString())?.Text
                        </td>
                        <td>
                            <button type="button"
                                    class="btn btn-sm btn-warning edit-btn"
                                    data-id="@Model.DepartmentMaster[i].Id"
                                    data-name="@Model.DepartmentMaster[i].DepartmentName"
                                    data-facultycode="@Model.DepartmentMaster[i].FacultyCode">
                                ✏️ Edit
                            </button>
                            <form asp-action="DeleteDepartment" method="post" style="display:inline-block;">
                                <input type="hidden" name="Id" value="@Model.DepartmentMaster[i].Id" />
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?');">🗑️ Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Edit Modal -->
<div class="modal fade" id="editDepartmentModal" tabindex="-1" aria-labelledby="editDepartmentLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddDepartmentToDepartmentMaster" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="editDepartmentLabel">Edit Department</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="DepartmentMaster[0].Id" id="edit_Id" />

                    <div class="mb-3">
                        <label class="form-label">Faculty</label>
                        <select name="DepartmentMaster[0].FacultyCode" id="edit_FacultyCode" class="form-select">
                            @foreach (var f in Model.Faculties)
                            {
                                <option value="@f.Value">@f.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department Name</label>
                        <input type="text" name="DepartmentMaster[0].DepartmentName" id="edit_DepartmentName" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">💾 Save Changes</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    $(document).ready(function () {
        $('#departmentTable').DataTable({
            paging: true,
            searching: true,
            ordering: true,
            scrollY: "400px",
            scrollCollapse: true,
            info: true
        });

        $(document).on("click", ".edit-btn", function () {
            $("#edit_Id").val($(this).data("id"));
            $("#edit_DepartmentName").val($(this).data("name"));
            $("#edit_FacultyCode").val($(this).data("facultycode"));

            $("#editDepartmentModal").modal("show");
        });
    });
</script>
