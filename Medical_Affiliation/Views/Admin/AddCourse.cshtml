@model AddCoursePageViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Add Course to College";
}

<!-- ✅ DataTables + Buttons CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css" />

<!-- Bootstrap Navbar -->
<nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
    <div class="container">

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a asp-controller="@ViewBag.Controller" asp-action="@ViewBag.Dashboard" asp-route-username="@ViewBag.UserName" class="nav-link btn btn-outline-primary">
                        🏠 Home
                    </a>
                </li>
            </ul>
            <form asp-controller="@ViewBag.Controller" asp-action="Logout" method="post" class="mb-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Logout</button>
            </form>
        </div>
    </div>
</nav>

<div class="container mt-4">
    <h2 class="mb-4">Add Course to Existing College</h2>


    @if (ViewBag.show == true)
    {
        
    <form asp-action="AddCourse" method="post">
            @Html.AntiForgeryToken()

        <div class="form-group mb-2">
            <label asp-for="CourseModel.FacultyId">Select Faculty</label>
                <select asp-for="CourseModel.FacultyId" class="form-control facultySelect" asp-items="Model.FacultyList" id="facultySelect">
                <option value="">-- Select Faculty --</option>
            </select>
                <span asp-validation-for="CourseModel.FacultyId" class="text-danger"></span>
        </div>

        <div class="form-group mb-2">
            <label asp-for="CourseModel.CollegeCode">Select College</label>
            <select asp-for="CourseModel.CollegeCode" class="form-control collegeSelect" asp-items="Model.CollegeList" id="collegeSelect">
                <option value="">-- Select College --</option>
            </select>
                <span asp-validation-for="CourseModel.CollegeCode" class="text-danger"></span>
        </div>
        <div class="form-group mb-2">
            <label asp-for="CourseModel.CourseLevel">Select Course Level</label>
                <select asp-for="CourseModel.CourseLevel" class="form-control courseLevelSelect" asp-items="Model.CourseLevelList" >
                <option value="">-- Select Course Level --</option>
            </select>
            <span asp-validation-for="CourseModel.CollegeCode" class="text-danger"></span>
        </div>

        <div class="form-group mb-2">
            <label for="courseSelect">Select Course</label>
            <select id="courseSelect" name="CourseModel.CourseCode" class="form-control courseSelect">
                <option value="">-- Select Course --</option>
            </select>
            <span asp-validation-for="CourseModel.CourseCode" class="text-danger"></span>
        </div>

            <div class="form-group mb-2">
            <label asp-for="CourseModel.ExistingIntake">Existing Intake</label>
            <input asp-for="CourseModel.ExistingIntake" class="form-control" placeholder="Enter intake" />
            <span asp-validation-for="CourseModel.ExistingIntake" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary mt-2">Add Course</button>
    </form>
    }
    @if (ViewBag.Dev)
    {
        <div style="text-align:end">
            <button type="button"
                    class="btn btn-sm btn-warning edit-btn"
                    data-bs-toggle="modal"
                    data-bs-target="#addCourseModal">
                Add Course Details(Dev)
            </button>
        </div>
    }

    <hr class="my-4" />

    <h3>Existing Colleges and Courses</h3>
    <table id="collegeTable" class="display table table-bordered table-striped mt-3">
        <thead>
            <tr>
                <th>College Name</th>
                <th>Course Name</th>
                <th>Existing Intake</th>
                <th>Delete</th>
                <th>Edit</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.ExistingCourses.OrderBy(e => e.CollegeName))
            {
                <tr>
                    <td>@item.CollegeName</td>
                    <td>@(string.IsNullOrWhiteSpace(item.CourseName) ? "No Course exists" : item.CourseName)</td>
                    <td>@item.ExistingIntake</td>
                    <td>
                        <form asp-action="DeleteCourse" method="post" class="delete-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="CollegeCode" value="@item.CollegeCode" />
                            <input type="hidden" name="CourseCode" value="@item.CourseCode" />
                            <input type="hidden" name="CourseName" value="@item.CourseName" />
                            <button type="submit" class="btn btn-danger btn-sm delete-btn">Delete</button>
                        </form>
                    </td>
                    <td>
                        <button type="button"
                                class="btn btn-sm btn-warning edit-btn"
                                data-bs-toggle="modal"
                                data-bs-target="#editCourseModal"
                                data-code="@item.CollegeCode"
                                data-collegename="@item.CollegeName"
                                data-courseCode ="@item.CourseCode"
                                data-coursename="@item.CourseName"
                                data-collegefacultyCode ="@item.CollegeFacultyId"
                                data-id =" @item.Id"
                                data-intake="@item.ExistingIntake">
                            Edit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div class="modal fade" id="editCourseModal" tabindex="-1" aria-labelledby="editCourseLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="EditCourse" id="editCourseForm" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                
                <div class="modal-header">
                    <h5 class="modal-title" id="editCollegeLabel">Edit College</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" id="CollegeCode" name="CollegeCode" />
                    <input type="hidden" id="courseid" name="Id" />
                    <input type="hidden" id="CollegeFacultyCode" name="CollegeFacultyCode" />


                    <div class="mb-3">
                        <label for="EditCollegeName" class="form-label">College Name</label>
                        <input type="text" id="EditCollegeName" name="CollegeName" class="form-control CollegeName" required readonly/>
                    </div>
                    <div class="mb-3">
                        <label for="EditCourseSelect" class="form-label">Select Course</label>
                        <select id="EditCourseSelect" name="CourseCode" class="form-control">
                            <option value="">-- Select Course --</option>
                            @foreach (var course in Model.CourseList)
                            {
                                <option value="@course.Value">@course.Text</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="ExistingIntake" class="form-label">RGUHS intake</label>
                        <input type="number" id="ExistingIntake" name="ExistingIntake" class="form-control" required />
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="addCourseModal" tabindex="-1" aria-labelledby="addCourseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="AddCourse" class="btform" method="post">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="addCourseModalLabel">Add New Course</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    
                    <!-- Faculty Dropdown -->
                    <div class="mb-3">
                        <label for="FacultyId" class="form-label">Select Faculty</label>
                        <select asp-for="CourseModel.FacultyId" asp-items="Model.FacultyList" id="facultySelect1" class="form-select facultySelect">
                            <option value="">-- Select Faculty --</option>
                        </select>
                    </div>

                    <!-- College Dropdown -->
                    <div class="mb-3">
                        <label for="CollegeCode" class="form-label ">Select College</label>
                        <select asp-for="CourseModel.CollegeCode" class="form-select collegeSelect">
                            <option value="">-- Select College --</option>
                        </select>
                    </div>


                    <!-- Course Level Dropdown -->
                    <div class="mb-3">
                        <label for="CourseLevel" class="form-label">Select Course Level</label>
                        <select asp-for="CourseModel.CourseLevel" asp-items="Model.CourseLevelList" class="form-select courseLevelSelect">
                            <option value="">-- Select Course Level --</option>
                        </select>
                    </div>

                    <!-- Course Prefix Dropdown -->
                    <div class="mb-3">
                        <label for="CoursePrefix" class="form-label">Select Prefix</label>
                        <select asp-for="CourseModel.CoursePrefix" asp-items="Model.CoursePrefixList" 
                                class="form-select prefixSelect" id="coursePrefixSelect">
                            <option value="">-- Select Prefix --</option>
                            <option value="add">+ Add New Prefix</option>
                        </select>
                    </div>

                    <div class="mb-3 d-none" id="newPrefixContainer">
                        <label for="NewCoursePrefix" class="form-label">Enter New Prefix</label>
                        <input type="text" id="newCoursePrefix"  name="CourseModel.CoursePrefix"
                               class="form-control" placeholder="Enter new prefix" />
                    </div>

                    
                    <!-- Course Name Input -->
                    <div class="mb-3">
                        <label for="CourseName" class="form-label">Course Name</label>
                        <input asp-for="CourseModel.CourseName" class="form-control" placeholder="Enter new course name" />
                    </div

                    <!-- Subject Name Input -->
                    <div class="mb-3">
                        <label for="SubjectName" class="form-label">Subject Name</label>
                        <input asp-for="CourseModel.SubjectName" class="form-control" placeholder="Enter new Subject name" />
                    </div


                    <!-- Intake -->
                    <div class="mb-3">
                        <label for="ExistingIntake" class="form-label">Existing Intake</label>
                        <input asp-for="CourseModel.ExistingIntake" class="form-control" type="number" />
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Course</button>
                </div>
            </form>
        </div>
    </div>
</div>

@Html.Hidden("Myurl", Url.Action("GetCollegesByFacultyForCourse", "Admin"))
@Html.Hidden("Myurl2", Url.Action("GetCoursesByFaculty", "Admin"))

@section Scripts {
    <!-- ✅ jQuery and DataTables -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>

    <!-- ✅ DataTables Buttons Extension -->
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

    <!-- ✅ Export dependencies -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <!-- ✅ SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            const logoUrl = 'data:image/jpeg;base64,';
            $('#editCourseModal').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget); // Button that triggered the modal
                // Get data attributes from the Edit button
                var collegeCode = button.data('code');
                var collegeName = button.data('collegename');
                var courseCode = button.data('coursecode');
                var facultyCode = button.data('collegefacultycode');
                var intake = button.data('intake');
                var id = $.trim(button.data('id'));

                // Populate modal fields
                $('#CollegeCode').val(collegeCode);
                $('.CollegeName').val(collegeName);
                $('#CollegeFacultyCode').val(facultyCode);
                $('#courseid').val(id);
                $('#ExistingIntake').val(intake);
                
                var coursesUrl = $("#Myurl2").val();
                $('#EditCourseSelect').empty().append('<option value="">-- Select Course --</option>');
                $.getJSON(coursesUrl, { facultyId: facultyCode }, function (data) {
                    $('#EditCourseSelect').empty();
                    $.each(data, function (i, course) {
                        $('#EditCourseSelect').append($('<option>', {
                            value: course.courseCode,
                            text: course.courseName
                        }));
                    });
                });
                // ✅ Set dropdown value (selects the correct course)
                $('#EditCourseSelect').val(courseCode);
            });

            $('#editCourseForm').submit(function (e) {
                e.preventDefault(); // prevent default form submit

                $.ajax({
                    url: $(this).attr('action'),
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function () {
                        $('#editCourseModal').modal('hide');

                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: 'Course updated successfully.',
                            confirmButtonColor: '#3085d6',
                            confirmButtonText: 'OK'
                        }).then(() => {
                            location.reload(); // refresh table after success
                        });
                    },
                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'Oops...',
                            text: 'Something went wrong while saving.'
                        });
                    }
                });
            });

            $('#collegeTable').DataTable({
                order: [[1, 'asc']],
                language: {
                    search: "Search Colleges:",
                    lengthMenu: "Show _MENU_ entries",
                    info: "Showing _START_ to _END_ of _TOTAL_ Courses"
                },
                dom: 'Bfrtip',
                buttons: [
                    {
                        extend: 'pdfHtml5',
                        text: 'PDF',
                        filename: 'List_of_Courses',
                        customize: function (doc) {
                            // Set PDF to landscape orientation
                            doc.pageOrientation = 'portrait';

                            // Remove default header
                            doc.content.splice(0, 1);

                            // Add custom header with logo and texts
                            doc.content.unshift({
                                table: {
                                    widths: ['auto', '*'], // Two columns: logo and text
                                    body: [
                                        [
                                            {
                                                image: logoUrl,  // Define logoUrl globally or pass it properly
                                                width: 100,
                                                height: 80,
                                                alignment: 'left',
                                                margin: [20, 0, 0, 0]
                                            },
                                            {
                                                text: 'Rajiv Gandhi University of Health Sciences, Karnataka\n4th \'T\' Block, Jayanagar, Bangalore - 560 041',
                                                fontSize: 18,
                                                bold: true,
                                                alignment: 'left',
                                                margin: [20, 20, 0, 0]
                                            }
                                        ],

                                        [
                                            {
                                                text: 'List of Colleges ',
                                                fontSize: 18,
                                                bold: true,
                                                decoration: 'underline',
                                                alignment: 'center',
                                                colSpan: 2
                                            },
                                            {}
                                        ]
                                    ]
                                },
                                layout: {
                                    hLineWidth: function (i, node) {
                                        if (i === 0 || i === node.table.body.length - 1) {
                                            return 2;
                                        }
                                        return 0;
                                    },
                                    vLineWidth: function () { return 0; },
                                    hLineColor: function (i, node) {
                                        return (i === 0 || i === node.table.body.length - 1) ? '#000000' : null;
                                    },
                                    paddingLeft: function () { return 10; },
                                    paddingRight: function () { return 10; },
                                    paddingTop: function () { return 5; },
                                    paddingBottom: function () { return 5; }
                                },
                                margin: [0, 0, 0, 10]
                            });

                            // Styling table headers and rows
                            doc.styles.tableHeader.color = 'black';
                            doc.styles.tableHeader.fillColor = '#F0F0F0';
                            doc.styles.tableBodyOdd.fillColor = '#FFFFFF';
                            doc.styles.tableBodyEven.fillColor = null;

                            // DateTime format helper
                            function formatDateTime(date) {
                                var day = date.getDate().toString().padStart(2, '0');
                                var month = (date.getMonth() + 1).toString().padStart(2, '0');
                                var year = date.getFullYear();
                                var hours = date.getHours().toString().padStart(2, '0');
                                var minutes = date.getMinutes().toString().padStart(2, '0');
                                return day + '/' + month + '/' + year + ' ' + hours + ':' + minutes;
                            }

                            // Footer with timestamp and pagination
                            doc.footer = function (page, pages) {
                                return {
                                    columns: [
                                        {
                                            alignment: 'left',
                                            margin: [20, 0, 0, 0],
                                            text: 'Downloaded on: ' + formatDateTime(new Date())
                                        },
                                        {
                                            alignment: 'right',
                                            margin: [0, 0, 20, 0],
                                            text: 'Page ' + page.toString() + ' of ' + pages.toString()
                                        }
                                    ],
                                    margin: [20, 10, 20, 10]
                                };
                            };

                            // Table layout styling
                            var tableLayout = {
                                hLineWidth: function (i) { return 0.5; },
                                vLineWidth: function (i) { return 0.5; },
                                hLineColor: function () { return '#aaa'; },
                                vLineColor: function () { return '#aaa'; },
                                paddingLeft: function () { return 1; },
                                paddingRight: function () { return 1; },
                                paddingTop: function () { return 5; },
                                paddingBottom: function () { return 5; },
                                fillColor: function (row) { return (row % 2 === 0) ? '#FFFFFF' : null; },
                                pageBreak: 'auto',
                                tableWidth: 'auto',
                                margin: [0, 10, 0, 10]
                            };

                            doc.defaultStyle.fontSize = 10;
                            doc.defaultStyle.alignment = 'left';
                            doc.pageMargins = [20, 30, 20, 30];

                            // Adjust column widths if table exists
                            if (doc.content[1].table && doc.content[1].table.body) {
                                doc.content[1].table.widths = ['60%', '30%','10%'];
                            }

                            doc.content[1].layout = tableLayout;


                        }
                    },
                    'excelHtml5',
                    'csvHtml5',
                    'print'
                ],
                responsive: true,
                paging: true,
                searching: true
            });

            document.querySelectorAll('.delete-form').forEach(form => {
                form.addEventListener('submit', function (e) {
                    e.preventDefault(); // stop form submit

                    Swal.fire({
                        title: 'Are you sure?',
                        text: "This course will be permanently deleted!",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        confirmButtonText: 'Yes, delete it!'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            form.submit();
                        }
                    });
                });
            });

            // Success alert from TempData
            

            $('.facultySelect').change(function () {
                var facultyId = $(this).val();
                var collegesUrl = $("#Myurl").val();
                var coursesUrl = $("#Myurl2").val();

                // Reset both dropdowns
                $('.collegeSelect').empty().append('<option value="">-- Select College --</option>');
                $('.courseSelect').empty().append('<option value="">-- Select Course --</option>');

                if (facultyId) {
                    // Load colleges
                    $.getJSON(collegesUrl, { facultyId: facultyId }, function (data) {
                        $('.collegeSelect').empty();
                        $.each(data, function (i, college) {
                            $('.collegeSelect').append($('<option>', {
                                value: college.collegeCode,
                                text: college.collegeName
                            }));
                        });
                    });

                    // Load courses
                    $.getJSON(coursesUrl, { facultyId: facultyId }, function (data) {
                        $('.courseSelect').empty();
                        $.each(data, function (i, course) {
                            $('.courseSelect').append($('<option>', {
                                value: course.courseCode,
                                text: course.courseName
                            }));
                        });
                    });
                }
            });

            function loadCourses() {
                var facultyId = $(".facultySelect").val();
                var courseLevel = $(".courseLevelSelect").val();
                var collegeCode = $(".collegeSelect").val();
                var url = "@Url.Action("GetCoursesByFacultyAndLevel", "Admin")";

                if (facultyId && courseLevel && collegeCode) {
                    $.getJSON(url, { facultyId: facultyId, courseLevel: courseLevel, collegeCode: collegeCode }, function (data) {
                        $(".courseSelect").empty().append('<option value="">-- Select Course --</option>');
                        $.each(data, function (i, course) {
                            $(".courseSelect").append($('<option>', {
                                value: course.value,
                                text: course.text
                            }));
                        });
                    });
                } else {
                    $(".courseSelect").empty().append('<option value="">-- Select Course --</option>');
                }

                // Trigger when faculty, college, or course level changes
                $(".facultySelect, .collegeSelect, .courseLevelSelect").change(loadCourses);
        
            }


        });

        $(document).ready(function () {
            $('.prefixSelect').change(function () {
                if ($(this).val() === "add") {
                    $('#newPrefixContainer').removeClass('d-none');
                    $('#newCoursePrefix').prop('required', true);
                    // Clear out the select value so input takes priority
                    $(this).removeAttr('name'); 
                    $('#newCoursePrefix').attr('name', 'CourseModel.CoursePrefix');
                } else {
                    $('#newPrefixContainer').addClass('d-none');
                    $('#newCoursePrefix').prop('required', false).val('');
                    // Restore select name binding
                    $(this).attr('name', 'CourseModel.CoursePrefix');
                    $('#newCoursePrefix').removeAttr('name');
                }
            });

            // $('.btform').on('submit', function () {
            //     if ($('#coursePrefixSelect').val() === "add") {
            //         var newPrefix = $('#newCoursePrefix').val();
            //         if (newPrefix.trim() !== "") {
            //             // overwrite select value with input
            //             $('#coursePrefixSelect').val(newPrefix);
            //         }
            //     }
            // });
        });

        @if (TempData["DeleteSuccess"] != null)
            {
                <text>
                        Swal.fire({
                            icon: 'success',
                            title: 'Deleted!',
                            text: '@TempData["DeleteSuccess"]'
                        });
                </text>
            }
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: '@TempData["SuccessMessage"]'
                    });
            </text>
        }
        else if (TempData["ErrorMessage"] != null)
        {
            <text>
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: '@TempData["ErrorMessage"]'
                    });
            </text>
        }
        else if (TempData["InfoMessage"] != null)
        {
            <text>
                    Swal.fire({
                        icon: 'info',
                        title: 'Info',
                        text: '@TempData["InfoMessage"]'
                    });
            </text>
        }
</script>

    @await Html.PartialAsync("_ValidationScriptsPartial")
}

