@model TalukMappingViewModel
@{
    ViewBag.Title = "Dental Colleges — Taluk Mapping";

    // Layout = null;

}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header">
            <h4>District Taluk Mapping</h4>
        </div>

        <div class="card-body">

            <div class="row mb-4">

                <div class="col-md-6">

                    <label class="form-label">
                        District
                    </label>

                    <select id="districtDropdown"
                            class="form-select">

                        <option value="">
                            Select District
                        </option>

                        @foreach (var district in Model.Districts)
                        {
                            <option value="@district.DistrictId">
                                @district.DistrictName
                            </option>
                        }

                    </select>

                </div>

            </div>

            <div id="talukContainer" class="row">
            </div>

            <hr />

            <div class="row mt-3">

                <div class="col-md-6">

                    <label class="form-label">
                        Add New Taluk
                    </label>

                    <div class="input-group">

                        <input type="text"
                               id="newTalukName"
                               class="form-control"
                               placeholder="Enter Taluk Name" />

                        <button type="button"
                                class="btn btn-success"
                                onclick="addNewTaluk()">

                            Add

                        </button>

                    </div>

                </div>

            </div>

            <div id="newTaluksContainer"
                 class="mt-3">
            </div>

            <div class="mt-4 text-end">

                <button type="button"
                        class="btn btn-primary"
                        onclick="saveMappings()">

                    Save Mapping

                </button>

            </div>

        </div>

    </div>

    <!-- Edit Taluk Modal -->
    <div class="modal fade" id="editTalukModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Edit Taluk</h5>
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <div class="modal-body">

                    <input type="hidden" id="editTalukId" />

                    <div class="mb-3">
                        <label class="form-label">Taluk ID</label>
                        <input type="text"
                               id="editTalukCode"
                               class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Taluk Name</label>
                        <input type="text"
                               id="editTalukName"
                               class="form-control" />
                    </div>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Close
                    </button>

                    <button type="button"
                            class="btn btn-primary"
                            onclick="updateTaluk()">
                        Save Changes
                    </button>

                </div>

            </div>
        </div>
    </div>

</div>

<script>

    let newTaluks = [];

    document.getElementById("districtDropdown")
        .addEventListener("change", loadTaluks);

    function loadTaluks() {

        const districtId =
            document.getElementById("districtDropdown").value;

        if (!districtId) {

            document.getElementById("talukContainer").innerHTML = "";
            return;
        }

        const url =
            '@Url.Action("GetTaluksForDistrict", "Admin")'
            + '?districtId='
            + districtId;

        fetch(url)
            .then(r => r.json())
            .then(data => {

                let html = '';

                data.forEach(taluk => {

                    html += `
                        <div class="col-md-4 mb-2">

                            <div class="d-flex align-items-center">

                                <div class="form-check flex-grow-1">

                                    <input
                                        class="form-check-input taluk-checkbox"
                                        type="checkbox"
                                        value="${taluk.talukId}"
                                        ${taluk.isSelected ? 'checked' : ''}>

                                        <label class="form-check-label taluk-editable"
                                               ondblclick="openEditTaluk(
                                                   '${taluk.talukId}',
                                                   '${taluk.talukName.replace(/'/g, "\\'")}'
                                               )"
                                               style="cursor:pointer;">

                                            ${taluk.talukName}

                                        </label>

                                </div>

                                <button type="button"
                                        class="btn btn-sm btn-danger ms-2"
                                        onclick="deleteTaluk('${taluk.talukId}')">

                                    Delete

                                </button>

                            </div>

                        </div>
                    `;
                });

                document.getElementById("talukContainer")
                    .innerHTML = html;
            });
    }

    function addNewTaluk() {

        const txt =
            document.getElementById("newTalukName");

        const talukName =
            txt.value.trim();

        if (!talukName) {

            alert("Please enter Taluk Name.");
            return;
        }

        if (newTaluks.some(x =>
            x.toLowerCase() === talukName.toLowerCase())) {

            alert("Taluk already added.");
            return;
        }

        newTaluks.push(talukName);

        renderNewTaluks();

        txt.value = "";
    }

    function openEditTaluk(talukId, talukName) {

        document.getElementById("editTalukId").value = talukId;
        document.getElementById("editTalukCode").value = talukId;
        document.getElementById("editTalukName").value = talukName;

        const modal =
            new bootstrap.Modal(
                document.getElementById("editTalukModal")
            );

        modal.show();
    }

    function updateTaluk() {

        const talukId =
            document.getElementById("editTalukId").value;

        const talukCode =
            document.getElementById("editTalukCode").value.trim();

        const talukName =
            document.getElementById("editTalukName").value.trim();

        if (!talukCode || !talukName) {

            alert("Taluk ID and Taluk Name are required.");
            return;
        }

        fetch('@Url.Action("UpdateTaluk", "Admin")',
            {
                method: 'POST',

                headers: {
                    'Content-Type': 'application/json'
                },

                body: JSON.stringify({
                    talukId: talukId,
                    newTalukId: talukCode,
                    talukName: talukName
                })
            })
            .then(r => r.json())
            .then(result => {

                alert(result.message);

                if (result.success) {

                    bootstrap.Modal
                        .getInstance(
                            document.getElementById("editTalukModal")
                        )
                        .hide();

                    loadTaluks();
                }
            })
            .catch(error => {

                console.error(error);

                alert("Error updating Taluk.");
            });
    }

    function renderNewTaluks() {

        let html = "";

        newTaluks.forEach((taluk, index) => {

            html += `
                <span class="badge bg-success me-2 mb-2 p-2">

                    ${taluk}

                    <button type="button"
                            class="btn-close btn-close-white ms-2"
                            onclick="removeNewTaluk(${index})">
                    </button>

                </span>
            `;
        });

        document.getElementById("newTaluksContainer")
            .innerHTML = html;
    }

    function removeNewTaluk(index) {

        newTaluks.splice(index, 1);

        renderNewTaluks();
    }

    function deleteTaluk(talukId) {

        if (!confirm("Are you sure you want to delete this Taluk?")) {
            return;
        }

        fetch(
            '@Url.Action("DeleteTaluk", "Admin")',
            {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },

                body: JSON.stringify({
                    talukId: talukId
                })
            })
            .then(r => r.json())
            .then(result => {

                alert(result.message);

                if (result.success) {

                    loadTaluks();
                }
            })
            .catch(error => {

                console.error(error);

                alert("Error deleting taluk.");
            });
    }

    function saveMappings() {

        const districtId =
            document.getElementById("districtDropdown").value;

        if (!districtId) {

            alert("Please select District.");
            return;
        }

        const selectedTaluks =
            Array.from(
                document.querySelectorAll(
                    '.taluk-checkbox:checked'
                )
            )
            .map(x => x.value);

        fetch(
            '@Url.Action("SaveDistrictTalukMapping", "Admin")',
            {
                method: 'POST',

                headers: {
                    'Content-Type': 'application/json'
                },

                body: JSON.stringify({
                    districtId: districtId,
                    selectedTalukIds: selectedTaluks,
                    newTaluks: newTaluks
                })
            })
            .then(r => r.json())
            .then(result => {

                if (!result.success) {

                    alert(result.message);
                    return;
                }

                alert(result.message);

                newTaluks = [];

                renderNewTaluks();

                loadTaluks();
            })
            .catch(error => {

                console.error(error);

                alert("Error saving mappings.");
            });
    }

</script>