@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/language.js"></script>

    <script>
        $(function () {

            /* ── Teaching room area calc ── */
            const studentCount  = document.getElementById('studentCount');
            const requiredArea  = document.getElementById('requiredArea');
            const availableArea = document.getElementById('availableArea');
            const defArea       = document.getElementById('deficiencyArea');
            const sumReq        = document.getElementById('summaryRequired');
            const sumAvail      = document.getElementById('summaryAvailable');
            const sumDef        = document.getElementById('summaryDeficiency');

            function recalcTeaching() {
                const s   = parseInt(studentCount?.value)   || 0;
                const av  = parseFloat(availableArea?.value) || 0;
                const req = s * 1.2;
                const def = Math.max(0, req - av);
                if (requiredArea) requiredArea.value = req.toFixed(2);
                if (defArea)      defArea.value      = def.toFixed(2);
                if (sumReq)       sumReq.textContent  = req.toFixed(2);
                if (sumAvail)     sumAvail.textContent = av.toFixed(2);
                if (sumDef) {
                    sumDef.textContent = def.toFixed(2);
                    sumDef.className   = 'summary-box-value ' + (def > 0 ? 'val-short' : 'val-ok');
                }
            }
            studentCount?.addEventListener('input', recalcTeaching);
            availableArea?.addEventListener('input', recalcTeaching);

            /* ── Museum area calc ── */
            const mSeating = document.getElementById('museumSeating');
            const mArea    = document.getElementById('museumSeatingArea');
            const mReq     = document.getElementById('museumRequiredArea');
            const mDef     = document.getElementById('museumDefArea');

            function recalcMuseum() {
                const s   = parseInt(mSeating?.value)  || 0;
                const av  = parseFloat(mArea?.value)   || 0;
                const req = s * 1.2;
                const def = Math.max(0, req - av);
                if (mReq) mReq.value = req.toFixed(2);
                if (mDef) mDef.value = def.toFixed(2);
            }
            mSeating?.addEventListener('input', recalcMuseum);
            mArea?.addEventListener('input', recalcMuseum);

            /* ── Land NO section toggle ── */
            function toggleLandNo() {
                const isNo = document.getElementById('landNo')?.checked;
                document.getElementById('landNoSection').style.display = isNo ? '' : 'none';
                document.getElementById('budgetSection').style.display  = isNo ? '' : 'none';
            }
            document.getElementById('landYes')?.addEventListener('change', toggleLandNo);
            document.getElementById('landNo')?.addEventListener('change', toggleLandNo);
            toggleLandNo();

            /* ── Save validation ── */
            $("#btnSave").on("click", function (e) {
                e.preventDefault();
                $(".input-error").removeClass("input-error");
                $(".section-block").removeClass("error-section");

                let isValid = true;
                document.querySelectorAll(".form-label-text.required").forEach(label => {
                    const parent = label.closest(".field-group");
                    if (!parent) return;

                    const radios = parent.querySelectorAll("input[type='radio']");
                    if (radios.length) {
                        if (!Array.from(radios).some(r => r.checked)) {
                            isValid = false;
                            parent.closest(".section-block")?.classList.add("error-section");
                        }
                        return;
                    }

                    const input = parent.querySelector("input:not([type='radio']):not([type='checkbox']), select, textarea");
                    if (input && !input.value.trim()) {
                        isValid = false;
                        input.classList.add("input-error");
                        parent.closest(".section-block")?.classList.add("error-section");
                    }
                });

                if (!isValid) {
                    Swal.fire({
                        icon: "error",
                        title: "Missing Fields",
                        text: "Please fill all required fields marked with *",
                        confirmButtonColor: "#0f2545"
                    });
                    const first = document.querySelector(".input-error, .error-section");
                    if (first) first.scrollIntoView({ behavior: "smooth", block: "center" });
                    return;
                }

                Swal.fire({
                    icon: "success",
                    title: "Saved Successfully!",
                    confirmButtonColor: "#1a6b3a",
                    timer: 2000, timerProgressBar: true
                }).then(() => { $("form").submit(); });
            });

            $("#btnNext").on("click", function () {
                $("#btnSave").click();
                setTimeout(() => {
                    if (!$(".input-error").length && !$(".error-section").length) {
                        window.location.href = '@Url.Action("Medical_SkillsLaboratory", "Medical_ContinuousAffiliation")';
                    }
                }, 2500);
            });

            /* ── Initial calc ── */
            recalcTeaching();
            recalcMuseum();
        });
    </script>

    <script>
        document.addEventListener("change", function (e) {

            if (e.target.classList.contains("file-validate")) {

                const file = e.target.files[0];
                const maxSize = 2 * 1024 * 1024; // ✅ 2MB

                if (file) {

                    // ❌ FILE SIZE CHECK
                    if (file.size > maxSize) {
                        Swal.fire({
                            icon: "error",
                            title: "File too large",
                            text: "Maximum allowed size is 2MB"
                        });

                        e.target.value = "";
                        return;
                    }

                    // ❌ FILE TYPE CHECK
                    const ext = file.name.split('.').pop().toLowerCase();

                    if (ext !== "pdf") {
                        Swal.fire({
                            icon: "error",
                            title: "Invalid file",
                            text: "Only PDF files are allowed"
                        });

                        e.target.value = "";
                        return;
                    }
                }
            }

        });
    </script>
}
