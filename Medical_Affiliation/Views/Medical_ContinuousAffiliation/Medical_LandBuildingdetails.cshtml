                <!-- ══════════════════════════════════════
                     TEACHING ROOMS
                ══════════════════════════════════════ -->
                <div class="section-label">
                    <span class="section-label-text">Teaching Rooms</span>
                    <span class="section-label-line"></span>
                </div>

                <div class="section-block" id="block-teaching">
                    <div class="section-block-header">
                        <span class="section-block-title">Area &amp; Compliance</span>
                    </div>
                    <div class="section-block-body">
                        <div class="info-box">
                            Minimum number of teaching rooms as per annual MBBS intake shall be provided and shared by all departments.
                            Each teaching room shall provide at least <strong>1.2 sq.m per student</strong> and shall be connected to larger lecture halls and internet facilities.
                        </div>

                        <div class="field-grid g-4">
                            <div class="field-group">
                                <label class="form-label-text required">No. of Students (Small Group)</label>
                                <input type="number" class="form-control" asp-for="SmallGroupStudents" id="studentCount" placeholder="Enter count" />
                            </div>
                            <div class="field-group">
                                <label class="form-label-text required">Required Area (Sq.m) <small style="font-weight:400;text-transform:none;">×1.2</small></label>
                                <input type="number" class="form-control" asp-for="RequiredAreaSqm" id="requiredArea" readonly />
                            </div>
                            <div class="field-group">
                                <label class="form-label-text required">Available Area (Sq.m)</label>
                                <input type="number" step="0.01" class="form-control" asp-for="AvailableAreaSqm" id="availableArea" placeholder="0.00" />
                            </div>
                            <div class="field-group">
                                <label class="form-label-text required">Area Deficiency (Sq.m)</label>
                                <input type="number" class="form-control" asp-for="AreaDeficiencySqm" id="deficiencyArea" readonly />
                            </div>
                        </div>

                        <div class="field-grid g-2" style="margin-top:14px;">

                            <!-- Teaching Rooms Shared by All Departments -->
                            <div class="field-group">
                                <label class="form-label-text required">Teaching Rooms Shared by All Departments</label>
                                <div class="toggle-group">
                                    <input class="toggle-pill-input pill-yes" type="radio" name="RoomsSharedByAllDepts" value="true" id="sharedYes"
                                           @(Model.RoomsSharedByAllDepts == true ? "checked" : "") />
                                    <label class="toggle-pill" for="sharedYes">YES</label>
                                    <input class="toggle-pill-input pill-no" type="radio" name="RoomsSharedByAllDepts" value="false" id="sharedNo"
                                           @(Model.RoomsSharedByAllDepts == false ? "checked" : "") />
                                    <label class="toggle-pill" for="sharedNo">NO</label>
                                </div>
                            </div>

                            <!-- Appropriate Area in Each Teaching Specialty -->
                            <div class="field-group">
                                <label class="form-label-text required">Appropriate Area in Each Teaching Specialty</label>
                                <div class="toggle-group">
                                    <input class="toggle-pill-input pill-yes" type="radio" name="AppropriateAreaEachSpecialty" value="true" id="specYes"
                                           @(Model.AppropriateAreaEachSpecialty == true ? "checked" : "") />
                                    <label class="toggle-pill" for="specYes">Available</label>
                                    <input class="toggle-pill-input pill-no" type="radio" name="AppropriateAreaEachSpecialty" value="false" id="specNo"
                                           @(Model.AppropriateAreaEachSpecialty == false ? "checked" : "") />
                                    <label class="toggle-pill" for="specNo">Not Available</label>
                                </div>
                            </div>

                            <!-- Connected to Larger Lecture Halls -->
                            <div class="field-group">
                                <label class="form-label-text required">Connected to Larger Lecture Halls</label>
                                <div class="toggle-group">
                                    <input class="toggle-pill-input pill-yes" type="radio" name="ConnectedToLectureHalls" value="true" id="lecYes"
                                           @(Model.ConnectedToLectureHalls == true ? "checked" : "") />
                                    <label class="toggle-pill" for="lecYes">YES</label>
                                    <input class="toggle-pill-input pill-no" type="radio" name="ConnectedToLectureHalls" value="false" id="lecNo"
                                           @(Model.ConnectedToLectureHalls == false ? "checked" : "") />
                                    <label class="toggle-pill" for="lecNo">NO</label>
                                </div>
                            </div>

                            <!-- Internet Facility in Teaching Rooms -->
                            <div class="field-group">
                                <label class="form-label-text required">Internet Facility in Teaching Rooms</label>
                                <div class="toggle-group">
                                    <input class="toggle-pill-input pill-yes" type="radio" name="InternetInTeachingRooms" value="true" id="netYes"
                                           @(Model.InternetInTeachingRooms == true ? "checked" : "") />
                                    <label class="toggle-pill" for="netYes">Available</label>
                                    <input class="toggle-pill-input pill-no" type="radio" name="InternetInTeachingRooms" value="false" id="netNo"
                                           @(Model.InternetInTeachingRooms == false ? "checked" : "") />
                                    <label class="toggle-pill" for="netNo">Not Available</label>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- ── Area Summary ── -->
                <div class="summary-card">
                    <div class="summary-title">Area &amp; Facility Summary</div>
                    <div class="summary-boxes">
                        <div class="summary-box">
                            <div class="summary-box-label">Required Teaching Room Area (Sq.m)</div>
                            <div class="summary-box-value val-required" id="summaryRequired">0</div>
                        </div>
                        <div class="summary-box">
                            <div class="summary-box-label">Available Teaching Room Area (Sq.m)</div>
