                <div class="section-label">
                    <span class="section-label-text">General Requirements</span>
                    <span class="section-label-line"></span>
                </div>

                <div class="section-block" id="block-general">
                    <div class="section-block-header">
                        <span class="section-block-title">Small Group Teaching — General</span>
                    </div>
                    <div class="section-block-body">
                        <div class="info-box">
                            The size of each small group batch shall be about <strong>15 students</strong>. The common pool of teaching rooms, student practical laboratories, museums and lecture theatres shall be used for small group teaching, shared by all departments, and all such areas shall have audio-visual and internet facilities with digital linkage.
                        </div>

                        <div class="field-grid g-2">
                            <div class="field-group">
                                <label class="form-label-text required">Annual MBBS Intake</label>
                                <select class="form-select" asp-for="AnnualMbbsIntake">
                                    <option value="100">100</option>
                                    <option value="150">150</option>
                                    <option value="200">200</option>
                                    <option value="250">250</option>
                                </select>
                            </div>

                            <div class="field-group">
                                <label class="form-label-text required">Small Group Batch Size</label>
                                <input type="number" class="form-control" asp-for="SmallGroupBatchSize" readonly />
                            </div>

                            <!-- FIXED: Each Yes/No pair now has its own unique name -->
                            <div class="field-group">
                                <label class="form-label-text required">Teaching Areas Shared by All Departments</label>
                                <div class="toggle-group">
                                    <input class="toggle-pill-input pill-yes" type="radio" name="TeachingAreasSharedAllDepts" value="true" id="sharedAllYes" @(Model.TeachingAreasSharedAllDepts == true ? "checked" : "") />
                                    <label class="toggle-pill" for="sharedAllYes">YES</label>
                                    <input class="toggle-pill-input pill-no" type="radio" name="TeachingAreasSharedAllDepts" value="false" id="sharedAllNo" @(Model.TeachingAreasSharedAllDepts == false ? "checked" : "") />
                                    <label class="toggle-pill" for="sharedAllNo">NO</label>
                                </div>
                            </div>

                            <div class="field-group">
                                <label class="form-label-text required">Audio-Visual Facilities in All Teaching Areas</label>
                                <div class="toggle-group">
                                    <input class="toggle-pill-input pill-yes" type="radio" name="AvInAllTeachingAreas" value="true" id="avAllYes" @(Model.AvInAllTeachingAreas == true ? "checked" : "") />
                                    <label class="toggle-pill" for="avAllYes">YES</label>
                                    <input class="toggle-pill-input pill-no" type="radio" name="AvInAllTeachingAreas" value="false" id="avAllNo" @(Model.AvInAllTeachingAreas == false ? "checked" : "") />
                                    <label class="toggle-pill" for="avAllNo">NO</label>
                                </div>
                            </div>

                            <div class="field-group">
                                <label class="form-label-text required">Internet Facility in All Teaching Areas</label>
                                <div class="toggle-group">
                                    <input class="toggle-pill-input pill-yes" type="radio" name="InternetInAllTeachingAreas" value="true" id="internetAllYes" @(Model.InternetInAllTeachingAreas == true ? "checked" : "") />
                                    <label class="toggle-pill" for="internetAllYes">YES</label>
                                    <input class="toggle-pill-input pill-no" type="radio" name="InternetInAllTeachingAreas" value="false" id="internetAllNo" @(Model.InternetInAllTeachingAreas == false ? "checked" : "") />
                                    <label class="toggle-pill" for="internetAllNo">NO</label>
                                </div>
                            </div>

                            <div class="field-group">
                                <label class="form-label-text required">Digitally Linked Between All Teaching Areas</label>
                                <div class="toggle-group">
                                    <input class="toggle-pill-input pill-yes" type="radio" name="DigitalLinkAllTeachingAreas" value="true" id="digitalLinkYes" @(Model.DigitalLinkAllTeachingAreas == true ? "checked" : "") />
                                    <label class="toggle-pill" for="digitalLinkYes">YES</label>
                                    <input class="toggle-pill-input pill-no" type="radio" name="DigitalLinkAllTeachingAreas" value="false" id="digitalLinkNo" @(Model.DigitalLinkAllTeachingAreas == false ? "checked" : "") />
                                    <label class="toggle-pill" for="digitalLinkNo">NO</label>
                                </div>
                            </div>
                        </div>
                    </div>
