                <!-- ── Footer ── -->
                <div class="form-footer">
                   @*  <button type="button" class="btn-prev"
                            onclick="window.location.href='@Url.Action("Nursing_Institute_Details", "Medical_ContinuousAffiliation")'">
                        ← Previous
