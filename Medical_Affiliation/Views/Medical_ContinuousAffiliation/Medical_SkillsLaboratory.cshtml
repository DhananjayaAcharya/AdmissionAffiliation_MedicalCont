@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const skillsIntake    = document.getElementById('skillsIntake');
            const skillsAreaAvail = document.getElementById('skillsAreaAvail');
            const skillsAreaReq   = document.getElementById('skillsAreaReq');
            const skillsAreaDef   = document.getElementById('skillsAreaDef');
            const sumReq          = document.getElementById('summaryRequired');
            const sumAvail        = document.getElementById('summaryAvailable');
            const sumDef          = document.getElementById('summaryDeficiency');

            const form    = document.getElementById('skillsLabForm');
            const saveBtn = document.getElementById('btnSave');
            const spinner = document.getElementById('saveSpinner');

            /* ── Area calculation ── */
            function recalcSkillsArea() {
                const intake = parseInt(skillsIntake.value) || 0;
                const avail  = parseFloat(skillsAreaAvail.value) || 0;
                const req    = intake <= 150 ? 600 : 800;
                const def    = Math.max(0, req - avail);

                skillsAreaReq.value = req.toFixed(2);
                skillsAreaDef.value = def.toFixed(2);

                sumReq.textContent   = req.toFixed(2);
                sumAvail.textContent = avail.toFixed(2);
                sumDef.textContent   = def.toFixed(2);
                sumDef.className     = 'summary-box-value ' + (def > 0 ? 'val-short' : 'val-ok');
            }

            skillsIntake.addEventListener('change', recalcSkillsArea);
            let timeout;
            skillsAreaAvail.addEventListener('input', function () {
                clearTimeout(timeout);
                timeout = setTimeout(recalcSkillsArea, 300);
            });
            recalcSkillsArea();

            /* ── Form submit ── */
            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                e.stopImmediatePropagation();

                if (!this.checkValidity()) {
                    this.reportValidity();
                    return;
                }

                saveBtn.disabled = true;
                spinner.classList.remove('d-none');

                try {
                    const formData = new FormData(form);
                    await fetch(form.action, { method: 'POST', body: formData });

                    await Swal.fire({
                        icon: 'success',
                        title: 'Saved Successfully!',
                        text: 'Skills Laboratory details saved.',
                        confirmButtonColor: '#0f2545'
                    });

                    window.location.href = '@Url.Action("Medical_SkillsLaboratory", "Medical_ContinuousAffiliation")';
                } catch (err) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Save Failed',
                        text: 'Please try again.',
                        confirmButtonColor: '#c0392b'
                    });
                } finally {
                    saveBtn.disabled = false;
                    spinner.classList.add('d-none');
                }
            });
        });
    </script>
}
