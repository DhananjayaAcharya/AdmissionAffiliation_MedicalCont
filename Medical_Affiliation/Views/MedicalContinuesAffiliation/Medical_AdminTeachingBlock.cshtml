@model AdminTeachingBlockListVM
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Administrative Teaching Block";
}

<style>
    :root {
        --primary: #4f46e5;
        --primary-soft: rgba(79, 70, 229, 0.12);
        --accent: #ec4899;
        --bg-body: #060714;
        --bg-gradient: radial-gradient(circle at top left, #1f2937 0, #020617 55%, #020617 100%);
        --glass-bg: rgba(15, 23, 42, 0.85);
        --glass-border: rgba(148, 163, 184, 0.35);
        --input-bg: rgba(15, 23, 42, 0.9);
        --input-border: rgba(148, 163, 184, 0.45);
        --input-border-focus: rgba(129, 140, 248, 0.9);
        --radius-lg: 20px;
        --radius-md: 14px;
        --shadow-soft: 0 24px 60px rgba(15, 23, 42, 0.85);
        --shadow-chip: 0 10px 25px rgba(15, 23, 42, 0.65);
        --text-main: #ffffff;
        --text-muted: #9ca3af;
        --danger: #f97373;
    }

    body {
        background: var(--bg-gradient);
    }

    .institution-form-shell {
        background: var(--bg-gradient);
        min-height: 100vh;
        padding: 32px 0 40px;
    }

    .institution-form-card {
        background: radial-gradient(circle at top left, rgba(148, 163, 184, 0.25), transparent 55%), radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.28), transparent 55%);
        border-radius: 32px;
        padding: 1px;
        box-shadow: var(--shadow-soft);
        position: relative;
        overflow: hidden;
    }

        .institution-form-card::before {
            content: "";
            position: absolute;
            inset: -40%;
            background: radial-gradient(circle at 0% 0%, rgba(244, 114, 182, 0.22), transparent 60%), radial-gradient(circle at 100% 100%, rgba(59, 130, 246, 0.28), transparent 55%);
            opacity: 0.4;
            filter: blur(32px);
            z-index: -2;
        }

    .institution-form-card-inner {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(15, 23, 42, 0.92));
        border-radius: 30px;
        border: 1px solid rgba(148, 163, 184, 0.28);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        position: relative;
        z-index: 1;
        padding: 28px 26px 30px;
    }

    @@media (min-width: 992px) {
        .institution-form-card-inner {
            padding: 30px 34px 34px;
        }
    }

    .form-header-modern {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
    }

    .form-header-title {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-header-icon {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        background: radial-gradient(circle at 30% 0, #e5e7eb 0, #9ca3af 12%, #111827 55%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #020617;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.85);
        position: relative;
    }

        .form-header-icon::after {
            content: "";
            position: absolute;
            inset: 2px;
            border-radius: inherit;
            border: 1px solid rgba(148, 163, 184, 0.55);
        }

    .form-header-title h4 {
        margin: 0;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: var(--text-main);
        font-size: 1.35rem;
    }

    .form-header-title span {
        display: block;
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .form-header-badge {
        padding: 6px 12px;
        border-radius: 999px;
        background: radial-gradient(circle at 0 0, rgba(59, 130, 246, 0.72), rgba(79, 70, 229, 0.9));
        color: #e5e7eb;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        border: 1px solid rgba(191, 219, 254, 0.8);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 10px 25px rgba(37, 99, 235, 0.6);
    }

    .section-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 11px;
        border-radius: 999px;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        background: rgba(15, 23, 42, 0.9);
        border: 1px solid rgba(148, 163, 184, 0.45);
        color: var(--text-muted);
        box-shadow: var(--shadow-chip);
    }

        .section-chip span.dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: radial-gradient(circle at 30% 0, #a5b4fc 0, #4f46e5 60%);
            box-shadow: 0 0 0 4px rgba(129, 140, 248, 0.35);
        }

    .section-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
        margin-top: 6px;
    }

        .section-title-row h5 {
            margin: 0;
            font-weight: 600;
            font-size: 1rem;
            color: var(--text-main);
            letter-spacing: 0.02em;
        }

    .section-panel.soft {
        border-radius: var(--radius-lg);
        border: 1px solid var(--glass-border);
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.94));
        padding: 16px 16px 4px;
        margin-bottom: 18px;
    }

    /* TABLE – match Sanctioned Intake look */
    .table {
        background: rgba(15, 23, 42, 0.95);
        border-radius: var(--radius-md);
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.2);
        color: var(--text-main);
        width: 100%;
        table-layout: fixed;
        border-collapse: collapse;
    }

        .table thead th {
            background: linear-gradient(135deg, rgba(79, 70, 229, 0.15), rgba(99, 102, 241, 0.1));
            color: #ffffff !important;
            border: none;
            font-weight: 700;
            font-size: 0.82rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            padding: 14px 12px;
            text-align: center;
            white-space: nowrap;
        }

            /* Column widths for Teaching Block */
            .table thead th:nth-child(1) { /* Facilities */
                width: 35%;
                text-align: left;
            }

            .table thead th:nth-child(2) { /* Size in Sq ft as per norms */
                width: 18%;
            }

            .table thead th:nth-child(3) { /* Is Available */
                width: 10%;
            }

            .table thead th:nth-child(4) { /* No of Rooms */
                width: 12%;
            }

            .table thead th:nth-child(5) { /* Size Available */
                width: 13%;
            }

            .table thead th:nth-child(6) { /* Deficiency */
                width: 12%;
            }

        .table tbody td {
            border-color: #6c757d;
            padding: 14px 12px;
            vertical-align: middle;
            color: #495057;
            font-size: 0.86rem;
        }

        .table tbody tr:hover {
            background: rgba(79, 70, 229, 0.08);
        }

        /* FIRST TWO COLUMNS – full visibility like course-name-cell */
        .table tbody td:nth-child(1),
        .table tbody td:nth-child(2) {
            white-space: normal;
            overflow: visible;
            text-overflow: clip;
            word-break: break-word;
            font-weight: 600;
        }

    .form-control,
    .form-select {
        border-radius: 999px;
        border: 1px solid var(--input-border);
        background: var(--input-bg);
        color: var(--text-main);
        font-size: 0.86rem;
        padding: 6px 12px;
        transition: all 0.18s ease-out;
        box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.9);
        width: 100%;
    }

        .form-control::placeholder {
            color: rgba(148, 163, 184, 0.75);
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--input-border-focus);
            outline: none;
            box-shadow: 0 0 0 1px rgba(129, 140, 248, 0.6), 0 0 0 6px rgba(79, 70, 229, 0.25);
            background: rgba(15, 23, 42, 0.98);
        }

        .form-control[type="file"] {
            padding: 8px 12px;
            cursor: pointer;
            background: radial-gradient(circle at 0 0, rgba(129, 140, 248, 0.2), rgba(15, 23, 42, 0.96));
        }

            .form-control[type="file"]::-webkit-file-upload-button {
                border: none;
                border-radius: 999px;
                padding: 6px 14px;
                margin-right: 10px;
                background: linear-gradient(135deg, #4f46e5, #6366f1);
                color: #e5e7eb;
                font-size: 0.78rem;
                text-transform: uppercase;
                letter-spacing: 0.09em;
                font-weight: 600;
                cursor: pointer;
            }

    .text-danger {
        font-size: 0.75rem;
        margin-top: 3px;
        color: var(--danger) !important;
    }

    .btn-primary.modern {
        border-radius: 999px;
        border: 0;
        padding: 10px 30px;
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: conic-gradient(from 160deg, #6366f1, #ec4899, #8b5cf6, #6366f1);
        color: #f9fafb;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 16px 40px rgba(79, 70, 229, 0.7);
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .btn-primary.modern span.pulse {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 0 0, rgba(248, 250, 252, 0.24), transparent 60%);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease-out;
        }

        .btn-primary.modern:hover span.pulse {
            opacity: 1;
        }

        .btn-primary.modern:hover {
            transform: translateY(-1px);
        }

    .btn-outline-primary {
        border-color: rgba(79, 70, 229, 0.6);
        color: #a5b4fc;
        background: rgba(79, 70, 229, 0.12);
        padding: 4px 12px;
        font-size: 0.75rem;
    }

        .btn-outline-primary:hover {
            background: rgba(79, 70, 229, 0.25);
            color: #e5e7eb;
        }

    .badge {
        font-size: 0.7rem;
        padding: 4px 8px;
    }

    .form-footer-note {
        margin-top: 10px;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-align: center;
    }

    @@media (max-width: 768px) {
        .institution-form-card-inner {
            padding: 18px 16px 24px;
        }

        .form-header-modern {
            flex-direction: column;
            align-items: flex-start;
        }

        .table thead th:nth-child(1) {
            width: 45% !important;
        }

        .table thead th:nth-child(2) {
            width: 25% !important;
        }
    }
</style>



<div class="institution-form-shell">
    <div class="container">
        <div class="institution-form-card">
            <div class="institution-form-card-inner">
                <div class="form-header-modern">
                    <div class="form-header-title">
                        <div class="form-header-icon">
                            <i class="bi bi-building"></i>
                        </div>
                        <div>
                            <h4>Administrative Details / Teaching Block</h4>
                            <span>Configure facilities as per norms</span>
                        </div>
                    </div>
                    <div class="form-header-badge">
                        Teaching Block
                    </div>
                </div>

                <form asp-action="Medical_AdminTeachingBlock" method="post">
                    @Html.AntiForgeryToken()
                    <div class="section-panel soft">
                        <div class="section-title-row">
                            <div class="section-chip">
                                <span class="dot"></span>
                                <span>Facilities Matrix</span>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-bordered table-striped align-middle">
                                <thead class="text-center">
                                    <tr>
                                        <th>Facilities</th>
                                        <th>Size in Sqft</th>
                                        <th>Is Available</th>
                                        <th>No of Rooms</th>
                                        <th>Size in Sqft </br> Available per room</th>
                                        <th>Deficiency</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Rows.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                @Model.Rows[i].Facilities
                                                <input type="hidden" asp-for="Rows[@i].Id" />
                                                <input type="hidden" asp-for="Rows[@i].CollegeCode" />
                                                <input type="hidden" asp-for="Rows[@i].FacultyCode" />
                                                <input type="hidden" asp-for="Rows[@i].FacilityId" />
                                                <input type="hidden" asp-for="Rows[@i].Facilities" />
                                                <input type="hidden"
                                                       asp-for="Rows[@i].SizeSqFtAsPerNorms"
                                                       class="norm-size"
                                                       data-row-index="@i" />
                                            </td>

                                            <td class="text-center">
                                                @Model.Rows[i].SizeSqFtAsPerNorms
                                            </td>

                                            <td class="text-center">
                                                <select asp-for="Rows[@i].IsAvailable" class="form-select form-select-sm">
                                                    <option value="true">Yes</option>
                                                    <option value="false">No</option>
                                                </select>
                                            </td>

                                            <td>
                                                <input asp-for="Rows[@i].NoOfRooms"
                                                       class="form-control form-control-sm"
                                                       autocomplete="off" />
                                            </td>

                                            <td>
                                                <input asp-for="Rows[@i].SizeSqFtAvailablePerRoom"
                                                       class="form-control form-control-sm size-available"
                                                       data-row-index="@i"
                                                       autocomplete="off" />
                                            </td>

                                            <td>
                                                <input asp-for="Rows[@i].Deficiency"
                                                       class="form-control form-control-sm deficiency"
                                                       data-row-index="@i"
                                                       readonly />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="text-center mt-3">
                        <button type="submit" class="btn btn-primary modern px-4">
                            <span class="pulse"></span>
                            Save Details
                        </button>
                    </div>
                </form>

                <div class="form-footer-note">
                    Values are computed as per current regulatory norms.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function parseNumber(text) {
            if (!text) return 0;
            var match = text.toString().match(/[\d.]+/);
            if (!match) return 0;
            var n = parseFloat(match[0]);
            return isNaN(n) ? 0 : n;
        }

        function recalcRow(i) {
            var normInput = document.querySelector('input.norm-size[data-row-index="' + i + '"]');
            var availInput = document.querySelector('input.size-available[data-row-index="' + i + '"]');
            var defInput = document.querySelector('input.deficiency[data-row-index="' + i + '"]');

            if (!normInput || !availInput || !defInput) return;

            var norm = parseNumber(normInput.value);
            var avail = parseNumber(availInput.value);

            var diff = avail - norm;
            if (!isNaN(diff)) {
                defInput.value = diff.toString();
            } else {
                defInput.value = "";
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".size-available").forEach(function (inp) {
                inp.addEventListener("input", function () {
                    var idx = this.getAttribute("data-row-index");
                    recalcRow(idx);
                });
            });

            document.querySelectorAll(".size-available").forEach(function (inp) {
                var idx = inp.getAttribute("data-row-index");
                recalcRow(idx);
            });
        });
    </script>
}
