@model AffiliationFinalDeclarationViewModel
@{
    ViewData["Title"] = "Final Declaration";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Fonts + Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --ink: #0f1923;
            --ink-mid: #2e3d4f;
            --ink-muted: #6b7a8d;
            --border: #d4dae3;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --accent: #1a4c8b;
            --accent-lt: #e8edf7;
            --gold: #c9a84c;
            --radius: 10px;
            --shadow: 0 2px 16px rgba(15,25,35,.07);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--ink);
        }

        /* HEADER */
        .page-header {
            background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
            padding: 28px 40px 24px;
            display: flex;
            align-items: center;
            gap: 18px;
            border-bottom: 3px solid var(--gold);
        }

        .page-header .emblem {
            width: 54px;
            height: 54px;
            border: 2px solid var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .page-header-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem;
            color: #ffffff;
        }

        .page-header-text p {
            font-size: .78rem;
            color: rgba(255,255,255,.55);
            margin-top: 3px;
            text-transform: uppercase;
        }

        /* WRAPPER */
        .form-wrap {
            max-width: 900px;
            margin: 32px auto;
            padding: 0 24px 60px;
        }

        .section-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .section-header {
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--border);
            background: #fafbfc;
        }

        .section-header h2 {
            font-size: 1.02rem;
            font-weight: 600;
        }

        .section-body {
            padding: 10px 20px;
        }

        input[type="text"] {
            width: 100%;
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 10px;
        }

        input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(26,76,139,.1);
        }

        .btn {
            font-size: 0.85rem;
            font-weight: 600;
            border-radius: 8px;
            padding: 10px 26px;
            cursor: pointer;
        }

        .btn-primary {
            background: linear-gradient(135deg, #1a4c8b, #1564c0);
            color: #fff;
        }

        .btn-ghost {
            border: 1px solid var(--border);
            background: transparent;
        }
    </style>

    <link rel="stylesheet" href="~/css/common-form.css" />
</head>

<body>

    <!-- HEADER -->
    <div class="page-header">
        <div class="emblem">
            <i class="bi bi-file-earmark-check" style="color:#c9a84c;"></i>
        </div>
        <div class="page-header-text">
            <h1>Final Declaration</h1>
            <p>Affiliation & Recognition Portal</p>
        </div>
    </div>

    <div class="form-wrap">

        <div class="section-card">
            <form asp-action="SaveDeclaration" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="section-header">
                    <i class="bi bi-pencil-square"></i>
                    <h2>Declaration Details</h2>
                </div>

                <div class="section-body">

                    <!-- Principal -->
                    <div class="mb-3">
                        <label class="mb-3">Principal Name</label>
                        <input asp-for="PrincipalName"
                               class="form-control"
                               disabled="@(Model.IsSubmitted)" />
                    </div>

                    <!-- Declaration -->
                    <div style="background:#f8f9fc; padding:15px; border-radius:8px; margin-top:15px;">
                        I hereby declare that all information provided is true and correct.
                    </div>

                    <!-- Checkbox -->
                    <div class="form-check mt-3">
                        <input type="checkbox" id="agreeCheck"
                               @(Model.IsSubmitted ? "checked disabled" : "") />
                        <label for="agreeCheck">I agree to the declaration</label>
                    </div>

                    @if (Model.IsSubmitted)
                    {
                        <div class="mt-3" style="color:green;">
                            ✔ Already submitted
                        </div>
                    }

                </div>

                <div style="padding:20px; text-align:center;">

                    @if (!Model.IsSubmitted)
                    {
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            Final Submit
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-ghost" disabled>
                            Submitted
                        </button>
                    }

                </div>

            </form>
        </div>

        <div class="d-flex justify-content-between mt-4 pt-3" style="border-top:1px solid #d4dae3;">

            <!-- 🔙 PREVIOUS -->
            <a href="@Url.Action("Medical_DepartmentOfficesAndEducationalUnit", "Medical_ContinuousAffiliation")"
               class="btn btn-ghost">
                ← Previous
            </a>

            <!-- 🔜 NEXT -->
            <a href="@Url.Action("Preview", "CAPreview")"
               class="btn btn-primary">
                Next →
            </a>

        </div>
    </div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.getElementById("submitBtn")?.addEventListener("click", function (e) {

        e.preventDefault();

        if (!document.getElementById("agreeCheck").checked) {
            Swal.fire({
                icon: 'warning',
                title: 'Declaration Required',
                text: 'Please accept the declaration'
            });
            return;
        }

        Swal.fire({
            title: 'Confirm Submission?',
            text: 'You cannot edit after this.',
            icon: 'warning',
            showCancelButton: true
        }).then((res) => {
            if (res.isConfirmed) {
                e.target.closest("form").submit();
            }
        });
    });

    // Success/Error
    const success = '@TempData["Success"]';
    if (success) Swal.fire({ icon: 'success', title: success });

    const error = '@TempData["Error"]';
    if (error) Swal.fire({ icon: 'error', title: error });

</script>
}
</body>
</html>