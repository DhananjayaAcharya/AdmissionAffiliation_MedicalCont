                                    {
                                        <span id="saleDeedFileName" class="file-name">
                                            No file selected
                                        </span>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("ViewDocument", "DentalCollege", new { filePath = Model.SaleDeedDocumentPath })"
                                           target="_blank"
                                           class="document-link">

                                            <span id="saleDeedFileName" class="file-name linked-file">

                                                @System.IO.Path.GetFileName(Model.SaleDeedDocumentPath)

                                            </span>

                                            <span class="view-btn">
                                                View
                                            </span>

                                        </a>
