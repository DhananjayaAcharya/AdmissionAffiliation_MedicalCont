@model Medical_Affiliation.ViewModels.DentalCollegeLandBuildingViewModel

@{
    ViewData["Title"] = "Land & Building Details";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
}

<link rel="stylesheet" href="~/css/dental-landbuilding.css" />

<div class="lb-page">

    <div class="lb-header">

        <div>
            @* <div class="lb-header-eyebrow">
                Dental Council Infrastructure Compliance
            </div> *@

            <div class="lb-header-title">
                Dental College Land & Building Details
            </div>

            <div class="lb-header-subtitle">
                Infrastructure compliance details as per DCI norms
            </div>
        </div>

        <div class="lb-header-badge">
            Seat Intake : @Model.SeatIntake
        </div>

    </div>

    <div class="lb-card">

        <form asp-action="DentalCollegeLandBuildingDetail" method="post" enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="SeatSlab" />
            <input type="hidden" asp-for="SeatIntake" />
            <input type="hidden" asp-for="CollegeCode" />
            <input type="hidden" asp-for="FacultyCode" />
            <input type="hidden" asp-for="LandUseCertificateDocumentPath" />
            <input type="hidden" asp-for="ApprovedLayoutPlanDocumentPath" />
            <input type="hidden" asp-for="LandSketchDocumentPath" />
            <input type="hidden" asp-for="DistanceCertificateDocumentPath" />
            <input type="hidden" asp-for="CompletionCertificateDocumentPath" />
            <input type="hidden" asp-for="StructuralStabilityCertificateDocumentPath" />
            <input type="hidden" asp-for="LiftLicenseDocumentPath" />
            <input type="hidden" asp-for="ElectricalSafetyCertificateDocumentPath" />
            <input type="hidden" asp-for="WaterSupplyCertificateDocumentPath" />
            <input type="hidden" asp-for="SewageSanitationApprovalDocumentPath" />

            <!-- LAND DETAILS -->

            <div class="lb-section-title">
                LAND DETAILS
            </div>

            <div class="table-responsive">

                <table class="table lb-table align-middle">

                    <thead>
                        <tr>
                            <th style="width:35%">Element</th>
                            <th style="width:25%">Requirement as per DCI</th>
                            <th style="width:40%">Existing / Available</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr>
                            <td>Total Land Area</td>

                            <td class="requirement-cell">

                                @if (!string.IsNullOrEmpty(Model.RequiredLandRequirementText))
                                {
                                    <span>
                                        @Model.RequiredLandRequirementText
                                    </span>
                                }
                                else
                                {
                                    <span>
                                        @Model.RequiredLandAcres Acres
                                    </span>
                                }

                            </td>

                            <td>
                                <input asp-for="TotalLandAreaAcres"
                                       class="form-control" />

                                <span asp-validation-for="TotalLandAreaAcres"
                                      class="text-danger"></span>
                            </td>
                        </tr>
                        <tr>
                            <td>Land Category</td>

                            <td class="requirement-cell">
                                As per MSSR
                            </td>

                            <td>
                                <select asp-for="LandCategory"
                                        class="form-select">

                                    <option value="">-- Select Category --</option>

                                    <option value="Metro / Tier 1">
                                        Metro / Tier 1
                                    </option>

                                    <option value="Tier 2 / Hilly / North Eastern States">
                                        Tier 2 / Hilly / North Eastern States
                                    </option>

                                    <option value="Any Other Area">
                                        Any Other Area
                                    </option>

                                </select>

                                <span asp-validation-for="LandCategory" class="text-danger"></span>
                            </td>
                        </tr>
                        <tr>
                            <td>Land Ownership</td>

                            <td class="requirement-cell">
                                Owned / 30 Year Lease
                            </td>

                            <td>
                                <select asp-for="LandOwnershipType" class="form-select">

                                    <option value="">-- Select --</option>
                                    <option value="Owned">Owned</option>
                                    <option value="Lease">Lease</option>

                                </select>
                            </td>
                        </tr>

                        <tr>
                            <td>Space for Future Expansion</td>

                            <td class="requirement-cell">
                                Mandatory
                            </td>

                            <td>
                                <select asp-for="HasFutureExpansionSpace" class="form-select">

                                    <option value="">-- Select --</option>
                                    <option value="true">Yes</option>
                                    <option value="false">No</option>

                                </select>
                            </td>
                        </tr>

                    </tbody>

                </table>

            </div>

            <!-- BUILDING DETAILS -->

            <div class="lb-section-title">
                BUILDING INFRASTRUCTURE
            </div>

            <div class="table-responsive">

                <table class="table lb-table align-middle">

                    <thead>
                        <tr>
                            <th style="width:35%">Element</th>
                            <th style="width:25%">Requirement as per DCI</th>
                            <th style="width:40%">Existing / Available</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr>
                            <td>Total Constructed Area (in Sq.m)</td>

                            <td class="requirement-cell">
                                @Model.RequiredBuiltupAreaSqm Sq.m
                            </td>

                            <td>
                                <input asp-for="TotalBuiltupAreaSqm" class="form-control" />
                            </td>
                        </tr>

                        <tr>
                            <td>Area Per Lecture Hall (in Sq.m)</td>

                            <td class="requirement-cell">
                                @Model.RequiredLectureHallAreaSqm Sq.m
                            </td>

                            <td>
                                <input asp-for="LectureHallAreaSqm" class="form-control" />
                            </td>
                        </tr>

                        <tr>
                            <td>Number of students one lecture hall can accommodate</td>

                            <td class="requirement-cell">
                                @Model.RequiredLectureHallCapacity
                            </td>

                            <td>
                                <input asp-for="LectureHallSeatingCapacity" class="form-control" />
                            </td>
                        </tr>
                        <tr>
                            <td>Number of lecture halls available in the College</td>

                            <td class="requirement-cell">
                                @Model.RequiredLectureHallCount
                            </td>

                            <td>
                                <input asp-for="LectureHallCount" class="form-control" />

                                <span asp-validation-for="LectureHallCount" class="text-danger"></span>
                            </td>
                        </tr>
                        <tr>
                            <td>Area of Museum & Demonstration Rooms (in Sq.m)</td>

                            <td class="requirement-cell">
                                As per DCI Norms
                            </td>

                            <td>
                                <input asp-for="MuseumDemoRoomsAreaSqm" class="form-control" />

                                <span asp-validation-for="MuseumDemoRoomsAreaSqm" class="text-danger"></span>
                            </td>
                        </tr>

                        <tr>
                            <td>Area of Departmental Areas (in Sq.m)</td>

                            <td class="requirement-cell">
                                As per DCI Norms
                            </td>

                            <td>
                                <input asp-for="DepartmentWiseAreaSqm" class="form-control" />

                                <span asp-validation-for="DepartmentWiseAreaSqm" class="text-danger"></span>
                            </td>
                        </tr>
                        <tr>
                            <td>Area of Preclinical Labs & Skill Labs (in Sq.m)</td>

                            <td class="requirement-cell">
                                As per DCI Norms
                            </td>

                            <td>
                                <input asp-for="PreclinicalSkillLabAreaSqm" class="form-control" />

                                <span asp-validation-for="PreclinicalSkillLabAreaSqm" class="text-danger"></span>
                            </td>
                        </tr>

                        <tr>
                            <td>Area of Examination Hall (in Sq.m)</td>

                            <td class="requirement-cell">
                                @Model.RequiredExamHallAreaSqm Sq.m
                            </td>

                            <td>
                                <input asp-for="ExaminationHallAreaSqm"class="form-control" />
                            </td>
                        </tr>

                        <tr>
                            <td>Area of Library Including Reading Room (in Sq.m)</td>

                            <td class="requirement-cell">
                                @Model.RequiredLibraryAreaSqm Sq.m
                            </td>

                            <td>
                                <input asp-for="LibraryAreaSqm" class="form-control" />
                            </td>
                        </tr>
                        <tr>
                            <td>Area of Dental Hospital (in Sq.m)</td>

                            <td class="requirement-cell">
                                @Model.RequiredHospitalAreaSqm Sq.m
                            </td>

                            <td>
                                <input asp-for="HospitalAreaSqm" class="form-control" />

                                <span asp-validation-for="HospitalAreaSqm" class="text-danger"></span>
                            </td>
                        </tr>

                    </tbody>

                </table>

            </div>


            <!-- ===================================================== -->
            <!-- BUILDING INFRASTRUCTURE -->
            <!-- ===================================================== -->

            <div class="lb-section-title">
                BUILDING INFRASTRUCTURE
            </div>

            <div class="table-responsive">

                <table class="table lb-table align-middle">

                    <thead>
                        <tr>
                            <th style="width:5%">Sl. No.</th>

                            <th style="width:30%">Infrastructure Requirement</th>

                            <th style="width:35%">Requirement as per DCI</th>

                            <th style="width:30%">Existing / Available</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model.InfrastructureDetails != null &&
                             Model.InfrastructureDetails.Any())
                        {
                            for (int i = 0; i < Model.InfrastructureDetails.Count; i++)
                            {
                                <tr>

                                    <!-- Hidden Fields -->

                                    <input type="hidden"
                                           asp-for="InfrastructureDetails[@i].Id" />

                                    <input type="hidden"
                                           asp-for="InfrastructureDetails[@i].RequirementId" />

                                    <input type="hidden"
                                           asp-for="InfrastructureDetails[@i].SeatSlab" />

                                    <input type="hidden"
                                           asp-for="InfrastructureDetails[@i].RequiredAreaSqFt" />

                                    <!-- Sl No -->

                                    <td>
                                        @Model.InfrastructureDetails[i].SlNo
                                    </td>

                                    <!-- Requirement Name -->

                                    <td>
                                        <div class="fw-semibold">
                                            @Model.InfrastructureDetails[i].RequirementName
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(
                                       Model.InfrastructureDetails[i].RequirementDescription))
                                        {
                                            <small class="text-muted d-block mt-1">
                                                @Model.InfrastructureDetails[i].RequirementDescription
                                            </small>
                                        }
                                    </td>

                                    <!-- DCI Requirement -->

                                    <td class="requirement-cell">

                                        @if (Model.InfrastructureDetails[i].RequiredAreaSqFt > 0)
                                        {
                                            <span>
                                                @Model.InfrastructureDetails[i].RequiredAreaSqFt Sq.ft.
                                            </span>
                                        }
                                        else
                                        {
                                            <span>N/A</span>
                                        }

                                    </td>

                                    <!-- Available Area -->

                                    <td>

                                        <input asp-for="InfrastructureDetails[@i].AvailableAreaSqFt"
                                               class="form-control"
                                               type="number"
                                               step="0.01" />

                                        <span asp-validation-for="InfrastructureDetails[@i].AvailableAreaSqFt"
                                              class="text-danger">
                                        </span>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    No infrastructure requirements configured.
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

            <!-- LAND DOCUMENTS -->

            <div class="lb-section-title">
                LAND DOCUMENTS
            </div>

            <div class="table-responsive">

                <table class="table lb-table align-middle">

                    <thead>
                        <tr>
                            <th style="width:35%">Document</th>
                            <th style="width:25%">Requirement</th>
                            <th style="width:40%">Upload</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr>
                            <td>Registered Sale Deed Document</td>
