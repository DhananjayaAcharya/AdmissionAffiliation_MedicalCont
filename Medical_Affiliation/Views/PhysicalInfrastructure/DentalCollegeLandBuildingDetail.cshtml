                            <td>
                                <div class="custom-upload-wrapper">

                                    <label class="upload-btn">
                                        Upload File

                                        <input asp-for="SaleDeedDocument" type="file" class="hidden-upload"  onchange="showFileName(this, 'saleDeedFileName')" />
                                    </label>

