@model List<DentalChairVm>

@{
    ViewData["Title"] = "Dental Chair Distribution";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
    var facultyCode = Context.Session.GetString("FacultyCode");
}
@{
    var seatSlab = Context.Session.GetString("SeatSlab") ?? Model.Select(f => f.SeatSlab).FirstOrDefault().ToString();
    var hospitalDetailsId = Context.Session.GetString("HospitalDetailsId") ?? Model.Select( f => f.HospitalDetailsId ).FirstOrDefault().ToString();
}
<style>
    .empty-state p {
        text-align: center;
        padding: 56px 20px;
        color: #6b7490;
        background-color: #f5f5f5;
        font-style: italic;
        border-radius: 10px;
    }

    .table-light th {
        background-color: lightgray;
    }

    .navigation-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .5rem 24px;
        border-top: 1px solid var(--border);
        margin-top: 20px;
    }
</style>

<link rel="stylesheet" href="~/css/chair-distribution.css" />
<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="chair-page-container">

    <!-- Header -->
    <div class="chair-header shadow-sm">
        <div>
            <h2 class="mb-1">Dental Chair Distribution</h2>
            <p class="mb-0 text-light-subtle">
                Course-wise dental chair requirement and availability details
            </p>
        </div>

        <div class="chair-badge">
            <span>Total Courses</span>
            <h4>@Model.Count</h4>
        </div>
    </div>

    <!-- Table Card -->
    <div class="table-card shadow-lg mt-2 mb-4">

        <div class="table-header">
            <h5 class="mb-0">Chair Distribution Details</h5>
        </div>
        @if (seatSlab == null || seatSlab == "0")
        {
            <div class="empty-state">
                <p>Please fill <a asp-action="IncreaseIntake" asp-controller="ContinuousAffiliationIncreaseintake">Course Intake</a>  details first.</p>
            </div>

        } else if (hospitalDetailsId == null)
        {
            <div class="empty-state">
                <p>Please fill <a asp-action="ClinicalFacilities" asp-controller="ContinuationAffiliationClinicalFacilities">Affiliated Hospital Information details</a> first. </p>
            </div>
        } else{
            <form asp-action="ChairDistribution" method="post" id="chairForm">
            <div class="table-responsive">
                    @Html.AntiForgeryToken()
                    <table class="table align-middle custom-chair-table mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Course Name</th>
                                <th>Course Level</th>
                                <th>Seat Slab</th>
                                <th>Chairs Required</th>
                                <th>Existing Chairs</th>
                            </tr>
                        </thead>

                        <tbody>

                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <tr>
                                    <td>
                                        <span class="serial-badge">@(i + 1)</span>
                                    </td>

                                    <td>
                                        <div class="course-name">
                                            @Model[i].CourseName
                                        </div>
                                    </td>

                                    <td>
                                        <span class="level-badge">
                                            @Model[i].CourseLevel
                                        </span>
                                    </td>

                                    <td>
                                        <span class="slab-chip">
                                            @Model[i].SeatSlab
                                        </span>
                                    </td>

                                    <td>
                                        <span class="required-count">
                                            @Model[i].ChairsRequired
                                        </span>
                                    </td>
                                    <td>
                                        <input type="number"
                                           class="form-control chair-input chair-existing"
                                               asp-for="@Model[i].ChairsExisting"
                                               min="0" />
                                    </td>
                                    <input type="hidden" asp-for="@Model[i].CourseCode" />
                                    <input type="hidden" asp-for="@Model[i].CourseName" />
                                    <input type="hidden" asp-for="@Model[i].CourseLevel" />
                                    <input type="hidden" asp-for="@Model[i].SeatSlab" />
                                    <input type="hidden" asp-for="@Model[i].SeatSlabId" />
                                    <input type="hidden" asp-for="@Model[i].ChairsRequired" />

                                    
                                </tr>
                            }

                        </tbody>
                    </table>
            </div>
            <!-- Footer -->
            <div class="table-footer" style="justify-content: space-between;">
                @* <a asp-action="DentalSkillsLaboratory" asp-controller="PhysicalInfrastructure"
                   class="btn btn-outline-secondary">

                    ← Previous

                </a> *@
                <button class="btn btn-primary save-btn px-4" type="button">
                    <i class="bi bi-save2 me-2"></i>
                    Save Chair Details
                </button>
                @* <a asp-controller="ContinuesAffiliation_Facultybased"
                   asp-action="MedicalUGBedDistribution"
                   class="btn btn-success next-btn">

                    Next →

                </a> *@
            </div>
        </form>
        }
        <div class="navigation-bar">

            @if (facultyCode == "1")
            {

                <a href="@Url.Action("Medical_EquimentDetails", "Medical_ContinuousAffiliation")"
                   class="btn-prev btn">Previous</a>
            }

            @if (facultyCode == "2")
            {
                <a href="@Url.Action("DentalSkillsLaboratory", "PhysicalInfrastructure")"
                   class="btn-prev btn">Previous</a>
            }

            @if (facultyCode == "1")
            {
                <a href="@Url.Action("CA_VehicleDetails", "Aff_AHS_ContinousApplication")"
                   class="btn btn-primary">Next</a>
            }

            @if (facultyCode == "2")
            {
                <a href="@Url.Action("MedicalUGBedDistribution", "ContinuesAffiliation_Facultybased")"
                   class="btn btn-primary">Next</a>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.querySelector(".save-btn").addEventListener("click", function(){
            const inputs = document.querySelectorAll(".chair-existing");
            let hasError = false;
            let errorMsg = "";
            inputs.forEach((input,idx) => {
                const value = input.value;

                if(value === ""){
                    hasError = true;
                    errorMsg = `Please enter chair count for ${idx+1}`;
                    return;
                }

                if(parseInt(value)<0){
                    hasError = true;
                    errorMsg = `Chair count cannot be negative in row ${row+1}`;
                    return;
                }
            })

            if(hasError){
                Swal.fire({
                    icon: "error",
                    title: "Check Again",
                    text: errorMsg,
                    confirmButtonColor: '#d33';
                });
                return;
            }

            document.querySelector("#chairForm").submit();
        })
    </script>

    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["Success"]',
                timer: 2000
                showConfirmationButton:false
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
            icon: 'error',
            title: 'Error',
            text: '@TempData["Error"]',
            confirmButtonColor: '#d33'
            });
        </script>
    }
}