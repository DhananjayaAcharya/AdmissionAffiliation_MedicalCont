@model FellowshipDashboardListVm
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Section Officer – Fellowship Applications";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container-fluid py-4" style="background-color:#f5f7fb;">
    <div class="row mb-3">
        <div class="col">
            <h4 class="mb-0 fw-semibold text-primary">
                Section Officer – Fellowship Applications
            </h4>
            <small class="text-muted">Review, approve or reject fellowship medical applications.</small>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-header d-flex justify-content-between align-items-center bg-white">
            <div>
                <span class="fw-semibold">Applications</span>
                <span class="badge bg-secondary ms-2">@Model.Items.Count</span>
            </div>
            <button type="submit" form="approvalForm" class="btn btn-sm btn-primary">
                Save Changes
            </button>
        </div>

        <div class="card-body p-0">
            <form asp-action="AdminDashboard_Fellowship" method="post" id="approvalForm">
                @Html.AntiForgeryToken()
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm mb-0 align-middle">
                        <thead class="table-light text-nowrap">
                            <tr>
                                <th>College</th>
                                <th>SlNo</th>
                                <th>Student / Course</th>
                                <th>Dates</th>
                                <th>Principal</th>
                                <th>Fellowship</th>
                                <th>Documents</th>
                                <th style="width:160px;">Status</th>
                                <th style="width:220px;">Remark</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Items != null && Model.Items.Count > 0)
                            {
                                @for (int i = 0; i < Model.Items.Count; i++)
                                {
                                    var item = Model.Items[i];
                                    <tr>
                                        <td class="fw-semibold">@item.CollegeName
                                            <input type="hidden" asp-for="Items[@i].CollegeCode" />
                                            <input type="hidden" asp-for="Items[@i].CollegeName" />
                                        </td>

                                        <td class="text-muted">
                                            @((i + 1).ToString("D2"))
                                            <input type="hidden" asp-for="Items[@i].Id" />
                                        </td>

                                        <td>
                                            <div class="fw-semibold">@item.StudentName</div>
                                            <div class="small text-muted">@item.Course</div>
                                        </td>

                                        <td class="small">
                                            <div>
                                                <span class="text-muted">DOB:</span>
                                                @item.DOB.ToString("dd-MM-yyyy")
                                            </div>
                                            <div>
                                                <span class="text-muted">DOJ:</span>
                                                @item.Dateofjoining.ToString("dd-MM-yyyy")
                                            </div>
                                            <div>
                                                <span class="text-muted">From:</span>
                                                @item.Admission_openingDate.ToString("dd-MM-yyyy")
                                                <span class="text-muted">–</span>
                                                @item.EndingDate.ToString("dd-MM-yyyy")
                                            </div>
                                        </td>

                                        <td>
                                            <div class="fw-semibold">@item.principal_name</div>
                                            @if (!string.IsNullOrWhiteSpace(item.principal_Declaration))
                                            {
                                                <span class="badge bg-light text-dark border small">
                                                    @item.principal_Declaration
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            <div class="small text-muted">Fellowship Code</div>
                                            <div class="fw-semibold">@item.FellowshipCode</div>
                                            <div class="small text-muted">KMC: @item.KMC_CertificateNumber</div>
                                        </td>

                                        <td class="text-nowrap">
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a asp-action="Download" asp-route-id="@item.Id" asp-route-doc="SSLC"
                                                   class="btn btn-outline-secondary @(!item.HasSSLC ? "disabled" : "")"
                                                   target="_blank">
                                                    SSLC
                                                </a>
                                                <a asp-action="Download" asp-route-id="@item.Id" asp-route-doc="KMC"
                                                   class="btn btn-outline-secondary @(!item.HasKMC ? "disabled" : "")"
                                                   target="_blank">
                                                    KMC
                                                </a>
                                                <a asp-action="Download" asp-route-id="@item.Id" asp-route-doc="EXP"
                                                   class="btn btn-outline-secondary @(!item.HasExperience ? "disabled" : "")"
                                                   target="_blank">
                                                    Exp
                                                </a>
                                                <a asp-action="Download" asp-route-id="@item.Id" asp-route-doc="APPT"
                                                   class="btn btn-outline-secondary @(!item.HasAppointment ? "disabled" : "")"
                                                   target="_blank">
                                                    Appt
                                                </a>
                                            </div>
                                        </td>

                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge status-badge"></span>
                                                <select asp-for="Items[@i].ApprovalStatus"
                                                        class="form-select form-select-sm approval-select w-auto">
                                                    <option value="Pending">Pending</option>
                                                    <option value="Approved">Approved</option>
                                                    <option value="Rejected">Rejected</option>
                                                </select>
                                            </div>
                                        </td>

                                        <td>
                                            <input asp-for="Items[@i].ApprovalRemark"
                                                   class="form-control form-control-sm remark-input"
                                                   placeholder="Reason (required when Rejected)" />
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center py-3 text-muted">
                                        No applications found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    function updateRowUI(row) {
        var statusSelect = row.find(".approval-select");
        var status = statusSelect.val();
        var remark = row.find(".remark-input");
        var badge = row.find(".status-badge");

        // badge color & text
        badge.removeClass("bg-secondary bg-success bg-danger");
        if (status === "Approved") {
            badge.addClass("bg-success").text("Approved");
        } else if (status === "Rejected") {
            badge.addClass("bg-danger").text("Rejected");
        } else {
            badge.addClass("bg-secondary").text("Pending");
        }

        // remark visibility
        if (status === "Rejected") {
            remark.prop("disabled", false).show();
        } else {
            remark.val("");
            remark.prop("disabled", true).hide();
        }
    }

    $(document).ready(function () {
        $("tbody tr").each(function () {
            updateRowUI($(this)); // initial
        });

        $(".approval-select").on("change", function () {
            updateRowUI($(this).closest("tr"));
        });
    });
</script>