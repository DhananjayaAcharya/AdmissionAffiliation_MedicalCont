<script>
    // Show selected filename
    document.querySelectorAll('input[type="file"]').forEach(input => {
        input.addEventListener('change', function() {
            const fileName = this.files.length > 0 ? this.files[0].name : 'No file chosen';
            this.closest('.file-upload-box').querySelector('.file-name').textContent = fileName;
        });
    });

    // Custom checkbox animation

    // 2. CUSTOM CHECKBOX – PERFECT FOR asp-for="AgreeTerms"
    const checkbox = document.getElementById('AgreeTerms');

    if (checkbox) {
        const visualBox = checkbox.nextElementSibling; // .custom-checkbox label

        const updateVisual = () => {
            if (checkbox.checked) {
                visualBox.innerHTML = `<svg width="18" height="18" fill="white" viewBox="0 0 16 16">
                    <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425a.247.247 0 0 1 .02-.022Z"/>
                </svg>`;
                visualBox.style.background = '#3b82f6';
                visualBox.style.borderColor = '#3b82f6';
            } else {
                visualBox.innerHTML = '';
                visualBox.style.background = '#334155';
                visualBox.style.borderColor = '#64748b';
            }
        };

        // Run on page load (important if value comes pre-checked from server)
        updateVisual();

        // Run every time user clicks
        checkbox.addEventListener('change', updateVisual);
    }
    
