@model LandBuildingDetailsVM


@{
    ViewData["Title"] = "Land and Building Details";
}

<style>
    :root {
        --primary: #3b82f6;
        --card-bg: rgba(15, 23, 42, 0.85);
        --card-border: rgba(255, 255, 255, 0.15);
    }

    body {
        background: #0f172a;
        color: white;
        font-family: 'Segoe UI', sans-serif;
        min-height: 100vh;
        background-image: radial-gradient(circle at top left, rgba(59,130,246,0.15), transparent 50%), radial-gradient(circle at bottom right, rgba(99,102,241,0.2), transparent 50%);
    }

    .page-header {
        background: linear-gradient(135deg, #1e3a8a, #3b82f6, #60a5fa);
        /* padding: 28px 0; */
        border-radius:18px;
        box-shadow: 0 15px 40px rgba(59,130,246,0.6);
        margin-bottom: 40px;
        position: relative;
        margin-top:20px;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.25), transparent 60%);
            animation: shine 8s infinite linear;
        }
    @@keyframes shine {
        0% {
            transform: translateX(-100%) translateY(-100%) rotate(20deg);
        }

        100% {
            transform: translateX(100%) translateY(100%) rotate(20deg);
        }
    }

    .page-title {
        font-size: 2.4rem;
        font-weight: 800;
        color: white;
        text-align: center;
        text-shadow: 0 4px 15px rgba(0,0,0,0.5);
        margin: 0;
    }

    .glass-card {
        background: var(--card-bg);
        backdrop-filter: blur(22px);
        -webkit-backdrop-filter: blur(22px);
        border-radius: 24px;
        border: 1px solid var(--card-border);
        padding: 36px;
        max-width: 1100px;
        margin: 0 auto 40px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

    .section-title {
        font-size: 1.8rem;
        color: #60a5fa;
        font-weight: 700;
        text-align: center;
        margin-bottom: 30px;
    }

    .instructions-box {
        background: rgba(30,41,59,0.7);
        border-left: 6px solid var(--primary);
        border-radius: 16px;
        padding: 28px;
        line-height: 1.9;
        font-size: 1.05rem;
    }

    .mobile-hint {
        background: linear-gradient(135deg, #7c3aed, #3b82f6);
        color: white;
        padding: 18px;
        border-radius: 16px;
        text-align: center;
        font-weight: 600;
        margin: 35px 0;
        font-size: 1.1rem;
    }

        .mobile-hint a {
            color: #fff;
            text-decoration: underline;
            font-weight: bold;
        }

    .form-label {
        color: #e0e7ff;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .form-control, .form-select {
        background: rgba(30,41,59,0.9);
        border: 1px solid #3b82f6;
        color: white;
        border-radius: 12px;
        padding: 12px 16px;
        margin-top:15px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #60a5fa;
            box-shadow: 0 0 0 3px rgba(96,165,250,0.3);
        }

    .radio-btn {
        background: rgba(255,255,255,0.1);
        border: 2px solid rgba(255,255,255,0.2);
        color: white;
        padding: 10px 26px;
        border-radius: 12px;
        transition: all 0.3s;
        font-weight: 500;
    }

    .btn-check:checked + .radio-btn {
        background: #3b82f6;
        border-color: #3b82f6;
        box-shadow: 0 0 20px rgba(59,130,246,0.6);
    }

    .file-upload-box {
        margin-top: 10px;
    }

    .file-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(30,41,59,0.8);
        border: 2px dashed #3b82f6;
        border-radius: 16px;
        padding: 18px 22px;
        cursor: pointer;
        color: #e0e7ff;
        font-weight: 500;
        transition: all 0.3s;
    }

        .file-label:hover {
            background: rgba(59,130,246,0.3);
            border-color: #60a5fa;
            transform: translateY(-2px);
        }

    .file-name {
        color: #60a5fa;
        font-weight: 600;
    }

    .file-upload-box small {
        color: #a5b4fc !important;
        font-size: 0.9rem;
        margin-top: 8px;
        display: block;
    }

    .deficiency-summary {
/*         background: linear-gradient(135deg, #7f1d1d, #991b1b); */
        color: white;
        padding: 22px;
        border-radius: 16px;
        text-align: center;
        margin-top: 35px;
        font-size: 1.15rem;
    }

    .btn-nav {
        padding: 16px 48px;
        border-radius: 16px;
        font-size: 1.1rem;
        font-weight: 600;
        min-width: 180px;
    }

    .btn-back {
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.3);
        color: white;
    }

    .btn-next {
        background: var(--primary);
        color: white;
        box-shadow: 0 10px 30px rgba(59,130,246,0.7);
    }

        .btn-next:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(59,130,246,0.8);
        }

    .agree-hidden {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
    }


    /* The square */
    .custom-checkbox {
        width: 26px;
        height: 26px;
        background: #334155;
        border: 2px solid #64748b;
        border-radius: 8px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s ease;
    }

    /* When checked, change color */
    .agree-hidden:checked + .custom-checkbox {
        background: var(--primary);
        border-color: var(--primary);
    }

        /* Tick mark when checked */
        .agree-hidden:checked + .custom-checkbox::after {
            content: "✔";
            color: #fff;
            font-size: 16px;
            font-weight: bold;
        }


    /* ────── NEW INDEPENDENT DEFICIENCY SUMMARY (No table-glass) ────── */
    .deficiency-card {
        background: rgba(15, 23, 42, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(59, 130, 246, 0.4);
        border-radius: 24px;
        padding: 40px 30px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
        margin-top: 50px;
    }

    .def-summary-title {
        font-size: 2.1rem;
        font-weight: 900;
        background: linear-gradient(90deg, #60a5fa, #3b82f6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-align: center;
        margin-bottom: 35px;
        letter-spacing: 1.5px;
    }

    .def-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 30px;
    }

    .def-box {
        flex: 1;
        min-width: 280px;
        background: rgba(30, 41, 59, 0.7);
        border-radius: 18px;
        padding: 30px 20px;
        text-align: center;
        border: 1px solid rgba(59, 130, 246, 0.3);
        transition: all 0.4s;
    }

        .def-box:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(59,130,246,0.4);
        }

    .def-label {
        font-size: 1.1rem;
        color: #94a3b8;
        margin-bottom: 12px;
        font-weight: 600;
    }

    .def-value {
        font-size: 2.8rem;
        font-weight: 900;
        letter-spacing: 1px;
    }

    .def-required {
        color: #fca5a5;
        text-shadow: 0 0 25px #ef4444;
    }

    .def-available {
        color: #67e8f9;
        text-shadow: 0 0 25px #06b6d4;
    }

    .def-deficiency {
        font-size: 3.2rem !important;
        transition: all 0.5s;
    }

    .def-short {
        color: #fecaca;
        text-shadow: 0 0 30px #ef4444;
    }

    .def-ok {
        color: #a7f3d0;
        text-shadow: 0 0 30px #22c55e;
    }

    .def-message {
        text-align: center;
        padding: 20px;
        border-radius: 16px;
        font-size: 1.3rem;
        font-weight: 700;
        margin-top: 20px;
        backdrop-filter: blur(10px);
    }

    .pdf-view-under {
        position: absolute;
        left: 0;
        bottom: -32px; /* Adjust lower or higher as needed */
        background: linear-gradient(135deg, #3b82f6, #2dd4bf);
        padding: 6px 14px;
        border-radius: 8px;
        color: #fff;
        font-size: 0.9rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 3px 6px rgba(0,0,0,0.2);
        transition: 0.2s ease;
        margin-left: 14px;
    }

        .pdf-view-under:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 12px rgba(0,0,0,0.3);
        }

    .row.mb-4 {
        margin-bottom: 50px !important; /* ensures button does not overlap next row */
    }


</style>

<!-- Header -->
<div class="page-header">
    <div class="container">
        <h1 class="page-title">LAND AND BUILDING DETAILS</h1>
    </div>
</div>

<div class="container">
    <form asp-action="SaveLandBuilding" enctype="multipart/form-data">
    <!-- INSTRUCTIONS CARD -->
    <div class="glass-card">
        <h2 class="section-title">Instructions</h2>
        <div class="instructions-box">
            <p><strong>Infrastructure is required as per the norms.</strong></p>
            <ul>
                <li>If the institution does not have own building: Registered Lease agreement to be attached not less than 30 Years. College should have an own building within 2 years.</li>
                <li>It is mandatory that all nursing institution shall have its own building within two academic years of its establishment.</li>
            </ul>
            <p><strong>Penalty for not having own building:</strong></p>
            <ul>
                <li>Institutions which do not have their own building within two years of establishment has to pay the penalty.</li>
                <li>The penalty is Rs.2 lakh per year for BSc(Nursing) program for 5 consecutive years. Even after 5 years if the institution does not have own building then the institution is deemed to be closed.</li>
            </ul>
        </div>

        <!-- I Agree Checkbox -->
            <!-- I AGREE CHECKBOX – 100% WORKING BINDING (2025 BEST PRACTICE) -->
            <div class="d-flex align-items-center gap-3 mt-4">
                <!-- This is the ONLY input ASP.NET Core needs -->
                <input type="checkbox"
                       asp-for="AgreeTerms"
                       class="position-absolute opacity-0"
                       id="AgreeTerms"
                       style="width:0; height:0;" />

                <!-- Visual clickable box -->
                <label for="AgreeTerms" class="custom-checkbox"></label>

                <!-- Clickable text -->
                <label for="AgreeTerms"
                       style="cursor:pointer; font-size:1.1rem; font-weight:600; color:#e0e7ff; user-select:none;">
                    I Agree to these above Terms and Conditions
                </label>
            </div>

            <!-- Required validation message (optional but recommended) -->
            <span asp-validation-for="AgreeTerms" class="text-danger"></span>


    </div>

    <!-- BUILDING DETAILS FORM -->
    <div class="glass-card">
        <div class="mobile-hint">
            Kindly capture latitude, longitude and building photograph from the mobile app.
            <a href="#">Click Here For Instructions</a>
        </div>

        <h2 class="section-title">BUILDING DETAILS</h2>

       



    <div class="row g-4">

        <!-- Land & Building Area -->
        <div class="col-lg-6">
            <label>Land in Acres</label>
            <input type="number" step="0.01" class="form-control" asp-for="LandAcres" required>
        </div>

        <div class="col-lg-6">
            <label>Total Area of Building in Sq.ft.</label>
            <input type="number" class="form-control" asp-for="BuildingArea" required>
        </div>

        <!-- Building Type & Owner -->
        <div class="col-lg-6">
            <label>Building Type <span class="text-danger">*</span></label>
            <select class="form-select" asp-for="BuildingType" required>
                <option value="">-- Select --</option>
                <option value="OWN">OWN</option>
                <option value="LEASED">LEASED</option>
            </select>
        </div>

        <div class="col-lg-6">
            <label>Building Owner Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" asp-for="OwnerName" required>
        </div>

        <!-- Court Case & Courses -->
        <div class="col-lg-6">
            <label>Any court case pending against the property?</label>
            <div class="d-flex gap-4 mt-2">
                <div>
                    <input class="btn-check" type="radio" asp-for="CourtCase" id="cYes" value="Yes">
                    <label class="btn radio-btn" for="cYes">Yes</label>
                </div>
                <div>
                    <input class="btn-check" type="radio" asp-for="CourtCase" id="cNo" value="No">
                    <label class="btn radio-btn" for="cNo">No</label>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <label>Does all the applied courses are imparted in this building?</label>
            <div class="d-flex gap-4 mt-2">
                <div>
                    <input class="btn-check" type="radio" asp-for="CoursesInBuilding" id="coYes" value="Yes">
                    <label class="btn radio-btn" for="coYes">YES</label>
                </div>
                <div>
                    <input class="btn-check" type="radio" asp-for="CoursesInBuilding" id="coNo" value="No">
                    <label class="btn radio-btn" for="coNo">NO</label>
                </div>
            </div>
        </div>

        <!-- Number of Classrooms & Labs -->
        <div class="col-lg-6">
            <label>Number of Classrooms</label>
            <input type="number" class="form-control" asp-for="Classrooms" min="1" required>
        </div>

        <div class="col-lg-6">
            <label>Number of Labs</label>
            <input type="number" class="form-control" asp-for="Labs" min="1" required>
        </div>

        <!-- Identifiers -->
        <div class="col-lg-6">
            <label>Survey No./PID No.</label>
            <input type="text" class="form-control" asp-for="Survey">
        </div>

        <div class="col-lg-6">
            <label>Enter RR Number</label>
            <input type="text" class="form-control" asp-for="RR">
        </div>

        <!-- Facilities -->
        <div class="col-lg-6">
            <label>Safe drinking water supply</label>
            <div class="d-flex gap-4 mt-2">
                <div>
                    <input class="btn-check" type="radio" asp-for="WaterSupply" id="waterYes" value="Available">
                    <label class="btn radio-btn" for="waterYes">Available</label>
                </div>
                <div>
                    <input class="btn-check" type="radio" asp-for="WaterSupply" id="waterNo" value="Not Available">
                    <label class="btn radio-btn" for="waterNo">Not Available</label>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <label>Auditorium</label>
            <div class="d-flex gap-4 mt-2">
                <div>
                    <input class="btn-check" type="radio" asp-for="Auditorium" id="audiYes" value="Available">
                    <label class="btn radio-btn" for="audiYes">Available</label>
                </div>
                <div>
                    <input class="btn-check" type="radio" asp-for="Auditorium" id="audiNo" value="Not Available">
                    <label class="btn radio-btn" for="audiNo">Not Available</label>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <label>Office Facilities</label>
            <div class="d-flex gap-4 mt-2">
                <div>
                    <input class="btn-check" type="radio" asp-for="OfficeFacilities" id="officeYes" value="Available">
                    <label class="btn radio-btn" for="officeYes">Available</label>
                </div>
                <div>
                    <input class="btn-check" type="radio" asp-for="OfficeFacilities" id="officeNo" value="Not Available">
                    <label class="btn radio-btn" for="officeNo">Not Available</label>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <label>Seating Capacity</label>
            <div class="d-flex gap-4 mt-2">
                <div>
                    <input class="btn-check" type="radio" asp-for="Seating" id="SeatYes" value="Available">
                    <label class="btn radio-btn" for="SeatYes">Available</label>
                </div>
                <div>
                    <input class="btn-check" type="radio" asp-for="Seating" id="SeatNo" value="Not Available">
                    <label class="btn radio-btn" for="SeatNo">Not Available</label>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <label>Electricity</label>
            <div class="d-flex gap-4 mt-2">
                <div>
                    <input class="btn-check" type="radio" asp-for="Electricity" id="elecYes" value="Available">
                    <label class="btn radio-btn" for="elecYes">Available</label>
                </div>
                <div>
                    <input class="btn-check" type="radio" asp-for="Electricity" id="elecNo" value="Not Available">
                    <label class="btn radio-btn" for="elecNo">Not Available</label>
                </div>
            </div>
        </div>

                <div class="row g-4 align-items-start mb-5 position-relative">
                    <div class="col-lg-7 position-relative">
                        <label class="d-block mb-2">
                            Attach Blue Print and Completion Certificate <span class="text-danger">*</span>
                        </label>
                        <div class="file-upload-box mb-2">
                            <input asp-for="BlueprintDoc" type="file" id="blueprint" accept=".pdf" style="display:none;">
                            <label for="blueprint" class="file-label d-flex justify-content-between align-items-center">
                                <span>Choose File</span>
                                <span class="file-name">No file chosen</span>
                            </label>
                            <small class="text-info">PDF Format (Max 1MB)</small>
                        </div>

                        @if (Model.BlueprintPdf != null && Model.BlueprintPdf.Length > 0)
                        {
                            <a target="_blank"
                               href="@Url.Action("ViewPdf", "NursingContinuesAffiliation", new { type = "Blueprint" })"
                               class="pdf-view-under">
                                View PDF
                            </a>

                        }
                    </div>

                    <div class="col-lg-5 d-flex align-items-start">
                        <div class="w-100">
                            <label class="d-block mb-2">Certificate Number</label>
                            <input type="text"
                                   class="form-control form-control-lg"
                                   asp-for="BlueprintCertNo"
                                   placeholder="Enter certificate number">
                        </div>
                    </div>
                </div>



                @* Row 2 *@
                <div class="row g-4 align-items-start mb-5 position-relative">
                    <div class="col-lg-7 position-relative">
                        <label class="d-block mb-2">
                            Certificate Approved by Competent Authority <span class="text-danger">*</span>
                        </label>

                        <div class="file-upload-box mb-2">
                            <input asp-for="ApprovalCert" type="file" id="approval" accept=".pdf" style="display:none;">
                            <label for="approval" class="file-label d-flex justify-content-between align-items-center">
                                <span>Choose File</span>
                                <span class="file-name">No file chosen</span>
                            </label>
                            <small class="text-info">PDF Format (Max 1MB)</small>
                        </div>

                        @if (Model.ApprovalCertPdf != null && Model.ApprovalCertPdf.Length > 0)
                        {
                            <a target="_blank"
                               href="@Url.Action("ViewPdf", "NursingContinuesAffiliation", new { type = "Approval" })"
                               class="pdf-view-under">
                                View PDF
                            </a>
                        }
                    </div>

                    <div class="col-lg-5 d-flex align-items-start">
                        <div class="w-100">
                            <label class="d-block mb-2">Certificate Number</label>
                            <input type="text"
                                   class="form-control form-control-lg"
                                   asp-for="ApprovalCertNo"
                                   placeholder="Enter certificate number">
                        </div>
                    </div>
                </div>


                @* Row 3 *@
                <div class="row g-4 align-items-start mb-5 position-relative">
                    <div class="col-lg-7 position-relative">
                        <label class="d-block mb-2">
                            Tax Paid Receipt / Certificate <span class="text-danger">*</span>
                        </label>

                        <div class="file-upload-box mb-2">
                            <input asp-for="TaxReceipt" type="file" id="tax" accept=".pdf" style="display:none;">
                            <label for="tax" class="file-label d-flex justify-content-between align-items-center">
                                <span>Choose File</span>
                                <span class="file-name">No file chosen</span>
                            </label>
                            <small class="text-info">PDF Format (Max 1MB)</small>
                        </div>

                        @if (Model.TaxReceiptPdf != null && Model.TaxReceiptPdf.Length > 0)
                        {
                            <a target="_blank"
                               href="@Url.Action("ViewPdf", "NursingContinuesAffiliation", new { type = "TaxReceipt" })"
                               class="pdf-view-under">
                                View PDF
                            </a>
                        }
                    </div>

                    <div class="col-lg-5 d-flex align-items-start">
                        <div class="w-100">
                            <label class="d-block mb-2">Certificate Number</label>
                            <input type="text"
                                   class="form-control form-control-lg"
                                   asp-for="TaxCertNo"
                                   placeholder="Enter certificate number">
                        </div>
                    </div>
                </div>


                @* Row 4 *@
                <div class="row g-4 align-items-start mb-5 position-relative">
                    <div class="col-lg-7 position-relative">
                        <label class="d-block mb-2">
                            RTC of Land <span class="text-danger">*</span>
                        </label>

                        <div class="file-upload-box mb-2">
                            <input asp-for="RTC" type="file" id="rtc" accept=".pdf" style="display:none;">
                            <label for="rtc" class="file-label d-flex justify-content-between align-items-center">
                                <span>Choose File</span>
                                <span class="file-name">No file chosen</span>
                            </label>
                            <small class="text-info">PDF Format (Max 1MB)</small>
                        </div>

                        @if (Model.RTCPdf != null && Model.RTCPdf.Length > 0)
                        {
                            <a target="_blank"
                               href="@Url.Action("ViewPdf", "NursingContinuesAffiliation", new { type = "RTC" })"
                               class="pdf-view-under">
                                View PDF
                            </a>
                        }
                    </div>

                    <div class="col-lg-5 d-flex align-items-start">
                        <div class="w-100">
                            <label class="d-block mb-2">Certificate Number</label>
                            <input type="text"
                                   class="form-control form-control-lg"
                                   asp-for="RTCCertNo"
                                   placeholder="Enter certificate number">
                        </div>
                    </div>
                </div>


                @* Row 5 *@
                <div class="row g-4 align-items-start mb-5 position-relative">
                    <div class="col-lg-7 position-relative">
                        <label class="d-block mb-2">
                            Occupancy Certificate <span class="text-danger">*</span>
                        </label>

                        <div class="file-upload-box mb-2">
                            <input asp-for="OccupancyCert" type="file" id="occupancy" accept=".pdf" style="display:none;">
                            <label for="occupancy" class="file-label d-flex justify-content-between align-items-center">
                                <span>Choose File</span>
                                <span class="file-name">No file chosen</span>
                            </label>
                            <small class="text-info">PDF Format (Max 1MB)</small>
                        </div>

                        @if (Model.OccupancyCertPdf != null && Model.OccupancyCertPdf.Length > 0)
                        {
                            <a target="_blank"
