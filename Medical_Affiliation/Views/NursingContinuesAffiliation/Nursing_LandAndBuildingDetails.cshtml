       function updateDeficiency() {

        const required = parseFloat(document.getElementById('requiredArea').value) || 0;
        const availableInput = document.getElementById("BuildingArea");  // FIXED
        const available = parseFloat(availableInput.value) || 0;

        const deficiency = Math.max(0, required - available);

        document.getElementById('availableArea').innerHTML =
            available.toLocaleString() + ' <small style="font-size:1rem;">Sq.ft</small>';

        document.getElementById('deficiencyArea').textContent = deficiency.toLocaleString();

        const defBox = document.querySelector('.def-box:nth-child(3)');
        const msg = document.getElementById('deficiencyMessage');

        msg.innerHTML = ""; // 👈 removes the red bar

        if (deficiency > 0) {
            defBox.classList.add('def-short');
            defBox.classList.remove('def-ok');
        } else {
            defBox.classList.add('def-ok');
            defBox.classList.remove('def-short');
        }
    }

    // Run on load + on input
        document.addEventListener('DOMContentLoaded', updateDeficiency);
    document.getElementById("BuildingArea").addEventListener('input', updateDeficiency);

       
    // -------------------------------------
    // NEXT BUTTON CONTROL (must save first)
    // -------------------------------------
    document.getElementById("btnNext").addEventListener("click", function () {
        if (window.formSaved) {
            window.location.href = '@Url.Action("ClassroomAndLaboratoryDetails", "NursingContinuesAffiliation")';
        } else {
            alert("Please save the details before going to the next page.");
        }
    });

    // set from controller: ViewBag.FormSaved = true;
    window.formSaved = @((ViewBag.FormSaved ?? false).ToString().ToLower());

</script>