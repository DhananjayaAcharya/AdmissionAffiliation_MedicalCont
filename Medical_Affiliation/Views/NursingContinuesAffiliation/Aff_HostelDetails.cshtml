@model AffHostelDetailsCreateVm
@{
    ViewData["Title"] = "Affiliation Hostel Details";
}

<style>
    .text-muted {
        --bs-text-opacity: 1;
        color: #ffffff !important;
    }

    :root {
        --primary: #4f46e5;
        --primary-soft: rgba(79, 70, 229, 0.12);
        --accent: #ec4899;
        --bg-body: #060714;
        --bg-gradient: radial-gradient(circle at top left, #1f2937 0, #020617 55%, #020617 100%);
        --glass-bg: rgba(15, 23, 42, 0.85);
        --glass-border: rgba(148, 163, 184, 0.35);
        --input-bg: rgba(15, 23, 42, 0.9);
        --input-border: rgba(148, 163, 184, 0.45);
        --input-border-focus: rgba(129, 140, 248, 0.9);
        --radius-lg: 20px;
        --radius-md: 14px;
        --shadow-soft: 0 24px 60px rgba(15, 23, 42, 0.85);
        --shadow-chip: 0 10px 25px rgba(15, 23, 42, 0.65);
        --text-main: #ffffff;
        --text-muted: #9ca3af;
        --danger: #f97373;
    }

    body {
        background: var(--bg-gradient);
    }

    .institution-form-shell {
        background: var(--bg-gradient);
        min-height: 100vh;
        padding: 32px 0 40px;
    }

    .institution-form-card {
        background: radial-gradient(circle at top left, rgba(148, 163, 184, 0.25), transparent 55%), radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.28), transparent 55%);
        border-radius: 32px;
        padding: 1px;
        box-shadow: var(--shadow-soft);
        position: relative;
        overflow: hidden;
    }

        .institution-form-card::before {
            content: "";
            position: absolute;
            inset: -40%;
            background: radial-gradient(circle at 0% 0%, rgba(244, 114, 182, 0.22), transparent 60%), radial-gradient(circle at 100% 100%, rgba(59, 130, 246, 0.28), transparent 55%);
            opacity: 0.4;
            filter: blur(32px);
            z-index: -2;
        }

    .institution-form-card-inner {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(15, 23, 42, 0.92));
        border-radius: 30px;
        border: 1px solid rgba(148, 163, 184, 0.28);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        position: relative;
        z-index: 1;
        padding: 28px 26px 30px;
    }

    @@media (min-width: 992px) {
        .institution-form-card-inner {
            padding: 30px 34px 34px;
        }
    }

    .form-header-modern {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
    }

    .form-header-title {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-header-icon {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        background: radial-gradient(circle at 30% 0, #e5e7eb 0, #9ca3af 12%, #111827 55%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #020617;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.85);
        position: relative;
    }

        .form-header-icon::after {
            content: "";
            position: absolute;
            inset: 2px;
            border-radius: inherit;
            border: 1px solid rgba(148, 163, 184, 0.55);
        }

    .form-header-title h4 {
        margin: 0;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: var(--text-main);
        font-size: 1.35rem;
    }

    .form-header-title span {
        display: block;
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .form-header-badge {
        padding: 6px 12px;
        border-radius: 999px;
        background: radial-gradient(circle at 0 0, rgba(59, 130, 246, 0.72), rgba(79, 70, 229, 0.9));
        color: #e5e7eb;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        border: 1px solid rgba(191, 219, 254, 0.8);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 10px 25px rgba(37, 99, 235, 0.6);
    }

    .section-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 11px;
        border-radius: 999px;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        background: rgba(15, 23, 42, 0.9);
        border: 1px solid rgba(148, 163, 184, 0.45);
        color: var(--text-muted);
        box-shadow: var(--shadow-chip);
    }

        .section-chip span.dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: radial-gradient(circle at 30% 0, #a5b4fc 0, #4f46e5 60%);
            box-shadow: 0 0 0 4px rgba(129, 140, 248, 0.35);
        }

    .section-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
        margin-top: 6px;
    }

        .section-title-row h5 {
            margin: 0;
            font-weight: 600;
            font-size: 1rem;
            color: var(--text-main);
            letter-spacing: 0.02em;
        }

    .section-panel.soft {
        border-radius: var(--radius-lg);
        border: 1px solid var(--glass-border);
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.94));
        padding: 16px 16px 4px;
        margin-bottom: 18px;
    }

    /* ALL FIELD HEADERS WHITE */
    .form-label {
        color: var(--text-main) !important;
        font-weight: 600 !important;
        font-size: 0.88rem !important;
        margin-bottom: 6px !important;
        letter-spacing: 0.01em;
    }

    .form-control,
    .form-select {
        border-radius: 999px;
        border: 1px solid var(--input-border);
        background: var(--input-bg);
        color: var(--text-main);
        font-size: 0.86rem;
        padding: 6px 12px;
        transition: all 0.18s ease-out;
        box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.9);
        width: 100%;
    }

        .form-control::placeholder {
            color: rgba(148, 163, 184, 0.75);
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--input-border-focus);
            outline: none;
            box-shadow: 0 0 0 1px rgba(129, 140, 248, 0.6), 0 0 0 6px rgba(79, 70, 229, 0.25);
            background: rgba(15, 23, 42, 0.98);
        }



        .form-control[type="file"] {
            padding: 8px 12px;
            cursor: pointer;
            background: radial-gradient(circle at 0 0, rgba(129, 140, 248, 0.2), rgba(15, 23, 42, 0.96));
        }

            .form-control[type="file"]::-webkit-file-upload-button {
                border: none;
                border-radius: 999px;
                padding: 6px 14px;
                margin-right: 10px;
                background: linear-gradient(135deg, #4f46e5, #6366f1);
                color: #e5e7eb;
                font-size: 0.78rem;
                text-transform: uppercase;
                letter-spacing: 0.09em;
                font-weight: 600;
                cursor: pointer;
            }

    .text-danger {
        font-size: 0.75rem;
        margin-top: 3px;
        color: var(--danger) !important;
    }

    .btn-primary.modern {
        border-radius: 999px;
        border: 0;
        padding: 10px 30px;
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: conic-gradient(from 160deg, #6366f1, #ec4899, #8b5cf6, #6366f1);
        color: #f9fafb;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 16px 40px rgba(79, 70, 229, 0.7);
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .btn-primary.modern span.pulse {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 0 0, rgba(248, 250, 252, 0.24), transparent 60%);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease-out;
        }

        .btn-primary.modern:hover span.pulse {
            opacity: 1;
        }

        .btn-primary.modern:hover {
            transform: translateY(-1px);
        }

    .form-footer-note {
        margin-top: 10px;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-align: center;
    }

    /* Document section */
    .document-section {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.94));
        border: 1px solid rgba(148, 163, 184, 0.28);
        border-radius: var(--radius-lg);
        padding: 16px 16px 14px;
        margin-bottom: 18px;
    }

    .document-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
    }

    .document-icon {
        width: 32px;
        height: 32px;
        border-radius: 999px;
        background: radial-gradient(circle at 30% 0, #f97373 0, #b91c1c 70%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-size: 0.9rem;
    }

    .document-title {
        margin: 0;
        color: var(--text-main);
        font-weight: 600;
        font-size: 0.9rem;
    }

    .document-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(248, 250, 252, 0.06), rgba(15, 23, 42, 0.98));
        border: 1px solid rgba(148, 163, 184, 0.55);
        color: var(--text-main);
        font-size: 0.8rem;
        text-decoration: none;
    }

        .document-link i {
            font-size: 0.85rem;
        }

    @@media (max-width: 768px) {
        .institution-form-card-inner {
            padding: 18px 16px 24px;
        }

        .form-header-modern {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="institution-form-shell">
    <div class="container">
        <div class="institution-form-card">
            <div class="institution-form-card-inner">
                <div class="form-header-modern">
                    <div class="form-header-title">
                        <div class="form-header-icon">
                            <i class="fas fa-building"></i>
                        </div>
                        <div>
                            <h4>Affiliation Hostel Details</h4>
                            <span>Provide hostel infrastructure and capacity details</span>
                        </div>
                    </div>
                    <div class="form-header-badge">
                        <span>HOSTEL MODULE</span>
                    </div>
                </div>

                <div class="section-panel soft">
                    <div class="section-title-row">
                        <div>
                            <div class="section-chip">
                                <span class="dot"></span>
                                <span>Institution & Hostel</span>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Aff_HostelDetails" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- College & Faculty (readonly, from session) -->
                       

                        <!-- Hostel Type -->
                        <div class="mb-3">
                            <label asp-for="Hostel.HostelType" class="form-label">Hostel Type</label>
                            <select asp-for="Hostel.HostelType"
                                    asp-items="Model.HostelTypes"
                                    class="form-select">
                                <option value="">Select hostel type</option>
                            </select>
                            <span asp-validation-for="Hostel.HostelType" class="text-danger"></span>
                        </div>

                        <!-- Built-up Area -->
                        <div class="mb-3">
                            <label asp-for="Hostel.BuiltUpAreaSqFt" class="form-label">Built-up Area (Sq Ft)</label>
                            <input asp-for="Hostel.BuiltUpAreaSqFt" class="form-control" placeholder="e.g., 5000" />
                            <span asp-validation-for="Hostel.BuiltUpAreaSqFt" class="text-danger"></span>
                        </div>

                        <!-- Has Separate Hostel -->
                        <div class="mb-3">
                            <label class="form-label">Has Separate Hostel</label><br />
                            <div class="form-check form-check-inline">
                                @Html.RadioButtonFor(m => m.Hostel.HasSeparateHostel, true, new { @class = "form-check-input", id = "HasSeparateHostelYes" })
                                <label class="form-check-label" for="HasSeparateHostelYes" style="color: var(--text-main) !important;">Yes</label>
                            </div>
                            <div class="form-check form-check-inline">
                                @Html.RadioButtonFor(m => m.Hostel.HasSeparateHostel, false, new { @class = "form-check-input", id = "HasSeparateHostelNo" })
                                <label class="form-check-label" for="HasSeparateHostelNo" style="color: var(--text-main) !important;">No</label>
                            </div>
                            <span asp-validation-for="Hostel.HasSeparateHostel" class="text-danger"></span>
                        </div>

                        <!-- Separate Provision Male/Female -->
                        <div class="mb-3">
                            <label class="form-label">Separate Provision for Male/Female</label><br />
                            <div class="form-check form-check-inline">
                                @Html.RadioButtonFor(m => m.Hostel.SeparateProvisionMaleFemale, true, new { @class = "form-check-input", id = "SeparateProvisionYes" })
                                <label class="form-check-label" for="SeparateProvisionYes" style="color: var(--text-main) !important;">Yes</label>
                            </div>
                            <div class="form-check form-check-inline">
                                @Html.RadioButtonFor(m => m.Hostel.SeparateProvisionMaleFemale, false, new { @class = "form-check-input", id = "SeparateProvisionNo" })
                                <label class="form-check-label" for="SeparateProvisionNo" style="color: var(--text-main) !important;">No</label>
                            </div>
                            <span asp-validation-for="Hostel.SeparateProvisionMaleFemale" class="text-danger"></span>
                        </div>

                        <!-- Female -->
                        <div class="row mb-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Hostel.TotalFemaleStudents" class="form-label">Total Female Students</label>
                                <input asp-for="Hostel.TotalFemaleStudents" class="form-control" />
                                <span asp-validation-for="Hostel.TotalFemaleStudents" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Hostel.TotalFemaleRooms" class="form-label">Total Female Rooms</label>
                                <input asp-for="Hostel.TotalFemaleRooms" class="form-control" />
                                <span asp-validation-for="Hostel.TotalFemaleRooms" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Male -->
                        <div class="row mb-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Hostel.TotalMaleStudents" class="form-label">Total Male Students</label>
                                <input asp-for="Hostel.TotalMaleStudents" class="form-control" />
                                <span asp-validation-for="Hostel.TotalMaleStudents" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Hostel.TotalMaleRooms" class="form-label">Total Male Rooms</label>
                                <input asp-for="Hostel.TotalMaleRooms" class="form-control" />
                                <span asp-validation-for="Hostel.TotalMaleRooms" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Existing Document Viewer -->
                        @if (Model.Hostel?.PossessionProofPath != null && Model.Hostel.PossessionProofPath.Length > 0)
                        {
                            <div class="document-section mb-3">
                                <div class="document-header">
                                    <div class="document-icon">
                                        <i class="fas fa-file-pdf"></i>
                                    </div>
                                    <p class="document-title">Current Possession Proof (PDF)</p>
                                </div>
                                <a href="@Url.Action("DownloadPossessionProof", new { collegeCode = Model.Hostel.CollegeCode, facultyCode = Model.Hostel.FacultyCode })"
                                   target="_blank"
                                   class="document-link">
                                    <i class="fas fa-eye"></i>
                                    View / Download Current Document
                                </a>
                            </div>
                        }

                        <!-- File Upload -->
                        <div class="mb-3">
                            <label class="form-label">Upload Possession Proof (PDF)</label>
                            <input type="file" name="possessionFile" accept="application/pdf" class="form-control" />
                            <small class="text-muted">If you upload a new file, it will replace the existing document.</small>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <a asp-action="AffCourseDetails"
                               asp-controller="NursingContinuesAffiliation"
                               class="btn btn-outline-secondary px-4">
                                ⬅ Previous
                            </a>
                            <button type="submit" class="btn btn-outline-primary px-4">
                                💾 Save & Proceed ➡
                            </button>
                        </div>

                        <div class="form-footer-note">
                            Fields are saved against the logged-in College and Faculty codes from session.
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
