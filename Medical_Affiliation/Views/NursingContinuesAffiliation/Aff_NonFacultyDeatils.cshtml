@model NonTeachingFacultyViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Non-Teaching Faculty Details";
}
    <style>
        :root {
            --primary: #4f46e5;
            --primary-soft: rgba(79, 70, 229, 0.12);
            --accent: #ec4899;
            --bg-body: #060714;
            --bg-gradient: radial-gradient(circle at top left, #1f2937 0, #020617 55%, #020617 100%);
            --glass-bg: rgba(15, 23, 42, 0.85);
            --glass-border: rgba(148, 163, 184, 0.35);
            --input-bg: rgba(15, 23, 42, 0.9);
            --input-border: rgba(148, 163, 184, 0.45);
            --input-border-focus: rgba(129, 140, 248, 0.9);
            --radius-lg: 20px;
            --radius-md: 14px;
            --shadow-soft: 0 24px 60px rgba(15, 23, 42, 0.85);
            --shadow-chip: 0 10px 25px rgba(15, 23, 42, 0.65);
            --text-main: #e5e7eb;
            --text-muted: #9ca3af;
            --danger: #f97373;
        }

        body {
            background: var(--bg-gradient);
        }

        .institution-form-shell {
            background: var(--bg-gradient);
            min-height: 100vh;
            padding: 32px 0 40px;
        }

        .institution-form-card {
            background: radial-gradient(circle at top left, rgba(148, 163, 184, 0.25), transparent 55%), radial-gradient(circle at bottom right, rgba(59, 130, 246, 0.28), transparent 55%);
            border-radius: 32px;
            padding: 1px;
            box-shadow: var(--shadow-soft);
            position: relative;
            overflow: hidden;
        }

            .institution-form-card::before {
                content: "";
                position: absolute;
                inset: -40%;
                background: radial-gradient(circle at 0% 0%, rgba(244, 114, 182, 0.22), transparent 60%), radial-gradient(circle at 100% 100%, rgba(59, 130, 246, 0.28), transparent 55%);
                opacity: 0.4;
                filter: blur(32px);
                z-index: -2;
            }

        .institution-form-card-inner {
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(15, 23, 42, 0.92));
            border-radius: 30px;
            border: 1px solid rgba(148, 163, 184, 0.28);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            position: relative;
            z-index: 1;
            padding: 28px 26px 30px;
        }

        @@media (min-width: 992px) {
            .institution-form-card-inner {
                padding: 30px 34px 34px;
            }
        }

        .form-header-modern {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 22px;
        }

        .form-header-title {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .form-header-icon {
            width: 42px;
            height: 42px;
            border-radius: 999px;
            background: radial-gradient(circle at 30% 0, #e5e7eb 0, #9ca3af 12%, #111827 55%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #020617;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.85);
            position: relative;
        }

            .form-header-icon::after {
                content: "";
                position: absolute;
                inset: 2px;
                border-radius: inherit;
                border: 1px solid rgba(148, 163, 184, 0.55);
            }

        .form-header-title h4 {
            margin: 0;
            font-weight: 600;
            letter-spacing: 0.02em;
            color: var(--text-main);
            font-size: 1.35rem;
        }

        .form-header-title span {
            display: block;
            font-size: 0.78rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .form-header-badge {
            padding: 6px 12px;
            border-radius: 999px;
            background: radial-gradient(circle at 0 0, rgba(59, 130, 246, 0.72), rgba(79, 70, 229, 0.9));
            color: #e5e7eb;
            font-size: 0.72rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            border: 1px solid rgba(191, 219, 254, 0.8);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            box-shadow: 0 10px 25px rgba(37, 99, 235, 0.6);
        }

            .form-header-badge i {
                font-size: 0.8rem;
            }

        .form-grid {
            margin-top: 8px;
        }

        .section-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 11px;
            border-radius: 999px;
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            background: rgba(15, 23, 42, 0.9);
            border: 1px solid rgba(148, 163, 184, 0.45);
            color: var(--text-muted);
            box-shadow: var(--shadow-chip);
        }

            .section-chip span.dot {
                width: 7px;
                height: 7px;
                border-radius: 50%;
                background: radial-gradient(circle at 30% 0, #a5b4fc 0, #4f46e5 60%);
                box-shadow: 0 0 0 4px rgba(129, 140, 248, 0.35);
            }

        .section-title-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 14px;
            margin-top: 6px;
        }

            .section-title-row h5 {
                margin: 0;
                font-weight: 600;
                font-size: 1rem;
                color: var(--text-main);
                letter-spacing: 0.02em;
            }

            .section-title-row small {
                font-size: 0.75rem;
                color: var(--text-muted);
            }

        .section-panel {
            border-radius: var(--radius-lg);
            border: 1px solid var(--glass-border);
            background: radial-gradient(circle at top left, rgba(79, 70, 229, 0.18), transparent 60%), linear-gradient(145deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.95));
            padding: 16px 16px 4px;
            margin-bottom: 18px;
        }

            .section-panel.alt {
                background: radial-gradient(circle at top right, rgba(236, 72, 153, 0.22), transparent 60%), linear-gradient(145deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.95));
            }

            .section-panel.soft {
                background: linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.94));
            }

        .field-group {
            margin-bottom: 14px;
        }

        .form-label {
            font-weight: 500;
            color: var(--text-main);
            font-size: 0.82rem;
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .form-label i {
                font-size: 0.74rem;
                color: var(--text-muted);
            }

        .form-control,
        textarea.form-control {
            border-radius: 999px;
            border: 1px solid var(--input-border);
            background: var(--input-bg);
            color: var(--text-main);
            font-size: 0.86rem;
            padding: 9px 13px;
            transition: all 0.18s ease-out;
            box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.9);
        }

        textarea.form-control {
            border-radius: 14px;
            min-height: 70px;
            resize: vertical;
        }

        .form-control::placeholder {
            color: rgba(148, 163, 184, 0.75);
        }

        .form-control:focus,
        textarea.form-control:focus {
            border-color: var(--input-border-focus);
            outline: none;
            box-shadow: 0 0 0 1px rgba(129, 140, 248, 0.6), 0 0 0 6px rgba(79, 70, 229, 0.25);
            background: rgba(15, 23, 42, 0.98);
            color: #f9fafb;
        }

        .text-danger {
            font-size: 0.75rem;
            margin-top: 3px;
            color: var(--danger) !important;
        }

        [asp-validation-summary] {
            border-radius: 12px;
            border: 1px solid rgba(248, 113, 113, 0.4);
            background: rgba(153, 27, 27, 0.18);
            padding: 10px 12px;
            font-size: 0.78rem;
            margin-bottom: 12px;
        }

        .btn-primary.modern {
            border-radius: 999px;
            border: 0;
            padding: 10px 30px;
            font-size: 0.88rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            background: conic-gradient(from 160deg, #6366f1, #ec4899, #8b5cf6, #6366f1);
            color: #f9fafb;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 16px 40px rgba(79, 70, 229, 0.7);
            position: relative;
            overflow: hidden;
        }

            .btn-primary.modern span.pulse {
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 0 0, rgba(248, 250, 252, 0.24), transparent 60%);
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.3s ease-out;
            }

            .btn-primary.modern:hover span.pulse {
                opacity: 1;
            }

            .btn-primary.modern:hover {
                transform: translateY(-1px);
            }

            .btn-primary.modern:active {
                transform: translateY(1px) scale(0.99);
                box-shadow: 0 10px 25px rgba(79, 70, 229, 0.6);
            }

        .form-footer-note {
            margin-top: 10px;
            font-size: 0.75rem;
            color: var(--text-muted);
            text-align: center;
        }

        @@media (max-width: 768px) {
            .institution-form-card-inner {
                padding: 18px 16px 24px;
            }

            .form-header-modern {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>

<div class="institution-form-shell">
    <div class="container">
        <div class="institution-form-card">
            <div class="institution-form-card-inner">
                <div class="form-header-modern">
                    <div class="form-header-title">
                        <div class="form-header-icon">
                            <i class="fas fa-user-tie"></i>
                        </div>
                        <div>
                            <h4>Non-Teaching Faculty Details</h4>
                            <span>College and faculty codes are loaded from session.</span>
                        </div>
                    </div>
                    <div class="form-header-badge">
                        <i class="fas fa-database"></i>
                        <span>Admission-Affiliation</span>
                    </div>
                </div>

                <form asp-action="Aff_NonFacultyDeatils" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="CollegeCode" />
                    <input type="hidden" asp-for="FacultyCode" />

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-grid">
                        <div class="section-title-row">
                            <div>
                                <div class="section-chip">
                                    <span class="dot"></span>
                                    FACULTY ROWS
                                </div>
                                <h5 class="mt-2">Add one or more non-teaching faculty</h5>
                            </div>
                        </div>

                        <div id="rowsContainer">
                            @for (int i = 0; i < Model.Rows.Count; i++)
                            {
                                <div class="section-panel alt faculty-row mb-3" data-index="@i">
                                    <input type="hidden" asp-for="Rows[@i].Id" />

                                    <div class="row">
                                        <div class="col-md-4 field-group">
                                            <label class="form-label">Faculty Name</label>
                                            <input asp-for="Rows[@i].FacultyName" class="form-control" placeholder="Enter name" />
                                            <span asp-validation-for="Rows[@i].FacultyName" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-3 field-group">
                                            <label class="form-label">Designation</label>
                                            <select asp-for="Rows[@i].Designation"
                                                    class="form-control"
                                                    asp-items="(IEnumerable<SelectListItem>)ViewBag.Designations">
                                                <option value="">-- Select designation --</option>
                                            </select>
                                            <span asp-validation-for="Rows[@i].Designation" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-3 field-group">
                                            <label class="form-label">Qualification</label>
                                            <select asp-for="Rows[@i].Qualification"
                                                    class="form-control"
                                                    asp-items="(IEnumerable<SelectListItem>)ViewBag.Qualifications">
                                                <option value="">-- Select qualification --</option>
                                            </select>
                                            <span asp-validation-for="Rows[@i].Qualification" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-2 d-flex align-items-end justify-content-end">
                                            <button type="button" class="btn btn-sm btn-outline-light btn-remove-row">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="row mt-2">
                                        <div class="col-md-4 field-group">
                                            <label class="form-label">Experience (Years)</label>
                                            <input asp-for="Rows[@i].TotalExperience" type="number" step="0.1" min="0" class="form-control" placeholder="e.g. 3.5" />
                                            <span asp-validation-for="Rows[@i].TotalExperience" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-8 field-group">
                                            <label class="form-label">Remarks</label>
                                            <textarea asp-for="Rows[@i].Remarks" class="form-control" placeholder="Remarks"></textarea>
                                            <span asp-validation-for="Rows[@i].Remarks" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <button type="button" id="btnAddRow" class="btn btn-primary modern">
                                <span class="pulse"></span>
                                <i class="fas fa-plus"></i> Add Row
                            </button>
                        </div>
                    </div>

                    <div class="mt-3 d-flex justify-content-between align-items-center">
                        <button type="submit" class="btn btn-primary modern">
                            <span class="pulse"></span>
                            <i class="fas fa-save"></i> Save All Rows
                        </button>
                        <a asp-action="Index" class="btn btn-sm btn-outline-light">
                            <i class="fas fa-arrow-left"></i> Back to list
                        </a>
                    </div>

                    <div class="form-footer-note">
                        All rows will be saved for the current college and faculty from session.
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
                let rowIndex = @Model.Rows.Count;

                $('#btnAddRow').on('click', function () {
                    const template = `
        <div class="section-panel alt faculty-row mb-3" data-index="${rowIndex}">
            <input type="hidden" name="Rows[${rowIndex}].Id" value="0" />
            <div class="row">
                <div class="col-md-4 field-group">
                    <label class="form-label">Faculty Name</label>
                    <input name="Rows[${rowIndex}].FacultyName" class="form-control" placeholder="Enter name" />
                </div>
                <div class="col-md-3 field-group">
                    <label class="form-label">Designation</label>
                    <select name="Rows[${rowIndex}].Designation" class="form-control">
                        <option value="">-- Select designation --</option>
                        @foreach (SelectListItem d in (IEnumerable<SelectListItem>)ViewBag.Designations)
                        {
                                @:<option value="@d.Value">@d.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 field-group">
                    <label class="form-label">Qualification</label>
                    <select name="Rows[${rowIndex}].Qualification" class="form-control">
                        <option value="">-- Select qualification --</option>
                        @foreach (SelectListItem q in (IEnumerable<SelectListItem>)ViewBag.Qualifications)
                        {
                                @:<option value="@q.Value">@q.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end justify-content-end">
                    <button type="button" class="btn btn-sm btn-outline-light btn-remove-row">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-md-4 field-group">
                    <label class="form-label">Experience (Years)</label>
                    <input name="Rows[${rowIndex}].TotalExperience" type="number" step="0.1" min="0" class="form-control" />
                </div>
                <div class="col-md-8 field-group">
                    <label class="form-label">Remarks</label>
                    <textarea name="Rows[${rowIndex}].Remarks" class="form-control" placeholder="Remarks"></textarea>
                </div>
            </div>
        </div>`;
                    $('#rowsContainer').append(template);
                    rowIndex++;
                });

                $(document).on('click', '.btn-remove-row', function () {
                    $(this).closest('.faculty-row').remove();
                });
    </script>
}
