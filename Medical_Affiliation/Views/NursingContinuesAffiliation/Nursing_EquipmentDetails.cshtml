@model List<EquipmentVM>


@{
    ViewData["Title"] = "Equipment / Instrument Details";
}

<div class="master-container">
    <div class="header-section">
        <h2 class="page-title">EQUIPMENT / INSTRUMENT DETAILS</h2>
        <button type="button" id="btnAdd" class="btn-add" title="Add new equipment">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Add Equipment
        </button>
    </div>

    <div class="table-container">
        <div class="table-wrapper">
            <table class="modern-table" id="equipTable">
                <thead >
                    <tr style="text-align:center">
                        <th>#</th>
                        <th>Equipment Name</th>
                        <th>Make</th>
                        <th>Model</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        int serial = 1;
                        foreach (var item in Model)
                        {
                            <tr data-id="@item.ID">
                                <td class="serial-cell">@serial</td>

                                <td>
                                    <input type="text" class="eq-name" value="@item.EquipmentName" style="font-weight:bold;" disabled />
                                </td>

                                <td>
                                    <input type="text" class="eq-make" value="@item.Make" style="font-weight:bold;" disabled />
                                </td>

                                <td>
                                    <input type="text" class="eq-model" value="@item.Model" style="font-weight:bold;" disabled />
                                </td>

                                <td class="action-cell">
                                    <button type="button"
                                            class="btn-action btn-delete"
                                            >
                                        Delete
                                    </button>
                                </td>
                            </tr>

                            serial++;
                        }
                    }
                </tbody>

            </table>
        </div>
        <div class="table-empty" id="emptyState">
            <div class="empty-icon">⚙️</div>
            <h3>No Equipment Added</h3>
            <p>Click "Add Equipment" to get started</p>
        </div>
    </div>

    <div class="nav-buttons">
        <button type="button" class="btn-nav btn-prev" onclick="window.location.href='@Url.Action("ClassroomAndLaboratoryDetails", "NursingContinuesAffiliation")'" >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
            Previous
        </button>

        
        <button type="button" class="btn-nav btn-next" onclick="window.location.href='@Url.Action("SaveAcademicMatters", "Aff_AcademicMatters")'">
            Next
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
        </button>
    </div>
</div>

<style>
    * {
        box-sizing: border-box;
    }

    .master-container {
        max-width: 1400px;
        margin: 40px auto;
        padding: 50px;
        background: linear-gradient(145deg, #667eea 0%, #764ba2 100%);
        border-radius: 32px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(255, 255, 255, 0.05);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        position: relative;
        overflow: hidden;
    }

        .master-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #ff6b6b, #4ecdc4, #45b7d1, #96ceb4, #feca57);
            background-size: 300% 300%;
            animation: gradientShift 3s ease infinite;
        }

    @@keyframes gradientShift {
        0%, 100% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .page-title {
        margin: 0;
        font-size: 2.8rem;
        font-weight: 900;
        background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -0.02em;
        line-height: 1.2;
    }

    .btn-add {
        display: flex;
        align-items: center;
        gap: 10px;
        background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
        color: #1e293b;
        border: 2px solid #e2e8f0;
        padding: 16px 32px;
        border-radius: 20px;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1), 0 4px 12px rgba(0, 0, 0, 0.05);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        backdrop-filter: blur(10px);
        position: relative;
        overflow: hidden;
    }

        .btn-add::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            transition: left 0.5s;
        }

        .btn-add:hover {
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15), 0 8px 20px rgba(0, 0, 0, 0.1);
            border-color: #3b82f6;
        }

            .btn-add:hover::before {
                left: 100%;
            }

        .btn-add:active {
            transform: translateY(-2px) scale(1.01);
        }

    .table-container {
        position: relative;
        min-height: 400px;
    }

    .table-wrapper {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(255, 255, 255, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.2);
        max-height: 600px;
        overflow-y: auto;
    }

    .modern-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
    }

        .modern-table thead {
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .modern-table th {
            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);
            color: white;
            padding: 20px 24px;
            text-align: left;
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            white-space: nowrap;
        }

            .modern-table th:first-child {
                border-top-left-radius: 20px;
            }

            .modern-table th:last-child {
                border-top-right-radius: 20px;
            }

        .modern-table td {
            padding: 20px 24px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }

        .modern-table tbody tr {
            background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

            .modern-table tbody tr:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
                background: linear-gradient(145deg, #ffffff 0%, #f1f5f9 100%);
            }

        .modern-table input {
            width: 100%;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 12px 16px;
            font-size: 1rem;
            background: white;
            color: #1e293b;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .modern-table input:focus {
                outline: none;
                border-color: #3b82f6;
                box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
                transform: translateY(-1px);
            }

            .modern-table input:disabled {
                background: linear-gradient(145deg, #f1f5f9, #e2e8f0);
                color: #64748b;
                border-color: #cbd5e1;
            }

    .serial-cell {
        text-align: center;
        font-weight: 800;
        color: #1e40af;
        font-size: 1.1rem;
        font-family: 'SF Mono', monospace;
        background: linear-gradient(135deg, #dbeafe, #bfdbfe);
    }

    .action-cell {
        white-space: nowrap;
        text-align: center;
    }

    .btn-action {
        padding: 10px 20px;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.85rem;
        cursor: pointer;
        margin: 0 6px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        position: relative;
        overflow: hidden;
    }

    .btn-save {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.3);
    }

    .btn-delete {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: white;
        box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
    }

    .btn-action:hover {
        transform: translateY(-2px) scale(1.05);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    }

    .btn-action.saved {
        background: linear-gradient(135deg, #059669, #047857);
        padding: 10px 16px;
    }

        .btn-action.saved::after {
            content: '✓';
            margin-left: 6px;
        }

    .table-empty {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        color: rgba(255, 255, 255, 0.8);
        pointer-events: none;
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 20px;
        filter: drop-shadow(0 4px 8px rgba(0,0,0,0.1));
    }

    .table-empty h3 {
        font-size: 1.5rem;
        margin: 0 0 8px 0;
        font-weight: 700;
    }

    .nav-buttons {
        display: flex;
        justify-content: space-between;
        margin-top: 60px;
        gap: 20px;
    }

    .btn-nav {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 18px 40px;
        border-radius: 20px;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: none;
        position: relative;
        overflow: hidden;
        min-width: 160px;
        justify-content: center;
    }

    .btn-prev {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        backdrop-filter: blur(10px);
        border: 2px solid rgba(255, 255, 255, 0.3);
    }

    .btn-next {
        background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
        color: #1e40af;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .btn-nav:hover:not(:disabled) {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    }

    .btn-nav:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none !important;
    }

    @@media (max-width: 768px) {
        .master-container {
            margin: 20px;
            padding: 30px 20px;
            border-radius: 24px;
        }

        .header-section {
            flex-direction: column;
            text-align: center;
        }

        .page-title {
            font-size: 2.2rem;
        }

        .nav-buttons {
            flex-direction: column;
        }

        .modern-table {
            font-size: 0.85rem;
        }

            .modern-table th,
            .modern-table td {
                padding: 16px 12px;
            }
    }
</style>

<script>
    let equipmentCount = 1;
    const tableBody = document.querySelector('#equipTable tbody');
    const tableContainer = document.querySelector('.table-container');
    const emptyState = document.getElementById('emptyState');
    const tableWrapper = document.querySelector('.table-wrapper');

    // Show empty state initially
    updateEmptyState();

    document.getElementById('btnAdd').addEventListener('click', addEquipmentRow);

    function addEquipmentRow() {
        const row = document.createElement('tr');
               row.innerHTML = `
                                    <td class="serial-cell">${equipmentCount}</td>

                                    <td><input type="text" class="eq-name" placeholder="Enter equipment name"></td>
                                    <td><input type="text" class="eq-make" placeholder="Enter make"></td>
                                    <td><input type="text" class="eq-model" placeholder="Enter model"></td>

                                    <td class="action-cell">
                                        <button type="button" class="btn-action btn-save">Save</button>
                                        <button type="button" class="btn-action btn-delete">Delete</button>
                                    </td>
                                `;


        tableBody.appendChild(row);
        equipmentCount++;
        updateEmptyState();
        row.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function updateEmptyState() {
        if (tableBody.children.length === 0) {
            emptyState.style.display = 'block';
            tableWrapper.style.display = 'none';
        } else {
            emptyState.style.display = 'none';
            tableWrapper.style.display = 'block';
        }
    }

        document.addEventListener('click', async (e) => {
        const saveBtn = e.target.closest('.btn-save');

           if (saveBtn) {
        const row = saveBtn.closest('tr');

        const name = row.querySelector('.eq-name').value.trim();
        const make = row.querySelector('.eq-make').value.trim();
        const model = row.querySelector('.eq-model').value.trim();

        if (!name) {
            showToast("Equipment name is required", "error");
            return;
        }

        // Prevent double click
        saveBtn.disabled = true;

        try {
            // AJAX POST
            const response = await fetch('/NursingContinuesAffiliation/SaveEquipment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `EquipmentName=${encodeURIComponent(name)}&Make=${encodeURIComponent(make)}&Model=${encodeURIComponent(model)}`
            });

            const result = await response.json();

            if (result.success) {

                // Disable inputs after save
                row.querySelectorAll('input').forEach(i => i.disabled = true);

                // Update Save button
                saveBtn.textContent = "Saved";
                saveBtn.classList.add("saved");
                saveBtn.disabled = true;

                // Attach database ID to row
                row.dataset.id = result.id;

                showToast("Equipment saved successfully", "success");

            } else {
                showToast("Failed to save. Try again.", "error");
                saveBtn.disabled = false;
            }

        } catch (err) {
            console.error(err);
            showToast("Error occurred while saving", "error");
            saveBtn.disabled = false;
        }
    }

             const deleteBtn = e.target.closest('.btn-delete');
                if (deleteBtn) {
                    const row = deleteBtn.closest('tr');
                   const id = row.dataset.id || deleteBtn.dataset.id;

                    if (!id) {
                        row.remove();
                        updateEmptyState();
                        return;
                    }

                  if (confirm("Are you sure you want to delete this equipment?")) {

                        const response = await fetch('/NursingContinuesAffiliation/DeleteEquipment', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `id=${id}`
                        });

                        const result = await response.json();

                        if (result.success) {
                            row.remove();
                            updateEmptyState();
                            showToast("Deleted successfully", "success");
                        }
                    }
                }


       });



    // Toast notification
    function showToast(message, type = 'info') {
        const toast = document.createElement('div');
        toast.className = `toast toast-${type}`;
        toast.textContent = message;
        document.body.appendChild(toast);

        setTimeout(() => {
            toast.style.opacity = '1';
            toast.style.transform = 'translateY(0)';
        }, 100);

        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // Add toast styles
    const toastStyle = document.createElement('style');
    toastStyle.textContent = `
        .toast {
            position: fixed;
            top: 100px;
            right: 20px;
            padding: 16px 24px;
            border-radius: 12px;
            font-weight: 600;
            color: white;
            opacity: 0;
            transform: translateY(-20px);
            z-index: 10000;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
        }
        .toast-success { background: linear-gradient(135deg, #10b981, #059669); }
        .toast-error { background: linear-gradient(135deg, #ef4444, #dc2626); }
        .toast-info { background: linear-gradient(135deg, #3b82f6, #2563eb); }
        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-4px); }
            75% { transform: translateX(4px); }
        }
    `;
    document.head.appendChild(toastStyle);

    // Navigation buttons
    document.querySelector('.btn-prev').addEventListener('click', () => {
        showToast('Previous section functionality to be implemented', 'info');
    });

    document.querySelector('.btn-next').addEventListener('click', () => {
        showToast('Next section functionality to be implemented', 'info');
    });
</script>
