@model DeclarationViewModel
@{
    ViewData["Title"] = "Declaration";
}

<div class="decl-wrapper">
    <div class="decl-container">

        @if (Model.IsPenaltyEnabled)
        {
            <div class="decl-alert decl-alert-warning">
                Application is enabled with penalty fees. Please pay the penalty fee and then submit the application.
            </div>
        }

        <div class="decl-alert decl-alert-danger">
            Editing or modification in application is not allowed after declaration.
        </div>

        <div class="decl-card">
            <div class="decl-card-header">
                <span>Declaration</span>
            </div>

            <div class="decl-card-body">
                <p class="decl-status">
                    Application submitted successfully on
                    <span class="decl-date">
                        @Model.SubmittedOn.ToString("dd-MM-yyyy")
                    </span>.
                    Your details have been forwarded to
                    <span class="decl-univ">@Model.UniversityName</span>
                    for verification.
                </p>

                <a asp-controller="Application"
                   asp-action="Download"
                   class="btn-decl-primary">
                    <span class="btn-icon">⬇</span>
                    Download Application
                </a>
            </div>
        </div>

        <div class="decl-nav">
            <a asp-action="Nursing_EquipmentDetails"
               asp-controller="NursingContinuesAffiliation"
               class="btn-decl-ghost">
                ← Previous
            </a>
        </div>
    </div>
</div>


    <style>
        :root {
            --decl-primary: #2563eb;
            --decl-primary-soft: #dbeafe;
            --decl-danger: #ef4444;
            --decl-warning: #f97316;
            --decl-bg: #0f172a;
            --decl-text-main: #0f172a;
            --decl-text-muted: #6b7280;
            --decl-radius-lg: 24px;
        }

        .decl-wrapper {
            min-height: calc(100vh - 80px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 16px;
            background: radial-gradient(circle at top left, #1d4ed8 0, transparent 55%), radial-gradient(circle at bottom right, #4f46e5 0, transparent 55%), linear-gradient(135deg, #0b1120, #020617);
        }

        .decl-container {
            width: 100%;
            max-width: 900px;
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(22px);
            border-radius: 32px;
            padding: 32px 28px 28px;
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.65), 0 0 0 1px rgba(148, 163, 184, 0.18);
            color: #e5e7eb;
            position: relative;
            overflow: hidden;
        }

            .decl-container::before {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at top right, rgba(59,130,246,0.18), transparent 55%);
                pointer-events: none;
            }

        .decl-alert {
            position: relative;
            padding: 12px 16px;
            border-radius: 999px;
            font-size: 0.9rem;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
            border: 1px solid transparent;
        }

            .decl-alert::before {
                content: "●";
                font-size: 0.8rem;
            }

        .decl-alert-warning {
            background: rgba(248, 250, 252, 0.03);
            border-color: rgba(234, 179, 8, 0.4);
            color: #facc15;
        }

        .decl-alert-danger {
            background: rgba(248, 250, 252, 0.04);
            border-color: rgba(239, 68, 68, 0.5);
            color: #fecaca;
        }

        .decl-card {
            position: relative;
            margin-top: 18px;
            border-radius: var(--decl-radius-lg);
            background: radial-gradient(circle at top left, rgba(59,130,246,0.35), transparent 55%), rgba(15,23,42,0.96);
            box-shadow: 0 18px 50px rgba(15, 23, 42, 0.9), 0 0 0 1px rgba(148,163,184,0.18);
            overflow: hidden;
        }

        .decl-card-header {
            padding: 16px 26px;
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            color: #f9fafb;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            text-align: center;
        }

        .decl-card-body {
            padding: 26px 26px 24px;
            text-align: center;
        }

        .decl-status {
            margin-bottom: 20px;
            font-size: 1.02rem;
            color: var(--decl-text-muted);
        }

        .decl-date {
            color: #22c55e;
            font-weight: 600;
        }

        .decl-univ {
            color: #bfdbfe;
            font-weight: 600;
        }

        .btn-decl-primary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 26px;
            border-radius: 999px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            color: #0f172a;
            background: linear-gradient(135deg, #f97316, #facc15);
            box-shadow: 0 16px 35px rgba(248, 181, 0, 0.45), 0 0 0 1px rgba(248, 250, 252, 0.3);
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }

            .btn-decl-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 20px 40px rgba(248, 181, 0, 0.55);
            }

        .btn-icon {
            font-size: 1.1rem;
        }

        .decl-nav {
            margin-top: 22px;
            display: flex;
            justify-content: flex-start;
        }

        .btn-decl-ghost {
            border-radius: 999px;
            padding: 8px 20px;
            font-size: 0.9rem;
            font-weight: 500;
            color: #e5e7eb;
            border: 1px solid rgba(148,163,184,0.6);
            background: transparent;
            text-decoration: none;
            transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
        }

            .btn-decl-ghost:hover {
                background: rgba(148,163,184,0.12);
                transform: translateY(-1px);
                box-shadow: 0 10px 25px rgba(15, 23, 42, 0.8);
                border-color: rgba(248,250,252,0.7);
            }

        @@media (max-width: 768px) {
            .decl-container {
                padding: 24px 18px 20px;
                border-radius: 24px;
            }

            .decl-status {
                font-size: 0.95rem;
            }
        }
    </style>

