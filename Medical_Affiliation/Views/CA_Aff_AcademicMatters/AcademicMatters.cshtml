@model Medical_Affiliation.Models.CA_Aff_AcademicMattersViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Medical_Affiliation.Models
@using System.Collections.Generic
@using System.Linq

@{
    ViewData["Title"] = "Academic Matters";
    Layout = "~/Views/Shared/_CaLayout.cshtml";

    var academicRows = Model.AcademicRows ?? new List<AcademicPerformanceViewModel>();
    var yearList = ViewBag.YearList as List<CaMstYearOfStudy> ?? new List<CaMstYearOfStudy>();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Academic Matters</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --ink: #0f1923;
            --ink-mid: #2e3d4f;
            --ink-muted: #6b7a8d;
            --border: #d4dae3;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --accent: #1a4c8b;
            --accent-lt: #e8edf7;
            --gold: #c9a84c;
            --radius: 10px;
            --shadow: 0 2px 16px rgba(15,25,35,.07);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--ink);
            min-height: 100vh;
        }

        .page-header {
            background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
            padding: 28px 40px 24px;
            display: flex;
            align-items: center;
            gap: 18px;
            border-bottom: 3px solid var(--gold);
        }

        .page-header .emblem {
            width: 54px; height: 54px;
            border: 2px solid var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .page-header .emblem svg { width: 28px; height: 28px; fill: var(--gold); }

        .page-header-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem;
            color: #ffffff;
            letter-spacing: .02em;
        }

        .page-header-text p {
            font-size: .78rem;
            color: rgba(255,255,255,.55);
            margin-top: 3px;
            letter-spacing: .06em;
            text-transform: uppercase;
        }

        .form-wrap {
            max-width: 1280px;
            margin: 2px auto;
            padding: 0 24px 60px;
        }

        .section-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            margin-bottom: 28px;
            animation: fadeUp .35s ease both;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .section-header {
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--border);
            background: #fafbfc;
        }

        .section-header .icon-wrap {
            width: 38px; height: 38px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .section-header h2 {
            font-size: 1.02rem;
            font-weight: 600;
            letter-spacing: .03em;
            color: var(--ink);
        }

        .section-body { padding: 1.5rem; }

        .custom-table {
            width: 100%;
            border-collapse: collapse;
        }

        .custom-table th, .custom-table td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .custom-table th {
            background: #f8f9fc;
            color: var(--ink-mid);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.76rem;
            letter-spacing: 0.05em;
        }

        .custom-table tr:hover { background: #f8fbff; }

        input.form-control {
            font-size: 0.875rem;
            background: #fafbfc;
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 9px 13px;
        }

        input.form-control:focus {
            border-color: var(--accent);
            background: #fff;
            box-shadow: 0 0 0 3px rgba(26,76,139,.1);
        }

        .pass-percentage {
            font-weight: 700;
            font-size: 0.95rem;
        }

        .btn {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            border-radius: 8px;
            padding: 10px 26px;
            letter-spacing: .03em;
            transition: all .18s;
        }

        .btn-primary {
            background: linear-gradient(135deg, #1a4c8b, #1564c0);
            color: #fff;
            box-shadow: 0 3px 14px rgba(26,76,139,.3);
        }

        .btn-primary:hover {
            box-shadow: 0 5px 20px rgba(26,76,139,.4);
            transform: translateY(-1px);
        }

        .btn-secondary {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--ink-muted);
        }

        .btn-secondary:hover {
            border-color: var(--ink-mid);
            color: var(--ink);
        }

        .custom-upload-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--accent);
            color: white;
            padding: 10px 18px;
            border-radius: 8px;
            font-size: 0.83rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .custom-upload-btn:hover { background: #1564c0; transform: translateY(-1px); }

        input[type="file"] { display: none !important; }
    </style>

    <link rel="stylesheet" href="~/css/common-form.css" />

</head>
<body>

    <div class="page-header">
        <div class="emblem">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
        </div>
        <div class="page-header-text">
            <h1>UG Academic Details</h1>
            @* <p>Postgraduate Courses — Academic Performance & Records</p> *@
        </div>
    </div>

    <div class="form-wrap">
        <form asp-action="AcademicMatters" asp-controller="CA_Aff_AcademicMatters" method="post" enctype="multipart/form-data" id="academicForm">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="CourseLevel" />
            <input type="hidden" asp-for="CollegeCode" />
            <input type="hidden" asp-for="FacultyId" />
            <input type="hidden" asp-for="AffiliationType" />

            <!-- 1. Academic Performance -->
            <div class="section-card">
                <div class="section-header">
                    <div class="icon-wrap" style="background:#e8edf7;">
                        <i class="bi bi-graph-up" style="font-size:1.5rem; color:#1a4c8b;"></i>
                    </div>
                    <h2>1. Academic Performance (Previous Year University Examination)</h2>
                </div>
                <div class="section-body">
                    <table class="custom-table" id="academicTable">
                        <thead>
                            <tr>
                                <th rowspan="2" class="text-center">Year</th>
                                <th colspan="2" class="text-center">Students Appeared</th>
                                <th colspan="4" class="text-center">Students Passed</th>
                                <th rowspan="2" class="text-center">Remarks</th>
                            </tr>
                            <tr>
                                <th class="text-center">Regular</th>
                                <th class="text-center">Repeater</th>
                                <th class="text-center">Passed</th>
                                <th class="text-center">Pass %</th>
                                <th class="text-center">First Class</th>
                                <th class="text-center">Distinction</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < academicRows.Count; i++)
                            {
                                var row = academicRows[i];
                                var yearName = yearList.FirstOrDefault(y => y.YearOfStudyId == row.YearOfStudyId)?.YearName ?? "N/A";

                                <tr data-row-index="@i">
                                    <td class="fw-semibold text-center">
                                        @yearName
                                        <input type="hidden" asp-for="AcademicRows[@i].YearOfStudyId" />
                                        <input type="hidden" asp-for="AcademicRows[@i].AcademicPerformanceId" />
                                    </td>
                                    <td><input type="number" min="0" class="form-control regular" asp-for="AcademicRows[@i].RegularStudents" id="regular_@i" /></td>
                                    <td><input type="number" min="0" class="form-control repeater" asp-for="AcademicRows[@i].RepeaterStudents" id="repeater_@i" /></td>
                                    <td><input type="number" min="0" class="form-control passed" asp-for="AcademicRows[@i].NumberOfStudentsPassed" id="passed_@i" /></td>
                                    <td class="text-center pass-percentage" id="pct_@i">0.00 %</td>
                                    <td><input type="number" min="0" class="form-control" asp-for="AcademicRows[@i].FirstClassCount" /></td>
                                    <td><input type="number" min="0" class="form-control" asp-for="AcademicRows[@i].DistinctionCount" /></td>
                                    <td><input type="text" class="form-control" asp-for="AcademicRows[@i].Remarks" /></td>

                                    <!-- Hidden field for Pass Percentage -->
                                    <input type="hidden" asp-for="AcademicRows[@i].PassPercentage" id="hiddenPct_@i" />
                                </tr>
                            }
                        </tbody>
                    </table>
                    <small class="text-muted d-block mt-3">Note: Pass % is calculated automatically. Passed students cannot exceed total appeared.</small>
                </div>
            </div>

            <!-- 2. Course Curriculum -->
            <div class="section-card">
                <div class="section-header">
                    <div class="icon-wrap" style="background:#e8edf7;">
                        <i class="bi bi-book" style="font-size:1.5rem; color:#1a4c8b;"></i>
                    </div>
                    <h2>2. Course Curriculum</h2>
                </div>
                <div class="section-body">
                    <table class="custom-table">
                        <tbody>
                            @for (int i = 0; i < Model.CourseCurriculums.Count; i++)
                            {
                                var item = Model.CourseCurriculums[i];
                                string fileInputId = $"curriculumFile_{i}";

                                <tr>
                                    <td class="fw-semibold">@item.CurriculumName</td>
                                    <td>
                                        <input type="hidden" asp-for="CourseCurriculums[@i].CurriculumName" />
                                        <input type="hidden" asp-for="CourseCurriculums[@i].CurriculumId" />

                                        <input type="file" class="curriculum-file"  id="@fileInputId" name="CourseCurriculums[@i].CurriculumPdfFiles" accept=".pdf" />

                                        <label for="@fileInputId" class="custom-upload-btn">
                                            <i class="bi bi-upload"></i> Upload PDF
                                        </label>
                                        <span class="file-name ms-2 text-muted" id="fileName_@i">No file chosen</span>

                                        @if (item.HasPdf == true)
                                        {
                                            <a asp-action="ViewCurriculumPdf" asp-route-curriculumId="@item.CurriculumId" target="_blank" class="btn btn-secondary ms-3">
                                                <i class="bi bi-eye"></i> View PDF
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- 3. Student Records (as Table) -->
            <div class="section-card">
                <div class="section-header">
                    <div class="icon-wrap" style="background:#e8edf7;">
                        <i class="bi bi-person-lines-fill" style="font-size:1.5rem; color:#1a4c8b;"></i>
                    </div>
                    <h2>3. Student Records</h2>
                </div>
                <div class="section-body">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th style="text-align:left; width:65%;">Register / Record Name</th>
                                <th class="text-center">Is Maintained?</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.StudentRegisterRecords.Count; i++)
                            {
                                var record = Model.StudentRegisterRecords[i];
                                <tr>
                                    <td style="text-align:left;" class="fw-semibold">
                                        @record.RegisterName
                                        <input type="hidden" asp-for="StudentRegisterRecords[@i].RegisterName" />
                                        <input type="hidden" asp-for="StudentRegisterRecords[@i].RegisterRecordId" />
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-4">
                                            <label class="check-label">
                                                <input class="form-check-input" type="radio" asp-for="StudentRegisterRecords[@i].IsMaintained" value="true" /> Yes
                                            </label>
                                            <label class="check-label">
                                                <input class="form-check-input" type="radio" asp-for="StudentRegisterRecords[@i].IsMaintained" value="false" /> No
                                            </label>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="d-flex justify-content-between align-items-center mt-4">

                <!-- 🔹 PREVIOUS -->
                <a asp-controller="AffiliationSS"
                   asp-action="AssociatedInstitutions"
                   class="btn btn-secondary">← Previous</a>

                <!-- 🔹 SAVE -->
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-cloud-arrow-up me-2"></i>Save Academic Matters
                </button>

                <!-- 🔹 NEXT -->
                <a asp-controller="Aff_CA_Med_FinanceDetails"
                   asp-action="Med_CA_AccountAndFeeDetails"
                   class="btn btn-primary">Next →</a>

            </div>
        </form>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
            $(document).ready(function () {
                var form = $("#academicForm");

                // Helper function
                function safeInt(val) {
                    var num = parseInt(val);
                    return isNaN(num) ? 0 : num;
                }

                // Custom Validator: Passed <= Regular + Repeater
                $.validator.addMethod("passedlesstotal", function (value, element) {
                    var idx = $(element).closest('tr').data('row-index');
                    if (idx === undefined) return true;

                    var regular = safeInt($('#regular_' + idx).val());
                    var repeater = safeInt($('#repeater_' + idx).val());
                    var passed = safeInt(value);

                    return passed <= (regular + repeater);
                }, "Passed students cannot exceed Regular + Repeater students.");

                $.validator.unobtrusive.adapters.add("passedlesstotal", [], function (options) {
                    options.rules["passedlesstotal"] = true;
                    options.messages["passedlesstotal"] = options.message;
                });

                // Recalculate Pass Percentage + Color
                function recalcRow(i) {
                    var regular = safeInt($('#regular_' + i).val());
                    var repeater = safeInt($('#repeater_' + i).val());
                    var passed = safeInt($('#passed_' + i).val());
                    var total = regular + repeater;
                    var pct = total > 0 ? (passed / total) * 100 : 0;

                    $('#pct_' + i).text(pct.toFixed(2) + ' %');
                    $('#hiddenPct_' + i).val(pct.toFixed(2));

                    if (total > 0) {
                        if (pct < 50) $('#pct_' + i).css('color', 'crimson');
                        else if (pct < 75) $('#pct_' + i).css('color', 'orange');
                        else $('#pct_' + i).css('color', 'green');
                    } else {
                        $('#pct_' + i).css('color', '');
                    }
                }

                // Auto-correct Passed value + Recalculate
                $(document).on('input', '[id^=regular_], [id^=repeater_], [id^=passed_]', function () {
                    var i = this.id.split('_')[1];
                    var regular = safeInt($('#regular_' + i).val());
                    var repeater = safeInt($('#repeater_' + i).val());
                    var passed = safeInt($('#passed_' + i).val());

                    if (passed > (regular + repeater)) {
                        $('#passed_' + i).val(regular + repeater);
                    }

                    recalcRow(i);
                });

                // Initial Calculation
                for (var i = 0; i < @academicRows.Count; i++) {
                    recalcRow(i);
                }

                // Form Submit Guard
                form.on('submit', function (e) {
                    if (!form.valid()) {
                        e.preventDefault();
                        $('html, body').animate({
                            scrollTop: $('.field-validation-error:first').offset().top - 100
                        }, 500);
                    }
                });

                // Reparse validation after adding custom rules
                form.removeData('validator').removeData('unobtrusiveValidation');
                $.validator.unobtrusive.parse(form);
            });
        </script>

        <script>

            document.addEventListener("change", function (e) {

                if (e.target.classList.contains("curriculum-file")) {

                    const file = e.target.files[0];
                    const maxSize = 2 * 1024 * 1024; // ✅ 2MB

                    if (file) {

                        // ❌ SIZE CHECK
                        if (file.size > maxSize) {
                            Swal.fire({
                                icon: "error",
                                title: "File too large",
                                text: "Maximum allowed size is 2MB"
                            });

                            e.target.value = "";
                            return;
                        }

                        // ❌ TYPE CHECK
                        const ext = file.name.split('.').pop().toLowerCase();
                        if (ext !== "pdf") {
                            Swal.fire({
                                icon: "error",
                                title: "Invalid file",
                                text: "Only PDF files are allowed"
                            });

                            e.target.value = "";
                            return;
                        }
                    }
                }

                if (e.target.classList.contains("curriculum-file")) {

                    const file = e.target.files[0];
                    const inputId = e.target.id;
                    const index = inputId.split('_')[1];

                    const fileNameSpan = document.getElementById("fileName_" + index);

                    if (file) {
                        fileNameSpan.textContent = file.name;
                    } else {
                        fileNameSpan.textContent = "No file chosen";
                    }

                    // ✅ existing validation (keep your code)
                    const maxSize = 2 * 1024 * 1024;

                    if (file) {

                        if (file.size > maxSize) {
                            Swal.fire({
                                icon: "error",
                                title: "File too large",
                                text: "Maximum allowed size is 2MB"
                            });

                            e.target.value = "";
                            fileNameSpan.textContent = "No file chosen";
                            return;
                        }

                        const ext = file.name.split('.').pop().toLowerCase();
                        if (ext !== "pdf") {
                            Swal.fire({
                                icon: "error",
                                title: "Invalid file",
                                text: "Only PDF files are allowed"
                            });

                            e.target.value = "";
                            fileNameSpan.textContent = "No file chosen";
                            return;
                        }
                    }
                }
            });
        </script>
    }
</body>
</html>