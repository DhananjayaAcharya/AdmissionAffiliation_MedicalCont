@model LICMemberCellViewModel

<style>
    .member-cell {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        min-width: 180px;
        max-width: 260px;
    }

    .member-link {
        font-size: 0.95rem;
        line-height: 1.2;
        font-weight: 700;
        color: #2563eb;
        text-decoration: none;
        cursor: pointer;
    }

    .member-link:hover {
        text-decoration: underline;
    }

    .inspection-dates {
        line-height: 1.4;
        margin-top: 0.35rem;
    }

    .badge-date {
        padding: 0.35em 0.6em;
        font-size: 0.78rem;
        margin: 0.15rem 0.25rem 0.15rem 0;
    }

    .dates-group {
        display: inline-flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .mismatch-pill {
        display: inline-flex;
        align-items: center;
        background: #fee2e2;
        color: #991b1b;
        padding: 0.32rem 0.75rem;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-top: 0.4rem;
    }
</style>

@if (Model?.Member == null)
{
    <span class="text-muted">Not Assigned</span>
}
else
{
    <div class="member-cell">

        <!-- Member Name -->
        <a href="javascript:void(0);"
           class="member-link"
           onclick="openMemberReport('@Model.Member.MemberName', '@Model.CollegeCode')">
            @Model.Member.MemberName
        </a>

        <!-- Inspection Dates -->
        <div class="inspection-dates small">
            <span class="text-muted fw-semibold me-1">
                Inspection:
            </span>

            @if (Model.Member?.InspectionDates?.Any() == true)
            {
                <span class="dates-group">
                    @foreach (var date in Model.Member.InspectionDates)
                    {
                        <span class="badge badge-date @(Model.Member.DateMismatchFlag ? "bg-danger" : "bg-success text-white")">
                            @date.ToString("dd-MM-yy")
                        </span>
                    }
                </span>
            }
            else
            {
                <span class="text-muted fst-italic">— none —</span>
            }

            @if (Model.Member?.DateMismatchFlag == true)
            {
                <div class="mismatch-pill">
                    Date mismatch
                </div>
            }
        </div>
    </div>
}

<script>
    async function openMemberReport(memberName, collegeCode) {
        try {
            const checkUrl =
                `/LIC_Director/CheckMemberReportExists?memberName=${encodeURIComponent(memberName)}&collegeCode=${encodeURIComponent(collegeCode)}`;

            const response = await fetch(checkUrl);
            const result = await response.json();

            if (!result.success) {
                Swal.fire({
                    icon: 'info',
                    title: 'Data Not Found',
                    text: 'No details available for this member.'
                });
                return;
            }

            window.location.href =
                `/LIC_Director/MemberReport?memberName=${encodeURIComponent(memberName)}&collegeCode=${encodeURIComponent(collegeCode)}`;

        } catch {
            Swal.fire({
                icon: 'info',
                title: 'Data Not Found',
                text: 'No details available for this member.'
            });
        }
    }
</script>