@model IList<Medical_Affiliation.Models.FacultyDetailsViewModel>
@inject IHttpContextAccessor HttpContextAccessor

@{
    Layout = null;
    ViewData["Title"] = "Faculty Details";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
    int currentStep = 5;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — RGUHS Portal</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>

    <style>
        :root {
            --navy: #0d1b3e;
            --navy-mid: #1a2f5f;
            --blue: #1d4ed8;
            --blue-light: #3b82f6;
            --gold: #c8a84b;
            --gold-pale: #f7f0dc;
            --surface: #f4f6fb;
            --card-bg: #ffffff;
            --border: #dde3f0;
            --text-main: #0d1b3e;
            --text-muted: #6b7a99;
            --danger: #dc2626;
            --success: #16a34a;
            --radius: 14px;
            --shadow-sm: 0 2px 8px rgba(13,27,62,.07);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--surface);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .portal-header {
            background: var(--navy);
            padding: 0 2rem;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 12px rgba(0,0,0,.25);
            border-bottom: 2px solid var(--gold);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .brand-emblem {
            width: 38px;
            height: 38px;
            background: var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--navy);
            font-weight: 700;
        }

        .brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .brand-title {
            font-family: 'Playfair Display', serif;
            font-size: 1rem;
            font-weight: 700;
            color: #fff;
        }

        .brand-sub {
            font-size: .7rem;
            color: rgba(255,255,255,.6);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .header-meta {
            font-size: .78rem;
            color: rgba(255,255,255,.7);
            display: flex;
            align-items: center;
            gap: 18px;
        }

            .header-meta span {
                display: flex;
                align-items: center;
                gap: 5px;
            }

        .btn-logout {
            background: transparent;
            border: 1px solid rgba(255,255,255,.35);
            color: rgba(255,255,255,.85);
            border-radius: 7px;
            padding: 5px 14px;
            font-size: .78rem;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s;
            font-family: 'DM Sans', sans-serif;
        }

            .btn-logout:hover {
                background: var(--danger);
                border-color: var(--danger);
                color: #fff;
            }

        .page-shell {
            display: flex;
            flex: 1;
        }

        .content-area {
            flex: 1;
            padding: 2rem;
            width: 100%;
            overflow-x: auto;
        }

        .page-title-block {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 1.75rem;
            padding-bottom: 1.25rem;
            border-bottom: 1px solid var(--border);
        }

            .page-title-block h1 {
                font-family: 'Playfair Display', serif;
                font-size: 1.7rem;
                font-weight: 700;
                color: var(--navy);
            }

        .page-crumb {
            font-size: .78rem;
            color: var(--text-muted);
            margin-top: 4px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .page-crumb i {
                color: var(--gold);
            }

        .stepper-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.5rem 1.25rem;
            margin-bottom: 1.75rem;
            box-shadow: var(--shadow-sm);
        }

        .stepper-label {
            font-size: .68rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            margin-bottom: .75rem;
        }

        .stepper {
            display: flex;
            align-items: flex-start;
            overflow-x: auto;
            scrollbar-width: none;
            padding-bottom: 4px;
        }

            .stepper::-webkit-scrollbar {
                display: none;
            }

        .step-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
            min-width: 0;
            position: relative;
        }

            .step-item:not(:last-child)::after {
                content: '';
                position: absolute;
                top: 14px;
                left: 50%;
                width: 100%;
                height: 2px;
                background: var(--border);
                z-index: 0;
            }

            .step-item.completed:not(:last-child)::after {
                background: var(--success);
            }

        .step-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid var(--border);
            background: var(--card-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .7rem;
            font-weight: 700;
            color: var(--text-muted);
            position: relative;
            z-index: 1;
            transition: all .3s;
            flex-shrink: 0;
        }

        .step-item.active .step-dot {
            border-color: var(--blue);
            background: var(--blue);
            color: #fff;
            box-shadow: 0 0 0 4px rgba(29,78,216,.15);
        }

        .step-item.completed .step-dot {
            border-color: var(--success);
            background: var(--success);
            color: #fff;
        }

        .step-title {
            font-size: .65rem;
            font-weight: 500;
            color: var(--text-muted);
            text-align: center;
            margin-top: 6px;
            line-height: 1.3;
            max-width: 88px;
            word-break: break-word;
        }

        .step-item.active .step-title {
            color: var(--blue);
            font-weight: 600;
        }

        .step-item.completed .step-title {
            color: var(--success);
        }

        .panel {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .panel-header {
            padding: .85rem 1.35rem;
            background: var(--navy);
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .panel-header h5 {
                font-family: 'Playfair Display', serif;
                font-size: 1rem;
                font-weight: 700;
                color: #fff;
                margin: 0;
            }

            .panel-header i {
                color: var(--gold);
                font-size: 1.15rem;
            }

            .panel-header .record-pill {
                margin-left: auto;
                background: rgba(255,255,255,.15);
                border-radius: 20px;
                padding: 2px 12px;
                font-size: .72rem;
                color: #fff;
                font-weight: 700;
            }

        .alert-custom {
            border-radius: 8px;
            padding: .65rem 1rem;
            font-size: .82rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 1rem;
        }

            .alert-custom.danger {
                background: #fef2f2;
                color: var(--danger);
                border: 1px solid #fecaca;
            }

            .alert-custom.info {
                background: #eff6ff;
                color: var(--blue);
                border: 1px solid #bfdbfe;
            }

        .faculty-table-wrap {
            overflow-x: auto;
        }

        .faculty-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .78rem;
            min-width: 1600px;
        }

            .faculty-table thead th {
                background: #1e3a5f;
                color: #fff;
                font-size: .65rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .7px;
                padding: .65rem .85rem;
                white-space: nowrap;
                border-bottom: 2px solid var(--border);
                position: sticky;
                top: 0;
                z-index: 5;
            }

            .faculty-table tbody td {
                padding: .5rem .75rem;
                border-bottom: 1px solid var(--border);
                vertical-align: middle;
            }

            .faculty-table tbody tr:hover td {
                background: #f4f7ff;
            }

            .faculty-table tbody tr.row-removed td {
                opacity: .4;
                pointer-events: none;
            }

            .faculty-table .sl-cell {
                font-weight: 700;
                color: var(--text-muted);
                font-size: .72rem;
                text-align: center;
                width: 40px;
            }

        .fc {
            font-family: 'DM Sans', sans-serif;
            font-size: .78rem;
            border: 1.5px solid var(--border);
            border-radius: 7px;
            padding: .38rem .65rem;
            color: var(--text-main);
            background: #fafbfd;
            width: 100%;
            min-width: 120px;
            transition: border-color .2s, box-shadow .2s;
        }

            .fc:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 2px rgba(29,78,216,.1);
                background: #fff;
                outline: none;
            }

            .fc::placeholder {
                color: #b0b9cc;
            }

            .fc:disabled {
                background: #f0f2f8;
                color: var(--text-muted);
                cursor: not-allowed;
            }

        .examiner-options {
            margin-top: 6px;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

            .examiner-options label {
                font-size: .72rem;
                font-weight: 500;
                color: var(--text-main);
                display: flex;
                align-items: center;
                gap: 5px;
                cursor: pointer;
            }

            .examiner-options input[type="checkbox"] {
                accent-color: var(--blue);
            }

        .doc-view-btn {
            background: #eff4ff;
            color: var(--blue);
            border: 1px solid #c7d7fd;
            border-radius: 6px;
            padding: 3px 8px;
            font-size: .68rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 3px;
            transition: all .18s;
            white-space: nowrap;
        }

            .doc-view-btn:hover {
                background: var(--blue);
                color: #fff;
                border-color: var(--blue);
            }

        .btn-remove {
            background: #fef2f2;
            color: var(--danger);
            border: 1px solid #fecaca;
            border-radius: 6px;
            padding: 4px 10px;
            font-size: .7rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
            transition: all .18s;
            white-space: nowrap;
        }

            .btn-remove:hover {
                background: var(--danger);
                color: #fff;
                border-color: var(--danger);
            }

        .btn-undo {
            background: #f0fdf4;
            color: var(--success);
            border: 1px solid #bbf7d0;
            border-radius: 6px;
            padding: 4px 10px;
            font-size: .7rem;
            font-weight: 600;
            cursor: pointer;
            display: none;
            align-items: center;
            gap: 4px;
            transition: all .18s;
            white-space: nowrap;
        }

            .btn-undo:hover {
                background: var(--success);
                color: #fff;
                border-color: var(--success);
            }

        .remarks-box {
            margin-top: 5px;
            font-size: .72rem;
            border-radius: 6px;
            border-color: var(--danger) !important;
        }

        .table-toolbar {
            padding: .85rem 1.25rem;
            border-top: 1px solid var(--border);
            background: var(--surface);
            display: flex;
            align-items: center;
            @*justify-content: space-between;*@
            justify-content: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-add {
            background: var(--success);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .55rem 1.2rem;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: background .2s, transform .15s;
            font-family: 'DM Sans', sans-serif;
        }

            .btn-add:hover {
                background: #15803d;
                transform: translateY(-1px);
            }

        .btn-official {
            background: var(--navy);
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .65rem 1.6rem;
            font-family: 'DM Sans', sans-serif;
            font-size: .875rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background .2s, transform .15s, box-shadow .2s;
            text-decoration: none;
        }

            .btn-official:hover {
                background: var(--blue);
                box-shadow: 0 4px 16px rgba(29,78,216,.25);
                transform: translateY(-1px);
                color: #fff;
            }

        .btn-official-outline {
            background: transparent;
            color: var(--navy);
            border: 1.5px solid var(--navy);
            border-radius: 8px;
            padding: .55rem 1.1rem;
            font-family: 'DM Sans', sans-serif;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all .2s;
            text-decoration: none;
        }

            .btn-official-outline:hover {
                background: var(--navy);
                color: #fff;
            }

        .nav-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1.5rem;
            padding-top: 1.25rem;
            border-top: 1px solid var(--border);
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--surface);
        }

        ::-webkit-scrollbar-thumb {
            background: #c0c8db;
            border-radius: 3px;
        }

        @@media (max-width: 1100px) {
            .content-area {
                padding: 1.25rem 1rem;
            }
        }

        @@media (max-width: 600px) {
            .portal-header .header-meta {
                display: none;
            }
        }
    </style>
</head>
<body>

    <header class="portal-header">
        <a href="#" class="brand">
            <div class="brand-emblem"><i class="bi bi-mortarboard-fill"></i></div>
            <div class="brand-text">
                <span class="brand-title">RGUHS Affiliation Portal</span>
                <span class="brand-sub">Rajiv Gandhi University of Health Sciences</span>
            </div>
        </a>
        <div class="header-meta">
            @using System.Text.RegularExpressions
            @{
                var collegeFullName = HttpContextAccessor.HttpContext.Session.GetString("CollegeName") ?? "";
                var collegeName = Regex.Replace(collegeFullName, @"[\s\-:]*[A-Za-z]*\d{3,}\s*$", "").Trim();
            }
            @if (!string.IsNullOrEmpty(collegeName))
            {
                <span><i class="bi bi-building"></i> @collegeName</span>
            }
            <span><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dd MMM yyyy")</span>
            <form asp-controller="Login" asp-action="Login" method="post" class="m-0">
                <button type="submit" class="btn-logout"><i class="bi bi-box-arrow-right"></i> Logout</button>
            </form>
        </div>
    </header>

    <div class="page-shell">
        <main class="content-area">

            <div class="page-title-block">
                <div>
                    <h1>Faculty Details</h1>
                    <div class="page-crumb">
                        <i class="bi bi-house-fill"></i> Home
                        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i> Admission Affiliation
                        <i class="bi bi-chevron-right" style="font-size:.65rem;"></i>
                        <strong>Add College Faculty</strong>
                    </div>
                </div>
                <span style="font-size:.72rem;color:var(--text-muted);background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:4px 12px;">
                    <i class="bi bi-shield-lock" style="color:var(--gold);"></i> Secure Session
                </span>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert-custom danger"><i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]</div>
            }
            @if (TempData["Info"] != null)
            {
                <div class="alert-custom info"><i class="bi bi-info-circle-fill"></i> @TempData["Info"]</div>
            }

            @{
                var stepTitles = new[] {
                        "Institute Basic Details", "Course Details", "Hospital Details",
                        "Required Faculty Details", "Add College Faculty details", "Academic Performance"
                        };
            }

            <form asp-action="Repo_FacultyDetails" method="post" enctype="multipart/form-data" id="facultyForm" autocomplete="off">
                @Html.AntiForgeryToken()

                <div class="panel">
                    <div class="panel-header">
                        <i class="bi bi-people"></i>
                        <h5>College Faculty Records</h5>
                        <span class="record-pill" id="recordCount">@Model.Count Entries</span>
                    </div>

                    <div class="faculty-table-wrap">
                        <table class="faculty-table" id="facultyTable">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Name of Faculty</th>
                                    <th>Department</th>
                                    <th>Designation</th>
                                    <th>Recognised PG Guide</th>
                                    <th>PG Guide Ship Letter</th>
                                    <th>Recognised PhD Guide</th>
                                    <th>Ph.D Guide Ship Letter</th>
                                    <th>Litigation Pending</th>
                                    <th>Litigation Doc</th>
                                    <th>Mobile</th>
                                    <th>Email</th>
                                    <th>PAN</th>
                                    <th>Aadhaar</th>
                                    <th>Is Examiner</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Count; i++)
                                {
                                    <tr data-index="@i">
                                        <td class="sl-cell">@(i + 1)</td>
                                        <td style="display:none;">
                                            @Html.HiddenFor(m => m[i].FacultyDetailId)
                                        </td>
                                        <td><input name="[@i].NameOfFaculty" value="@Model[i].NameOfFaculty" class="fc" placeholder="Full name" /></td>
                                        <td>@Html.DropDownListFor(m => m[i].SelectedDepartment, Model[i].DepartmentDetails, "Select", new { @class = "fc" })</td>
                                        <td>@Html.DropDownListFor(m => m[i].Designation, Model[i].Designations, "Select", new { @class = "fc" })</td>
                                        <td>
                                            @Html.DropDownListFor(m => m[i].RecognizedPGTeacher,
                                            new List<SelectListItem> {
                                                                                new SelectListItem("Select",""),
                                                                                new SelectListItem("Yes","Yes"),
                                                                                new SelectListItem("No","No")
                                                                                }, new { @class = "fc pg-teacher" })
                                    </td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                            <input type="file" name="[@i].GuideRecognitionDoc" class="fc pg-doc file-validate"
                                                   style="display:@(Model[i].RecognizedPGTeacher == "Yes" ? "block" : "none");min-width:140px;" />
                                            @if (Model[i].PGRecognitionDocData != null)
                                            {
                                                <a href="@Url.Action("ViewFacultyDocument", new { id = Model[i].FacultyDetailId, type = "pg", mode = "view" })"
                                                   target="_blank" class="doc-view-btn"><i class="bi bi-eye"></i> View</a>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        @Html.DropDownListFor(m => m[i].RecognizedPhDTeacher,
                                        new List<SelectListItem> {
                                                                                new SelectListItem("Select",""),
                                                                                new SelectListItem("Yes","Yes"),
                                                                                new SelectListItem("No","No")
                                                                                }, new { @class = "fc phd-teacher" })
                                    </td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                            <input type="file" name="[@i].PhDRecognitionDoc" class="fc phd-doc file-validate"
                                                   style="display:@(Model[i].RecognizedPhDTeacher == "Yes" ? "block" : "none");min-width:140px;" />
                                            @if (Model[i].PhDRecognitionDocData != null)
                                            {
                                                <a href="@Url.Action("ViewFacultyDocument", new { id = Model[i].FacultyDetailId, type = "phd", mode = "view" })"
                                                   target="_blank" class="doc-view-btn"><i class="bi bi-eye"></i> View</a>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        @Html.DropDownListFor(m => m[i].LitigationPending,
                                        new List<SelectListItem> {
                                                                                new SelectListItem("Select",""),
                                                                                new SelectListItem("Yes","Yes"),
                                                                                new SelectListItem("No","No")
                                                                                }, new { @class = "fc litig-teacher" })
                                    </td>
                                    <td>
                                        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">
                                            <input type="file" name="[@i].LitigationDoc" class="fc litig-doc file-validate"
                                                   style="display:@(Model[i].LitigationPending == "Yes" ? "block" : "none");min-width:140px;" />
                                            @if (Model[i].LitigationDocData != null)
                                            {
                                                <a href="@Url.Action("ViewFacultyDocument", new { id = Model[i].FacultyDetailId, type = "litig", mode = "view" })"
                                                   target="_blank" class="doc-view-btn"><i class="bi bi-eye"></i> View</a>
                                            }
                                        </div>
                                    </td>
                                    <td><input name="[@i].Mobile" value="@Model[i].Mobile" class="fc" placeholder="10-digit" /></td>
                                    <td><input name="[@i].Email" value="@Model[i].Email" class="fc" placeholder="email@domain.com" /></td>
                                    <td><input name="[@i].PAN" value="@Model[i].PAN" class="fc" placeholder="ABCDE1234F" /></td>
                                    <td><input name="[@i].Aadhaar" value="@Model[i].Aadhaar" class="fc" placeholder="12-digit" /></td>
                                    <td>
                                        @Html.DropDownListFor(m => m[i].IsExaminer,
                                        new List<SelectListItem> {
                                                                                new SelectListItem("Select",""),
                                                                                new SelectListItem("Yes","Yes"),
                                                                                new SelectListItem("No","No")
                                                                                }, new { @class = "fc is-examiner", data_index = i })
                                        <div class="examiner-options" id="examinerOptions_@i"
                                             style="display:@(Model[i].IsExaminer == "Yes" ? "flex" : "none")">
                                            <label><input type="checkbox" name="[@i].ExaminerForList" value="UG" @(Model[i].ExaminerForList?.Contains("UG") == true ? "checked" : "") /> UG</label>
                                            <label><input type="checkbox" name="[@i].ExaminerForList" value="PG" @(Model[i].ExaminerForList?.Contains("PG") == true ? "checked" : "") /> PG</label>
                                            <label><input type="checkbox" name="[@i].ExaminerForList" value="PhD" @(Model[i].ExaminerForList?.Contains("PhD") == true ? "checked" : "") /> PhD</label>
                                        </div>
                                    </td>
                                    <td style="text-align:center;white-space:nowrap;min-width:160px;">
                                        <button type="button" class="btn-remove remove-row">
                                            <i class="bi bi-trash3"></i> Remove
                                        </button>
                                        <button type="button" class="btn-undo undo-row">
                                            <i class="bi bi-arrow-counterclockwise"></i> Undo
                                        </button>
                                        <input type="text" name="[@i].RemoveRemarks"
                                               class="fc remarks-box"
                                               value="@Model[i].RemoveRemarks"
                                               placeholder="Enter removal reason…"
                                               style="display:none;margin-top:5px;" />
                                    </td>
                                </tr>
                                                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="table-toolbar">
                        <button type="button" id="addRow" class="btn-add">
                            <i class="bi bi-plus-circle"></i> Add Row
                        </button>
                       @*  <button type="submit" class="btn-official">
                            <i class="bi bi-save2"></i> Save &amp; Proceed
                        </button> *@
                    </div>
                </div>

                <div class="nav-footer">
                    <a asp-controller="ContinuesAffiliation_Facultybased" asp-action="NonTeachingStaffDepartmentwise" class="btn-official-outline">
                        <i class="bi bi-arrow-left"></i> Previous
                    </a>
                    <span style="font-size:.75rem;color:var(--text-muted);">
                        <i class="bi bi-info-circle"></i> Guide Ship Letter required only if PG/PhD Guide is Yes.
                    </span>
                    <button type="submit" class="btn-official">
                        <i class="bi bi-save2"></i> Save &amp; Proceed <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </form>

        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @{
        string deptOptions = string.Join("",
        Model.First().DepartmentDetails.Select(d =>
        $"<option value='{System.Net.WebUtility.HtmlEncode(d.Value)}'>{System.Net.WebUtility.HtmlEncode(d.Text)}</option>"));

        string desigOptions = string.Join("",
        Model.First().Designations.Select(d =>
        $"<option value='{System.Net.WebUtility.HtmlEncode(d.Value)}'>{System.Net.WebUtility.HtmlEncode(d.Text)}</option>"));
    }
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const DepartmentOptions  = `@Html.Raw(deptOptions)`;
        const DesignationOptions = `@Html.Raw(desigOptions)`;

        $(document).ready(function () {
            var rowIndex = @Model.Count;

            function toggleConditionals(row) {
                row.find(".pg-doc").toggle(row.find(".pg-teacher").val() === "Yes");
                row.find(".phd-doc").toggle(row.find(".phd-teacher").val() === "Yes");
                row.find(".litig-doc").toggle(row.find(".litig-teacher").val() === "Yes");
            }

            $(document).on("change", ".pg-teacher, .phd-teacher, .litig-teacher", function () {
                toggleConditionals($(this).closest("tr"));
            });

            $(document).on("change", ".is-examiner", function () {
                var idx  = $(this).data("index");
                var show = $(this).val() === "Yes";
                $("#examinerOptions_" + idx).css("display", show ? "flex" : "none");
                if (!show) {
                    $("#examinerOptions_" + idx + " input[type='checkbox']").prop("checked", false);
                }
            });

            function updateSlNo() {
                var n = 1;
                $("#facultyTable tbody tr").each(function () {
                    if (!$(this).hasClass("row-removed")) {
                        $(this).find("td.sl-cell").text(n++);
                    }
                });
                $("#recordCount").text(
                    $("#facultyTable tbody tr:not(.row-removed)").length + " Entries"
                );
            }

            $(document).on("click", ".remove-row", function () {
                var row     = $(this).closest("tr");
                var remarks = row.find(".remarks-box");
                remarks.show().focus();
                remarks.off("blur.remove").on("blur.remove", function () {
                    if ($(this).val().trim() !== "") {
                        row.addClass("row-removed");
                        row.find(".remove-row").hide();
                        row.find(".btn-undo").css("display", "inline-flex");
                        row.find("input:not([type=hidden]):not(.remarks-box), select").prop("disabled", true);
                        updateSlNo();
                    } else {
                        remarks.hide();
                    }
                });
            });

            $(document).on("click", ".undo-row", function () {
                var row     = $(this).closest("tr");
                var remarks = row.find(".remarks-box");
                row.removeClass("row-removed");
                remarks.val("").hide();
                row.find("input, select").prop("disabled", false);
                row.find(".remove-row").show();
                $(this).hide();
                updateSlNo();
            });

            $("#addRow").on("click", function () {
                var slno = $("#facultyTable tbody tr:not(.row-removed)").length + 1;
                var ri   = rowIndex;

                var newRow = `
                <tr data-index="${ri}">
                    <td class="sl-cell">${slno}</td>
                    <td style="display:none;">
                        <input type="hidden" name="[${ri}].FacultyDetailId" value="0" />
                    </td>
                    <td><input name="[${ri}].NameOfFaculty" class="fc" placeholder="Full name" /></td>
                    <td>
                        <select name="[${ri}].SelectedDepartment" class="fc">
                            <option value="">Select</option>${DepartmentOptions}
                        </select>
                    </td>
                    <td>
                        <select name="[${ri}].Designation" class="fc">
                            <option value="">Select</option>${DesignationOptions}
                        </select>
                    </td>
                    <td>
                        <select name="[${ri}].RecognizedPGTeacher" class="fc pg-teacher">
                            <option value="">Select</option><option>Yes</option><option>No</option>
                        </select>
                    </td>
                    <td>
                        <input type="file" name="[${ri}].GuideRecognitionDoc" class="fc pg-doc file-validate" style="display:none;min-width:140px;" />
                    </td>
                    <td>
                        <select name="[${ri}].RecognizedPhDTeacher" class="fc phd-teacher">
                            <option value="">Select</option><option>Yes</option><option>No</option>
                        </select>
                    </td>
                    <td>
                        <input type="file" name="[${ri}].PhDRecognitionDoc" class="fc phd-doc file-validate" style="display:none;min-width:140px;" />
                    </td>
                    <td>
                        <select name="[${ri}].LitigationPending" class="fc litig-teacher">
                            <option value="">Select</option><option>Yes</option><option>No</option>
                        </select>
                    </td>
                    <td>
        <input type="file" name="[${ri}].LitigationDoc" class="fc litig-doc file-validate" style="display:none;min-width:140px;" />
                    </td>
                    <td><input name="[${ri}].Mobile"  class="fc" placeholder="10-digit" /></td>
                    <td><input name="[${ri}].Email"   class="fc" placeholder="email@domain.com" /></td>
                    <td><input name="[${ri}].PAN"     class="fc" placeholder="ABCDE1234F" /></td>
                    <td><input name="[${ri}].Aadhaar" class="fc" placeholder="12-digit" /></td>
                    <td>
                        <select name="[${ri}].IsExaminer" class="fc is-examiner" data-index="${ri}">
                            <option value="">Select</option><option>Yes</option><option>No</option>
                        </select>
                        <div class="examiner-options" id="examinerOptions_${ri}" style="display:none;">
                            <label><input type="checkbox" name="[${ri}].ExaminerForList" value="UG"  /> UG</label>
                            <label><input type="checkbox" name="[${ri}].ExaminerForList" value="PG"  /> PG</label>
                            <label><input type="checkbox" name="[${ri}].ExaminerForList" value="PhD" /> PhD</label>
                        </div>
                    </td>
                    <td style="text-align:center;white-space:nowrap;min-width:160px;">
                        <button type="button" class="btn-remove remove-row">
                            <i class="bi bi-trash3"></i> Remove
                        </button>
                        <button type="button" class="btn-undo undo-row" style="display:none;">
                            <i class="bi bi-arrow-counterclockwise"></i> Undo
                        </button>
                        <input type="text" name="[${ri}].RemoveRemarks" class="fc remarks-box"
                               placeholder="Enter removal reason…" style="display:none;margin-top:5px;" />
                    </td>
                </tr>`;

                $("#facultyTable tbody").append(newRow);
                rowIndex++;
                updateSlNo();
            });
        });

        document.addEventListener("change", function (e) {

            if (e.target.classList.contains("file-validate")) {

                const file = e.target.files[0];
                const maxSize = 2 * 1024 * 1024; // ✅ 2MB

                if (file) {

                    // ❌ FILE SIZE CHECK
                    if (file.size > maxSize) {
                        Swal.fire({
                            icon: "error",
                            title: "File too large",
                            text: "Maximum allowed size is 2MB"
                        });

                        e.target.value = "";
                        return;
                    }

                    // ❌ OPTIONAL TYPE CHECK (recommended)
                    const ext = file.name.split('.').pop().toLowerCase();
                    const allowed = ["pdf", "jpg", "png"];

                    if (!allowed.includes(ext)) {
                        Swal.fire({
                            icon: "error",
                            title: "Invalid file",
                            text: "Only PDF, JPG, PNG files are allowed"
                        });

                        e.target.value = "";
                        return;
                    }
                }
            }

        });
    </script>

</body>
</html>
