            <label style="font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;color:#8fa3be;
                              text-transform:uppercase;letter-spacing:.1em;display:block;margin-bottom:7px">Remarks</label>
            <textarea id="rmk_@Model.Id"
