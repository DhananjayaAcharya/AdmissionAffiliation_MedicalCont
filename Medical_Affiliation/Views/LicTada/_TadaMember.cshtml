</div>

<!-- ═══ SCRIPTS ═══ -->
@if (mode == "cw")
{
    <script>
        function modalCalc(id) {
            var km = parseFloat(document.getElementById('km_' + id).value) || 0;
            var rkm = parseFloat(document.getElementById('rkm_' + id).value) || 0;
            var totalKm = km + rkm;
            var fmt = function (n) { return '₹ ' + Math.round(n).toLocaleString('en-IN'); };
            var isShortTrip = totalKm > 0 && totalKm <= 40;
            var travelCost = isShortTrip ? 0 : totalKm * 15;
            var onEl = document.getElementById('cpOnward_' + id);
            var rtEl = document.getElementById('cpReturn_' + id);
            var ttEl = document.getElementById('cpTotal_' + id);
            if (onEl) onEl.textContent = fmt(isShortTrip ? 0 : km * 15);
            if (rtEl) rtEl.textContent = fmt(isShortTrip ? 0 : rkm * 15);
            if (ttEl) ttEl.textContent = fmt(travelCost) + (isShortTrip ? ' ⚠️ ≤40km: No Travel/DA' : '');
            var travelEl = document.getElementById('bcTravel_' + id);
            if (travelEl) { travelEl.textContent = fmt(travelCost); travelEl.setAttribute('data-val', travelCost); travelEl.style.color = isShortTrip ? '#e03055' : '#0d1b2e'; }
            var daEl = document.getElementById('bcDA_' + id);
            if (daEl) {
                if (!daEl.hasAttribute('data-original')) daEl.setAttribute('data-original', parseFloat(daEl.getAttribute('data-val')) || 0);
                var origDA = parseFloat(daEl.getAttribute('data-original')) || 0;
                var effDA = isShortTrip ? 0 : origDA;
                daEl.textContent = fmt(effDA); daEl.setAttribute('data-val', effDA);
                daEl.style.color = (isShortTrip && origDA > 0) ? '#e03055' : '#0d1b2e';
            }
            function getVal(eid) { var e = document.getElementById(eid); return e ? (parseFloat(e.getAttribute('data-val')) || 0) : 0; }
            var tot = travelCost + getVal('bcDA_' + id) + getVal('bcLCA_' + id) + getVal('bcCol_' + id) + getVal('bcAR_' + id) + getVal('bcAF_' + id);
            var totEl = document.getElementById('claimTotal_' + id);
            if (totEl) {
                totEl.textContent = '₹ ' + Math.round(tot).toLocaleString('en-IN');
                totEl.style.color = '#0f9b6e'; clearTimeout(totEl._ft);
                totEl._ft = setTimeout(function () { totEl.style.color = ''; }, 1400);
            }
        }

        function ltCWSave(id) {
            var kmEl  = document.getElementById('km_'  + id);
            var rkmEl = document.getElementById('rkm_' + id);
            var rmkEl = document.getElementById('rmk_' + id);
            var btn   = document.getElementById('ltSave_' + id);
            if (!kmEl || !rkmEl) { ltToast('❌ KM fields not found.', 'err'); return; }
            var km  = parseFloat(kmEl.value)  || 0;
            var rkm = parseFloat(rkmEl.value) || 0;
            var rmk = rmkEl ? rmkEl.value.trim() : '';
            if (km < 0 || rkm < 0) { ltToast('⚠️ KM cannot be negative.', 'err'); return; }
            btn.disabled = true; btn.textContent = '⏳ Saving KM…';
            fetch('/LicTada/SaveKm', {
                method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + encodeURIComponent(id) + '&km=' + encodeURIComponent(km) + '&rkm=' + encodeURIComponent(rkm)
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (!d.success) throw new Error('KM save failed');
                btn.textContent = '⏳ Verifying…';
                return fetch('/LicTada/CWVerify', {
                    method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'id=' + encodeURIComponent(id) + '&remarks=' + encodeURIComponent(rmk)
                });
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (!d.success) throw new Error('Verify failed');
                btn.textContent = '✅ Verified!'; btn.style.background = '#e5f7f2';
                btn.style.color = '#0f9b6e'; btn.style.border = '2px solid #86e0c8'; btn.style.boxShadow = 'none';
                ltToast('✅ KM saved and member verified successfully.', 'ok');
                setTimeout(ltClose, 1500);
            })
            .catch(function (e) {
                btn.disabled = false; btn.textContent = '💾 Save KM & Mark as Verified';
                ltToast('❌ ' + (e.message || 'Operation failed'), 'err');
            });
        }
    </script>
}

