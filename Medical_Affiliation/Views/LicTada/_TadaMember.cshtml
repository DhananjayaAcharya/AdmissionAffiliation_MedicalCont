                    @if (doc.Has)
                    {
                        <span style="background:#e5f7f2;color:#0f9b6e;border:1px solid #86e0c8;border-radius:20px;padding:2px 10px;font-size:10px;font-family:'JetBrains Mono',monospace;font-weight:700">✓ Available</span>
                    }
                    else
                    {
                        <span style="background:#f8fafc;color:#8fa3be;border:1px solid #e2e8f3;border-radius:20px;padding:2px 10px;font-size:10px;font-family:'JetBrains Mono',monospace;font-weight:700">Not uploaded</span>
                    }
                </div>
                @if (doc.Has)
                {
                    <div style="padding:14px 16px">
                        <div style="display:flex;align-items:center;gap:12px">
                            <span style="font-size:28px">@doc.Icon</span>
                            <div style="flex:1">
                                <div style="font-weight:600;font-size:13px;color:#0d1b2e">@doc.FileName</div>
                                <div style="font-size:10.5px;color:#8fa3be;font-family:'JetBrains Mono',monospace">
                                    @(doc.IsB64 ? "Base64 encoded PDF" : "File stored on server")
                                </div>
                            </div>
                            <div style="display:flex;gap:6px">
                                @if (doc.IsB64)
                                {
                                    <a href="#" onclick="ltViewPdf('@doc.Data'); return false;"
                                       style="padding:7px 16px;border-radius:8px;font-size:12px;font-weight:600;
                      text-decoration:none;color:#fff;background:@clrGrad;cursor:pointer">📄 View</a>
                                    <a href="data:application/octet-stream;base64,@doc.Data" download="@doc.FileName"
                                       style="background:#fff;color:#2d3f5c;padding:7px 16px;border-radius:8px;text-decoration:none;font-size:12px;font-weight:600;border:1.5px solid #e2e8f3">⬇ Download</a>
                                }
                                else
                                {
                                    <a href="/uploads/@doc.Data" target="_blank"
                                       style="padding:7px 16px;border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;color:#fff;background:@clrGrad">📄 View</a>
                                    <a href="/uploads/@doc.Data" download="@doc.FileName"
