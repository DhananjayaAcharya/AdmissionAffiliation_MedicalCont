@model Medical_Affiliation.Models.LicTadaMember
@{
    var mname = ViewBag.MemberName as string ?? "Member";
    var mode = ViewBag.Mode as string ?? "view";

    string clr, clrL, clrB, clrGrad;
    switch (Model.TypeOfMembers)
    {
        case "AC Member":
            clr = "#6d35cc"; clrL = "#f0eafd"; clrB = "#c9b3f5";
            clrGrad = "linear-gradient(135deg,#6d35cc,#9b59e8)"; break;
        case "Subject Expert":
        case "Subject Expertise":
            clr = "#0f9b6e"; clrL = "#e5f7f2"; clrB = "#86e0c8";
            clrGrad = "linear-gradient(135deg,#0f9b6e,#1ac48c)"; break;
        default:
            clr = "#2d6be4"; clrL = "#e8f0fd"; clrB = "#b3cdfb";
            clrGrad = "linear-gradient(135deg,#2d6be4,#5b8ef0)"; break;
    }

    string F(decimal v) => "₹ " + string.Format("{0:#,##0}", v);
    string Dt(DateTime? d) => d.HasValue ? d.Value.ToString("dd MMM yyyy") : "—";

    bool cwActioned = Model.F_CaseWorker_Approve_Status == "Verified"
                    || Model.F_CaseWorker_Approve_Status == "Rejected";
    bool aoActioned = Model.F_AO_SP_Approved_Status == "Approved"
                    || Model.F_AO_SP_Approved_Status == "Rejected";
    bool fo2Actioned = Model.FO_Level2_ApprovedStatus == "Approved"
                    || Model.FO_Level2_ApprovedStatus == "Rejected";

    bool hasBills = !string.IsNullOrEmpty(Model.UploadedBills);
    bool hasOrder = !string.IsNullOrEmpty(Model.LicApprovalFileName);
    bool isBills64 = hasBills && Model.UploadedBills.Length > 200;

    var trail = new (string Lbl, string Icon, string Sts, string Date)[]
    {
        ("Director",    "🏛", Model.DR_ApprovalStatus,           Dt(Model.DRApprovedDate)),
        ("FO Level 1",  "💼", Model.FO_Level1_ApprovedStatus,    Dt(Model.FO_Level1_ForwardedDate)),
        ("Case Worker", "🔍", Model.F_CaseWorker_Approve_Status, Dt(Model.F_CaseWorker_Approved_Date)),
        ("AO / SP",     "📊", Model.F_AO_SP_Approved_Status,     Dt(Model.F_AO_SP_Approved_Date)),
        ("FO Level 2",  "✅", Model.FO_Level2_ApprovedStatus,    Dt(Model.FO_Level2_ApprovedDate)),
        ("Cashier",     "💳", Model.Cashier_Update,              Dt(Model.CashierApprovedDate)),
    };

    bool kmEditable = mode == "cw" || mode == "ao" || mode == "fo2";
}

<!-- ═══ HEADER ═══ -->
<div style="background:linear-gradient(135deg,#0f1b35,#1e2d52);padding:26px 30px 22px;border-radius:30px 30px 0 0;
            display:flex;justify-content:space-between;align-items:flex-start;gap:16px;position:relative;overflow:hidden">
    <div style="position:absolute;inset:0;opacity:.03;background:repeating-linear-gradient(45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:24px 24px;pointer-events:none"></div>
    <div style="flex:1;min-width:0;position:relative;z-index:1">
        <span style="display:inline-block;border-radius:20px;padding:3px 13px;background:@(clrL)22;color:@clr;
                     border:1px solid @(clrB)66;font-size:10px;font-family:'JetBrains Mono',monospace;
                     font-weight:700;text-transform:uppercase;letter-spacing:.12em;margin-bottom:10px">
            @(Model.TypeOfMembers ?? "Member")
        </span>
        <h2 style="font-size:24px;font-weight:800;color:#ffffff;letter-spacing:-.03em;line-height:1.2;font-family:'Outfit',sans-serif">
            @mname
        </h2>
        <div style="color:rgba(255,255,255,.5);font-family:'JetBrains Mono',monospace;font-size:11.5px;margin-top:7px;display:flex;gap:14px;flex-wrap:wrap">
            <span>📱 @Model.MobileNo</span>
            <span>📍 @(string.IsNullOrEmpty(Model.Division) ? "N/A" : Model.Division)</span>
            <span>📅 @Model.NoOfDays day(s)</span>
            @if (!string.IsNullOrEmpty(Model.FacultyCode))
            {
                <span>🏛 @Model.FacultyCode</span>
            }
        </div>
    </div>
    <button onclick="ltClose()"
            style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:10px;
                   color:rgba(255,255,255,.65);width:38px;height:38px;cursor:pointer;font-size:24px;
                   display:flex;align-items:center;justify-content:center;flex-shrink:0;line-height:1;
                   position:relative;z-index:1;transition:all .15s;font-family:sans-serif"
            onmouseover="this.style.background='rgba(224,48,85,.3)';this.style.color='#fff'"
            onmouseout="this.style.background='rgba(255,255,255,.08)';this.style.color='rgba(255,255,255,.65)'">
        ×
    </button>
</div>

<!-- ═══ CW REMARKS BANNER — shown to AO and FO2 ═══ -->
@if ((mode == "ao" || mode == "fo2") &&
     (!string.IsNullOrWhiteSpace(Model.F_CaseWorker_Approve_Remarks) || !string.IsNullOrWhiteSpace(Model.F_CaseWorker_Approve_Status)))
{
    bool cwVerified = Model.F_CaseWorker_Approve_Status == "Verified";
    bool cwRejected = Model.F_CaseWorker_Approve_Status == "Rejected";
    <div style="margin:0;padding:13px 24px;
                    background:@(cwVerified ? "linear-gradient(90deg,#e5f7f2,#f0fdf8)" : cwRejected ? "linear-gradient(90deg,#fde8ed,#fff5f7)" : "linear-gradient(90deg,#f0ebff,#faf8ff)");
                    border-bottom:1.5px solid @(cwVerified ? "#86e0c8" : cwRejected ? "#f9a8be" : "#d4c5f5");
                    display:flex;align-items:flex-start;gap:12px">
        <span style="font-size:18px;flex-shrink:0;margin-top:1px">🔍</span>
        <div style="flex:1">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px">
                <div style="font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;
                                color:@(cwVerified ? "#0f9b6e" : cwRejected ? "#e03055" : "#6d35cc");
                                text-transform:uppercase;letter-spacing:.12em">
                    Case Worker Remarks
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.F_CaseWorker_Approve_Status))
                {
                    <span style="font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;
                                         padding:2px 8px;border-radius:4px;
                                         background:@(cwVerified ? "#e5f7f2" : cwRejected ? "#fde8ed" : "#f0ebff");
                                         color:@(cwVerified ? "#0f9b6e" : cwRejected ? "#e03055" : "#6d35cc");
                                         border:1px solid @(cwVerified ? "#86e0c8" : cwRejected ? "#f9a8be" : "#d4c5f5")">
                        @(cwVerified ? "✅ Verified" : cwRejected ? "❌ Rejected" : Model.F_CaseWorker_Approve_Status)
                        &nbsp;·&nbsp; @Dt(Model.F_CaseWorker_Approved_Date)
                    </span>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.F_CaseWorker_Approve_Remarks))
            {
                <div style="font-family:'JetBrains Mono',monospace;font-size:11.5px;
                                    color:@(cwVerified ? "#0d5c3a" : cwRejected ? "#a01030" : "#3d2a6e");font-style:italic">
                    "@Model.F_CaseWorker_Approve_Remarks"
                </div>
            }
            else
            {
                <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#a0b3cc;font-style:italic">
                    No remarks entered by Case Worker
                </div>
            }
        </div>
    </div>
}

<!-- ═══ AO REMARKS BANNER — shown to FO2 only ═══ -->
@if (mode == "fo2" &&
     (!string.IsNullOrWhiteSpace(Model.F_AO_SP_Approved_Remarks) || !string.IsNullOrWhiteSpace(Model.F_AO_SP_Approved_Status)))
{
    bool aoApproved = Model.F_AO_SP_Approved_Status == "Approved";
    bool aoRejected = Model.F_AO_SP_Approved_Status == "Rejected";
    <div style="margin:0;padding:13px 24px;
                    background:@(aoApproved ? "linear-gradient(90deg,#e8f0fd,#f0f5ff)" : aoRejected ? "linear-gradient(90deg,#fde8ed,#fff5f7)" : "linear-gradient(90deg,#fef7e6,#fffdf0)");
                    border-bottom:1.5px solid @(aoApproved ? "#b3cdfb" : aoRejected ? "#f9a8be" : "#f8d98a");
                    display:flex;align-items:flex-start;gap:12px">
        <span style="font-size:18px;flex-shrink:0;margin-top:1px">📊</span>
        <div style="flex:1">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px">
                <div style="font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;
                                color:@(aoApproved ? "#2d6be4" : aoRejected ? "#e03055" : "#c97b00");
                                text-transform:uppercase;letter-spacing:.12em">
                    AO / SP Remarks
                </div>
                @if (!string.IsNullOrWhiteSpace(Model.F_AO_SP_Approved_Status))
                {
                    <span style="font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;
                                         padding:2px 8px;border-radius:4px;
                                         background:@(aoApproved ? "#e8f0fd" : aoRejected ? "#fde8ed" : "#fef7e6");
                                         color:@(aoApproved ? "#2d6be4" : aoRejected ? "#e03055" : "#c97b00");
                                         border:1px solid @(aoApproved ? "#b3cdfb" : aoRejected ? "#f9a8be" : "#f8d98a")">
                        @(aoApproved ? "✅ Approved" : aoRejected ? "❌ Rejected" : Model.F_AO_SP_Approved_Status)
                        &nbsp;·&nbsp; @Dt(Model.F_AO_SP_Approved_Date)
                    </span>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.F_AO_SP_Approved_Remarks))
            {
                <div style="font-family:'JetBrains Mono',monospace;font-size:11.5px;
                                    color:@(aoApproved ? "#1a3a7a" : aoRejected ? "#a01030" : "#7a5200");font-style:italic">
                    "@Model.F_AO_SP_Approved_Remarks"
                </div>
            }
            else
            {
                <div style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#a0b3cc;font-style:italic">
                    No remarks entered by AO / SP
                </div>
            }
        </div>
    </div>
}

<!-- ═══ BODY ═══ -->
<div style="padding:26px 30px">

    <!-- ① JOURNEY -->
    <div style="margin-bottom:24px">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;margin-bottom:13px;
                    font-family:'JetBrains Mono',monospace;color:@clr;display:flex;align-items:center;gap:8px">
            🗺 Journey Details
            <span style="flex:1;height:1px;background:#e2e8f3;display:block"></span>
        </div>
        <div style="background:#f8fafc;border:1px solid #e2e8f3;border-radius:14px;padding:18px">

            <!-- Onward -->
            <div style="font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;color:#8fa3be;
                        text-transform:uppercase;letter-spacing:.12em;margin-bottom:12px;display:flex;align-items:center;gap:6px">
                <span style="width:3px;height:12px;background:@clr;border-radius:2px;display:inline-block"></span>
                Onward Journey
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:16px">
                <div>
                    <div style="color:#8fa3be;font-size:9.5px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-weight:600;margin-bottom:4px">From Place</div>
                    <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#0d1b2e;font-weight:500">
                        @(string.IsNullOrEmpty(Model.FromPlace) ? "—" : Model.FromPlace)
                    </div>
                </div>
                <div>
                    <div style="color:#8fa3be;font-size:9.5px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-weight:600;margin-bottom:4px">To Place</div>
                    <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#0d1b2e;font-weight:500">
                        @(string.IsNullOrEmpty(Model.ToPlace) ? "—" : Model.ToPlace)
                    </div>
                </div>
                <div>
                    <div style="color:#8fa3be;font-size:9.5px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-weight:600;margin-bottom:4px">
                        Kilometers
                        @if (kmEditable)
                        {
                            <em style="color:#c97b00;font-size:9px;margin-left:4px;font-style:italic">editable</em>
                        }
                    </div>
                    @if (kmEditable)
                    {
                        <input type="number" id="km_@Model.Id" value="@Model.Kilometers" min="0" step="0.1"
                               oninput="modalCalc('@Model.Id')"
                               style="background:#fff;border:1.5px solid #e2e8f3;border-radius:8px;color:#0d1b2e;
                                          padding:8px 12px;font-family:'JetBrains Mono',monospace;font-size:13px;
                                          width:100%;outline:none;box-sizing:border-box;transition:border-color .15s"
                               onfocus="this.style.borderColor='@clr'"
                               onblur="this.style.borderColor='#e2e8f3'" />
                    }
                    else
                    {
                        <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#0d1b2e;font-weight:500">@Model.Kilometers km</div>
                    }
                </div>
            </div>

            <hr style="border:none;border-top:1px dashed #e2e8f3;margin:14px 0" />

            <!-- Return -->
            <div style="font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;color:#8fa3be;
                        text-transform:uppercase;letter-spacing:.12em;margin-bottom:12px;display:flex;align-items:center;gap:6px">
                <span style="width:3px;height:12px;background:#64748b;border-radius:2px;display:inline-block"></span>
                Return Journey
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px">
                <div>
                    <div style="color:#8fa3be;font-size:9.5px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-weight:600;margin-bottom:4px">Return From</div>
                    <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#0d1b2e;font-weight:500">
                        @(string.IsNullOrEmpty(Model.ReturnFromPlace) ? "—" : Model.ReturnFromPlace)
                    </div>
                </div>
                <div>
                    <div style="color:#8fa3be;font-size:9.5px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-weight:600;margin-bottom:4px">Return To</div>
                    <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#0d1b2e;font-weight:500">
                        @(string.IsNullOrEmpty(Model.ReturnToPlace) ? "—" : Model.ReturnToPlace)
                    </div>
                </div>
                <div>
                    <div style="color:#8fa3be;font-size:9.5px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.1em;font-weight:600;margin-bottom:4px">
                        Return KM
                        @if (kmEditable)
                        {
                            <em style="color:#c97b00;font-size:9px;margin-left:4px;font-style:italic">editable</em>
                        }
                    </div>
                    @if (kmEditable)
                    {
                        <input type="number" id="rkm_@Model.Id" value="@Model.ReturnKilometers" min="0" step="0.1"
                               oninput="modalCalc('@Model.Id')"
                               style="background:#fff;border:1.5px solid #e2e8f3;border-radius:8px;color:#0d1b2e;
                                          padding:8px 12px;font-family:'JetBrains Mono',monospace;font-size:13px;
                                          width:100%;outline:none;box-sizing:border-box;transition:border-color .15s"
                               onfocus="this.style.borderColor='@clr'"
                               onblur="this.style.borderColor='#e2e8f3'" />
                    }
                    else
                    {
                        <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#0d1b2e;font-weight:500">@Model.ReturnKilometers km</div>
                    }
                </div>
            </div>

            <!-- Live cost preview strip — cw, ao, fo2 -->
            @if (kmEditable)
            {
                <div id="costPreview_@Model.Id"
                     style="margin-top:14px;padding:10px 16px;background:#f0ebff;border:1px solid #d4c5f5;
                                border-radius:10px;font-family:'JetBrains Mono',monospace;font-size:11px;
                                color:#6d35cc;font-weight:700;display:flex;gap:18px;flex-wrap:wrap">
                    <span>Onward: <span id="cpOnward_@Model.Id">₹ @string.Format("{0:#,##0}", Model.Kilometers * 15)</span></span>
                    <span>Return: <span id="cpReturn_@Model.Id">₹ @string.Format("{0:#,##0}", Model.ReturnKilometers * 15)</span></span>
                    <span style="margin-left:auto;font-size:13px">
                        Travel Total: <span id="cpTotal_@Model.Id">₹ @string.Format("{0:#,##0}", (Model.Kilometers + Model.ReturnKilometers) * 15)</span>
                    </span>
                </div>
            }
        </div>
    </div>

    <!-- ② CLAIM BREAKDOWN -->
    <div style="margin-bottom:24px">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;margin-bottom:13px;
                    font-family:'JetBrains Mono',monospace;color:@clr;display:flex;align-items:center;gap:8px">
            💰 Claim Breakdown
            <span style="flex:1;height:1px;background:#e2e8f3;display:block"></span>
        </div>
        <div style="background:#f8fafc;border:1px solid #e2e8f3;border-radius:14px;padding:18px">
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
                @{
                    var items = new (string L, string V, string Id, decimal Raw)[]
                    {
                                ("Days",     Model.NoOfDays.ToString(), "",                         0m),
                                ("Travel",   F(Model.TravelCost),       "bcTravel_" + Model.Id,     Model.TravelCost),
                                ("DA",       F(Model.DACost),           "bcDA_"     + Model.Id,     Model.DACost),
                                ("LCA",      F(Model.LCACost),          "bcLCA_"    + Model.Id,     Model.LCACost),
                                ("College",  F(Model.CollegeCost),      "bcCol_"    + Model.Id,     Model.CollegeCost),
                                ("Air/Road", F(Model.AirRoadCost),      "bcAR_"     + Model.Id,     Model.AirRoadCost),
                    };
                    if (Model.AirFair > 0)
                        items = items.Append(("Air Fare", F(Model.AirFair), "bcAF_" + Model.Id, Model.AirFair)).ToArray();
                }
                @foreach (var it in items)
                {
                    <div>
                        <div style="color:#8fa3be;font-size:9.5px;font-family:'JetBrains Mono',monospace;
                                        text-transform:uppercase;letter-spacing:.1em;font-weight:600;margin-bottom:4px">
                            @it.L
                        </div>
                        @if (!string.IsNullOrEmpty(it.Id))
                        {
                            <div id="@it.Id" data-val="@it.Raw"
                                 style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#0d1b2e;font-weight:600">
                                @it.V
                            </div>
                        }
                        else
                        {
                            <div style="font-family:'JetBrains Mono',monospace;font-size:13px;color:#0d1b2e;font-weight:600">
                                @it.V
                            </div>
                        }
                    </div>
                }
            </div>
            <div style="margin-top:18px;padding:16px 20px;border-radius:12px;
                        background:linear-gradient(90deg,@(clrL),transparent);
                        border:1px solid @(clrB)55;display:flex;justify-content:space-between;align-items:center">
                <span style="color:#5a6e8a;font-family:'JetBrains Mono',monospace;font-size:11px;
                             text-transform:uppercase;letter-spacing:.1em;font-weight:600">Total Claim Amount</span>
                <span id="claimTotal_@Model.Id"
                      style="font-size:26px;font-weight:800;letter-spacing:-.03em;color:@clr;
                             font-family:'Outfit',sans-serif;transition:color .3s">
                    ₹ @string.Format("{0:#,##0}", Model.TotalClaimAmount)
                </span>
            </div>
        </div>
    </div>

    <!-- ③ APPROVAL TRAIL -->
    <div style="margin-bottom:24px">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;margin-bottom:13px;
                    font-family:'JetBrains Mono',monospace;color:@clr;display:flex;align-items:center;gap:8px">
            🔖 Approval Trail
            <span style="flex:1;height:1px;background:#e2e8f3;display:block"></span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
            @foreach (var t in trail)
            {
                bool done = !string.IsNullOrEmpty(t.Sts) && t.Sts != "—";
                bool rej = t.Sts == "Rejected";
                bool fwd = t.Sts == "Forwarded";
                string tbg = done ? (rej ? "#fde8ed" : fwd ? "#fef7e6" : "#e5f7f2") : "#ffffff";
                string tbd = done ? (rej ? "#f9a8be" : fwd ? "#f8d98a" : "#86e0c8") : "#e2e8f3";
                string tclr = done ? (rej ? "#e03055" : fwd ? "#c97b00" : "#0f9b6e") : "#8fa3be";
                <div style="display:flex;justify-content:space-between;align-items:center;padding:11px 15px;
                                background:@tbg;border:1.5px solid @tbd;border-radius:10px">
                    <div>
                        <span style="color:#5a6e8a;font-size:12px;font-family:'JetBrains Mono',monospace;display:block">@t.Icon @t.Lbl</span>
                        <span style="font-size:9.5px;color:#8fa3be;font-family:'JetBrains Mono',monospace;display:block;margin-top:2px">@t.Date</span>
                    </div>
                    <span style="font-size:11px;font-weight:700;font-family:'JetBrains Mono',monospace;color:@tclr">
                        @(done? t.Sts: "Pending")
                    </span>
                </div>
            }
        </div>
    </div>

    <!-- ④ FLAGS -->
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:22px">
        <span style="padding:4px 14px;border-radius:20px;font-size:11px;font-family:'JetBrains Mono',monospace;font-weight:600;border:1px solid;
              @(Model.IsBanglore ? "background:#e5f7f2;color:#0f9b6e;border-color:#86e0c8" : "background:#f8fafc;color:#8fa3be;border-color:#e2e8f3")">
            @(Model.IsBanglore ? "✓" : "✗") Bangalore: @(Model.IsBanglore ? "Yes" : "No")
        </span>
        <span style="padding:4px 14px;border-radius:20px;font-size:11px;font-family:'JetBrains Mono',monospace;font-weight:600;border:1px solid;
              @(Model.IsLCA ? "background:#e5f7f2;color:#0f9b6e;border-color:#86e0c8" : "background:#f8fafc;color:#8fa3be;border-color:#e2e8f3")">
            @(Model.IsLCA ? "✓" : "✗") LCA: @(Model.IsLCA ? "Yes" : "No")
        </span>
    </div>

    <!-- ⑤ DOCUMENTS -->
    <div style="margin-bottom:24px">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;margin-bottom:13px;
                    font-family:'JetBrains Mono',monospace;color:@clr;display:flex;align-items:center;gap:8px">
            📎 Documents
            <span style="flex:1;height:1px;background:#e2e8f3;display:block"></span>
        </div>
        @{
            var docs = new (string Title, string Icon, bool Has, bool IsB64, string Data, string FileName)[]
            {
                ("Uploaded Bills", "🧾", hasBills, isBills64, Model.UploadedBills       ?? "", "UploadedBill.pdf"),
                ("Order Copy", "📋", hasOrder, true, Model.LicApprovalFileName ?? "", "OrderCopy.pdf")
            };
        }
        @foreach (var doc in docs)
        {
            <div style="border:1.5px solid #e2e8f3;border-radius:14px;overflow:hidden;margin-bottom:10px">
                <div style="padding:11px 16px;background:#f8fafc;display:flex;align-items:center;
