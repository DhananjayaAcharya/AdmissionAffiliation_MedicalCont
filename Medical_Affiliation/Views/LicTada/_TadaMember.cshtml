            }
            if (km < 0 || rkm < 0) { ltToast('⚠️ KM cannot be negative.', 'err'); return; }

            if (approveBtn) { approveBtn.disabled = true; approveBtn.style.opacity = '.6'; }
            if (rejectBtn)  { rejectBtn.disabled  = true; rejectBtn.style.opacity  = '.6'; }
            var activeBtn = action === 'Approved' ? approveBtn : rejectBtn;
            if (activeBtn) activeBtn.textContent = '⏳ Saving KM…';

            /* Step 1 — SaveKm */
            fetch('/LicTada/SaveKm', {
                method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + encodeURIComponent(id) + '&km=' + encodeURIComponent(km) + '&rkm=' + encodeURIComponent(rkm)
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (!d.success) throw new Error('KM save failed');
                if (activeBtn) activeBtn.textContent = '⏳ Saving decision…';
                /* Step 2 — FO2Action */
                return fetch('/LicTada/FO2Action', {
                    method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'id=' + encodeURIComponent(id) + '&action=' + encodeURIComponent(action) + '&remarks=' + encodeURIComponent(rmk)
                });
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (!d.success) throw new Error(d.message || 'FO2 action failed');
                if (action === 'Approved') {
                    if (approveBtn) {
                        approveBtn.textContent = '✅ Approved!'; approveBtn.style.background = '#e5f7f2';
                        approveBtn.style.color = '#0f9b6e'; approveBtn.style.border = '2px solid #86e0c8';
                        approveBtn.style.boxShadow = 'none'; approveBtn.style.opacity = '1';
                    }
                    ltToast('✅ KM saved and claim approved by FO Level 2.', 'ok');
                } else {
                    if (rejectBtn) {
                        rejectBtn.textContent = '❌ Rejected'; rejectBtn.style.background = '#fde8ed'; rejectBtn.style.opacity = '1';
                    }
                    ltToast('❌ KM saved and claim rejected by FO Level 2.', 'err');
                }
                setTimeout(ltClose, 1600);
            })
            .catch(function (e) {
                if (approveBtn) { approveBtn.disabled = false; approveBtn.style.opacity = '1'; approveBtn.textContent = '✅ Approve'; }
                if (rejectBtn)  { rejectBtn.disabled  = false; rejectBtn.style.opacity  = '1'; rejectBtn.textContent  = '❌ Reject'; }
                ltToast('❌ ' + (e.message || 'Operation failed'), 'err');
            });
        }
    </script>
   
}
<script>
    function ltViewPdf(b64) {
        var binary = atob(b64);
        var bytes = new Uint8Array(binary.length);
        for (var i = 0; i < binary.length; i++) {
            bytes[i] = binary.charCodeAt(i);
        }
        var blob = new Blob([bytes], { type: 'application/pdf' });
        var url  = URL.createObjectURL(blob);
        window.open(url, '_blank');
    }
</script>