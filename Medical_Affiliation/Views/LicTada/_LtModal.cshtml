<div id="ltOverlay"
     style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(17,24,39,.7);
            backdrop-filter:blur(6px);align-items:center;justify-content:center;padding:16px"
     onclick="ltCloseOut(event)">
    <div style="background:#fff;border-radius:24px;width:100%;max-width:820px;max-height:92vh;
                overflow-y:auto;box-shadow:0 32px 80px rgba(17,24,39,.3);
                animation:mdIn .22s cubic-bezier(.34,1.2,.64,1)">
        <div id="ltModalContent">
            <div style="padding:60px;text-align:center;font-family:'IBM Plex Mono',monospace;
                        font-size:12px;color:#94a3b8">
                <div style="font-size:28px;margin-bottom:10px">⏳</div>
                Loading...
            </div>
        </div>
    </div>
</div>
<style>
    @@keyframes mdIn {
        from { opacity:0; transform:translateY(24px) scale(.97); }
        to   { opacity:1; transform:none; }
    }
</style>
