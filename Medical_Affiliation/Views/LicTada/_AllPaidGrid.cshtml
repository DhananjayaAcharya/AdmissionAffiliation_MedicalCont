    <div class="pd-summary-bar">
        <span class="pd-summary-badge">
            ✅ <strong id="pd-flat-count">@flatPaid.Count</strong> paid member(s)
        </span>
        <div class="pd-summary-total">
            <small>Grand Total Sanctioned ₹</small>
            <span id="pd-grand-total">@string.Format("{0:#,##0}", flatPaid.Sum(x => x.Amount))</span>
