}

<script>
    (function () {
        'use strict';

        var BC = {}, IF = {};

        /* ── BOOT ── FIX: defer loadAllBankCols so DOM rows are guaranteed present */
        function boot() {
            if (!document.getElementById('pd-flat-table')) return;
            setTimeout(loadAllBankCols, 0);   /* ← KEY FIX: was loadAllBankCols() inline */
            wireSearch();
            wireExports();
            wireSlips();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', boot);
        } else {
            boot();
        }

        /* ══════════════════════════════════════════
           SEARCH
        ══════════════════════════════════════════ */
        function wireSearch() {
            var inp = document.getElementById('pd-universal-search');
            var clr = document.getElementById('pd-search-clear');
            if (!inp) return;

            function doSearch() {
                var q    = inp.value.trim().toLowerCase();
                var rows = document.querySelectorAll('#pd-flat-tbody .pd-flat-row');
                var shown = 0, total = 0;
                rows.forEach(function (row) {
                    var haystack = row.textContent.toLowerCase();
                    row.querySelectorAll('[data-val]').forEach(function (el) {
                        haystack += ' ' + (el.getAttribute('data-val') || '').toLowerCase();
                    });
                    var match = !q || haystack.indexOf(q) !== -1;
                    row.style.display = match ? '' : 'none';
                    if (match) { shown++; total += parseFloat(row.getAttribute('data-amt') || 0); }
                });
                setTxt('pd-flat-count',    shown);
                setTxt('pd-visible-count', shown);
                setTxt('pd-grand-total',   fmt(total));
                setTxt('pd-grand-total2',  fmt(total));
                if (clr) clr.style.display = q ? 'block' : 'none';
            }

            inp.addEventListener('input', doSearch);
            inp.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') { inp.value = ''; doSearch(); }
            });
            if (clr) {
                clr.addEventListener('click', function () {
                    inp.value = ''; doSearch(); inp.focus();
                });
            }
        }

        /* ══════════════════════════════════════════
           ROW HELPERS
        ══════════════════════════════════════════ */
        function getVisibleRows() {
            return Array.from(
                document.querySelectorAll('#pd-flat-tbody .pd-flat-row')
            ).filter(function (r) { return r.style.display !== 'none'; });
        }

        function rowToArray(row) {
            var tds = row.querySelectorAll('td');
            return [
                txt(tds[0]),
                txt(tds[1]),
                txt(tds[2]),
                txt(tds[3]),
                txt(tds[4]),
                txt(tds[5]),
                dval(tds[6]),
                dval(tds[7]),
                dval(tds[8]),
                dval(tds[9]),
                amtClean(tds[10]),
                amtClean(tds[11]),
                txt(tds[12])
            ];
        }

        function amtClean(td) {
            if (!td) return '';
            return td.textContent.trim().replace(/₹/g, '').replace(/Rs\.?/gi, '').trim();
        }

        var HEADERS = [
            '#', 'College', 'Acad. Year', 'Insp. Date', 'Type', 'Member Name',
            'Bank A/C No.', 'Bank Name', 'Branch', 'IFSC Code',
            'Claimed Amt (Rs.)', 'Sanctioned Amt (Rs.)', 'Status'
        ];

        function txt(td)  { return td ? td.textContent.trim() : ''; }
        function dval(td) {
            if (!td) return '';
            var v = (td.getAttribute('data-val') || '').trim();
            if (!v || v === '⏳' || v === '—') v = td.textContent.trim();
            if (v === '⏳' || v === '—') v = '';
            return v;
        }

        /* ══════════════════════════════════════════
           EXPORTS
        ══════════════════════════════════════════ */
        function wireExports() {
            on('pd-btn-csv',   'click', exportCSV);
            on('pd-btn-excel', 'click', exportExcel);
            on('pd-btn-pdf',   'click', exportPDF);
            on('pd-btn-print', 'click', exportPrint);
        }

        function exportCSV() {
            var rows = getVisibleRows().map(rowToArray);
            var csv  = [HEADERS].concat(rows).map(function (r) {
                return r.map(function (c) {
                    return '"' + String(c).replace(/"/g, '""') + '"';
                }).join(',');
            }).join('\n');
            dlBlob('\uFEFF' + csv, 'paid_members.csv', 'text/csv');
        }

        function exportExcel() {
            loadScript(
                'https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js',
                'sheetjs-xlsx',
                function () {
                    var rows   = getVisibleRows().map(rowToArray);
                    var wsData = [HEADERS].concat(rows.map(function (r) {
                        var copy = r.slice();
                        [10, 11].forEach(function (i) {
                            var n = parseFloat(String(copy[i]).replace(/,/g, '').replace(/[^\d.]/g, ''));
                            copy[i] = isNaN(n) ? copy[i] : n;
                        });
                        return copy;
                    }));
                    var wb = XLSX.utils.book_new();
                    var ws = XLSX.utils.aoa_to_sheet(wsData);
                    ws['!cols'] = [
                        {wch:5},{wch:32},{wch:12},{wch:14},{wch:18},{wch:22},
                        {wch:18},{wch:20},{wch:16},{wch:14},{wch:16},{wch:16},{wch:10}
                    ];
                    XLSX.utils.book_append_sheet(wb, ws, 'Paid Members');
                    XLSX.writeFile(wb, 'paid_members_' + dateTag() + '.xlsx');
                }
            );
        }

        function exportPDF() {
            var rows = getVisibleRows().map(rowToArray);
            var grandClaimed = 0, grandSanctioned = 0;
            rows.forEach(function (r) {
                grandClaimed    += parseFloat(String(r[10]).replace(/,/g, '').replace(/[^\d.]/g, '')) || 0;
                grandSanctioned += parseFloat(String(r[11]).replace(/,/g, '').replace(/[^\d.]/g, '')) || 0;
            });
            var now     = new Date().toLocaleString('en-IN');
            var dateStr = new Date().toLocaleDateString('en-IN');

            function loadLogoThenPDF(logoB64, logoMime) {
                loadScript(
                    'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js',
                    'jspdf-core',
                    function () {
                        loadScript(
                            'https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js',
                            'jspdf-autotable',
                            function () { buildPDF(logoB64, logoMime); }
                        );
                    }
                );
            }

            fetch('/images/newlogo.jpeg', { credentials: 'same-origin' })
                .then(function (r) { return r.blob(); })
                .then(function (blob) {
                    var reader = new FileReader();
                    reader.onloadend = function () {
                        loadLogoThenPDF(reader.result.split(',')[1], blob.type || 'image/jpeg');
                    };
                    reader.readAsDataURL(blob);
                })
                .catch(function () { loadLogoThenPDF(null, null); });

            function buildPDF(logoB64, logoMime) {
                var jsPDF  = window.jspdf.jsPDF;
                var doc    = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'a3' });
                var PW     = doc.internal.pageSize.getWidth();
                var PH     = doc.internal.pageSize.getHeight();
                var M      = 30;
                var HDR_H  = 105;
                var FTR_H  = 36;
                var TOP_BAR = 5;
                var LOGO_W  = 72, LOGO_H = 72;
                var RED    = [143, 26, 26];
                var AMBER  = [180, 83, 9];
                var DARK   = [30,  30,  30];
                var GREY   = [110, 110, 110];
                var LGREY  = [220, 220, 220];
                var WHITE  = [255, 255, 255];
                var GREEN  = [15,  118, 110];
                var TW     = PW - M * 2;

                function drawWatermark() {
                    if (!logoB64) return;
                    try {
                        doc.setGState(new doc.GState({ opacity: 0.04 }));
                        var wmW = PH * 0.85;
                        doc.addImage(logoB64, logoMime || 'JPEG', (PW - wmW) / 2, (PH - wmW) / 2, wmW, wmW);
                        doc.setGState(new doc.GState({ opacity: 1 }));
                    } catch (e) {}
                }

                function drawPageHeader() {
                    doc.setFillColor(255, 255, 255);
                    doc.rect(0, 0, PW, HDR_H, 'F');
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(0, 0, PW, TOP_BAR, 'F');
                    if (logoB64) {
                        doc.addImage(logoB64, logoMime || 'JPEG', M, TOP_BAR + 10, LOGO_W, LOGO_H);
                        doc.addImage(logoB64, logoMime || 'JPEG', PW - M - LOGO_W, TOP_BAR + 10, LOGO_W, LOGO_H);
                    }
                    doc.setFontSize(18); doc.setFont('helvetica', 'bold');
                    doc.setTextColor.apply(doc, RED);
                    doc.text('Rajiv Gandhi University of Health Sciences, Karnataka', PW / 2, TOP_BAR + 30, { align: 'center' });
                    doc.setFontSize(9.5); doc.setFont('helvetica', 'normal');
                    doc.setTextColor.apply(doc, DARK);
                    doc.text("4th 'T' Block, Jayanagar, Bangalore - 560 041", PW / 2, TOP_BAR + 50, { align: 'center' });
                    doc.text('Phone: 080-29601933  |  Website: www.rguhs.ac.in', PW / 2, TOP_BAR + 65, { align: 'center' });
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(0, HDR_H - 5, PW, 3, 'F');
                    doc.setFillColor(200, 200, 200);
                    doc.rect(0, HDR_H - 2, PW, 1, 'F');
                }

                function sectionHeading(label, y) {
                    doc.setDrawColor.apply(doc, LGREY);
                    doc.setFillColor(250, 250, 252);
                    doc.rect(M, y, TW, 24, 'FD');
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(M, y, 5, 24, 'F');
                    doc.setFontSize(10.5); doc.setFont('helvetica', 'bold');
                    doc.setTextColor.apply(doc, RED);
                    doc.text(label, M + 14, y + 17);
                }

                function drawPageFooter() {
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(0, PH - FTR_H, PW, 2, 'F');
                    doc.setFontSize(8); doc.setFont('helvetica', 'normal');
                    doc.setTextColor.apply(doc, GREY);
                    doc.text('Rajiv Gandhi University of Health Sciences, Karnataka', M, PH - FTR_H + 18);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor.apply(doc, DARK);
                    doc.text('Printed on: ' + dateStr, PW - M, PH - FTR_H + 18, { align: 'right' });
                }

                drawWatermark();
                drawPageHeader();

                var sy = HDR_H + 6;
                sectionHeading('Paid Members Report', sy);

                var infoData = [
                    ['Report Generated',      now],
                    ['Total Paid Records',     String(rows.length)],
                    ['Grand Total Claimed',    'Rs. ' + fmt(grandClaimed)],
                    ['Grand Total Sanctioned', 'Rs. ' + fmt(grandSanctioned)]
                ];
                var infoY = sy + 24, rowH = 22;
                infoData.forEach(function (pair, i) {
                    doc.setFillColor.apply(doc, i % 2 === 0 ? [255,255,255] : [248,249,252]);
                    doc.setDrawColor.apply(doc, LGREY);
                    doc.rect(M, infoY, TW, rowH, 'FD');
                    doc.setFontSize(9); doc.setFont('helvetica', 'normal');
                    doc.setTextColor.apply(doc, GREY);
                    doc.text(pair[0], M + 10, infoY + 15);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor.apply(doc, i === 2 ? AMBER : i === 3 ? GREEN : DARK);
                    doc.text(pair[1], M + 260, infoY + 15);
                    infoY += rowH;
                });

                var tableHeadY = infoY + 12;
                sectionHeading('Paid Members Details', tableHeadY);

                var tableBody = rows.map(function (r) {
                    return [r[0],r[1],r[2],r[3],r[4],r[5],r[6],r[7],r[8],r[9],r[10],r[11],'Paid'];
                });

                var units  = [2, 14, 5, 6, 8, 10, 10, 10, 8, 6, 8, 8, 5];
                var uTotal = units.reduce(function (a, b) { return a + b; }, 0);
                var scale  = TW / uTotal;
                var cw     = units.map(function (u) { return +(u * scale).toFixed(1); });

                var footRow = [
                    { content: 'Grand Total', colSpan: 10,
                      styles: { halign:'right', fontStyle:'bold', textColor:RED, fillColor:[255,245,245] } },
                    { content: 'Rs. ' + fmt(grandClaimed),
                      styles: { halign:'right', fontStyle:'bold', textColor:AMBER, fillColor:[255,245,245] } },
                    { content: 'Rs. ' + fmt(grandSanctioned),
                      styles: { halign:'right', fontStyle:'bold', textColor:GREEN, fillColor:[255,245,245] } },
                    { content: '', styles: { fillColor:[255,245,245] } }
                ];

                doc.autoTable({
                    startY: tableHeadY + 24, tableWidth: TW,
                    head: [['#','College','Acad.\nYear','Insp.\nDate','Type','Member Name',
                             'Bank A/C No.','Bank Name','Branch','IFSC Code',
                             'Claimed\nAmt (Rs.)','Sanctioned\nAmt (Rs.)','Status']],
                    body: tableBody, foot: [footRow], showFoot: 'lastPage',
                    margin: { left:M, right:M, top:HDR_H+4, bottom:FTR_H+8 },
                    styles: { fontSize:7, cellPadding:{top:4,bottom:4,left:4,right:4},
                              lineColor:LGREY, lineWidth:0.4, textColor:DARK,
                              font:'helvetica', overflow:'linebreak', minCellHeight:22 },
                    headStyles: { fillColor:RED, textColor:WHITE, fontStyle:'bold', fontSize:7,
                                  halign:'center', valign:'middle', minCellHeight:30,
                                  cellPadding:{top:5,bottom:5,left:4,right:4} },
                    alternateRowStyles: { fillColor:[248,249,252] },
                    footStyles: { fillColor:[255,245,245], textColor:DARK, fontStyle:'bold', fontSize:8 },
                    columnStyles: {
                        0:  { cellWidth:cw[0],  halign:'center', valign:'middle' },
                        1:  { cellWidth:cw[1],  halign:'left',   valign:'middle' },
                        2:  { cellWidth:cw[2],  halign:'center', valign:'middle' },
                        3:  { cellWidth:cw[3],  halign:'center', valign:'middle' },
                        4:  { cellWidth:cw[4],  halign:'left',   valign:'middle' },
                        5:  { cellWidth:cw[5],  halign:'left',   valign:'middle' },
                        6:  { cellWidth:cw[6],  halign:'left',   valign:'middle', fontStyle:'bold' },
                        7:  { cellWidth:cw[7],  halign:'left',   valign:'middle' },
                        8:  { cellWidth:cw[8],  halign:'left',   valign:'middle' },
                        9:  { cellWidth:cw[9],  halign:'center', valign:'middle', fontStyle:'bold' },
                        10: { cellWidth:cw[10], halign:'right',  valign:'middle', fontStyle:'bold', textColor:AMBER },
                        11: { cellWidth:cw[11], halign:'right',  valign:'middle', fontStyle:'bold', textColor:GREEN },
                        12: { cellWidth:cw[12], halign:'center', valign:'middle' }
                    },
                    didDrawPage: function () { drawWatermark(); drawPageHeader(); drawPageFooter(); }
                });
                doc.save('paid_members_' + dateTag() + '.pdf');
            }
        }

