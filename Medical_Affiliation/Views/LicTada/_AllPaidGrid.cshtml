@model List<Medical_Affiliation.Models.LicTadaGridRow>

@{
    var flatPaid = new List<(int RowIdx, int Id, string CollegeCode, string CollegeName, string CollegeTown,
                              string AcademicYear, DateOnly InspectionDate, string TypeOfMembers, string MemberName,
                              string Phone, decimal Amount, decimal OldAmt)>();
    int rp = 0;
    if (Model != null)
    {
        foreach (var r in Model)
        {
            var members = new List<(string Tag, int Id, string Name, string Phone, decimal Amt, decimal OldAmt)>
            {
                ("Senate Members",    r.SenetMemberId,      r.SenetMember,      r.SenetMemberPhNo,      r.SenetMemberAmount,  r.SenetMemberOldAmount),
                ("Academic Council",  r.AcMemberId,         r.AcMember,         r.AcMemberPhNo,         r.AcMemberAmount,     r.AcMemberOldAmount),
                ("Subject Expertise", r.SubjectExpertiseId, r.SubjectExpertise, r.SubjectExpertisePhNo, r.SubjectExpertiseAmount, r.SubjectExpertiseOldAmount),
            };
            foreach (var m in members)
            {
                if (!string.IsNullOrEmpty(m.Name))
                {
                    rp++;
                    flatPaid.Add((rp, m.Id, r.CollegeCode, r.CollegeName, r.CollegeTown,
                                  r.AcademicYear, r.InspectionDate.Value, m.Tag, m.Name, m.Phone, m.Amt, m.OldAmt));
                }
            }
        }
    }
}

@if (Model == null || !Model.Any())
{
    <div style="padding:72px 24px;text-align:center">
        <div style="font-size:48px;margin-bottom:14px;opacity:.35">✅</div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:13px;color:#94a3b8">No paid records found.</div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#cbd5e1;margin-top:6px">Records appear here after Cashier marks as paid</div>
    </div>
}
else
{
    <style>
        .pd-summary-bar {
            padding: 14px 24px;
            background: linear-gradient(135deg,#0f172a 0%,#1e293b 50%,#0f2a1a 100%);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            border-bottom: 2px solid #16a37f;
        }

        .pd-summary-badge {
            background: rgba(22,163,127,.15);
            border: 1px solid rgba(22,163,127,.4);
            border-radius: 20px;
            padding: 5px 14px;
            font-family: 'IBM Plex Mono',monospace;
            font-size: 11px;
            color: #6ee7b7;
            font-weight: 600;
        }

        .pd-summary-total {
            font-family: 'IBM Plex Mono',monospace;
            font-size: 18px;
            font-weight: 700;
            color: #34d399;
        }

            .pd-summary-total small {
                font-size: 12px;
                color: #6ee7b7;
                margin-right: 4px;
            }

        .pd-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            padding: 13px 24px;
            background: #f8fafc;
