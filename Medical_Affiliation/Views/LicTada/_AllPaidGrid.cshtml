                + 'th{padding:8px 10px;font-size:8px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;text-align:left}'
                + 'td{padding:7px 10px;font-size:10px;border-bottom:1px solid #f1f5f9}'
