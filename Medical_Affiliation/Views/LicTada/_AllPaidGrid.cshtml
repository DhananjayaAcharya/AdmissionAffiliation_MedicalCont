                            style="padding:11px 14px;vertical-align:middle;font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:700;color:#16a37f">
                            <span style="color:#cbd5e1;font-size:10px">⏳</span>
                        </td>
                        <td class="pd-bank-name" data-phone="@row.Phone" data-val=""
                            style="padding:11px 14px;vertical-align:middle;font-family:'IBM Plex Mono',monospace;font-size:11px;color:#1e293b">
                            <span style="color:#cbd5e1">—</span>
                        </td>
                        <td class="pd-bank-branch" data-phone="@row.Phone" data-val=""
                            style="padding:11px 14px;vertical-align:middle;font-family:'IBM Plex Mono',monospace;font-size:11px;color:#64748b">
                            <span style="color:#cbd5e1">—</span>
                        </td>
                        <td class="pd-bank-ifsc" data-phone="@row.Phone" data-val=""
                            style="padding:11px 14px;vertical-align:middle;font-family:'IBM Plex Mono',monospace;font-size:11px;color:#2563eb;font-weight:600">
                            <span style="color:#cbd5e1">—</span>
                        </td>

                        <td style="padding:11px 14px;vertical-align:middle;text-align:right;font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:800;color:#f59e0b">
                            ₹ @string.Format("{0:#,##0}", row.OldAmt)
                        </td>
                        <td style="padding:11px 14px;vertical-align:middle;text-align:right;font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:800;color:#16a37f">
                            ₹ @string.Format("{0:#,##0}", row.Amount)
                        </td>

                        <td style="padding:11px 14px;vertical-align:middle;text-align:center">
                            <span class="pd-status-paid">✅ Paid</span>
                        </td>
                        <td style="padding:11px 14px;vertical-align:middle;text-align:center">
                            <button class="pd-slip-btn btn-pd-slip"
                                    data-name="@row.MemberName"
                                    data-phone="@row.Phone"
                                    data-college="@row.CollegeName"
                                    data-year="@row.AcademicYear"
                                    data-oldamt="@row.OldAmt"
