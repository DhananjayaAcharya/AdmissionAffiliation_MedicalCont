    </div>

    <div id="pd-flat-footer">
        <div>
            <div class="pd-footer-total">
                Grand Total Sanctioned ₹ <span id="pd-grand-total2">@string.Format("{0:#,##0}", flatPaid.Sum(x => x.Amount))</span>
            </div>
            <div class="pd-footer-count">
                <span id="pd-visible-count">@flatPaid.Count</span> record(s) shown
            </div>
        </div>
        <button class="pd-print-all-btn" id="btn-pd-print-all-slips">
            📄 Print All Slips
        </button>
