    <div style="padding:16px 24px 0;overflow-x:auto">
        <table id="pd-flat-table" class="display nowrap" style="width:100%;font-size:12px">
            <thead>
                <tr style="background:linear-gradient(to right,#0f172a,#1e293b)">
                    @{
                        string th = "padding:12px 14px;text-align:left;font-family:'IBM Plex Mono',monospace;font-size:9px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.14em;white-space:nowrap;border-bottom:2px solid #334155";
                    }
                    <th style="@th;width:44px">#</th>
                    <th style="@th;min-width:210px">College</th>
                    <th style="@th;min-width:100px">Acad. Year</th>
                    <th style="@th;min-width:95px">Date of Inspection</th>
                    <th style="@th;min-width:140px">Type</th>
                    <th style="@th;min-width:170px">Member Name</th>
                    <th style="@th;min-width:140px">Bank A/C No.</th>
                    <th style="@th;min-width:140px">Bank Name</th>
                    <th style="@th;min-width:120px">Branch</th>
                    <th style="@th;min-width:110px">IFSC Code</th>
                    <th style="@th;text-align:right;min-width:130px">Claimed Amount ₹</th>
                    <th style="@th;text-align:right;min-width:130px">Sanctioned Amount ₹</th>
