    </div>

    <div class="pd-toolbar">
        <div class="pd-btn-group">
            <button class="pd-ebtn pd-ebtn-csv" id="pd-btn-csv">📑 CSV</button>
            <button class="pd-ebtn pd-ebtn-excel" id="pd-btn-excel">📊 Excel</button>
            <button class="pd-ebtn pd-ebtn-pdf" id="pd-btn-pdf">📄 PDF</button>
            <button class="pd-ebtn pd-ebtn-print" id="pd-btn-print">🖨 Print</button>
        </div>
        <div class="pd-search-wrap">
            <span class="pd-search-icon">🔍</span>
            <input type="text" id="pd-universal-search"
                   placeholder="Search name, college, bank, IFSC..."
