                    : "pd-type-subject";

                    <tr class="pd-flat-row"
                        data-id="@row.Id"
                        data-phone="@row.Phone"
                        data-year="@row.AcademicYear"
                        data-name="@row.MemberName"
                        data-amt="@row.Amount"
                        data-oldamt="@row.OldAmt"
                        style="border-bottom:1px solid #f1f5f9">

                        <td style="padding:11px 14px;vertical-align:middle;font-family:'IBM Plex Mono',monospace;font-size:11px;color:#94a3b8;font-weight:600;text-align:center">@row.RowIdx</td>

                        <td style="padding:11px 14px;vertical-align:middle">
                            <div class="pd-college-name">@row.CollegeName</div>
                            <div class="pd-college-sub">@row.CollegeTown · @row.CollegeCode</div>
                        </td>

                        <td style="padding:11px 14px;vertical-align:middle;text-align:center">
                            <span class="pd-badge-year">@row.AcademicYear</span>
                        </td>

                        <td style="padding:10px 13px;vertical-align:middle">
                            <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:700;color:#16a37f;background:#d1fae5;border:1px solid #6ee7b7;border-radius:6px;padding:2px 8px;white-space:nowrap">
                                @row.InspectionDate.ToString("dd MMM yyyy")
