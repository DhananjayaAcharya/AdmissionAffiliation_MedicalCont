                + '.pb{display:block;margin:14px auto;padding:8px 24px;background:#16a37f;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:12px;font-weight:600;font-family:Arial,sans-serif}'
                + '.ft{margin-top:18px;text-align:center;font-size:9px;color:#94a3b8;border-top:1px solid #e2e8f0;padding-top:10px}'
                + '@@media print{.pb{display:none}}'
                + '</style></head><body>'
                + '<button class="pb" onclick="window.print()">🖨 Print / Save as PDF</button>'
                + '<div class="hdr"><div><h1>Medical Affiliation System</h1>'
                + '<p>Cashier — Paid Members Report &nbsp;·&nbsp; ' + now + '</p></div>'
                + '<div style="font-size:10px;color:#64748b;text-align:right">Total: <strong>' + rows.length + '</strong> records</div></div>'
                + '<div class="stats">'
                + '<div class="stat"><div class="sl">Total Records</div><div class="sv">' + rows.length + '</div></div>'
                + '<div class="stat"><div class="sl">Grand Total Claimed</div><div class="sv a">Rs. ' + fmt(grandClaimed) + '</div></div>'
                + '<div class="stat"><div class="sl">Grand Total Sanctioned</div><div class="sv g">Rs. ' + fmt(grandSanctioned) + '</div></div>'
                + '<div class="stat"><div class="sl">Report Date</div><div class="sv" style="font-size:11px">' + now + '</div></div>'
