            var now  = new Date().toLocaleString('en-IN');
            var grandClaimed = 0, grandSanctioned = 0;
            rows.forEach(function (r) {
                grandClaimed    += parseFloat(String(r[10]).replace(/[^\d.]/g, '')) || 0;
                grandSanctioned += parseFloat(String(r[11]).replace(/[^\d.]/g, '')) || 0;
            });
            var trs = rows.map(function (r, ri) {
                return '<tr>' + r.map(function (c, ci) {
                    var align = (ci === 10 || ci === 11) ? 'text-align:right;' : '';
