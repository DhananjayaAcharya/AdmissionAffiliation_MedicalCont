@model List<Medical_Affiliation.Models.LicTadaGridRow>

@if (Model == null || !Model.Any())
{
    <div class="lt-empty">
        <div style="font-size:40px;margin-bottom:12px">✅</div>
        <div style="font-family:'Inter',sans-serif;font-size:14px;font-weight:600;color:#334155;margin-bottom:5px">No Pending Records</div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#94a3b8">Records appear here after SO/AS/AO review</div>
    </div>
}
else
{
    <style>
        .FO2-tbl { width:100%;border-collapse:collapse;font-size:12.5px;font-family:'Inter',sans-serif }
        .FO2-tbl thead tr { background:#f0fdf8;border-bottom:2px solid #6ee7b7 }
        .FO2-tbl th { padding:11px 14px;text-align:left;font-family:'IBM Plex Mono',monospace;font-size:9px;font-weight:700;color:#16a37f;text-transform:uppercase;letter-spacing:.12em;white-space:nowrap }
        .FO2-tbl td { padding:10px 14px;vertical-align:middle }
        .FO2-tbl tr.FO2-first td { border-bottom:1px dashed #d1fae5;background:#fff }
        .FO2-tbl tr.FO2-mid   td { border-bottom:1px dashed #d1fae5;background:#fff }
        .FO2-tbl tr.FO2-last  td { border-bottom:2px solid #6ee7b7; background:#fff }
        .FO2-tbl tr.FO2-first:hover td,.FO2-tbl tr.FO2-mid:hover td,.FO2-tbl tr.FO2-last:hover td { background:#f0fdf8 }
        .FO2-tbl tr.FO2-first td.grp-start { border-left:3px solid #16a37f }
        .mt-badge { display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:8px;font-weight:700;padding:2px 7px;border-radius:4px;text-transform:uppercase;letter-spacing:.07em;white-space:nowrap }
        .mt-senate { background:#dbeafe;color:#2563eb;border:1px solid #93c5fd }
        .mt-ac     { background:#ede9fe;color:#7c3aed;border:1px solid #c4b5fd }
        .mt-expert { background:#fef7e6;color:#d4860a;border:1px solid #f0cc84 }
        .mem-btn { background:none;border:none;padding:0;cursor:pointer;font-family:'Inter',sans-serif;font-size:12.5px;font-weight:600;color:#1e293b;transition:color .12s }
        .mem-btn:hover { color:#16a37f;text-decoration:underline;text-underline-offset:3px }
        .mem-empty { font-family:'IBM Plex Mono',monospace;font-size:11px;color:#cbd5e1;font-style:italic }
        .mem-phone { font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:#94a3b8 }
        .amt-chip { display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:700;color:#1e293b;background:#f0fdf8;border:1px solid #6ee7b7;border-radius:6px;padding:3px 10px }
        .amt-chip.amt-empty { background:#f8fafc;color:#cbd5e1;border-color:#f1f5f9;font-style:italic;font-weight:400;font-size:11px }
        .FO2-footer { padding:12px 20px;border-top:1px solid #f1f5f9;background:#fafbfc;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px }

        .insp-date-cell {
            border-left: 1px solid #f1f5f9;
            border-right: 1px solid #f1f5f9;
            min-width: 120px;
            text-align: center;
            vertical-align: middle;
        }

        .insp-date-pill {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
        }

            .insp-date-pill .insp-label {
                font-family: 'IBM Plex Mono', monospace;
                font-size: 8px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .1em;
                color: #94a3b8;
            }

            .insp-date-pill .insp-value {
                font-family: 'IBM Plex Mono', monospace;
                font-size: 12px;
                font-weight: 700;
                color: #1e293b;
                background: #f1f5f9;
                border: 1px solid #e2e8f0;
                border-radius: 6px;
                padding: 4px 10px;
                white-space: nowrap;
            }

                .insp-date-pill .insp-value.insp-empty {
                    color: #cbd5e1;
                    background: #f8fafc;
                    border-color: #f1f5f9;
                    font-weight: 400;
                    font-style: italic;
                    font-size: 11px;
                }
    </style>

    <div style="overflow-x:auto">
        <table class="FO2-tbl">
            <thead>
                <tr>
                    <th style="width:36px">#</th>
                    <th>Academic Year</th>
                    <th>College</th>
                    <th>Type of Member</th>
                    <th>Name</th>
                    <th>Mobile Number</th>
                    <th>Date of Inspection</th>
                    <th style="min-width:140px">CW Remarks</th>
                    <th style="min-width:130px">Claim ₹</th>
                    <th style="min-width:120px">Action</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var r = Model[i];

                    <tr class="FO2-first">
                        <td rowspan="3" class="grp-start"
                            style="font-family:'IBM Plex Mono',monospace;color:#94a3b8;font-size:11px;
                                   text-align:center;border-right:1px solid #d1fae5;vertical-align:middle">
                            @(i + 1)
                        </td>
                        <td rowspan="3" style="border-right:1px solid #d1fae5;min-width:90px;vertical-align:middle">
                            <span style="font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:700;
                                         color:#16a37f;background:#d1fae5;padding:3px 9px;border-radius:6px">
                                @r.AcademicYear
                            </span>
                        </td>
                        <td rowspan="3" style="border-right:1px solid #d1fae5;min-width:200px;vertical-align:middle">
                            <div style="font-family:'Inter',sans-serif;font-weight:700;color:#1e293b;font-size:13px;line-height:1.4">@r.CollegeName</div>
                            <div style="color:#94a3b8;font-size:10.5px;font-family:'IBM Plex Mono',monospace;margin-top:3px">📍 @r.CollegeTown</div>
                            <div style="color:#cbd5e1;font-size:9.5px;font-family:'IBM Plex Mono',monospace;margin-top:2px">@r.CollegeCode</div>
                        </td>

                        <td><span class="mt-badge mt-senate">Senate</span></td>
                        <td style="min-width:180px">
                            @if (!string.IsNullOrWhiteSpace(r.SenetMember))
                            { <button class="mem-btn" onclick="ltOpen('@r.SenetMemberPhNo','@r.SenetMember','FO2','')">@r.SenetMember</button> }
                            else { <span class="mem-empty">— Not Assigned</span> }
                        </td>
                        <td style="min-width:130px">
                            @if (!string.IsNullOrWhiteSpace(r.SenetMemberPhNo))
                            { <span class="mem-phone">@r.SenetMemberPhNo</span> }
                            else { <span class="mem-empty">—</span> }
                        </td>
                        <td rowspan="3" class="insp-date-cell">
                            <div class="insp-date-pill">
                                <span class="insp-label">Inspected</span>
                                @if (r.InspectionDate.HasValue)
                                {
                                   @*  <span class="insp-value">@r.InspectionDate.Value.ToString("dd MMM yyyy")</span> *@
                                    <span class="insp-value">@r.InspectionDate.Value.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</span>
                                }
                                else
                                {
                                    <span class="insp-value insp-empty">Not Set</span>
                                }
                            </div>
                        </td>
                        <td rowspan="3" style="border-left:1px solid #d1fae5;border-right:1px solid #d1fae5;vertical-align:top;min-width:140px">
                            @if (!string.IsNullOrWhiteSpace(r.CaseWorkerRemarks))
                            { <span style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:#475569;font-style:italic">"@r.CaseWorkerRemarks"</span> }
                            else { <span style="font-family:'IBM Plex Mono',monospace;font-size:10px;color:#cbd5e1">No remarks</span> }
                        </td>
                        <td style="border-left:1px solid #d1fae5">
                            @if (r.SenetMemberAmount > 0) { <span class="amt-chip">₹ @string.Format("{0:#,##0}", r.SenetMemberAmount)</span> }
                            else { <span class="amt-chip amt-empty">—</span> }
                        </td>
                        <td rowspan="3" style="border-left:1px solid #d1fae5;vertical-align:middle;text-align:center">
                            <span style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;color:#94a3b8">Click name →</span>
                        </td>
                    </tr>

                    <tr class="FO2-mid">
                        <td><span class="mt-badge mt-ac">AC Member</span></td>
                        <td style="min-width:180px">
                            @if (!string.IsNullOrWhiteSpace(r.AcMember))
                            { <button class="mem-btn" onclick="ltOpen('@r.AcMemberPhNo','@r.AcMember','FO2','')">@r.AcMember</button> }
                            else { <span class="mem-empty">— Not Assigned</span> }
                        </td>
                        <td style="min-width:130px">
                            @if (!string.IsNullOrWhiteSpace(r.AcMemberPhNo))
                            { <span class="mem-phone">@r.AcMemberPhNo</span> }
                            else { <span class="mem-empty">—</span> }
                        </td>
                        
                        <td style="border-left:1px solid #d1fae5">
                            @if (r.AcMemberAmount > 0) { <span class="amt-chip">₹ @string.Format("{0:#,##0}", r.AcMemberAmount)</span> }
                            else { <span class="amt-chip amt-empty">—</span> }
                        </td>
                    </tr>

                    <tr class="FO2-last">
                        <td><span class="mt-badge mt-expert">Expert</span></td>
                        <td style="min-width:180px">
                            @if (!string.IsNullOrWhiteSpace(r.SubjectExpertise))
                            { <button class="mem-btn" onclick="ltOpen('@r.SubjectExpertisePhNo','@r.SubjectExpertise','FO2','')">@r.SubjectExpertise</button> }
                            else { <span class="mem-empty">— Not Assigned</span> }
                        </td>
                        <td style="min-width:130px">
                            @if (!string.IsNullOrWhiteSpace(r.SubjectExpertisePhNo))
                            { <span class="mem-phone">@r.SubjectExpertisePhNo</span> }
                            else { <span class="mem-empty">—</span> }
                        </td>
                        <td style="border-left:1px solid #d1fae5">
                            @if (r.SubjectExpertiseAmount > 0) { <span class="amt-chip">₹ @string.Format("{0:#,##0}", r.SubjectExpertiseAmount)</span> }
                            else { <span class="amt-chip amt-empty">—</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="FO2-footer">
        <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#64748b">
            ✅ <strong style="color:#334155">@Model.Count</strong> college(s) awaiting FO2 Decision
        </span>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#16a37f;font-weight:600">
            ⚡ Click member name to Approve or Reject
        </span>
    </div>
}



