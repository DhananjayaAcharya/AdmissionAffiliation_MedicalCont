@{
    var role  = ViewBag.Role as string ?? "";
    var uname = ViewBag.UserName as string ?? "User";
    var label = ViewBag.DesignationLabel as string ?? role;
    var inits = uname.Length >= 2 ? uname.Substring(0, 2).ToUpper() : "U";

    string bdgBg  = role == "Finance"    ? "#dbeafe"
                  : role == "CaseWorker" ? "#ede9fe"
                  : role == "AO"         ? "#fef7e6"
                  : role == "Cashier"    ? "#d1fae5"
                  : "#f1f5f9";
    string bdgClr = role == "Finance"    ? "#2563eb"
                  : role == "CaseWorker" ? "#7c3aed"
                  : role == "AO"         ? "#d4860a"
                  : role == "Cashier"    ? "#16a37f"
                  : "#64748b";
    string bdgBdr = role == "Finance"    ? "#93c5fd"
                  : role == "CaseWorker" ? "#c4b5fd"
                  : role == "AO"         ? "#f0cc84"
                  : role == "Cashier"    ? "#6ee7b7"
                  : "#e2e8f0";
    string avGrad = role == "Finance"    ? "linear-gradient(135deg,#2563eb,#7c3aed)"
                  : role == "CaseWorker" ? "linear-gradient(135deg,#7c3aed,#a855f7)"
                  : role == "AO"         ? "linear-gradient(135deg,#d4860a,#f5b942)"
                  : role == "Cashier"    ? "linear-gradient(135deg,#16a37f,#34d399)"
                  : "linear-gradient(135deg,#64748b,#94a3b8)";
}
<nav class="lt-nav">
    <div class="lt-brand">
        <div class="lt-brand-icon">🎓</div>
        <div>
            <div class="lt-brand-name">LIC TA/DA Management</div>
            <div class="lt-brand-sub">RGUHS · Affiliation Portal</div>
        </div>
    </div>
    <div class="lt-user">
        <span class="lt-desig-badge" style="background:@bdgBg;color:@bdgClr;border:1.5px solid @bdgBdr">@label</span>
        <span class="lt-uname">@uname</span>
        <div class="lt-avatar" style="background:@avGrad">@inits</div>
        <form asp-controller="Admin" asp-action="FinanceLogout" method="post" style="display:inline;">
            <button type="submit" class="lt-logout">
                ⏏ Logout
            </button>
        </form>
    </div>
</nav>
