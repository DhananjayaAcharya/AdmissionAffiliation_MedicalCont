                + '<td></td>'
                + '</tr></tfoot></table>'
                + '<div class="ft">Medical Affiliation System &nbsp;·&nbsp; Confidential &nbsp;·&nbsp; ' + now + '</div>'
                + '<button class="pb" style="margin-top:14px" onclick="window.print()">🖨 Print / Save as PDF</button>'
                + '</body></html>';

            var w = window.open('', '_blank', 'width=1200,height=860,scrollbars=yes');
            if (!w) { alert('Pop-up blocked — please allow pop-ups.'); return; }
            w.document.open(); w.document.write(html); w.document.close();
            setTimeout(function () { try { w.print(); } catch (e) {} }, 700);
        }

        /* ══════════════════════════════════════════
           3. BANK DETAILS (unchanged logic)
        ══════════════════════════════════════════ */
        function fetchBank(phone) {
            if (!phone || !phone.trim()) return Promise.resolve(null);
            phone = phone.trim();
            if (BC[phone] !== undefined) return Promise.resolve(BC[phone]);
            if (IF[phone]) return IF[phone];
            IF[phone] = fetch('/LicTada/BankDetails?phone=' + encodeURIComponent(phone), {
                method: 'GET', credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(function (r) { return r.json(); })
            .then(function (d) { BC[phone] = d;    delete IF[phone]; return d; })
            .catch(function ()  { BC[phone] = null; delete IF[phone]; return null; });
            return IF[phone];
        }

        function loadAllBankCols() {
            var phones = [];
            document.querySelectorAll('#pd-flat-tbody .pd-flat-row').forEach(function (row) {
                var ph = (row.getAttribute('data-phone') || '').trim();
                if (ph && phones.indexOf(ph) < 0) phones.push(ph);
            });
            phones.forEach(function (phone) {
                fetchBank(phone).then(function (d) {
                    var found  = d && (d.found === true || d.Found === true);
                    var acct   = found ? getVal(d, ['accountNumber',  'AccountNumber'])        : '';
                    var bname  = found ? getVal(d, ['bankName',       'BankName'])             : '';
                    var branch = found ? getVal(d, ['branchName',     'BranchName'])           : '';
                    var ifsc   = found ? getVal(d, ['ifscCode',       'IfscCode', 'IFSCCode']) : '';

                    qsa('.pd-bank-acct[data-phone="'   + phone + '"]', function (c) {
                        c.innerHTML = acct
                            ? esc(acct)
                            : '<span style="color:#f59e0b;font-size:10px">⚠ N/A</span>';
                        c.setAttribute('data-val', acct);
                    });
                    qsa('.pd-bank-name[data-phone="'   + phone + '"]', function (c) {
                        c.textContent = bname  || '—'; c.setAttribute('data-val', bname);
                    });
                    qsa('.pd-bank-branch[data-phone="' + phone + '"]', function (c) {
                        c.textContent = branch || '—'; c.setAttribute('data-val', branch);
                    });
                    qsa('.pd-bank-ifsc[data-phone="'   + phone + '"]', function (c) {
                        c.textContent = ifsc   || '—'; c.setAttribute('data-val', ifsc);
                    });
                });
            });
        }

        /* ══════════════════════════════════════════
           4. SLIPS (unchanged logic)
        ══════════════════════════════════════════ */
        function wireSlips() {
            document.addEventListener('click', function (e) {
                var btn = e.target.closest('.btn-pd-slip');
                if (!btn) return;
                printSlip(
                    btn.getAttribute('data-phone'),
                    btn.getAttribute('data-name'),
                    btn.getAttribute('data-college'),
                    btn.getAttribute('data-year'),
                    btn.getAttribute('data-amt')
                );
            });

            var pab = document.getElementById('btn-pd-print-all-slips');
            if (pab) {
                pab.addEventListener('click', function () {
                    var rows = Array.from(document.querySelectorAll('#pd-flat-tbody .pd-flat-row'));
                    if (!rows.length) return;
                    var phones = rows
                        .map(function (r) { return (r.getAttribute('data-phone') || '').trim(); })
                        .filter(function (p, i, a) { return p && a.indexOf(p) === i; });

                    Promise.all(phones.map(fetchBank)).then(function () {
                        var slips = rows.map(function (row) {
                            var ph = (row.getAttribute('data-phone') || '').trim();
                            return buildSlipHTML(ph,
                                row.getAttribute('data-name')    || '',
                                row.getAttribute('data-college') || '',
                                row.getAttribute('data-year')    || '',
                                row.getAttribute('data-amt')     || '0',
                                BC[ph]
                            );
                        }).join('<div style="page-break-after:always"></div>');
                        openPrintWin(slips, 'All Payment Slips');
                    });
                });
            }
        }

        function printSlip(phone, name, college, year, amt) {
            fetchBank(phone).then(function (d) {
                openPrintWin(buildSlipHTML(phone, name, college, year, amt, d), 'Payment Slip — ' + name);
            });
        }

        function buildSlipHTML(phone, name, college, year, amt, d) {
            var found  = d && (d.found === true || d.Found === true);
            var acct   = found ? getVal(d, ['accountNumber',     'AccountNumber'])        : '';
            var bname  = found ? getVal(d, ['bankName',          'BankName'])             : '';
            var branch = found ? getVal(d, ['branchName',        'BranchName'])           : '';
            var ifsc   = found ? getVal(d, ['ifscCode',          'IfscCode', 'IFSCCode']) : '';
            var aname  = found ? getVal(d, ['accountHolderName', 'AccountHolderName'])    : '';
            var pan    = found ? getVal(d, ['panNumber',         'PanNumber'])            : '';
            var aadhar = found ? getVal(d, ['aadhaarNumber',     'AadhaarNumber'])        : '';
            var travel = found ? getVal(d, ['modeOfTravel',      'ModeOfTravel'])         : '';
            var amtFmt = 'Rs. ' + parseFloat(amt || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 });
            var dateStr = new Date().toLocaleString('en-IN');

            var brows = [
                ['Bank',           bname + (branch ? ' · ' + branch : '')],
                ['Account Name',   aname],
                ['Account No.',    acct || '⚠ Not on file'],
                ['IFSC Code',      ifsc],
                ['PAN',            pan],
                ['Mode of Travel', travel],
                ['Aadhaar',        aadhar]
            ].filter(function (x) { return x[1] && x[1].trim(); });

            var btbl = brows.length
                ? '<table style="width:100%;border-collapse:collapse;font-size:12px;margin-top:8px">'
                  + brows.map(function (r) {
                      return '<tr>'
                          + '<td style="padding:7px 12px;border:1px solid #e2e8f0;color:#94a3b8;'
                          +     'font-size:9.5px;text-transform:uppercase;letter-spacing:.08em;width:150px">' + esc(r[0]) + '</td>'
                          + '<td style="padding:7px 12px;border:1px solid #e2e8f0;font-weight:600;color:#1e293b">' + esc(r[1]) + '</td>'
                          + '</tr>';
                  }).join('') + '</table>'
                : '<div style="color:#e53e3e;font-size:12px;padding:12px 0">⚠ No bank details on file</div>';

            return '<div style="font-family:Arial,sans-serif;padding:40px 44px;color:#1e293b;max-width:700px;margin:auto">'
                + '<div style="background:linear-gradient(135deg,#0f172a,#1e293b);border-radius:12px;'
                +     'padding:24px 28px;margin-bottom:24px;display:flex;justify-content:space-between;align-items:flex-start">'
                + '<div><h1 style="margin:0 0 6px;font-size:20px;color:#fff">' + esc(name) + '</h1>'
                + '<p style="margin:0;color:#94a3b8;font-size:12px">' + esc(college) + ' &nbsp;·&nbsp; ' + esc(year) + '</p></div>'
                + '<div style="text-align:right">'
                + '<span style="display:inline-block;padding:5px 16px;border-radius:20px;'
                +     'background:rgba(22,163,127,.2);color:#34d399;font-size:10px;font-weight:700;'
                +     'border:1px solid rgba(22,163,127,.4)">✅ PAYMENT SLIP</span>'
                + '<div style="font-size:9px;color:#64748b;margin-top:6px">' + dateStr + '</div></div></div>'
                + '<div style="font-size:8.5px;text-transform:uppercase;letter-spacing:.14em;color:#94a3b8;font-weight:700;margin-bottom:6px">Amount Paid</div>'
                + '<div style="font-size:36px;font-weight:800;color:#16a37f;margin:0 0 24px;letter-spacing:-.02em">' + amtFmt + '</div>'
                + '<div style="border-top:1.5px solid #e2e8f0;margin-bottom:20px"></div>'
                + '<div style="font-size:8.5px;text-transform:uppercase;letter-spacing:.14em;color:#94a3b8;font-weight:700;margin-bottom:10px">Bank Details</div>'
                + btbl
                + '<div style="margin-top:32px;text-align:center;font-size:9.5px;color:#cbd5e1;'
                +     'border-top:1px solid #f1f5f9;padding-top:14px">Generated by Medical Affiliation System &nbsp;·&nbsp; ' + dateStr + '</div></div>';
        }

        function openPrintWin(bodyHtml, title) {
            var html = '<!DOCTYPE html><html><head><meta charset="UTF-8"><title>' + esc(title) + '</title>'
                + '<style>'
                + 'body{margin:0;padding:0;background:#f8fafc}'
                + '.pbtn{display:block;margin:16px auto;padding:9px 28px;background:#16a37f;color:#fff;'
                +     'border:none;border-radius:8px;cursor:pointer;font-size:13px;font-weight:600;font-family:Arial,sans-serif}'
                + '@@media print{.pbtn{display:none}body{background:#fff}}'
                + '</style></head><body>'
                + '<button class="pbtn" onclick="window.print()">🖨 Print / Save as PDF</button>'
                + bodyHtml
                + '<button class="pbtn" onclick="window.print()">🖨 Print / Save as PDF</button>'
                + '</body></html>';
            var w = window.open('', '_blank', 'width=820,height=960,scrollbars=yes');
            if (!w) { alert('Pop-up blocked!'); return; }
            w.document.open(); w.document.write(html); w.document.close(); w.focus();
            setTimeout(function () { try { w.print(); } catch (e) {} }, 900);
        }

        /* ══════════════════════════════════════════
           HELPERS
        ══════════════════════════════════════════ */
        function getVal(d, keys) {
            if (!d) return '';
            for (var i = 0; i < keys.length; i++) { var v = d[keys[i]]; if (v) return v; }
            return '';
        }
        function esc(s) {
            if (s == null) return '';
            return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
        function fmt(n) {
            return parseFloat(n || 0).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
        }
        function setTxt(id, v) { var el = document.getElementById(id); if (el) el.textContent = v; }
        function qsa(q, fn)    { document.querySelectorAll(q).forEach(fn); }
        function on(id, ev, fn){ var el = document.getElementById(id); if (el) el.addEventListener(ev, fn); }
        function dateTag()     { return new Date().toISOString().slice(0, 10); }
        function dlBlob(content, filename, mime) {
            var blob = new Blob([content], { type: mime });
            var a    = document.createElement('a');
            a.href   = URL.createObjectURL(blob);
            a.download = filename;
            document.body.appendChild(a); a.click();
            setTimeout(function () { document.body.removeChild(a); URL.revokeObjectURL(a.href); }, 500);
        }

        /* load a CDN script only once */
        function loadScript(src, id, cb) {
            if (document.getElementById(id)) { cb(); return; }
            var s   = document.createElement('script');
            s.id    = id;
            s.src   = src;
            s.onload  = cb;
            s.onerror = function () { alert('Could not load library from CDN. Check your internet connection.'); };
            document.head.appendChild(s);
        }

        /* console helper: window.pdPrefetchAll() to force-refresh bank data */
        window.pdPrefetchAll = function () { BC = {}; IF = {}; loadAllBankCols(); };

    })();

</script>