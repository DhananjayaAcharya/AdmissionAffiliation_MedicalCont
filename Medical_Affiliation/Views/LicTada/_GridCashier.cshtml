                var TOP_BAR  = 5;           // top red bar thickness
                var LOGO_W   = 72;          // logo size in header
                var LOGO_H   = 72;
                var RED      = [143, 26, 26];
                var DARK     = [30,  30,  30];
                var GREY     = [110, 110, 110];
                var LGREY    = [220, 220, 220];
                var WHITE    = [255, 255, 255];

                /* usable table width = page width - 2 margins */
                var TW = PW - M * 2;

                /* ── watermark: very large, very faint logo centred ── */
                function drawWatermark() {
                    if (!logoB64) return;
                    try {
