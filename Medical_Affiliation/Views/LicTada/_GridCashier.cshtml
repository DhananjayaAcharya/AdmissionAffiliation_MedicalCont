                        lineWidth:   0.4,
                        textColor:   DARK,
                        font:        'helvetica',
                        overflow:    'linebreak'
                    },
                    headStyles: {
                        fillColor:  RED,
                        textColor:  WHITE,
                        fontStyle:  'bold',
                        fontSize:   7.5,
                        halign:     'left',
                        cellPadding: { top: 5, bottom: 5, left: 4, right: 4 }
                    },
                    alternateRowStyles: { fillColor: [248, 249, 252] },
                    footStyles: {
