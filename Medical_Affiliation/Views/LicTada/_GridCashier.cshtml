                    /* thick top red bar */
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(0, 0, PW, TOP_BAR, 'F');

                    /* logo left */
                    if (logoB64) {
                        doc.addImage(logoB64, logoMime || 'JPEG',
                            M, TOP_BAR + 10, LOGO_W, LOGO_H);
