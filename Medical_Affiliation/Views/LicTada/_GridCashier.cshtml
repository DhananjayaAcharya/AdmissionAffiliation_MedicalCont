        /* ── CSV (no external lib) ── */
        function exportCSV() {
            var rows = getVisibleRows().map(rowToArray);
            var csv  = [HEADERS].concat(rows).map(function (r) {
                return r.map(function (c) {
                    return '"' + String(c).replace(/"/g, '""') + '"';
                }).join(',');
            }).join('\n');
            dlBlob('\uFEFF' + csv, 'paid_members.csv', 'text/csv');
        }

        /* ── EXCEL via SheetJS (loaded on demand) ── */
        function exportExcel() {
            loadScript(
                'https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js',
                'sheetjs-xlsx',
                function () {
                    var rows   = getVisibleRows().map(rowToArray);

                    /* convert amount column (index 9) to a real number for Excel */
                    var wsData = [HEADERS].concat(rows.map(function (r) {
                        var copy = r.slice();
                        var n = parseFloat(String(copy[9]).replace(/,/g, '').replace(/[^\d.]/g, ''));
                        copy[9] = isNaN(n) ? copy[9] : n;
                        return copy;
                    }));

                    var wb = XLSX.utils.book_new();
                    var ws = XLSX.utils.aoa_to_sheet(wsData);

                    /* column widths */
                    ws['!cols'] = [
                        {wch:5},{wch:30},{wch:12},{wch:18},{wch:22},
                        {wch:18},{wch:20},{wch:16},{wch:14},{wch:14},{wch:10}
                    ];

                    XLSX.utils.book_append_sheet(wb, ws, 'Paid Members');
                    XLSX.writeFile(wb, 'paid_members_' + dateTag() + '.xlsx');
                }
            );
        }

        /* ── PDF — RGUHS university document style with logo + watermark ── */
        function exportPDF() {
            var rows = getVisibleRows().map(rowToArray);
            var grandTotal = 0;
            rows.forEach(function (r) {
                grandTotal += parseFloat(String(r[9]).replace(/,/g, '').replace(/[^\d.]/g, '')) || 0;
            });
            var now     = new Date().toLocaleString('en-IN');
            var dateStr = new Date().toLocaleDateString('en-IN');

            /* ── Step 1: load the logo image as base64 first ── */
            function loadLogoThenPDF(logoBase64, logoMime) {
                loadScript(
                    'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js',
                    'jspdf-core',
                    function () {
                        loadScript(
                            'https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js',
                            'jspdf-autotable',
                            function () {
                                buildPDF(logoBase64, logoMime);
                            }
                        );
                    }
                );
            }

            /* fetch logo from the app's own server → convert to base64 */
            fetch('/images/newlogo.jpeg', { credentials: 'same-origin' })
                .then(function (r) { return r.blob(); })
                .then(function (blob) {
                    var reader = new FileReader();
                    reader.onloadend = function () {
                        /* result = "data:image/jpeg;base64,xxxx" */
                        var b64  = reader.result.split(',')[1];
                        var mime = blob.type || 'image/jpeg';
                        loadLogoThenPDF(b64, mime);
                    };
                    reader.readAsDataURL(blob);
                })
                .catch(function () {
                    /* logo fetch failed — build PDF without logo */
                    loadLogoThenPDF(null, null);
                });

            /* ── Step 2: build the actual PDF ── */
            function buildPDF(logoB64, logoMime) {
                var jsPDF    = window.jspdf.jsPDF;
                var doc      = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'a3' });
                var PW       = doc.internal.pageSize.getWidth();   // 1190 pt
                var PH       = doc.internal.pageSize.getHeight();  //  842 pt
                var M        = 30;          // left/right margin
                var HDR_H    = 105;         // ← taller header height
