                    doc.setFont('helvetica', 'normal');
                    doc.setTextColor.apply(doc, GREY);
                    doc.text(pair[0], M + 10, infoY + 15);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor.apply(doc, i === 2 ? RED : DARK);
                    doc.text(pair[1], M + 240, infoY + 15);
                    infoY += rowH;
                });

                /* ── table section heading ── */
                var tableHeadY = infoY + 12;
