                ];
                var infoY = sy + 24;
                var rowH  = 22;
                infoData.forEach(function (pair, i) {
                    doc.setFillColor.apply(doc, i % 2 === 0 ? [255,255,255] : [248,249,252]);
                    doc.setDrawColor.apply(doc, LGREY);
                    doc.rect(M, infoY, TW, rowH, 'FD');
