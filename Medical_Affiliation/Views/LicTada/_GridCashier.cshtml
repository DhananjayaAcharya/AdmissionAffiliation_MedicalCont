                    /* divider lines at bottom of header */
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(0, HDR_H - 5, PW, 3, 'F');
                    doc.setFillColor(200, 200, 200);
                    doc.rect(0, HDR_H - 2, PW, 1, 'F');
                }

                /* ── section heading with left red bar ── */
                function sectionHeading(label, y) {
                    doc.setDrawColor.apply(doc, LGREY);
                    doc.setFillColor(250, 250, 252);
                    doc.rect(M, y, TW, 24, 'FD');
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(M, y, 5, 24, 'F');
                    doc.setFontSize(10.5);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor.apply(doc, RED);
                    doc.text(label, M + 14, y + 17);
                }

                /* ── page footer ── */
                function drawPageFooter() {
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(0, PH - FTR_H, PW, 2, 'F');
                    doc.setFontSize(8);
                    doc.setFont('helvetica', 'normal');
                    doc.setTextColor.apply(doc, GREY);
                    doc.text('Rajiv Gandhi University of Health Sciences, Karnataka',
