        /* ══════════════════════════════════════════
           1. SEARCH  (pure JS — no DataTables needed)
        ══════════════════════════════════════════ */
        function wireSearch() {
            var inp = document.getElementById('pd-universal-search');
            var clr = document.getElementById('pd-search-clear');
            if (!inp) return;

            function doSearch() {
                var q = inp.value.trim().toLowerCase();
                var rows = document.querySelectorAll('#pd-flat-tbody .pd-flat-row');
                var shown = 0, total = 0;

                rows.forEach(function (row) {
                    /* search across: all td text + bank data-val attrs */
                    var haystack = row.textContent.toLowerCase();

                    /* also include bank column data-val (loaded async) */
                    row.querySelectorAll('[data-val]').forEach(function (el) {
                        haystack += ' ' + (el.getAttribute('data-val') || '').toLowerCase();
                    });

                    var match = !q || haystack.indexOf(q) !== -1;
                    row.style.display = match ? '' : 'none';
                    if (match) {
                        shown++;
                        total += parseFloat(row.getAttribute('data-amt') || 0);
                    }
                });

                setTxt('pd-flat-count',    shown);
                setTxt('pd-visible-count', shown);
                setTxt('pd-grand-total',   fmt(total));
                setTxt('pd-grand-total2',  fmt(total));
                if (clr) clr.style.display = q ? 'block' : 'none';
            }

            inp.addEventListener('input',   doSearch);
            inp.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') { inp.value = ''; doSearch(); }
            });
            if (clr) {
                clr.addEventListener('click', function () {
                    inp.value = ''; doSearch(); inp.focus();
                });
            }
        }

        /* ══════════════════════════════════════════
           HELPERS — read visible rows
        ══════════════════════════════════════════ */
        function getVisibleRows() {
            return Array.from(
                document.querySelectorAll('#pd-flat-tbody .pd-flat-row')
            ).filter(function (r) { return r.style.display !== 'none'; });
        }

        function rowToArray(row) {
            var tds = row.querySelectorAll('td');
            return [
                txt(tds[0]),              // #
                txt(tds[1]),              // College
                txt(tds[2]),              // Acad Year
                txt(tds[3]),              // Type
                txt(tds[4]),              // Member Name
                dval(tds[5]),             // Bank A/C
                dval(tds[6]),             // Bank Name
                dval(tds[7]),             // Branch
                dval(tds[8]),             // IFSC
                amtClean(tds[9]),         // Amount — stripped of ₹ symbol
                txt(tds[10])              // Status
            ];
        }

        /* strips ₹ and any non-numeric chars except digits, commas, dots */
        function amtClean(td) {
            if (!td) return '';
            var raw = td.textContent.trim();
            /* remove the ₹ / Rs. prefix and whitespace, keep digits/commas/dots */
            raw = raw.replace(/₹/g, '').replace(/Rs\.?/gi, '').trim();
            return raw;
        }

        var HEADERS = [
            '#', 'College', 'Acad. Year', 'Type', 'Member Name',
            'Bank A/C No.', 'Bank Name', 'Branch', 'IFSC Code',
            'Amount Paid (Rs.)', 'Status'
        ];

        function txt(td)  { return td ? td.textContent.trim() : ''; }
        function dval(td) {
            if (!td) return '';
            var v = (td.getAttribute('data-val') || '').trim();
            if (!v || v === '⏳' || v === '—') v = td.textContent.trim();
            if (v === '⏳' || v === '—') v = '';
            return v;
        }

        /* ══════════════════════════════════════════
