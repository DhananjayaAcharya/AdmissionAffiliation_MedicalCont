<script>
    
    (function () {
        'use strict';

        var BC = (typeof bankCache !== 'undefined') ? bankCache : {};
        var IF = (typeof inFlight  !== 'undefined') ? inFlight  : {};

        /* ══════════════════════════════════════════════════════════════
           BANK FETCH
        ══════════════════════════════════════════════════════════════ */
        function fetchBank(phone) {
            if (!phone || !phone.trim()) return Promise.resolve(null);
            phone = phone.trim();
            if (BC[phone] !== undefined) return Promise.resolve(BC[phone]);
            if (IF[phone]) return IF[phone];
            IF[phone] = fetch('/LicTada/BankDetails?phone=' + encodeURIComponent(phone), {
                method: 'GET', credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            }).then(function (r) { return r.json(); })
              .then(function (d) { BC[phone] = d; delete IF[phone]; return d; })
              .catch(function ()  { BC[phone] = null; delete IF[phone]; return null; });
            return IF[phone];
        }

        function getVal(d, keys) {
            if (!d) return '';
            for (var i = 0; i < keys.length; i++) { var v = d[keys[i]]; if (v) return v; }
            return '';
        }

        /* ══════════════════════════════════════════════════════════════
           LOAD BANK COLUMNS
        ══════════════════════════════════════════════════════════════ */
        function loadAllBankCols() {
            var phones = [];
            document.querySelectorAll('#cs-flat-tbody .cs-flat-row').forEach(function (row) {
                var ph = (row.getAttribute('data-phone') || '').trim();
                if (ph && phones.indexOf(ph) < 0) phones.push(ph);
            });
            phones.forEach(function (phone) {
                fetchBank(phone).then(function (d) {
                    var found  = d && (d.found === true || d.Found === true);
                    var acct   = found ? getVal(d, ['accountNumber',  'AccountNumber'])        : '';
                    var bname  = found ? getVal(d, ['bankName',       'BankName'])             : '';
                    var branch = found ? getVal(d, ['branchName',     'BranchName'])           : '';
                    var ifsc   = found ? getVal(d, ['ifscCode',       'IfscCode', 'IFSCCode']) : '';

                    qsa('.cs-bank-acct[data-phone="'   + phone + '"]', function (c) {
                        c.innerHTML = acct ? esc(acct) : '<span style="color:#f0a500;font-size:10px">⚠ N/A</span>';
                        c.setAttribute('data-val', acct);
                    });
                    qsa('.cs-bank-name[data-phone="'   + phone + '"]', function (c) {
                        c.textContent = bname  || '—'; c.setAttribute('data-val', bname);
                    });
                    qsa('.cs-bank-branch[data-phone="' + phone + '"]', function (c) {
                        c.textContent = branch || '—'; c.setAttribute('data-val', branch);
                    });
                    qsa('.cs-bank-ifsc[data-phone="'   + phone + '"]', function (c) {
                        c.textContent = ifsc   || '—'; c.setAttribute('data-val', ifsc);
                    });
                });
            });
        }

        /* ══════════════════════════════════════════════════════════════
           CHECKBOX + SELECTION BAR
        ══════════════════════════════════════════════════════════════ */
        var chkAll = document.getElementById('cs-chk-all');
        if (chkAll) {
            chkAll.addEventListener('change', function () {
                qsa('.cs-flat-chk', function (c) { c.checked = chkAll.checked; });
                updateSelBar();
            });
        }
        document.addEventListener('change', function (e) {
            if (e.target && e.target.classList.contains('cs-flat-chk')) updateSelBar();
        });

        function updateSelBar() {
            var checked = document.querySelectorAll('.cs-flat-chk:checked');
            var total = 0;
            checked.forEach(function (c) {
                var row = c.closest('.cs-flat-row');
                if (row) total += parseFloat(row.getAttribute('data-amt') || 0);
            });
            var f = function (n) { return n.toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 }); };
            ['cs-sel-count', 'cs-sel-count2'].forEach(function (id) { setTxt(id, checked.length); });
            ['cs-sel-total', 'cs-sel-total2'].forEach(function (id) { setTxt(id, f(total)); });
            var btn = document.getElementById('btn-flat-pay-selected');
            if (btn) {
                var en = checked.length > 0;
                btn.disabled      = !en;
                btn.style.opacity = en ? '1' : '.5';
                btn.style.cursor  = en ? 'pointer' : 'not-allowed';
            }
        }

        /* ══════════════════════════════════════════════════════════════
           CLICK DELEGATION — Pay + PDF Slip
        ══════════════════════════════════════════════════════════════ */
        document.addEventListener('click', function (e) {

            /* Individual Pay */
            var payBtn = e.target.closest('.btn-row-pay');
            if (payBtn) {
                var id   = payBtn.getAttribute('data-id');
                var name = payBtn.getAttribute('data-name');
                var rmk  = prompt('Payment remarks for ' + name + ' (optional):') || '';
                if (!confirm('Mark ' + name + ' as PAID?')) return;
                payBtn.disabled = true; payBtn.innerHTML = '⏳...';
                payMember(id, rmk, function (ok) {
                    if (ok) {
                        if (typeof ltToast === 'function') ltToast('💳 ' + name + ' marked as paid', 'ok');
                        var row = payBtn.closest('.cs-flat-row');
                        if (row) { row.style.opacity = '.25'; setTimeout(function () { row.remove(); updateSelBar(); }, 600); }
                    } else {
                        if (typeof ltToast === 'function') ltToast('Failed.', 'err');
                        payBtn.disabled = false; payBtn.innerHTML = '💳 Pay';
                    }
                });
                return;
            }

            /* PDF Slip */
            var slipBtn = e.target.closest('.btn-row-pdf');
            if (slipBtn) {
                printSlip(
                    slipBtn.getAttribute('data-phone'),
                    slipBtn.getAttribute('data-name'),
                    slipBtn.getAttribute('data-college'),
                    slipBtn.getAttribute('data-year'),
                    slipBtn.getAttribute('data-amt')
                );
                return;
            }
        });

        /* ══════════════════════════════════════════════════════════════
           BULK PAY
        ══════════════════════════════════════════════════════════════ */
        var paySelBtn = document.getElementById('btn-flat-pay-selected');
        if (paySelBtn) {
            paySelBtn.addEventListener('click', function () {
                var checked = Array.from(document.querySelectorAll('.cs-flat-chk:checked'));
                if (!checked.length) return;
                var names = checked.map(function (c) { return c.closest('.cs-flat-row').getAttribute('data-name'); }).join(', ');
                var rmk   = prompt('Bulk payment remarks (optional):\n' + checked.length + ' member(s): ' + names) || '';
                if (!confirm('Mark ' + checked.length + ' member(s) as PAID?')) return;
                paySelBtn.disabled = true; paySelBtn.innerHTML = '⏳ Processing...';
                var ids = checked.map(function (c) { return c.getAttribute('data-id'); });
                var failed = 0;
                function next(idx) {
                    if (idx >= ids.length) {
                        if (typeof ltToast === 'function')
                            ltToast('💳 ' + (ids.length - failed) + ' paid' + (failed ? ' (' + failed + ' failed)' : ''), 'ok');
                        paySelBtn.disabled = false; paySelBtn.innerHTML = '💳 Mark Selected as Paid';
                        updateSelBar(); return;
                    }
                    payMember(ids[idx], rmk, function (ok) {
                        if (ok) {
                            var row = document.querySelector('.cs-flat-row[data-id="' + ids[idx] + '"]');
                            if (row) { row.style.opacity = '.25'; setTimeout(function () { row.remove(); }, 500); }
                        } else { failed++; }
                        next(idx + 1);
                    });
                }
                next(0);
            });
        }

        /* ══════════════════════════════════════════════════════════════
           PRINT ALL SLIPS
        ══════════════════════════════════════════════════════════════ */
        var printAllBtn = document.getElementById('btn-print-all-slips');
        if (printAllBtn) {
            printAllBtn.addEventListener('click', function () {
                var rows = Array.from(document.querySelectorAll('#cs-flat-tbody .cs-flat-row'));
                if (!rows.length) return;
                var phones = rows.map(function (r) { return (r.getAttribute('data-phone') || '').trim(); })
                                 .filter(function (p, i, a) { return p && a.indexOf(p) === i; });
                Promise.all(phones.map(fetchBank)).then(function () {
                    var slips = rows.map(function (row) {
                        return buildSlipHTML(
                            (row.getAttribute('data-phone')  || '').trim(),
                            row.getAttribute('data-name')    || '',
                            row.getAttribute('data-college') || '',
                            row.getAttribute('data-year')    || '',
                            row.getAttribute('data-amt')     || '0',
                            BC[(row.getAttribute('data-phone') || '').trim()]
                        );
                    }).join('<div style="page-break-after:always;margin:0;padding:0"></div>');
                    openPrintWindow(slips, 'All Payment Slips');
                });
            });
        }

        /* ══════════════════════════════════════════════════════════════
           PAY MEMBER (API call)
        ══════════════════════════════════════════════════════════════ */
        function payMember(id, remarks, cb) {
            fetch('/LicTada/CashierPay', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + encodeURIComponent(id) + '&remarks=' + encodeURIComponent(remarks)
            }).then(function (r) { return r.json(); })
              .then(function (res) { cb(res.success === true); })
              .catch(function () { cb(false); });
        }

        /* ══════════════════════════════════════════════════════════════
           PDF SLIP (individual / print-all)
        ══════════════════════════════════════════════════════════════ */
        function printSlip(phone, name, college, year, amt) {
            fetchBank(phone).then(function (d) {
                openPrintWindow(buildSlipHTML(phone, name, college, year, amt, d), 'Payment Slip - ' + name);
            });
        }

        function buildSlipHTML(phone, name, college, year, amt, d) {
            var found  = d && (d.found === true || d.Found === true);
            var acct   = found ? getVal(d, ['accountNumber',     'AccountNumber'])        : '';
            var bname  = found ? getVal(d, ['bankName',          'BankName'])             : '';
            var branch = found ? getVal(d, ['branchName',        'BranchName'])           : '';
            var ifsc   = found ? getVal(d, ['ifscCode',          'IfscCode', 'IFSCCode']) : '';
            var aname  = found ? getVal(d, ['accountHolderName', 'AccountHolderName'])    : '';
            var pan    = found ? getVal(d, ['panNumber',         'PanNumber'])            : '';
            var aadhar = found ? getVal(d, ['aadhaarNumber',     'AadhaarNumber'])        : '';
            var travel = found ? getVal(d, ['modeOfTravel',      'ModeOfTravel'])         : '';
            var amtFmt  = 'Rs. ' + parseFloat(amt || 0).toLocaleString('en-IN', { minimumFractionDigits: 2 });
            var dateStr = new Date().toLocaleString('en-IN');

            var bankRows = [
                ['Bank',           bname + (branch ? ' - ' + branch : '')],
                ['Account Name',   aname],
                ['Account No.',    acct || 'Not on file'],
                ['IFSC Code',      ifsc],
                ['PAN',            pan],
                ['Mode of Travel', travel],
                ['Aadhaar',        aadhar]
            ].filter(function (x) { return x[1] && x[1].trim(); });

            var bankTable = bankRows.length
                ? '<table style="width:100%;border-collapse:collapse;font-size:12px;margin-top:6px">'
                  + bankRows.map(function (r) {
                        return '<tr>'
                            + '<td style="padding:6px 10px;border:1px solid #e2e8f0;color:#888;font-size:10px;text-transform:uppercase;width:140px">' + esc(r[0]) + '</td>'
                            + '<td style="padding:6px 10px;border:1px solid #e2e8f0;font-weight:600;color:#1e293b">' + esc(r[1]) + '</td>'
                            + '</tr>';
                    }).join('') + '</table>'
                : '<p style="color:#e53e3e;font-size:12px;margin:8px 0">No bank details on file</p>';

            return '<div style="font-family:Arial,sans-serif;padding:36px 40px;color:#1e293b;max-width:680px;margin:auto">'
                + '<div style="display:flex;justify-content:space-between;align-items:flex-start;'
                +              'margin-bottom:18px;border-bottom:2px solid #e2e8f0;padding-bottom:16px">'
                +   '<div>'
                +     '<h1 style="margin:0 0 4px;font-size:22px;color:#1e293b">' + esc(name) + '</h1>'
                +     '<p style="margin:0;color:#64748b;font-size:13px">' + esc(college) + ' - ' + esc(year) + '</p>'
                +   '</div>'
                +   '<div style="text-align:right">'
                +     '<span style="display:inline-block;padding:4px 16px;border-radius:20px;background:#d1fae5;'
                +                  'color:#16a37f;font-size:11px;font-weight:700;border:1px solid #6ee7b7">Payment Slip</span>'
                +     '<br><span style="font-size:10px;color:#94a3b8;margin-top:4px;display:block">' + dateStr + '</span>'
                +   '</div>'
                + '</div>'
                + '<div style="font-size:9px;text-transform:uppercase;letter-spacing:.12em;color:#94a3b8;font-weight:700;margin-bottom:6px">Claim Amount</div>'
                + '<p style="font-size:32px;font-weight:800;color:#16a37f;margin:0 0 20px">' + amtFmt + '</p>'
                + '<hr style="border:none;border-top:1.5px solid #e2e8f0;margin:0 0 16px">'
                + '<div style="font-size:9px;text-transform:uppercase;letter-spacing:.12em;color:#94a3b8;font-weight:700;margin-bottom:8px">Bank Details</div>'
                + bankTable
                + '<footer style="margin-top:30px;text-align:center;font-size:10px;color:#cbd5e1;'
                +                'border-top:1px solid #eee;padding-top:12px">'
                +   'Generated by Medical Affiliation System - ' + dateStr
                + '</footer>'
                + '</div>';
        }

        function openPrintWindow(bodyHtml, title) {
            var html = '<!DOCTYPE html><html><head><meta charset="UTF-8"><title>' + esc(title) + '</title>'
                + '<style>'
                + 'body{margin:0;padding:0;background:#f8fafc}'
                + '.pbtn{display:block;margin:16px auto;padding:9px 28px;background:#2563eb;color:#fff;'
                +       'border:none;border-radius:8px;cursor:pointer;font-size:13px;font-weight:600;font-family:Arial,sans-serif}'
                + '@@media print{.pbtn{display:none}body{background:#fff}}'
                + '</style></head><body>'
                + '<button class="pbtn" onclick="window.print()">Print / Save as PDF</button>'
                + bodyHtml
                + '<button class="pbtn" onclick="window.print()">Print / Save as PDF</button>'
                + '</body></html>';
            var w = window.open('', '_blank', 'width=820,height=960,scrollbars=yes');
            if (!w) { alert('Pop-up blocked! Please allow pop-ups.'); return; }
            w.document.open(); w.document.write(html); w.document.close(); w.focus();
            setTimeout(function () { try { w.print(); } catch (e) {} }, 900);
        }

        /* ══════════════════════════════════════════════════════════════
           EXPORT — read visible rows from the table
           Columns: 0=chk 1=# 2=College 3=Year 4=Type 5=Member
                    6=BankAcct 7=BankName 8=Branch 9=IFSC
                    10=TotalClaim 11=Sanctioned 12=Action
        ══════════════════════════════════════════════════════════════ */
        function getExportRows() {
            return Array.from(document.querySelectorAll('#cs-flat-tbody .cs-flat-row'))
                        .filter(function (r) { return r.style.display !== 'none'; });
        }

        function rowToExportArray(row) {
            var tds = row.querySelectorAll('td');
            return [
                txt(tds[1]),        // #
                txt(tds[2]),        // College (name + town)
                txt(tds[3]),        // Acad Year
                txt(tds[4]),        // Type
                txt(tds[5]),        // Member Name
                dval(tds[6]),       // Bank A/C
                dval(tds[7]),       // Bank Name
                dval(tds[8]),       // Branch
                dval(tds[9]),       // IFSC
                amtClean(tds[10]),  // Total Claim
                amtClean(tds[11])   // Sanctioned
            ];
        }

        var EXPORT_HEADERS = [
            '#', 'College', 'Acad. Year', 'Type', 'Member Name',
            'Bank A/C No.', 'Bank Name', 'Branch', 'IFSC Code',
            'Total Claim (Rs.)', 'Sanctioned (Rs.)'
        ];

        function txt(td)      { return td ? td.textContent.trim() : ''; }
        function dval(td) {
            if (!td) return '';
            var v = (td.getAttribute('data-val') || '').trim();
            if (!v || v === '⏳' || v === '—') v = td.textContent.trim();
            if (v === '⏳' || v === '—') v = '';
            return v;
        }
        function amtClean(td) {
            if (!td) return '';
            return td.textContent.trim().replace(/Rs\.?/gi, '').replace(/[^\d,.-]/g, '').trim();
        }

        /* ══════════════════════════════════════════════════════════════
           EXCEL EXPORT — SheetJS
        ══════════════════════════════════════════════════════════════ */
        function exportExcel() {
            loadScript(
                'https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js',
                'sheetjs-xlsx',
                function () {
                    var rows   = getExportRows().map(rowToExportArray);
                    var wsData = [EXPORT_HEADERS].concat(rows.map(function (r) {
                        var copy = r.slice();
                        /* cols 9 & 10 = amounts → real numbers */
                        [9, 10].forEach(function (i) {
                            var n = parseFloat(String(copy[i]).replace(/,/g, ''));
                            copy[i] = isNaN(n) ? copy[i] : n;
                        });
                        return copy;
                    }));
                    var wb = XLSX.utils.book_new();
                    var ws = XLSX.utils.aoa_to_sheet(wsData);
                    ws['!cols'] = [
                        {wch:4},{wch:32},{wch:12},{wch:18},{wch:24},
                        {wch:18},{wch:22},{wch:16},{wch:14},{wch:14},{wch:14}
                    ];
                    XLSX.utils.book_append_sheet(wb, ws, 'Pending Payments');
                    XLSX.writeFile(wb, 'pending_payments_' + dateTag() + '.xlsx');
                }
            );
        }

        /* ══════════════════════════════════════════════════════════════
           PDF EXPORT — RGUHS style (jsPDF + AutoTable)
        ══════════════════════════════════════════════════════════════ */
        function exportPDF() {
            var rows       = getExportRows().map(rowToExportArray);
            var grandTotal = 0;
            rows.forEach(function (r) {
                grandTotal += parseFloat(String(r[9]).replace(/,/g, '').replace(/[^\d.]/g, '')) || 0;
            });
            var now     = new Date().toLocaleString('en-IN');
            var dateStr = new Date().toLocaleDateString('en-IN');

            /* Step 1: fetch logo → base64 */
            function loadLogoThenPDF(b64, mime) {
                loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js', 'jspdf-core', function () {
                    loadScript('https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js', 'jspdf-autotable', function () {
                        buildPDF(b64, mime);
                    });
                });
            }

            fetch('/images/newlogo.jpeg', { credentials: 'same-origin' })
                .then(function (r) { return r.blob(); })
                .then(function (blob) {
                    var reader = new FileReader();
                    reader.onloadend = function () {
                        loadLogoThenPDF(reader.result.split(',')[1], blob.type || 'image/jpeg');
                    };
                    reader.readAsDataURL(blob);
                })
                .catch(function () { loadLogoThenPDF(null, null); });

            /* Step 2: build PDF */
            function buildPDF(logoB64, logoMime) {
                var jsPDF   = window.jspdf.jsPDF;
                var doc     = new jsPDF({ orientation: 'landscape', unit: 'pt', format: 'a3' });
                var PW      = doc.internal.pageSize.getWidth();
                var PH      = doc.internal.pageSize.getHeight();
                var M       = 30;
                var HDR_H   = 105;
                var FTR_H   = 36;
                var TOP_BAR = 5;
                var LOGO_W  = 72;
                var LOGO_H  = 72;
                var RED     = [143, 26, 26];
                var DARK    = [30,  30,  30];
                var GREY    = [110, 110, 110];
                var LGREY   = [220, 220, 220];
                var WHITE   = [255, 255, 255];
                var TW      = PW - M * 2;

                /* watermark */
                function drawWatermark() {
                    if (!logoB64) return;
                    try {
                        doc.setGState(new doc.GState({ opacity: 0.04 }));
                        var wmW = PH * 0.85;
                        doc.addImage(logoB64, logoMime || 'JPEG', (PW - wmW) / 2, (PH - wmW) / 2, wmW, wmW);
                        doc.setGState(new doc.GState({ opacity: 1 }));
                    } catch (e) {}
                }

                /* page header */
                function drawPageHeader() {
                    doc.setFillColor(255, 255, 255);
                    doc.rect(0, 0, PW, HDR_H, 'F');
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(0, 0, PW, TOP_BAR, 'F');
                    if (logoB64) {
                        doc.addImage(logoB64, logoMime || 'JPEG', M, TOP_BAR + 10, LOGO_W, LOGO_H);
                        doc.addImage(logoB64, logoMime || 'JPEG', PW - M - LOGO_W, TOP_BAR + 10, LOGO_W, LOGO_H);
                    }
                    doc.setFontSize(18); doc.setFont('helvetica', 'bold');
                    doc.setTextColor.apply(doc, RED);
                    doc.text('Rajiv Gandhi University of Health Sciences, Karnataka', PW / 2, TOP_BAR + 30, { align: 'center' });
                    doc.setFontSize(9.5); doc.setFont('helvetica', 'normal');
                    doc.setTextColor.apply(doc, DARK);
                    doc.text("4th 'T' Block, Jayanagar, Bangalore - 560 041", PW / 2, TOP_BAR + 50, { align: 'center' });
                    doc.text('Phone: 080-29601933  |  Website: www.rguhs.ac.in',  PW / 2, TOP_BAR + 65, { align: 'center' });
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(0, HDR_H - 5, PW, 3, 'F');
                    doc.setFillColor(200, 200, 200);
                    doc.rect(0, HDR_H - 2, PW, 1, 'F');
                }

                /* section heading */
                function sectionHeading(label, y) {
                    doc.setDrawColor.apply(doc, LGREY);
                    doc.setFillColor(250, 250, 252);
                    doc.rect(M, y, TW, 24, 'FD');
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(M, y, 5, 24, 'F');
                    doc.setFontSize(10.5); doc.setFont('helvetica', 'bold');
                    doc.setTextColor.apply(doc, RED);
                    doc.text(label, M + 14, y + 17);
                }

                /* page footer */
                function drawPageFooter() {
                    doc.setFillColor.apply(doc, RED);
                    doc.rect(0, PH - FTR_H, PW, 2, 'F');
                    doc.setFontSize(8); doc.setFont('helvetica', 'normal');
                    doc.setTextColor.apply(doc, GREY);
                    doc.text('Rajiv Gandhi University of Health Sciences, Karnataka', M, PH - FTR_H + 18);
                    doc.setFont('helvetica', 'bold'); doc.setTextColor.apply(doc, DARK);
                    doc.text('Printed on: ' + dateStr, PW - M, PH - FTR_H + 18, { align: 'right' });
                }

                /* PAGE 1 */
                drawWatermark();
                drawPageHeader();

                /* summary section */
                var sy = HDR_H + 6;
                sectionHeading('Pending Payments Report', sy);

                var infoData = [
                    ['Report Generated',      now],
                    ['Total Pending Records', String(rows.length)],
                    ['Grand Total Claim',     'Rs. ' + fmt(grandTotal)]
                ];
                var infoY = sy + 24;
                infoData.forEach(function (pair, i) {
                    doc.setFillColor.apply(doc, i % 2 === 0 ? [255,255,255] : [248,249,252]);
                    doc.setDrawColor.apply(doc, LGREY);
                    doc.rect(M, infoY, TW, 22, 'FD');
                    doc.setFontSize(9); doc.setFont('helvetica', 'normal');
                    doc.setTextColor.apply(doc, GREY);
                    doc.text(pair[0], M + 10, infoY + 15);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor.apply(doc, i === 2 ? RED : DARK);
                    doc.text(pair[1], M + 240, infoY + 15);
                    infoY += 22;
                });

                /* table */
                var tableHeadY = infoY + 12;
                sectionHeading('Pending Payment Details', tableHeadY);

                /* build body — split college cell into name + town */
                var tableBody = rows.map(function (r) {
                    var college  = r[1];
                    var townPart = '';
                    var parts    = college.split('\n');
                    if (parts.length > 1) {
                        college  = parts[0].trim();
                        townPart = parts[1].replace(/·.*$/, '').trim();
                    }
                    return [
                        r[0],       // #
                        college,    // College Name
                        townPart,   // Town
                        r[2],       // Acad Year
                        r[3],       // Type
                        r[4],       // Member Name
                        r[5],       // Bank A/C
                        r[6],       // Bank Name
                        r[7],       // Branch
                        r[8],       // IFSC
                        r[9],       // Total Claim
                        r[10]       // Sanctioned
                    ];
                });

                /* proportional column widths — 12 cols, sum = TW */
                var units = [2, 13, 6, 5, 8, 10, 10, 8, 7, 6.5, 7, 7];
                var uSum  = units.reduce(function (a, b) { return a + b; }, 0);
                var cw    = units.map(function (u) { return +(u * TW / uSum).toFixed(1); });

                doc.autoTable({
                    startY:     tableHeadY + 24,
                    tableWidth: TW,
                    head: [[
                        '#', 'College', 'Town', 'Acad. Year', 'Type', 'Member Name',
                        'Bank A/C No.', 'Bank Name', 'Branch', 'IFSC',
                        'Total Claim (Rs.)', 'Sanctioned (Rs.)'
                    ]],
                    body: tableBody,
                    foot: [[
                        '', '', '', '', '',
                        { content: 'Grand Total', colSpan: 5,
                          styles: { halign: 'right', fontStyle: 'bold', textColor: RED } },
                        '', '', '', '',
                        { content: 'Rs. ' + fmt(grandTotal),
