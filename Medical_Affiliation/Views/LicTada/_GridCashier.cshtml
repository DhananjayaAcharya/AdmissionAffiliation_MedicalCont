                        doc.setGState(new doc.GState({ opacity: 0.04 }));
                        var wmW = PH * 0.85;   // ~715 pt — nearly full page height
                        var wmH = wmW;
                        doc.addImage(
                            logoB64, logoMime || 'JPEG',
                            (PW - wmW) / 2,
                            (PH - wmH) / 2,
