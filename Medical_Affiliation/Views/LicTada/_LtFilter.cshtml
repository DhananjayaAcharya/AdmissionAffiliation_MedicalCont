@model Medical_Affiliation.Models.LicTadaDashboardVM
@{
    var filterId = ViewBag.FilterId as string ?? "ltFilter";
    var btnId = ViewBag.FilterBtnId as string ?? "ltFilterBtn";
    var fetchFn = ViewBag.FetchFn as string ?? "ltFetch()";
    var yearId = ViewBag.YearId as string ?? "ltYear";
    var facId = ViewBag.FacId as string ?? "ltFaculty";
    var colId = ViewBag.ColId as string ?? "ltCollege";
}
<div id="@filterId" style="display:none;padding:20px 24px;background:linear-gradient(135deg,#f0f4ff,#f8fafc);border-bottom:1px solid #edf1f7;display:none;grid-template-columns:1fr 1fr 1fr auto;gap:16px;align-items:end;animation:fadeSlide .2s ease">
    <style>
        @@keyframes fadeSlide {
            from

        {
            opacity: 0;
            transform: translateY(-8px)
        }

        to {
            opacity: 1;
            transform: none
        }

        }</style>
    <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:600;color:#8fa3be;text-transform:uppercase;letter-spacing:.12em">📅 Academic Year</label>
        <select id="@yearId" style="padding:0 34px 0 14px;background:#fff;border:1.5px solid #e2e8f3;border-radius:12px;color:#0d1b2e;font-family:'JetBrains Mono',monospace;font-size:12px;outline:none;height:42px;cursor:pointer;appearance:none;background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%228%22 viewBox=%220 0 12 8%22%3E%3Cpath d=%22M1 1l5 5 5-5%22 stroke=%22%238fa3be%22 stroke-width=%221.5%22 fill=%22none%22 stroke-linecap=%22round%22/%3E%3C/svg%3E');background-repeat:no-repeat;background-position:right 12px center"
                onfocus="this.style.borderColor='#2d6be4';this.style.boxShadow='0 0 0 4px rgba(45,107,228,.1)'"
                onblur="this.style.borderColor='#e2e8f3';this.style.boxShadow='none'">
            <option value="">— All Years —</option>
            @foreach (var y in Model.AcademicYears)
            {
                <option value="@y.Value">@y.Text</option>
            }
        </select>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:600;color:#8fa3be;text-transform:uppercase;letter-spacing:.12em">🏛 Faculty</label>
        <select id="@facId" style="padding:0 34px 0 14px;background:#fff;border:1.5px solid #e2e8f3;border-radius:12px;color:#0d1b2e;font-family:'JetBrains Mono',monospace;font-size:12px;outline:none;height:42px;cursor:pointer;appearance:none;background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%228%22 viewBox=%220 0 12 8%22%3E%3Cpath d=%22M1 1l5 5 5-5%22 stroke=%22%238fa3be%22 stroke-width=%221.5%22 fill=%22none%22 stroke-linecap=%22round%22/%3E%3C/svg%3E');background-repeat:no-repeat;background-position:right 12px center"
                onfocus="this.style.borderColor='#2d6be4';this.style.boxShadow='0 0 0 4px rgba(45,107,228,.1)'"
                onblur="this.style.borderColor='#e2e8f3';this.style.boxShadow='none'">
            <option value="">— All Faculties —</option>
            @foreach (var f in Model.Faculties)
            {
                <option value="@f.Value">@f.Text</option>
            }
        </select>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:600;color:#8fa3be;text-transform:uppercase;letter-spacing:.12em">🏫 College</label>
        <select id="@colId" style="padding:0 34px 0 14px;background:#fff;border:1.5px solid #e2e8f3;border-radius:12px;color:#0d1b2e;font-family:'JetBrains Mono',monospace;font-size:12px;outline:none;height:42px;cursor:pointer;appearance:none;background-image:url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%228%22 viewBox=%220 0 12 8%22%3E%3Cpath d=%22M1 1l5 5 5-5%22 stroke=%22%238fa3be%22 stroke-width=%221.5%22 fill=%22none%22 stroke-linecap=%22round%22/%3E%3C/svg%3E');background-repeat:no-repeat;background-position:right 12px center"
                onfocus="this.style.borderColor='#2d6be4';this.style.boxShadow='0 0 0 4px rgba(45,107,228,.1)'"
                onblur="this.style.borderColor='#e2e8f3';this.style.boxShadow='none'">
            <option value="">— All Colleges —</option>
            @foreach (var c in Model.Colleges)
            {
                <option value="@c.Value">@c.Text</option>
            }
        </select>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:600;color:transparent;text-transform:uppercase;letter-spacing:.12em">&nbsp;</label>
        <button onclick="@fetchFn"
                style="background:linear-gradient(135deg,#1e2d52,#2d6be4);border:none;border-radius:12px;padding:0 24px;color:#fff;cursor:pointer;font-family:'Outfit',sans-serif;font-size:13px;font-weight:700;height:42px;white-space:nowrap;box-shadow:0 4px 14px rgba(45,107,228,.35);transition:all .18s;display:flex;align-items:center;gap:7px"
                onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 6px 20px rgba(45,107,228,.45)'"
                onmouseout="this.style.transform='none';this.style.boxShadow='0 4px 14px rgba(45,107,228,.35)'">
            🔍 Fetch Records
        </button>
    </div>
</div>
<script>
    document.getElementById('@filterId').style.display = 'none';
</script>