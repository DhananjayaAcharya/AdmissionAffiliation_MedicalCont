@model Medical_Affiliation.Models.LicTadaDashboardVM
@{
    Layout = null;
    var userName = ViewBag.UserName as string ?? "Finance Officer";
    var label    = ViewBag.DesignationLabel as string ?? "Finance Officer";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Finance Officer — LIC TA/DA</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/lictada.css" />
</head>
<body>

    <nav class="lt-nav">
        <div class="lt-brand">
            <div class="lt-brand-icon">🎓</div>
            <div>
                <div class="lt-brand-name">LIC TA/DA Management</div>
                <div class="lt-brand-sub">RGUHS · Affiliation Portal</div>
            </div>
        </div>
        <div class="lt-user">
            <span class="lt-desig-badge" style="background:#dbeafe;color:#2563eb;border:1.5px solid #93c5fd">@label</span>
            <span class="lt-uname">@userName</span>
            <div class="lt-avatar" style="background:linear-gradient(135deg,#2563eb,#7c3aed)">
                @(userName.Length >= 2 ? userName.Substring(0, 2).ToUpper() : "FO")
            </div>
            <form asp-controller="Admin" asp-action="FinanceLogout" method="post" style="display:inline;">
                <button type="submit" class="lt-logout">⏏ Logout</button>
            </form>
        </div>
    </nav>

    <div class="lt-page">

        <div class="lt-page-hd">
            <div class="lt-ph-left">
                <h1>Finance Officer Dashboard</h1>
                <p>LIC Inspection College &mdash; TA/DA Claim Processing and Routing</p>
            </div>
        </div>

        <div class="lt-workflow">
            <div class="lt-wf-step lt-wf-active"><span class="lt-wf-badge wfb-blue">FO</span><span class="lt-wf-label">Finance Officer</span></div>
            <span class="lt-wf-arrow">→</span>
            <div class="lt-wf-step"><span class="lt-wf-badge wfb-gold">SO/AS/AO</span><span class="lt-wf-label">Routing Desk</span></div>
            <span class="lt-wf-arrow">→</span>
            <div class="lt-wf-step"><span class="lt-wf-badge wfb-violet">CW</span><span class="lt-wf-label">Case Worker</span></div>
            <span class="lt-wf-arrow">→</span>
            <div class="lt-wf-step"><span class="lt-wf-badge wfb-gold">SO/AS/AO</span><span class="lt-wf-label">Verification</span></div><span class="lt-wf-arrow">&rarr;</span><div class="lt-wf-step lt-wf-active"><span class="lt-wf-badge wfb-blue">FO2</span><span class="lt-wf-label">Final Decision</span></div>
            <span class="lt-wf-arrow">→</span>
            <div class="lt-wf-step"><span class="lt-wf-badge wfb-rose">Reject</span><span class="lt-wf-label">Director</span></div>
            <span class="lt-wf-arrow">/ →</span>
            <div class="lt-wf-step"><span class="lt-wf-badge wfb-emerald">CS</span><span class="lt-wf-label">Cashier</span></div>
        </div>

        <div class="lt-tab-wrap">
            <button class="lt-tab active" id="tabFresh" onclick="ltTab('fresh')">
                📥 Fresh Records
                <span class="lt-tab-badge" id="badgeFresh" style="background:#fef7e6;color:#d4860a;border:1px solid #f0cc84">—</span>
            </button>
            <button class="lt-tab" id="tabFinal" onclick="ltTab('final')">
                ✅ FO2 Decision
                <span class="lt-tab-badge" id="badgeFinal" style="background:#d1fae5;color:#16a37f;border:1px solid #6ee7b7">—</span>
            </button>
            <!-- ADD THIS -->
            <button class="lt-tab" id="tabPaid" onclick="ltTab('paid')">
                💰 Amount Paid List
                <span class="lt-tab-badge" id="badgePaid" style="background:#d1fae5;color:#16a37f;border:1px solid #6ee7b7">—</span>
            </button>
        </div>

        <!-- TAB 1 : Fresh Records -->
        <div id="paneFresh">
            <div class="lt-card">
                <div class="lt-card-hd">
                    <div>
                        <div class="lt-card-title">📥 Fresh Records from Director</div>
                        <div class="lt-card-sub">Approved by Director · Not yet forwarded to Case Worker</div>
                    </div>
                    <button class="lt-btn-sec" id="btnFresh" onclick="ltToggleFilter('filterFresh','btnFresh')">▼ Show Filters</button>
                </div>
                <div class="lt-filter" id="filterFresh" style="display:none">
                    <div class="lt-fg">
                        <label class="lt-lbl">📅 Academic Year</label>
                        <select id="ltYearF" class="lt-sel">
                            <option value="">— All Years —</option>
                            @foreach (var y in Model.AcademicYears)
                            {
                                <option value="@y.Value">@y.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">🏛 Faculty</label>
                        <select id="ltFacF" class="lt-sel">
                            <option value="">— All Faculties —</option>
                            @foreach (var f in Model.Faculties)
                            {
                                <option value="@f.Value">@f.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">🏫 College</label>
                        <select id="ltColF" class="lt-sel">
                            <option value="">— All Colleges —</option>
                            @foreach (var c in Model.Colleges)
                            {
                                <option value="@c.Value">@c.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">&nbsp;</label>
                        <button class="lt-btn-fetch" onclick="ltFetchFresh()">🔍 Fetch Records</button>
                    </div>
                </div>
                <div id="gridFresh">
                    <div class="lt-empty">
                        <div style="font-size:40px;margin-bottom:10px">📋</div>
                        Open filters and click Fetch to load fresh records
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB 2 : FO2 Decision -->
        <div id="paneFinal" style="display:none">
            <div class="lt-card">
                <div class="lt-card-hd">
                    <div>
                        <div class="lt-card-title">✅ FO2 Decision</div>
                        <div class="lt-card-sub">SO/AS/AO verified · Awaiting your FO2 Decision before Cashier</div>
                    </div>
                    <button class="lt-btn-sec" id="btnFinal" onclick="ltToggleFilter('filterFinal','btnFinal')">▼ Show Filters</button>
                </div>
                <div class="lt-filter" id="filterFinal" style="display:none">
                    <div class="lt-fg">
                        <label class="lt-lbl">📅 Academic Year</label>
                        <select id="ltYearN" class="lt-sel">
                            <option value="">— All Years —</option>
                            @foreach (var y in Model.FinalAcademicYears)
                            {
                                <option value="@y.Value">@y.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">🏛 Faculty</label>
                        <select id="ltFacN" class="lt-sel">
                            <option value="">— All Faculties —</option>
                            @foreach (var f in Model.FinalFaculties)
                            {
                                <option value="@f.Value">@f.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">🏫 College</label>
                        <select id="ltColN" class="lt-sel">
                            <option value="">— All Colleges —</option>
                            @foreach (var c in Model.FinalColleges)
                            {
                                <option value="@c.Value">@c.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">&nbsp;</label>
                        <button class="lt-btn-fetch" onclick="ltFetchFinal()">🔍 Fetch Records</button>
                    </div>
                </div>
                <div id="gridFinal">
                    <div class="lt-empty">
                        <div style="font-size:40px;margin-bottom:10px">✅</div>
                        Open filters and click Fetch to load FO2 Decision records
                    </div>
                </div>
            </div>
        </div>

        <div id="cardPaid" style="display:none">
            <div class="lt-card">
                <div class="lt-card-hd">
                    <div>
                        <div class="lt-card-title">💰 Amount Paid List</div>
                        <div class="lt-card-sub">All payments processed by Cashier</div>
                    </div>
                    <button class="lt-btn-sec" id="btnPD" onclick="ltToggleFilter('filterPD','btnPD')">▼ Show Filters</button>
                </div>
                <div class="lt-filter" id="filterPD" style="display:none">
                    <div class="lt-fg">
                        <label class="lt-lbl">📅 Academic Year</label>
                        <select id="ltYearPD" class="lt-sel">
                            <option value="">— All Years —</option>
                            @foreach (var y in Model.PaidAcademicYears)
                            {
                                <option value="@y.Value">@y.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">🏛 Faculty</label>
                        <select id="ltFacPD" class="lt-sel">
                            <option value="">— All Faculties —</option>
                            @foreach (var f in Model.PaidFaculties)
                            {
                                <option value="@f.Value">@f.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">🏫 College</label>
                        <select id="ltColPD" class="lt-sel">
                            <option value="">— All Colleges —</option>
                            @foreach (var c in Model.PaidColleges)
                            {
                                <option value="@c.Value">@c.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">&nbsp;</label>
                        <button class="lt-btn-fetch" onclick="ltFetchPD()">🔍 Fetch Records</button>
                    </div>
                </div>
                <div id="gridPD">
                    <div class="lt-empty">
                        <div style="font-size:40px;margin-bottom:10px">💰</div>
                        Open filters and click Fetch to load paid records
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Modal overlay -->
    <div id="ltOverlay"
         style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(17,24,39,.7);
                backdrop-filter:blur(6px);align-items:center;justify-content:center;padding:16px"
         onclick="ltCloseOut(event)">
        <div style="background:#fff;border-radius:24px;width:100%;max-width:820px;max-height:92vh;
                    overflow-y:auto;box-shadow:0 32px 80px rgba(17,24,39,.3);
                    animation:mdIn .22s cubic-bezier(.34,1.2,.64,1)">
            <div id="ltModalContent">
                <div class="lt-loading" style="padding:60px">⏳ Loading...</div>
            </div>
        </div>
    </div>
    <div id="ltToast" class="lt-toast" style="display:none"></div>

    <style>
        @@keyframes mdIn {
            from { opacity:0; transform:translateY(24px) scale(.97); }
            to   { opacity:1; transform:none; }
        }
    </style>

    <script src="/js/lictada.js"></script>
    <script>
               function ltTab(name) {
            document.getElementById('paneFresh').style.display  = name === 'fresh' ? 'block' : 'none';
            document.getElementById('paneFinal').style.display  = name === 'final' ? 'block' : 'none';
            document.getElementById('cardPaid').style.display   = name === 'paid'  ? 'block' : 'none';

            document.getElementById('tabFresh').className = 'lt-tab' + (name === 'fresh' ? ' active' : '');
            document.getElementById('tabFinal').className = 'lt-tab' + (name === 'final' ? ' active' : '');
            document.getElementById('tabPaid').className  = 'lt-tab' + (name === 'paid'  ? ' active' : '');
        }
        function ltFetchFresh() {
            ltDoFetch('/LicTada/FOFreshGrid', 'gridFresh',
                document.getElementById('ltYearF').value,
                document.getElementById('ltFacF').value,
                document.getElementById('ltColF').value,
                function (n) { document.getElementById('badgeFresh').textContent = n; });
        }
        function ltFetchFinal() {
            ltDoFetch('/LicTada/FOFinalGrid', 'gridFinal',
                document.getElementById('ltYearN').value,
                document.getElementById('ltFacN').value,
                document.getElementById('ltColN').value,
                function (n) { document.getElementById('badgeFinal').textContent = n; });
        }

                       function ltFetchPD() {
            var gridEl = document.getElementById('gridPD');
            gridEl.innerHTML = '<div class="lt-loading" style="padding:40px">⏳ Loading records...</div>';
            fetch('/LicTada/AllPaidGrid', {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                body: 'year='     + encodeURIComponent(document.getElementById('ltYearPD').value)
                    + '&faculty=' + encodeURIComponent(document.getElementById('ltFacPD').value)
                    + '&college=' + encodeURIComponent(document.getElementById('ltColPD').value)
            })
            .then(function(r) { return r.text(); })
            .then(function(html) {
                gridEl.innerHTML = '';
                var tmp = document.createElement('div');
                tmp.innerHTML = html;
                while (tmp.firstChild) gridEl.appendChild(tmp.firstChild);
                gridEl.querySelectorAll('script').forEach(function(old) {
                    try {
                        var s = document.createElement('script');
                        var blob = new Blob([old.textContent], { type: 'text/javascript' });
                        var url = URL.createObjectURL(blob);
                        s.src = url; s.onload = function() { URL.revokeObjectURL(url); };
                        document.body.appendChild(s);
                    } catch(e) { console.warn(e); }
                });
                var rows = gridEl.querySelectorAll('.pd-flat-row');
                document.getElementById('badgePaid').textContent = rows.length || '0';
                /* FIX: increased delay to 500ms so Blob scripts finish executing
                   before pdPrefetchAll is called. The partial view's own boot()
                   also defers loadAllBankCols via setTimeout(fn,0) as a second
                   safety net, so bank details load correctly either way. */
                setTimeout(function() {
                    if (typeof window.pdPrefetchAll === 'function') window.pdPrefetchAll();
                }, 500);
            })
            .catch(function(err) {
                gridEl.innerHTML = '<div class="lt-empty">⚠️ Failed to load paid records.</div>';
                console.error(err);
            });
        }
        function ltForward(id, btn, routedTo) {
            if (!routedTo) { ltToast('Please select SO/AS/AO before forwarding.', 'err'); return; }
            btn.disabled    = true;
            btn.textContent = '⏳ Forwarding...';
            fetch('/LicTada/ForwardToCW', {
                method:  'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body:    'id=' + id + '&remarks=&routedTo=' + encodeURIComponent(routedTo)
            })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (res.success) {
                    btn.textContent = '✅ Forwarded';
                    btn.style.background  = '#d1fae5';
                    btn.style.color       = '#16a37f';
                    btn.style.borderColor = '#6ee7b7';
                    btn.style.boxShadow   = 'none';
                    ltToast('✓ Forwarded to ' + routedTo + ' successfully', 'ok');
                    var firstRow = document.getElementById('fogrp_' + id);
                    if (firstRow) {
                        var midRow  = firstRow.nextElementSibling;
                        var lastRow = midRow ? midRow.nextElementSibling : null;
                        [firstRow, midRow, lastRow].forEach(function (row) {
                            if (row) { row.style.transition = 'opacity .5s'; row.style.opacity = '.2'; }
                        });
                        setTimeout(function () {
                            if (firstRow) firstRow.remove();
                            if (midRow)   midRow.remove();
                            if (lastRow)  lastRow.remove();
                        }, 550);
                    }
                } else {
                    ltToast('Forward failed. Please try again.', 'err');
                    btn.disabled    = false;
                    btn.textContent = '📤 Forward to CW';
                }
            })
            .catch(function () {
                ltToast('Network error. Please try again.', 'err');
                btn.disabled    = false;
                btn.textContent = '📤 Forward to CW';
            });
        }

        function ltFO2Approve(id, btn) {
            var rmk = prompt('Approval remarks (optional):') || '';
            if (!confirm('APPROVE — send to Cashier?')) return;
            btn.disabled = true; btn.textContent = '⏳';
            fetch('/LicTada/FO2Approve', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body:   'id=' + id + '&remarks=' + encodeURIComponent(rmk)
            })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (res.success) { ltToast('✅ Approved — sent to Cashier', 'ok'); fadeRow(btn); }
                else { ltToast('Approval failed.', 'err'); btn.disabled = false; btn.textContent = '✅ Approve'; }
            })
            .catch(function () { ltToast('Network error.', 'err'); btn.disabled = false; });
        }

        function ltFO2Reject(id, btn) {
            var rmk = prompt('Rejection reason (required):');
            if (!rmk || !rmk.trim()) { ltToast('Remarks required.', 'err'); return; }
            if (!confirm('REJECT — return to Director?')) return;
            btn.disabled = true; btn.textContent = '⏳';
            fetch('/LicTada/FO2Reject', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body:   'id=' + id + '&remarks=' + encodeURIComponent(rmk)
            })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (res.success) { ltToast('Rejected — returned to Director.', 'err'); fadeRow(btn); }
                else { ltToast('Reject failed.', 'err'); btn.disabled = false; btn.textContent = '❌ Reject'; }
            })
            .catch(function () { ltToast('Network error.', 'err'); btn.disabled = false; });
        }

        function fadeRow(btn) {
            var row = btn.closest('tr');
            if (row) {
                row.style.transition = 'opacity .5s';
                row.style.opacity    = '.25';
                setTimeout(function () { row.remove(); }, 600);
            }
        }


         function loadBankPanels(container) {
            (container || document).querySelectorAll('.bank-panel[data-phone], .pd-bank-panel[data-phone]').forEach(function(p) {
                if (p.getAttribute('data-loaded') === 'true') return;
                var phone = (p.getAttribute('data-phone') || '').trim();
                if (!phone) {
                    p.innerHTML = '<span style="font-family:\'IBM Plex Mono\',monospace;font-size:11px;color:#d4860a">⚠️ No phone number</span>';
                    p.setAttribute('data-loaded', 'true'); return;
                }
                p.innerHTML = '<span style="font-family:\'IBM Plex Mono\',monospace;font-size:10px;color:#94a3b8">⏳ Loading…</span>';
                fetch('/LicTada/BankDetails?phone=' + encodeURIComponent(phone), {
                    method: 'GET', credentials: 'same-origin',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(function(r) { return r.json(); })
                .then(function(d) {
                    var found  = d && (d.found === true || d.Found === true);
                    var acctNo = d ? (d.accountNumber || d.AccountNumber || '') : '';
                    if (!found || !acctNo.trim()) {
                        p.innerHTML = '<span style="font-family:\'IBM Plex Mono\',monospace;font-size:11px;color:#d4860a;background:#fef7e6;border:1px solid #f0cc84;border-radius:6px;padding:4px 10px;display:inline-block">⚠️ No bank info on file</span>';
                        p.setAttribute('data-loaded', 'true'); return;
                    }
                    var bank   = d.bankName           || d.BankName           || '';
                    var branch = d.branchName         || d.BranchName         || '';
                    var name   = d.accountHolderName  || d.AccountHolderName  || '';
                    var ifsc   = d.ifscCode           || d.IfscCode           || d.IFSCCode  || '';
                    var pan    = d.panNumber          || d.PanNumber          || d.PANNumber || '';
                    var travel = d.modeOfTravel       || d.ModeOfTravel       || '';
                    var aadhar = d.aadhaarNumber      || d.AadhaarNumber      || '';
                    var rows = [
                        ['Bank',     bank + (branch ? ' · ' + branch : ''), '#1e293b', '700'],
                        ['A/C Name', name,   '#1e293b', '500'],
                        ['A/C No.',  acctNo, '#16a37f', '700'],
                        ['IFSC',     ifsc,   '#2563eb', '500'],
                        ['PAN',      pan,    '#64748b', '500'],
                        ['Travel',   travel, '#64748b', '500'],
                        ['Aadhaar',  aadhar, '#64748b', '500'],
                    ].filter(function(x) { return x[1] && x[1].trim(); });
                    var h = '<div style="display:grid;grid-template-columns:76px 1fr;gap:3px 8px;font-family:\'IBM Plex Mono\',monospace;font-size:11px">';
                    rows.forEach(function(x) {
                        h += '<span style="color:#94a3b8;font-size:9px;text-transform:uppercase;letter-spacing:.07em">' + esc(x[0]) + '</span>'
                           + '<span style="color:' + x[2] + ';font-weight:' + x[3] + '">' + esc(x[1]) + '</span>';
                    });
                    h += '</div>';
                    p.innerHTML = h;
                    p.setAttribute('data-loaded', 'true');
                })
                .catch(function(err) {
                    p.innerHTML = '<span style="color:#e53e3e;font-family:\'IBM Plex Mono\',monospace;font-size:11px">⚠️ ' + esc(err.message) + '</span>';
                    p.setAttribute('data-loaded', 'true');
                });
            });
        }

    </script>
</body>
</html>




