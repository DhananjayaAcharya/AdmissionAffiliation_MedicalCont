@model Medical_Affiliation.Models.LicTadaDashboardVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>LIC TA/DA Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/lictada.css" />
</head>
<body>

    <nav class="lt-nav">
        <div class="lt-brand">
            <div class="lt-brand-icon">🎓</div>
            <div>
                <div class="lt-brand-name">LIC TA/DA Management</div>
                <div class="lt-brand-sub">University Affiliation Portal</div>
            </div>
        </div>
        <div class="lt-user">
            <span class="lt-role">Finance Officer</span>
            <div class="lt-avatar" style="background:linear-gradient(135deg,#2563eb,#7c3aed)">FO</div>
        </div>
    </nav>

    <div class="lt-page">

        <div class="lt-page-hd">
            <div class="lt-ph-left">
                <h1>Payment Dashboard</h1>
                <p>LIC Inspection College &mdash; TA/DA Claim Processing &amp; Verification</p>
            </div>
        </div>

        <!-- Workflow Banner -->
        <div class="lt-workflow">
            <div class="lt-wf-step">
                <span class="lt-wf-badge wfb-blue">FO</span>
                <span class="lt-wf-label">Finance Officer</span>
            </div>
            <span class="lt-wf-arrow">→</span>
            <div class="lt-wf-step">
                <span class="lt-wf-badge wfb-violet">CW</span>
                <span class="lt-wf-label">Case Worker</span>
            </div>
            <span class="lt-wf-arrow">→</span>
            <div class="lt-wf-step">
                <span class="lt-wf-badge wfb-gold">AO/AS</span>
                <span class="lt-wf-label">SO/AS/AO</span>
            </div>
            <span class="lt-wf-arrow">→</span>
            <div class="lt-wf-step">
                <span class="lt-wf-badge wfb-blue">FO2</span>
                <span class="lt-wf-label">FO2 Decision</span>
            </div>
            <span class="lt-wf-arrow">→</span>
            <div class="lt-wf-step">
                <span class="lt-wf-badge wfb-rose">Reject</span>
                <span class="lt-wf-label">Director</span>
            </div>
            <span class="lt-wf-arrow">/ →</span>
            <div class="lt-wf-step">
                <span class="lt-wf-badge wfb-emerald">CS</span>
                <span class="lt-wf-label">Cashier</span>
            </div>
        </div>

        <!-- Stat Cards -->
        <div class="lt-stats" id="ltStats" style="display:none">
            <div class="lt-stat" style="border-color:#93c5fd">
                <div class="lt-si">📋</div>
                <div class="lt-sv" id="stTotal" style="color:#2563eb">0</div>
                <div class="lt-sl">Total Records</div>
            </div>
            <div class="lt-stat" style="border-color:#c4b5fd">
                <div class="lt-si">✅</div>
                <div class="lt-sv" id="stCW" style="color:#7c3aed">0</div>
                <div class="lt-sl">CW Verified</div>
            </div>
            <div class="lt-stat" style="border-color:#f0cc84">
                <div class="lt-si">📤</div>
                <div class="lt-sv" id="stFO" style="color:#d4860a">0</div>
                <div class="lt-sl">FO Forwarded</div>
            </div>
            <div class="lt-stat" style="border-color:#6ee7b7">
                <div class="lt-si">🔍</div>
                <div class="lt-sv" id="stAO" style="color:#16a37f">0</div>
                <div class="lt-sl">ASAO Verified</div>
            </div>
            <div class="lt-stat" style="border-color:#6ee7b7">
                <div class="lt-si">💰</div>
                <div class="lt-sv" id="stCS" style="color:#16a37f">0</div>
                <div class="lt-sl">Gone for Cashier</div>
            </div>
        </div>

        <!-- Main Card -->
        <div class="lt-card">
            <div class="lt-card-hd">
                <div style="display:flex;align-items:center;gap:10px">
                    <span style="font-size:18px">💳</span>
                    <div>
                        <div class="lt-card-title">Verify Payments</div>
                    </div>
                </div>
                <button class="lt-btn-pri" id="ltToggleBtn" onclick="ltToggle()">
                    ▼ Open Panel
                </button>
            </div>

            <!-- Filter Panel -->
            <div id="ltPanel" style="display:none">
                <div class="lt-filter">
                    <div class="lt-fg">
                        <label class="lt-lbl">Academic Year</label>
                        <select id="ltYear" class="lt-sel">
                            <option value="">— Select Year —</option>
                            @foreach (var y in Model.AcademicYears)
                            {
                                <option value="@y.Value">@y.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">Faculty</label>
                        <select id="ltFaculty" class="lt-sel">
                            <option value="">— Select Faculty —</option>
                            @foreach (var f in Model.Faculties)
                            {
                                <option value="@f.Value">@f.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">College</label>
                        <select id="ltCollege" class="lt-sel">
                            <option value="">— All Colleges —</option>
                            @foreach (var c in Model.Colleges)
                            {
                                <option value="@c.Value">@c.Text</option>
                            }
                        </select>
                    </div>
                    <div class="lt-fg">
                        <label class="lt-lbl">&nbsp;</label>
                        <button class="lt-btn-fetch" onclick="ltFetch()">
                            🔍 Fetch Records
                        </button>
                    </div>
                </div>
            </div>

            <!-- Grid populated by AJAX -->
            <div id="ltGrid"></div>
        </div>

    </div>

    <!-- Member Detail Modal -->
    <div id="ltOverlay" class="lt-overlay" style="display:none"
         onclick="ltCloseOut(event)">
        <div class="lt-modal">
            <div id="ltModalContent">
                <div class="lt-loading">⏳ Loading...</div>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div id="ltToast" class="lt-toast" style="display:none"></div>

    <script src="~/js/lictada.js"></script>
</body>
</html>


