@{
    var active = ViewBag.WfActive as string ?? "";
}
<div class="lt-workflow">
    @{
        var steps = new (string Key, string Badge, string Label, string Cls)[] {
            ("fo",      "FO",  "Finance Officer",  "wfb-blue"),
            ("soa",     "SO",  "SO/AS/AO Routing", "wfb-gold"),
            ("cw",      "CW",  "Case Worker",      "wfb-violet"),
            ("ao",      "SO",  "SO/AS/AO Verify",  "wfb-gold"),
            ("fo2",     "FO2", "FO2 Decision",     "wfb-blue"),
            ("cashier", "CS",  "Cashier",          "wfb-emerald"),
        };
    }

    @for (int i = 0; i < steps.Length; i++)
    {
        var s  = steps[i];
        bool isA = active == s.Key;

        <div class="lt-wf-step @(isA ? "lt-wf-active" : "")">
            <span class="lt-wf-badge @s.Cls">@s.Badge</span>
            <span class="lt-wf-label">@s.Label</span>
        </div>

        @if (i == 3)
        {
            <span class="lt-wf-arrow">→</span>
            <div class="lt-wf-step">
                <span class="lt-wf-badge wfb-rose">Reject</span>
                <span class="lt-wf-label">Director</span>
            </div>
            <span class="lt-wf-arrow">/ →</span>
        }
        else if (i < steps.Length - 1)
        {
            <span class="lt-wf-arrow">→</span>
        }
    }
</div>



