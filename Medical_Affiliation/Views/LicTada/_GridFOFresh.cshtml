@model List<Medical_Affiliation.Models.LicTadaGridRow>

@if (Model == null || !Model.Any())
{
    <div class="lt-empty">
        <div style="font-size:40px;margin-bottom:12px">📋</div>
        <div style="font-family:'Inter',sans-serif;font-size:14px;font-weight:600;color:#334155;margin-bottom:5px">No Records Found</div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#94a3b8">Try adjusting Year / Faculty / College filters</div>
    </div>
}
else
{
    <style>
        .fo-tbl { width:100%;border-collapse:collapse;font-size:12.5px;font-family:'Inter',sans-serif }
        .fo-tbl thead tr { background:#f8fafc;border-bottom:2px solid #e2e8f0 }
        .fo-tbl th { padding:11px 14px;text-align:left;font-family:'IBM Plex Mono',monospace;font-size:9px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.12em;white-space:nowrap }
        .fo-tbl td { padding:10px 14px;vertical-align:middle }
        .fo-tbl tr.fo-first td { border-bottom:1px dashed #f1f5f9;background:#fff }
        .fo-tbl tr.fo-mid   td { border-bottom:1px dashed #f1f5f9;background:#fff }
        .fo-tbl tr.fo-last  td { border-bottom:2px solid #e2e8f0;background:#fff }
        .fo-tbl tr.fo-first:hover td,.fo-tbl tr.fo-mid:hover td,.fo-tbl tr.fo-last:hover td { background:#fafbff }
        .fo-tbl tr.fo-first td.grp-start { border-left:3px solid #d4860a }
        .mt-badge { display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:8px;font-weight:700;padding:2px 7px;border-radius:4px;text-transform:uppercase;letter-spacing:.07em;white-space:nowrap }
        .mt-senate { background:#dbeafe;color:#2563eb;border:1px solid #93c5fd }
        .mt-ac     { background:#ede9fe;color:#7c3aed;border:1px solid #c4b5fd }
        .mt-expert { background:#fef7e6;color:#d4860a;border:1px solid #f0cc84 }
        .mem-btn { background:none;border:none;padding:0;cursor:pointer;font-family:'Inter',sans-serif;font-size:12.5px;font-weight:600;color:#1e293b;transition:color .12s }
        .mem-btn:hover { color:#d4860a;text-decoration:underline;text-underline-offset:3px }
        .mem-empty { font-family:'IBM Plex Mono',monospace;font-size:11px;color:#cbd5e1;font-style:italic }
        .mem-phone { font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:#94a3b8 }
        .amt-chip { display:inline-block;font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:700;color:#1e293b;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:6px;padding:3px 10px }
        .amt-chip.amt-empty { background:#f8fafc;color:#cbd5e1;border-color:#f1f5f9;font-style:italic;font-weight:400;font-size:11px }
        .btn-fwd { display:inline-flex;align-items:center;gap:5px;padding:7px 15px;border-radius:8px;border:1.5px solid #f0cc84;background:#fef7e6;color:#d4860a;font-family:'Inter',sans-serif;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;transition:all .15s }
        .btn-fwd:hover { background:#fef3c7;border-color:#d4860a;transform:translateY(-1px);box-shadow:0 4px 12px rgba(212,134,10,.18) }
        .btn-fwd:disabled { opacity:.55;cursor:not-allowed;transform:none;box-shadow:none }
        .route-sel { width:100%;margin-bottom:7px;padding:6px 8px;border:1px solid #e2e8f0;border-radius:7px;font-family:'IBM Plex Mono',monospace;font-size:10px;color:#334155;background:#fff; }
        .fo-footer { padding:12px 20px;border-top:1px solid #f1f5f9;background:#fafbfc;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px }

        .insp-date-cell {
            border-left: 1px solid #f1f5f9;
            border-right: 1px solid #f1f5f9;
            min-width: 120px;
            text-align: center;
            vertical-align: middle;
        }

        .insp-date-pill {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
        }

            .insp-date-pill .insp-label {
                font-family: 'IBM Plex Mono', monospace;
                font-size: 8px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .1em;
                color: #94a3b8;
            }

            .insp-date-pill .insp-value {
                font-family: 'IBM Plex Mono', monospace;
                font-size: 12px;
                font-weight: 700;
                color: #1e293b;
                background: #f1f5f9;
                border: 1px solid #e2e8f0;
                border-radius: 6px;
                padding: 4px 10px;
                white-space: nowrap;
            }

                .insp-date-pill .insp-value.insp-empty {
                    color: #cbd5e1;
                    background: #f8fafc;
                    border-color: #f1f5f9;
                    font-weight: 400;
                    font-style: italic;
                    font-size: 11px;
                }
    </style>

    <div style="overflow-x:auto">
        <table class="fo-tbl">
            <thead>
                <tr>
                    <th style="width:36px">#</th>
                    <th>Academic Year</th>
                    <th>College</th>
                    <th>Type of Member</th>
                    <th>Name</th>
                    <th>Mobile Number</th>
                    <th>Date of Inspection</th>
                    <th style="min-width:130px">Claim ₹</th>
                    <th style="min-width:150px">Action</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var r = Model[i];

                    <tr class="fo-first" id="fogrp_@r.MemberId">
                        <td rowspan="3" class="grp-start"
                            style="font-family:'IBM Plex Mono',monospace;color:#94a3b8;font-size:11px;
                                   text-align:center;border-right:1px solid #f1f5f9;vertical-align:middle">
                            @(i + 1)
                        </td>
                        <td rowspan="3" style="border-right:1px solid #f1f5f9;min-width:90px;vertical-align:middle">
                            <span style="font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:700;
                                         color:#2563eb;background:#dbeafe;padding:3px 9px;border-radius:6px">
                                @r.AcademicYear
                            </span>
                        </td>
                        <td rowspan="3" style="border-right:1px solid #f1f5f9;min-width:200px;vertical-align:middle">
                            <div style="font-family:'Inter',sans-serif;font-weight:700;color:#1e293b;font-size:13px;line-height:1.4">@r.CollegeName</div>
                            <div style="color:#94a3b8;font-size:10.5px;font-family:'IBM Plex Mono',monospace;margin-top:3px">📍 @r.CollegeTown</div>
                            <div style="color:#cbd5e1;font-size:9.5px;font-family:'IBM Plex Mono',monospace;margin-top:2px">@r.CollegeCode</div>
                        </td>

                        <td><span class="mt-badge mt-senate">Senate</span></td>
                        <td style="min-width:180px">
                            @if (!string.IsNullOrWhiteSpace(r.SenetMember))
                            { <button class="mem-btn" onclick="ltOpen('@r.SenetMemberPhNo','@r.SenetMember','fo','')">@r.SenetMember</button> }
                            else { <span class="mem-empty">— Not Assigned</span> }
                        </td>
                        <td style="min-width:130px">
                            @if (!string.IsNullOrWhiteSpace(r.SenetMemberPhNo))
                            { <span class="mem-phone">@r.SenetMemberPhNo</span> }   
                            else { <span class="mem-empty">—</span> }
                        </td>
                        <td rowspan="3" class="insp-date-cell">
                            <div class="insp-date-pill">
                                <span class="insp-label">Inspected</span>
                                @if (r.InspectionDate.HasValue)
                                {
                                   @*  <span class="insp-value">@r.InspectionDate.Value.ToString("dd MMM yyyy")</span> *@
                                    <span class="insp-value">@r.InspectionDate.Value.ToString("dd MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)</span>
                                }
                                else
                                {
                                    <span class="insp-value insp-empty">Not Set</span>
                                }
                            </div>
                        </td>
                      
                        <td style="border-left:1px solid #f1f5f9">
                            @if (r.SenetMemberAmount > 0) { <span class="amt-chip">₹ @string.Format("{0:#,##0}", r.SenetMemberAmount)</span> }
                            else { <span class="amt-chip amt-empty">—</span> }
                        </td>
                        <td rowspan="3" style="border-left:1px solid #f1f5f9;vertical-align:middle;min-width:260px">
                            <select class="route-sel" id="routeUser_@r.MemberId">
                                <option value="">-- Select SO/AS/AO --</option>
                                <option value="SO">SO</option>
                                <option value="AS">AS</option>
                                <option value="AO">AO</option>
                            </select>
                            <button class="btn-fwd" id="btnFwd_@r.MemberId" onclick="ltForward('@r.MemberId', this, document.getElementById('routeUser_@r.MemberId').value)">
                                📤 Forward to SO/AS/AO
                            </button>
                        </td>
                    </tr>

                    <tr class="fo-mid">
                        <td><span class="mt-badge mt-ac">AC Member</span></td>
                        <td style="min-width:180px">
                            @if (!string.IsNullOrWhiteSpace(r.AcMember))
                            { <button class="mem-btn" onclick="ltOpen('@r.AcMemberPhNo','@r.AcMember','fo','')">@r.AcMember</button> }
                            else { <span class="mem-empty">— Not Assigned</span> }
                        </td>
                        <td style="min-width:130px">
                            @if (!string.IsNullOrWhiteSpace(r.AcMemberPhNo))
                            { <span class="mem-phone">@r.AcMemberPhNo</span> }
                            else { <span class="mem-empty">—</span> }
                        </td>
                        <td style="border-left:1px solid #f1f5f9">
                            @if (r.AcMemberAmount > 0) { <span class="amt-chip">₹ @string.Format("{0:#,##0}", r.AcMemberAmount)</span> }
                            else { <span class="amt-chip amt-empty">—</span> }
                        </td>
                    </tr>

                    <tr class="fo-last">
                        <td><span class="mt-badge mt-expert">Expert</span></td>
                        <td style="min-width:180px">
                            @if (!string.IsNullOrWhiteSpace(r.SubjectExpertise))
                            { <button class="mem-btn" onclick="ltOpen('@r.SubjectExpertisePhNo','@r.SubjectExpertise','fo','')">@r.SubjectExpertise</button> }
                            else { <span class="mem-empty">— Not Assigned</span> }
                        </td>
                        <td style="min-width:130px">
                            @if (!string.IsNullOrWhiteSpace(r.SubjectExpertisePhNo))
                            { <span class="mem-phone">@r.SubjectExpertisePhNo</span> }
                            else { <span class="mem-empty">—</span> }
                        </td>
                        <td style="border-left:1px solid #f1f5f9">
                            @if (r.SubjectExpertiseAmount > 0) { <span class="amt-chip">₹ @string.Format("{0:#,##0}", r.SubjectExpertiseAmount)</span> }
                            else { <span class="amt-chip amt-empty">—</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="fo-footer">
        <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#64748b">
            🗂 <strong style="color:#334155">@Model.Count</strong> college(s) awaiting forwarding
        </span>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#d4860a;font-weight:600">
            ⚡ Click member name to view claim · Select SO/AS/AO and forward
        </span>
    </div>
}
