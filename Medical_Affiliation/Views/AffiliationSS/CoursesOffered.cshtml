@model AffiliationSSViewModel
@{
    ViewData["Title"] = "Affiliation – SS Courses";
    Layout = "~/Views/Shared/_CaLayout.cshtml";
    var courseLevel= Context.Session.GetString("CourseLevel");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Affiliation – SS Courses</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --ink: #0f1923;
            --ink-mid: #2e3d4f;
            --ink-muted: #6b7a8d;
            --border: #d4dae3;
            --bg: #f4f6f9;
            --surface: #ffffff;
            --accent: #1a4c8b;
            --accent-lt: #e8edf7;
            --danger: #c0392b;
            --gold: #c9a84c;
            --radius: 10px;
            --shadow: 0 2px 16px rgba(15,25,35,.07);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--ink);
            min-height: 100vh;
        }

        /* ─── TOP HEADER ─────────────────────────────── (Exact same as PG Affiliation) */
        .page-header {
            background: linear-gradient(135deg, #0f1923 0%, #1a4c8b 100%);
            padding: 28px 40px 24px;
            display: flex;
            align-items: center;
            gap: 18px;
            border-bottom: 3px solid var(--gold);
        }

        .page-header .emblem {
            width: 54px;
            height: 54px;
            border: 2px solid var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .page-header .emblem svg {
            width: 28px;
            height: 28px;
            fill: var(--gold);
        }

        .page-header-text h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem;
            color: #ffffff;
            letter-spacing: .02em;
        }

        .page-header-text p {
            font-size: .78rem;
            color: rgba(255,255,255,.55);
            margin-top: 3px;
            letter-spacing: .06em;
            text-transform: uppercase;
        }

        .form-wrap {
            max-width: 1280px;
            margin: 32px auto;
            padding: 0 24px 60px;
        }

        /* Section Card */
        .section-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            margin-bottom: 28px;
            animation: fadeUp .35s ease both;
        }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .section-header {
            padding: .8rem 1.2rem;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--border);
            background: #fafbfc;
        }

        .section-header .icon-wrap {
            width: 38px;
            height: 38px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .section-header h2 {
            font-size: 1.02rem;
            font-weight: 600;
            letter-spacing: .03em;
            color: var(--ink);
            margin: 0;
        }

        .section-body {
            padding: 1rem;
        }

        /* Scrollable Table Container */
        .scrollable-table-container {
            max-height: 420px;           /* Adjust height as needed */
            overflow-y: auto;
            border: 1px solid var(--border);
            border-radius: 8px;
        }

        .custom-table {
            width: 100%;
            border-collapse: collapse;
        }

        .custom-table thead {
            position: sticky;
            top: 0;
            z-index: 10;
            background: #f8f9fc;
        }

        .custom-table th {
            background: #f8f9fc;
            color: var(--ink-mid);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.76rem;
            letter-spacing: 0.05em;
            padding: 16px;
            text-align: left;
            border-bottom: 2px solid var(--border);
        }

        .custom-table td {
            padding: .2rem .6rem;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        .custom-table tr:hover {
            background: #f8fbff;
        }

        /* Scrollbar */
        .scrollable-table-container::-webkit-scrollbar {
            width: 8px;
        }

        .scrollable-table-container::-webkit-scrollbar-thumb {
            background: #c1c9d4;
            border-radius: 4px;
        }

        .scrollable-table-container::-webkit-scrollbar-thumb:hover {
            background: #a8b3c4;
        }

        /* Form Controls */
        input.form-control, textarea.form-control {
            width: 100%;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.875rem;
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 9px 12px;
        }

        input[readonly] {
            background: #f0f2f5;
            color: var(--ink-muted);
            width: 65%;
        }

        .btn {
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            border-radius: 8px;
            padding: 11px 28px;
            cursor: pointer;
            letter-spacing: .03em;
            transition: all .18s;
        }

        .btn-ghost {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--ink-muted);
        }

        .btn-ghost:hover {
            border-color: var(--ink-mid);
            color: var(--ink);
        }

        .btn-primary {
            background: linear-gradient(135deg, #1a4c8b, #1564c0);
            color: #fff;
            box-shadow: 0 3px 14px rgba(26,76,139,.3);
        }

        .btn-primary:hover {
            box-shadow: 0 5px 20px rgba(26,76,139,.4);
            transform: translateY(-1px);
        }

        .badge {
            font-size: 0.82rem;
            padding: 6px 14px;
            border-radius: 9999px;
            background: #e8edf7;
            color: var(--accent);
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .page-header {
                padding: 20px 20px 18px;
                flex-direction: column;
                text-align: center;
                gap: 12px;
            }
            .form-wrap { padding: 0 16px 40px; }
            .btn { width: 100%; }
        }
        @@media (min-width: 1024px){
            textarea.form-control {
                width: 24vw;
            }
        }
    </style>
</head>
<body>

    <!-- PAGE HEADER - Matching your PG Course Affiliation page -->
    <div class="page-header">
        <div class="emblem">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
            </svg>
        </div>
        <div class="page-header-text">
            <h1>Affiliation – SS Courses</h1>
            <p>Affiliation &amp; Recognition Portal — Postgraduate Courses</p>
        </div>
    </div>

    <div class="form-wrap">

        <!-- Courses Table with Scrollable Body -->
        <div class="section-card">
            <div class="section-header">
                <div class="icon-wrap" style="background:#e8edf7;">
                    <i class="bi bi-mortarboard-fill" style="font-size:1.4rem; color:#1a4c8b;"></i>
                </div>
                <h2>SS Courses Details</h2>
            </div>
            <div class="section-body">
                <form asp-action="SaveCourses" method="post">
                    <div class="scrollable-table-container">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Course Name</th>
                                    <th>Level</th>
                                    <th>Sanctioned</th>
                                    <th>Admitted</th>
                                    <th>Year of Starting</th>
                                    <th>Remarks</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.AllCourses.Count; i++)
                                {
                                    <tr>
                                        <input type="hidden" asp-for="AllCourses[i].CourseCode" />
                                        <input type="hidden" asp-for="AllCourses[i].CourseName" />
                                        <input type="hidden" asp-for="AllCourses[i].CourseLevel" />

                                        <td class="fw-semibold">@Model.AllCourses[i].CourseName</td>
                                        <td><span class="badge">@Model.AllCourses[i].CourseLevel</span></td>
                                        <td><input asp-for="AllCourses[i].Sanctioned" class="form-control" readonly /></td>
                                        <td><input asp-for="AllCourses[i].Admitted" class="form-control" /></td>
                                        <td><input asp-for="AllCourses[i].YearOfStarting" class="form-control" /></td>
                                        <td><textarea asp-for="AllCourses[i].Remarks" class="form-control" rows="2"></textarea></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @* <div style="padding:24px; border-top:1px solid var(--border); text-align:right; margin-top: 16px;">
                        <button type="submit" class="btn btn-primary">
                            Save Changes
                        </button>
                    </div> *@



                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 0 .5rem;">
                        <a asp-action="Aff_PrincipalDetails" asp-controller="ContinuesAffiliation_Facultybased"
                           class="btn btn-ghost">← Previous</a>
                            <div style="padding:20px 24px; border-top:1px solid var(--border); text-align:center;">
                                <small class="text-muted">Maximum file size: 1 MB</small><br>
                                <button type="submit" class="btn btn-primary mt-2">
                                    <i class="bi bi-cloud-arrow-up me-2"></i>Save
                                </button>
                            </div>
                        <a asp-action="AssociatedInstitutions" asp-controller="AffiliationSS"
                           class="btn btn-primary">Next →</a>
                    </div>
                </form>
            </div>
        </div>

    </div>

