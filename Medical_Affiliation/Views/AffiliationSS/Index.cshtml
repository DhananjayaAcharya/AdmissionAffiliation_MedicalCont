@model AffiliationSSViewModel
@{
    ViewData["Title"] = "Affiliation – SS Courses";
}

<!-- Page Wrapper -->
<div class="container-fluid py-4 affiliation-ss">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Affiliated SS Courses</h2>
            <p class="text-muted mb-0">Overview of offered and intake-based courses</p>
        </div>
        <span class="badge bg-gradient-primary px-3 py-2">@Model.AllCourses.Count() Courses</span>
    </div>

    <!-- Stats Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <h6>Total Courses</h6>
                <h3>@Model.AllCourses.Count()</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card accent">
                <h6>Intake Only</h6>
                <h3>@Model.AllCourses.Count(c => c.Remarks == "Present in intake only")</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card success">
                <h6>Officially Offered</h6>
                <h3>@Model.AllCourses.Count(c => c.Remarks != "Present in intake only")</h3>
            </div>
        </div>
    </div>

    <!-- Courses Table -->
    <div class="card glass-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <form asp-action="SaveCourses" method="post">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-header">
                            <tr>
                                <th>Course Name</th>
                                <th>Level</th>
                                <th>Sanctioned</th>
                                <th>Admitted</th>
                                <th>Year</th>
                                <th>Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.AllCourses.Count; i++)
                            {
                                <tr>

                                    <!-- Hidden fields to POST values -->
                                    <input type="hidden" asp-for="AllCourses[i].CourseCode" />
                                    <input type="hidden" asp-for="AllCourses[i].CourseName" />
                                    <input type="hidden" asp-for="AllCourses[i].CourseLevel" />

                                    <td class="fw-semibold">
                                        @Model.AllCourses[i].CourseName
                                    </td>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @Model.AllCourses[i].CourseLevel
                                        </span>
                                    </td>

                                    <td>
                                        <input asp-for="AllCourses[i].Sanctioned"
                                               class="form-control form-control-sm"
                                               readonly />
                                    </td>

                                    <td>
                                        <input asp-for="AllCourses[i].Admitted"
                                               class="form-control form-control-sm" />
                                    </td>

                                    <td>
                                        <input asp-for="AllCourses[i].YearOfStarting"
                                               class="form-control form-control-sm" />
                                    </td>

                                    <td>
                                        <textarea asp-for="AllCourses[i].Remarks"
                                                  class="form-control form-control-sm"
                                                  rows="2"
                                                  style="resize:none"></textarea>
                                    </td>

                                </tr>
                            }
                        </tbody>

                    </table>
                    <div class="d-flex justify-content-end mt-3">
                        <button type="submit" class="btn btn-primary px-4">
                            Save
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<!-- Custom Styles -->
<style>
    .affiliation-ss {
        font-family: "Inter", system-ui, sans-serif;
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #4f46e5, #6366f1);
    }

    .stat-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.06);
        transition: transform 0.2s ease;
    }

        .stat-card:hover {
            transform: translateY(-3px);
        }

        .stat-card h6 {
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            color: #6b7280;
        }

        .stat-card h3 {
            margin: 0;
            font-weight: 700;
            color: #111827;
        }

        .stat-card.accent {
            border-left: 6px solid #f59e0b;
        }

        .stat-card.success {
            border-left: 6px solid #10b981;
        }

    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 18px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .table-header {
        background: #f9fafb;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
    }

    .table td,
    .table th {
        padding: 14px 16px;
        vertical-align: middle;
    }

    .intake-only {
        background-color: #fff7ed;
    }

        .intake-only:hover {
            background-color: #ffedd5 !important;
        }
</style>
