@using Microsoft.AspNetCore.Mvc.Rendering
@model List<Medical_Affiliation.Models.Nursing_YearwiseMaterialsDataViewModel>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Affiliated Year-wise Clinical Materials";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    int currentStep = 3;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    @@media (max-width: 1450px) {
        .main-container {
            max-width: 940px !important;
            margin-left: 19rem !important;
            padding: 1em !important;
            padding-top: 10px !important;
            max-height: 30vh;
            overflow: auto;
        }

        .college-container {
            margin-bottom: 8px !important;
        }

        .status-bar-container {
            padding: 0.2rem 0;
        }

        .clg-basic {
            margin-bottom: 0.5rem !important;
        }

        .card.mb-3 {
            margin-bottom: 5px;
        }

        .container.mt-4 {
            margin-top: 5px !important;
        }

        h2 {
            font-size: 1.5em;
            margin-bottom: 5px;
        }
    }

    body {
        background: #f6f8fb;
    }
    .main-container {
        margin-left: 25rem;
        background: #ffffff;
        padding: 2.5rem;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        max-height: 100vh;
        overflow-y: auto;
    }
    .progressbar-pipeline {
        display: flex;
        gap: 2rem;
        list-style: none;
        padding: 0;
        margin: 1rem 0;
    }
    .progress-step-btn {
        background: none;
        border: none;
        font-weight: 600;
        text-transform: uppercase;
        color: #6b7280;
        position: relative;
    }
    .progress-step-btn.active {
        color: #3b82f6;
    }
    .progress-step-btn.completed {
        color: #22c55e;
    }
    .card {
        box-shadow: 0 2px 8px rgba(0,0,0,0.07);
        border-radius: 12px;
    }
    .form-control:focus {
        box-shadow: 0 0 8px rgba(0, 123, 255, 0.4);
        border-color: #007bff;
    }
    .card-header {
        font-weight: 600;
    }
    .table-responsive {
        overflow-x: auto;
        border-radius: 12px;
    }
    .sidebar-btn {
        min-width: 150px;
        font-weight: 500;
        border-radius: 24px;
    }
</style>

@if (!string.IsNullOrEmpty(facultyCode))
{
    @await Component.InvokeAsync("Sidebar")
}

@* <div class="main-container mx-auto"> *@
    <!-- Progress Bar -->
    <div class="status-bar-container mb-4">
        @{
            var collegeFullName = HttpContextAccessor.HttpContext.Session.GetString("CollegeName") ?? "";
            var collegeName = System.Text.RegularExpressions.Regex.Replace(collegeFullName, @"[\s\-:]*[A-Za-z]*\d{3,}\s*$", "").Trim();
            var stepTitles = new[] {
        "Institute Basic Details",
        "Course Details",
        //"Clinical Material Details",
        "Hospital Details",
        "Required Faculty Details",
        "Add College Faculty details",
        "Academic Performance"
                };
        }
        <span class="fw-bold fs-5">@collegeName</span>
        <ul class="progressbar-pipeline" role="progressbar">
            @for (int i = 0; i < stepTitles.Length; i++)
            {
                var isActive = (currentStep == i + 1);
                var isCompleted = (currentStep > i + 1);
                <li class="@(isCompleted ? "completed" : "")">
                    <span class="progress-step-btn @(isActive ? "active" : (isCompleted ? "completed" : ""))">
                        @stepTitles[i]
                    </span>
                </li>
            }
        </ul>
    </div>

    <h2 class="text-center fw-bold mb-4 text-primary">Hospital Details</h2>
    <form asp-action="Unani_YearwiseMaterials" method="post" enctype="multipart/form-data" id="mainForm">
        <div class="card shadow-lg border-0 mb-4 rounded-4">
            <div class="card-header bg-primary text-white rounded-top-4">
                <h5 class="mb-0">🏥 Hospital Details</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="HospitalType" class="form-label">Select Hospital Level</label>
                    <select id="HospitalType" name="HospitalType" class="form-select" required>
                        <option value="">-- Select --</option>
                        @foreach (var item in ViewBag.HospitalTypes as List<SelectListItem>)
                        {
                            <option value="@item.Value" @@(item.Selected ? "selected" : "")>@item.Text</option>
                        }
                    </select>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold" for="ParentHospitalName">Hospital Name</label>
                        <input type="text" id="ParentHospitalName" class="form-control rounded-pill" name="ParentHospitalName" placeholder="Enter Hospital Name" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold" for="ParentHospitalAddress">Hospital Address</label>
                        <input type="text" id="ParentHospitalAddress" class="form-control rounded-pill" name="ParentHospitalAddress" placeholder="Enter Address" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold" for="HospitalOwnerName">Hospital Owner Name</label>
                        <input type="text" id="HospitalOwnerName" class="form-control rounded-pill" name="HospitalOwnerName" placeholder="Owner Name" />
                    </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold" for="Kpmebeds">KPME Beds</label>
                        <input type="number" id="Kpmebeds" class="form-control rounded-pill" name="Kpmebeds" min="0" placeholder="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold" for="PostBasicBeds">PCB Beds</label>
                        <input type="number" id="PostBasicBeds" class="form-control rounded-pill" name="PostBasicBeds" min="0" placeholder="0" />
                    </div>
                </div>
                <div class="row g-3 mt-3">
                    <div class="col-md-3">
                        <label class="form-label fw-semibold" for="ParentHospitalKpmebedsDocFile">KPME Beds Document</label>
                        <input type="file" id="ParentHospitalKpmebedsDocFile" class="form-control rounded-pill" name="ParentHospitalKpmebedsDocFile" />
                    </div>
                <div class="col-md-3 mt-3">
                    <label class="form-label fw-semibold" for="ParentHospitalPostBasicDocFile">PCB Beds Document</label>
                    <input type="file" id="ParentHospitalPostBasicDocFile" class="form-control rounded-pill" name="ParentHospitalPostBasicDocFile" />
                </div>
                   @*  <div class="col-md-3">
                        <label class="form-label fw-semibold" for="PolutionControlDocFile">Polution Control Document</label>
                        <input type="file" id="PolutionControlDocFile" class="form-control rounded-pill" name="PolutionControlDocFile" />
                    </div> *@
                    <div class="col-md-3">
                        <label class="form-label fw-semibold" for="FireSafetyDocFile">Fire Safety Document</label>
                        <input type="file" id="FireSafetyDocFile" class="form-control rounded-pill" name="FireSafetyDocFile" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold" for="BiomedicalWasteManagemenDocFile">Bio Medical Waste Management Document</label>
                        <input type="file" id="BiomedicalWasteManagemenDocFile" class="form-control rounded-pill" name="BiomedicalWasteManagemenDocFile" />
                    </div>
                    
                </div>
            </div>
        </div>

        <!-- Year-wise Materials Table -->
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-secondary text-white rounded-top-4">
                <h5 class="mb-0">📊 Year-wise Materials</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Parameter</th>
                            <th id="year1"></th>
                            <th id="year2"></th>
                            <th id="year3"></th>
                            <th>Upload Document</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr>
                                <td>
                                    @Model[i].ParametersName
                                    <input type="hidden" name="[@i].ParametersId" value="@Model[i].ParametersId" />
                                    <input type="hidden" name="[@i].ParametersName" value="@Model[i].ParametersName" />
                                    <input type="hidden" name="[@i].CollegeCode" value="@Model[i].CollegeCode" />
                                    <input type="hidden" name="[@i].FacultyCode" value="@Model[i].FacultyCode" />
                                </td>
                                <td>
                                    <input type="number" name="[@i].Year1" class="form-control rounded" min="0" />
                                </td>
                                <td>
                                    <input type="number" name="[@i].Year2" class="form-control rounded" min="0" />
                                </td>
                                <td>
                                    <input type="number" name="[@i].Year3" class="form-control rounded" min="0" />
                                </td>
                                <td>
                                    <input type="file" name="[@i].UploadDocument" class="form-control" />
                                    @* Explicit mapping hidden field so controller knows target column *@
                                    <input type="hidden" name="[@i].UploadTarget"
                                           value="@(Model[i].ParametersName != null && Model[i].ParametersName.IndexOf("Minor", System.StringComparison.OrdinalIgnoreCase) >= 0
                                                   ? "MinorOperationsSurgeries"
                                                   : (Model[i].ParametersName != null && Model[i].ParametersName.IndexOf("Major", System.StringComparison.OrdinalIgnoreCase) >= 0
                                                       ? "MajorOperationsSurgeries"
                                                       : (Model[i].ParametersName != null && Model[i].ParametersName.IndexOf("IPD", System.StringComparison.OrdinalIgnoreCase) >= 0
                                                           ? "IpdDocument"
                                                           : (Model[i].ParametersName != null && Model[i].ParametersName.IndexOf("OPD", System.StringComparison.OrdinalIgnoreCase) >= 0
                                                               ? "OpdDocument" : ""))))" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                </div>
            </div>
            <div class="card-footer text-end">
                <button type="submit" class="btn btn-success px-5 py-2 rounded-pill fw-semibold shadow-sm">
                    💾 Save Details
                </button>
            </div>
        </div>
    </form>

    <!-- Read-only Saved Data Table -->
<div class="card shadow-sm mt-5">
    <div class="card-header bg-dark text-white">Saved Year-wise Materials Records</div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-striped align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Hospital Type</th>
                    <th>Parameter</th>
                    <th>Year1</th>
                    <th>Year2</th>
                    <th>Year3</th>
                    <th>Parent Hospital Name</th>
                    <th>Address</th>
                    <th>KPME Beds</th>
                    <th>PCB Beds</th>
                    <th>Owner Name</th>
                    <th>Fire Safety Document</th>
                    <th>KPME Document</th>
                    <th>PCB Beds Document</th>
                    <th>Bio Medical Waste Management Document</th>
                    <th>OPD Document</th>
                    <th>IPD Document</th>
                    <th>Major Ops Doc</th>
                    <th>Minor Ops Doc</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.YearwiseData != null && ((IEnumerable<dynamic>)ViewBag.YearwiseData).Any())
                {
                    foreach (var item in ViewBag.YearwiseData)
                    {
                        <tr>
                            <td>@item.HospitalType</td>
                            <td>@item.ParametersName</td>
                            <td>@item.Year1</td>
                            <td>@item.Year2</td>
                            <td>@item.Year3</td>
                            <td>@item.ParentHospitalName</td>
                            <td>@item.ParentHospitalAddress</td>
                            <td>@item.Kpmebeds</td>
                            <td>@item.PostBasicBeds</td>
                            <td>@item.HospitalOwnerName</td>
                            <td>
                                @if (item.FireSafetyDoc != null)
                                {
                                    <a asp-action="ViewDocument" asp-route-collegeCode="@item.CollegeCode" asp-route-fileType="FireSafetyDoc" target="_blank">View</a>
                                }
                            </td>
                          
                            <td>
                                @if (item.ParentHospitalKpmebedsDoc != null)
                                {
                                    <a asp-action="ViewDocument" asp-route-collegeCode="@item.CollegeCode" asp-route-fileType="Kpmebeds" target="_blank">View</a>
                                }
                            </td>
                            <td>
                                @if (item.ParentHospitalPostBasicDoc != null)
                                {
                                    <a asp-action="ViewDocument" asp-route-collegeCode="@item.CollegeCode" asp-route-fileType="PostBasic" target="_blank">View</a>
                                }
                            </td>
                            <td>
                                @if (item.BiomedicalWasteManagemenDoc != null)
                                {
                                    <a asp-action="ViewDocument" asp-route-collegeCode="@item.CollegeCode" asp-route-fileType="BiomedicalWasteManagemenDoc" target="_blank">View</a>
                                }
                            </td>
                            <td>
                                @if (item.opddoc != null)
                                {
                                    <a asp-action="ViewDocument" asp-route-collegeCode="@item.CollegeCode" asp-route-fileType="OpdDocument" target="_blank">View</a>
                                }
                            </td>
                            <td>
                                @if (item.Ipddoc != null)
                                {
                                    <a asp-action="ViewDocument" asp-route-collegeCode="@item.CollegeCode" asp-route-fileType="IpdDocument" target="_blank">View</a>
                                }
                            </td>
                            <td>
                                @if (item.MajorOperationsSurgeries != null)
                                {
                                    <a asp-action="ViewDocument" asp-route-collegeCode="@item.CollegeCode" asp-route-fileType="MajorOperationsSurgeries" target="_blank">View</a>
                                }
                            </td>
                            <td>
                                @if (item.MinorOperationsSurgeries != null)
                                {
                                    <a asp-action="ViewDocument" asp-route-collegeCode="@item.CollegeCode" asp-route-fileType="MinorOperationsSurgeries" target="_blank">View</a>
                                }
                            </td>
                            <td>
                                <form asp-action="DeleteYearwiseMaterial1" method="post" onsubmit="return confirm('Are you sure you want to delete this record?');">
                                    <input type="hidden" name="parametersId" value="@item.ParametersId" />
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="20" class="text-center text-danger">No data available</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

    <div class="d-flex justify-content-between my-3">
        <a asp-controller="Aff_Unani" asp-action="Unani_UGPG" class="btn btn-outline-secondary sidebar-btn">
            ⬅ Previous
        </a>
        <a asp-controller="Aff_Unani" asp-action="Unani_ManageDesignationIntake" class="btn btn-outline-secondary sidebar-btn">
            💾 Proceed to Next
        </a>
    </div>
<script>
    // Get the current year dynamically
    const currentYear = new Date().getFullYear();
    // Fill the header cells with current and previous two years
    document.getElementById('year1').textContent = currentYear;
    document.getElementById('year2').textContent = currentYear - 1;
    document.getElementById('year3').textContent = currentYear - 2;
</script>
