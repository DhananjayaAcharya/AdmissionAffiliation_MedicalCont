@model List<Nursing_YearwiseMaterialsDataViewModel>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Affiliated Year-wise Clinical Materials";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background-color: #f4f6f9;
    }

    .main-container {
        max-width: 95%;
        margin: 2rem auto;
        background: #fff;
        padding: 2rem 3rem;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .card-header {
        font-weight: 600;
        font-size: 1.1rem;
        border-top-left-radius: 15px !important;
        border-top-right-radius: 15px !important;
    }

    .form-control {
        border-radius: 12px;
    }

        .form-control:focus {
            box-shadow: 0 0 8px rgba(13,110,253,0.3);
            border-color: #0d6efd;
        }

    .progressbar-pipeline {
        display: flex;
        gap: 1rem;
        list-style: none;
        padding: 0;
        flex-wrap: wrap;
    }

    .progress-step-btn {
        background: none;
        border: none;
        font-weight: 600;
        color: #6c757d;
        position: relative;
        padding: 5px;
    }

        .progress-step-btn.active {
            color: #0d6efd;
            border-bottom: 2px solid #0d6efd;
        }

        .progress-step-btn.completed {
            color: #198754;
        }
</style>

@if (!string.IsNullOrEmpty(facultyCode))
{
    @await Component.InvokeAsync("Sidebar")
}

<div class="main-container">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold">@HttpContextAccessor.HttpContext.Session.GetString("CollegeName")</h4>
        <form asp-controller="Login" asp-action="Login" method="post">
            <button type="submit" class="btn btn-outline-danger">Logout</button>
        </form>
    </div>

    <!-- Progressbar Navigation -->
    <ul class="progressbar-pipeline">
        @{
            var steps = new[] {
                "Nursing_BasicDetails", "Nursing_UGPG", "Nursing_YearwiseMaterials",
                "Nursing_Affiliated_YearwiseMaterials", "Nursing_TeachingFacultyDetails",
                "Nursing_FacultyDetails", "FacultyExamResults"
                };

            var titles = new[] {
                "Basic Details", "Course", "Clinical Materials",
                "Affiliated Clinical", "Designation", "Faculty", "Performance"
                };

            for (int i = 0; i < titles.Length; i++)
            {
                var isActive = (i == 3);
                var isCompleted = (i < 3);
                <li>
                    <form method="get" action="@Url.Action(steps[i], "Aff_Nursing")">
                        <button type="submit" class="progress-step-btn @(isActive ? "active" : isCompleted ? "completed" : "")">
                            @titles[i]
                        </button>
                    </form>
                </li>
            }
        }
    </ul>

    <hr />

    <!-- Main Title -->
    <h2 class="text-center text-primary fw-bold mb-4">
        Affiliated Year-wise Clinical Materials
    </h2>

    <!-- Form Starts -->
    <form asp-action="Nursing_YearwiseMaterials" method="post" enctype="multipart/form-data">

        <!-- Parent Hospital Details -->
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                🏥 Parent Hospital Details
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Hospital Name</label>
                        <input type="text" name="ParentHospitalName" class="form-control" placeholder="Enter Hospital Name" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Address</label>
                        <input type="text" name="ParentHospitalAddress" class="form-control" placeholder="Enter Address" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Owner Name</label>
                        <input type="text" name="HospitalOwnerName" class="form-control" placeholder="Owner Name" />
                    </div>
                </div>

                <div class="row g-3 mt-3">
                    <div class="col-md-4">
                        <label class="form-label">KPME Beds</label>
                        <input type="number" name="Kpmebeds" class="form-control" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Post Basic Beds</label>
                        <input type="number" name="PostBasicBeds" class="form-control" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Total Beds</label>
                        <input type="number" name="TotalBeds" class="form-control" min="0" />
                    </div>
                </div>

                <div class="row g-3 mt-3">
                    <div class="col-md-3">
                        <label class="form-label">KPME Beds Document</label>
                        <input type="file" name="ParentHospitalKpmebedsDocFile" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">MOU Document</label>
                        <input type="file" name="ParentHospitalMoudocFile" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Owner Proof</label>
                        <input type="file" name="ParentHospitalOwnerNameDocFile" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Post Basic Proof</label>
                        <input type="file" name="ParentHospitalPostBasicDocFile" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Year-wise Materials Table -->
        <div class="card">
            <div class="card-header bg-secondary text-white">
                📊 Year-wise Clinical Materials
            </div>
            <div class="card-body p-0">
                <table class="table table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Parameter</th>
                            <th>Year 1</th>
                            <th>Year 2</th>
                            <th>Year 3</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr>
                                <td>
                                    @Model[i].ParametersName
                                    <input type="hidden" asp-for="@Model[i].ParametersId" />
                                </td>
                                <td><input type="number" name="[@i].Year1" class="form-control" /></td>
                                <td><input type="number" name="[@i].Year2" class="form-control" /></td>
                                <td><input type="number" name="[@i].Year3" class="form-control" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer text-end">
                <button type="submit" class="btn btn-success px-4">💾 Save</button>
            </div>
        </div>
    </form>

    <!-- Navigation Buttons -->
    <div class="d-flex justify-content-between mt-4">
        <a asp-action="Nursing_YearwiseMaterials" class="btn btn-outline-secondary">⬅ Previous</a>
        <a asp-action="Nursing_Affiliated_YearwiseMaterials" class="btn btn-primary">Next ➡</a>
    </div>
    <div class="card shadow-sm mt-5">
        <div class="card-header bg-dark text-white">Saved Year-wise Materials Records</div>
        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Parameter</th>
                        <th>Year1</th>
                        <th>Year2</th>
                        <th>Year3</th>
                        <th>Parent Hospital Name</th>
                        <th>Address</th>
                        <th>KPME Beds</th>
                        <th>Post Basic Beds</th>
                        <th>Total Beds</th>
                        <th>Owner Name</th>
                        <th>MOU Doc</th>
                        <th>Owner Doc</th>
                        <th>KPME Doc</th>
                        <th>Post Basic Doc</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.YearwiseData != null && ((IEnumerable<dynamic>)ViewBag.YearwiseData).Any())
                    {
                        foreach (var item in ViewBag.YearwiseData)
                        {
                            <tr>
                                <td>@item.ParametersName</td>
                                <td>@item.Year1</td>
                                <td>@item.Year2</td>
                                <td>@item.Year3</td>
                                <td>@item.parentHospitalName</td>
                                <td>@item.parentHospitalAddress</td>
                                <td>@item.KPMEBeds</td>
                                <td>@item.PostBasicBeds</td>
                                <td>@item.TotalBeds</td>
                                <td>@item.HospitalOwnerName</td>
                                <td>@item.parentHospitalMOUdoc</td>
                                <td>@item.parentHospitalOwnerNameDoc</td>
                                <td>@item.parentHospitalKPMEbedsDoc</td>
                                <td>@item.parentHospitalPostBasicDoc</td>
                                <td>
                                    <form asp-action="DeleteYearwiseMaterial1" method="post" onsubmit="return confirm('Are you sure you want to delete this record?');">
                                        <input type="hidden" name="parametersId" value="@item.ParametersId" />
                                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="15" class="text-center text-danger">No data available</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="d-flex justify-content-between">
</div>
