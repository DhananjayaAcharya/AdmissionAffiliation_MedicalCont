@model CourseFacultyListViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@inject IHttpContextAccessor HttpContextAccessor


@{
    ViewData["Title"] = "Nodal Officer Details";
    var facultyCode = HttpContextAccessor.HttpContext.Session.GetString("FacultyCode");
    Context.Response.Headers["Cache-Control"] = "no-cache, no-store, must-revalidate";
    Context.Response.Headers["Pragma"] = "no-cache";
    Context.Response.Headers["Expires"] = "0";
}
@if (!string.IsNullOrEmpty(facultyCode))
{
    @await Component.InvokeAsync("Sidebar")
}
<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-gradient bg-primary text-white text-center py-3 rounded-top-4">
            <h3 class="mb-0">
                <i class="bi bi-journal-text me-2"></i> AHS Course Details
            </h3>
        </div>

        <div class="card-body p-4">

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Message"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-action="AHS_CourseDetails" method="post" enctype="multipart/form-data">
                <div class="table-responsive">
                    <table class="table table-hover align-middle shadow-sm">
                        <thead class="table-light border-bottom">
                            <tr class="text-center">
                                <th>Sl. No.</th>
                                <th>Course Name</th>
                                <th>Recognized(YES/NO)</th>
                                <th>RGUHS Notification No</th>
                                <th>Upload Document</th>
                                <th>Existing Document</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Courses.Count; i++)
                            {
                                <tr>
                                    <td class="fw-semibold text-center">@Model.Courses[i].SlNo</td>
                                    <td>
                                        <span class="fw-semibold">@Model.Courses[i].CourseName</span>
                                        <input type="hidden" asp-for="Courses[@i].CourseId" />
                                        <input type="hidden" asp-for="Courses[@i].CourseName" />
                                    </td>
                                    <td class="text-center">
                                        <div class="form-check d-flex justify-content-center">
                                            <input class="form-check-input" type="checkbox" asp-for="Courses[@i].IsRecognized" />
                                        </div>
                                    </td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm rounded-3"
                                               asp-for="Courses[@i].RguhsNotificationNo"
                                               placeholder="Enter Notification No" />
                                    </td>
                                    <td>
                                        <input type="file" class="form-control form-control-sm rounded-3"
                                               asp-for="Courses[@i].SupportingFile"
                                               accept=".pdf,.doc,.docx" />
                                    </td>
                                    <td class="text-center">
                                        @if (!string.IsNullOrEmpty(Model.Courses[i].UploadedFilePath))
                                        {
                                            <a href="@Model.Courses[i].UploadedFilePath"
                                               target="_blank" class="btn btn-outline-primary btn-sm rounded-pill">
                                                <i class="bi bi-eye-fill"></i> View
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No File</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-success btn-lg px-4 rounded-pill shadow-sm">
                        <i class="bi bi-save me-2"></i> Save Details
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
