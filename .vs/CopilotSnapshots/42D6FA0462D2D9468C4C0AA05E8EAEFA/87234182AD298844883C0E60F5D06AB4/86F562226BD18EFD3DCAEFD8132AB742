<div class="institution-form-shell">
    <div class="container">
        <div class="institution-form-card">
            <div class="institution-form-card-inner">

                <div class="form-header-modern">
                    <div class="form-header-title">
                        <div class="form-header-icon">
                            <i class="bi bi-bar-chart"></i>
                        </div>
                        <div>
                            <h4>Application for Affiliation for the Academic Year 2026–27</h4>
                            <span>UG, PG, SS course-wise intake details</span>
                        </div>
                    </div>
                    <a asp-controller="Collegelogin" asp-action="Dashboard" class="text-decoration-none">
                        <span class="form-header-badge">
                            <i class="bi bi-file-earmark-text"></i>
                            Home
                        </span>
                    </a>

                </div>

                <!-- Single college-level upload DIV (added) -->
                <div id="college-upload-wrapper" class="form-group mb-3" style="margin-bottom:18px;">
                    <label for="collegeBankStatement" style="color:var(--text-main); font-weight:600;">
                        Upload Bank Statement (college-level, upload once)
                    </label>
                    <input type="file" id="collegeBankStatement" name="bankStatement" class="form-control-file" />
                    @* <small class="form-text text-muted" style="color:var(--text-muted);">
                        Select the college bank statement once. When you click Save for UG/PG/SS the file will be submitted with that section.
                    </small> *@
                </div>

                <script>
                    // Move the single global file input into the form whose submit button was clicked.
                    document.addEventListener('DOMContentLoaded', function () {
                        const globalFileInput = document.getElementById('collegeBankStatement');
                        if (!globalFileInput) return;

                        // Attach click handlers to submit buttons inside forms that post to Medical_LatestIntakeData
                        document.querySelectorAll('form').forEach(form => {
                            // safety: only target forms that post to the controller action
                            var action = (form.getAttribute('action') || '').toLowerCase();
                            var aspAction = form.getAttribute('asp-action');
                            if (aspAction && aspAction.toLowerCase() !== 'medical_latestintakedata') return;

                            form.querySelectorAll('button[type="submit"]').forEach(btn => {
                                btn.addEventListener('click', function () {
                                    // move input into the clicked form just before submission
                                    if (!globalFileInput) return;
                                    if (globalFileInput.form !== form) {
                                        form.appendChild(globalFileInput);
                                    }
                                });
                            });
                        });
                    });
                </script>

                <!-- ========== UG FORM (only if data) ========== -->
                @if (Model.UgCourses != null && Model.UgCourses.Count > 0)
                {
                    using (Html.BeginForm("Medical_LatestIntakeData", "LatestMedicalAffiliation", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.FacultyCode)
                        @Html.HiddenFor(m => m.CollegeCode)
                        <input type="hidden" name="courseLevel" value="UG" />

                        <div id="ug-section" class="section-panel soft">
                            <div class="section-title-row">
                                <div>
                                    <div class="section-chip">
                                        <span class="dot"></span>
                                        <span>Undergraduate</span>
                                    </div>
                                    <h5>UG Intake</h5>
                                </div>
                            </div>

                            <table class="table table-bordered table-sm">
                                <thead>
                                    <tr>
                                        <th>Course Name</th>
                                        <th>Existing Intake For Continuation Affiliation</th>
                                        <th>Additional Seats Requested(if any)</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.UgCourses.Count; i++)
                                    {
                                        <tr>
                                            <td class="course-name-cell">
                                                <span class="course-title">@Model.UgCourses[i].CourseName</span>
                                                @Html.HiddenFor(m => m.UgCourses[i].CourseCode)
                                                @Html.HiddenFor(m => m.UgCourses[i].CourseName)
                                            </td>
                                            <td>
                                                @Html.TextBoxFor(m => m.UgCourses[i].ExistingIntake,
                                                    new {
                                                        @class = "form-control form-control-sm existing-intake",
                                                        type = "number",
                                                        min = "0",
                                                        @readonly = "readonly"
                                                    })
                                            </td>
                                            <td>
                                                @Html.TextBoxFor(m => m.UgCourses[i].AdditionalIntake,
                                                    new {
                                                        @class = "form-control form-control-sm additional-intake",
                                                        type = "number",
                                                        min = "0",
                                                        required = "required"
                                                    })
                                                @Html.ValidationMessageFor(m => m.UgCourses[i].AdditionalIntake, "", new { @class = "text-danger" })
                                            </td>
                                            <td class="total-intake-cell">
                                                <span class="total-intake">
                                                    @Model.UgCourses[i].TotalIntake
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                            <div class="section-panel soft mt-3">
                                <div class="declaration-block px-4 py-3" style="font-size: 0.85rem; line-height: 1.5;">
                                    <div style="display:flex; align-items:flex-start; gap:12px;">
