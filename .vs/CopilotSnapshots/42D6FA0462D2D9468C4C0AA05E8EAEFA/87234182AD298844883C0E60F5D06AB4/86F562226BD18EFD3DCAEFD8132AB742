@model IntakePageViewModel

@using Microsoft.AspNetCore.Http

@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewBag.Title = "Application for Affiliation for the Academic Year 2026–27";
    var collegeName = HttpContextAccessor.HttpContext.Session.GetString("CollegeName");
}

<!-- Bootstrap Icons CDN for icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<!-- jQuery + DataTables CSS/JS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

<style>
    :root {
        /* Official Government-style palette - Blue/Navy primary */
        --primary: #0b5ed7;              /* Primary blue */
        --primary-soft: rgba(11, 94, 215, 0.12);
        --accent: #198754;               /* Secondary green */
        --accent-soft: rgba(25, 135, 84, 0.12);
        
        /* Backgrounds */
        --bg-body: #0b1120;
        --bg-gradient: radial-gradient(circle at top left, #1f2933 0%, #0b1120 55%, #020617 100%);
        --glass-bg: rgba(15, 23, 42, 0.95);
        --glass-border: rgba(148, 163, 184, 0.45);

        /* Input backgrounds */
        --input-bg-editable: rgba(30, 64, 175, 0.35);    /* editable */
        --input-bg-editable-hover: rgba(30, 64, 175, 0.5);
        --input-bg-readonly: rgba(15, 23, 42, 0.9);      /* readonly */
        --input-border: rgba(148, 163, 184, 0.6);
        --input-border-focus: rgba(56, 189, 248, 0.9);
        --input-border-readonly: rgba(148, 163, 184, 0.4);
        
        /* Shape and elevation */
        --radius-lg: 16px;
        --radius-md: 12px;
        --shadow-soft: 0 18px 45px rgba(15, 23, 42, 0.9);
        --shadow-chip: 0 10px 25px rgba(15, 23, 42, 0.7);
        
        /* Typography */
        --text-main: #f9fafb;
        --text-muted: #9ca3af;
        --text-readonly: #e5e7eb;
        --danger: #dc3545;
    }

    /* College name white highlight */
    .college-name-highlight {
        font-weight: 600;
        color: #ffffff !important;
    }

    /* Fixed Add Course button (bottom right) */
    .add-course-btn-container {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 1000;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
    }

    .add-course-btn {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        border: none;
        background: linear-gradient(135deg, var(--primary), #0b3b80);
        color: #f9fafb;
        font-size: 1.6rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 16px 40px rgba(11, 94, 215, 0.6);
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

    .add-course-btn:hover {
        transform: translateY(-4px) scale(1.05);
        box-shadow: 0 20px 50px rgba(11, 94, 215, 0.75);
    }

    .add-course-btn:active {
        transform: translateY(-2px) scale(1.02);
    }

    .add-course-btn::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        background: rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: width 0.3s, height 0.3s;
    }

    .add-course-btn:hover::before {
        width: 100%;
        height: 100%;
    }

    .add-course-tooltip {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.95));
        color: var(--text-main);
        padding: 10px 16px;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 500;
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(12px);
        white-space: nowrap;
        box-shadow: var(--shadow-soft);
        opacity: 0;
        visibility: hidden;
        position: absolute;
        bottom: 76px;
        right: 0;
        transform: translateX(50%) translateY(12px);
        transition: all 0.3s ease;
    }

    .add-course-btn-container:hover .add-course-tooltip {
        opacity: 1;
        visibility: visible;
        transform: translateX(50%) translateY(0);
    }

    .course-name-cell {
        color: var(--text-main) !important;
        font-weight: 700 !important;
        font-size: 0.95rem !important;
        background: linear-gradient(135deg, var(--primary-soft), var(--glass-bg)) !important;
        min-width: 280px !important;
        max-width: 320px !important;
        position: relative;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .course-name-cell .course-title {
        color: var(--text-main) !important;
        font-weight: 700;
        font-size: 0.95rem;
        line-height: 1.4;
        display: block;
        padding-right: 8px;
    }

    .course-name-cell::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: linear-gradient(180deg, var(--primary), #0b3b80);
        border-radius: 0 4px 4px 0;
    }

    body {
        background: var(--bg-gradient);
        color: var(--text-main);
    }

    .institution-form-shell {
        background: var(--bg-gradient);
        min-height: 100vh;
        padding: 32px 0 100px 0;
    }

    .institution-form-card {
        background: linear-gradient(135deg, #0f172a, #020617);
        border-radius: 24px;
        padding: 1px;
        box-shadow: var(--shadow-soft);
        position: relative;
        overflow: hidden;
    }

    .institution-form-card-inner {
        background: rgba(15, 23, 42, 0.98);
        border-radius: 22px;
        border: 1px solid var(--glass-border);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        position: relative;
        z-index: 1;
        padding: 28px 26px 30px;
    }

    @@media (min-width: 992px) {
        .institution-form-card-inner {
            padding: 30px 34px 34px;
        }
    }

    .form-header-modern {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
    }

    .form-header-title {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-header-icon {
        width: 42px;
        height: 42px;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(11, 94, 215, 0.15), rgba(15, 23, 42, 0.95));
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-main);
        box-shadow: var(--shadow-soft);
        position: relative;
    }

    .form-header-icon::after {
        content: "";
        position: absolute;
        inset: 2px;
        border-radius: inherit;
        border: 1px solid var(--glass-border);
    }

    .form-header-title h4 {
        margin: 0;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: var(--text-main);
        font-size: 1.35rem;
    }

    .form-header-title span {
        display: block;
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    .form-header-badge {
        padding: 6px 14px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--primary), #0b3b80);
        color: #e5e7eb;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        border: 1px solid rgba(191, 219, 254, 0.8);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 10px 25px rgba(11, 94, 215, 0.6);
    }

    .section-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 11px;
        border-radius: 999px;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        background: rgba(15, 23, 42, 0.96);
        border: 1px solid var(--glass-border);
        color: var(--text-muted);
        box-shadow: var(--shadow-chip);
    }

    .section-chip span.dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 0, var(--primary-soft), var(--primary));
        box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.35);
    }

    .section-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
        margin-top: 6px;
    }

    .section-title-row h5 {
        margin: 0;
        font-weight: 600;
        font-size: 1rem;
        color: var(--text-main);
        letter-spacing: 0.02em;
    }

    .section-panel.soft {
        border-radius: var(--radius-lg);
        border: 1px solid var(--glass-border);
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.96));
        padding: 16px 16px 4px;
        margin-bottom: 18px;
    }

    .table {
        background: #020617;
        border-radius: var(--radius-md);
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.35);
        color: var(--text-main);
        width: 100%;
        table-layout: fixed;
    }

    .table thead th {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.96));
        color: #e5e7eb !important;
        border: none;
        font-weight: 700;
        font-size: 0.82rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 14px 12px;
    }

    .table thead th:nth-child(1) { width: 35%; }
    .table thead th:nth-child(2) { width: 15%; }
    .table thead th:nth-child(3) { width: 20%; }
    .table thead th:nth-child(4) { width: 30%; }

    .table tbody td {
        border-color: rgba(148, 163, 184, 0.15);
        padding: 14px 12px;
        vertical-align: middle;
        color: var(--text-main);
    }

    .table tbody tr:hover {
        background: rgba(11, 94, 215, 0.08);
    }

    /* Total column in light background and black text */
    .total-intake-cell {
        background-color: #f3f4f6 !important;
        color: #000000 !important;
    }

    .total-intake {
        color: #000000 !important;
        font-weight: 600;
    }

    /* Editable input & select */
    .form-control,
    .form-select {
        border-radius: 999px;
        border: 1px solid var(--input-border);
        background: var(--input-bg-editable);
        color: #ffffff;
        font-size: 0.86rem;
        padding: 6px 12px;
        transition: all 0.18s ease-out;
        box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.95);
        width: 100%;
    }

    .form-control:hover,
    .form-select:hover {
        background: var(--input-bg-editable-hover);
        color: #ffffff;
    }

    .form-control::placeholder {
        color: rgba(148, 163, 184, 0.75);
    }

    .form-control:focus,
    .form-select:focus {
        border-color: var(--input-border-focus);
        outline: none;
        box-shadow: 0 0 0 1px rgba(56, 189, 248, 0.8), 0 0 0 4px rgba(15, 23, 42, 0.9);
        background: var(--input-bg-editable-hover);
        color: #ffffff;
    }

    /* Force white text for all input types */
    input[type="text"],
    input[type="number"],
    input[type="email"],
    input[type="password"],
    input[type="file"],
    textarea {
        color: #ffffff !important;
    }

    input[type="text"]:focus,
    input[type="number"]:focus,
    input[type="email"]:focus,
    input[type="password"]:focus,
    input[type="file"]:focus,
    textarea:focus {
        color: #ffffff !important;
    }

    /* Readonly fields (ExistingIntake etc.) */
    .form-control[readonly],
    input[readonly] {
        background: var(--input-bg-readonly);
        border-color: var(--input-border-readonly);
        color: #ffffff !important;
        cursor: default;
        box-shadow: none;
    }

    .form-control[readonly]:focus,
    input[readonly]:focus {
        box-shadow: none;
        border-color: var(--input-border-readonly);
        color: #ffffff !important;
    }

    /* File input */
    .form-control[type="file"] {
        padding: 8px 12px;
        cursor: pointer;
        background: linear-gradient(135deg, var(--primary-soft), var(--input-bg-readonly));
    }

    .form-control[type="file"]::-webkit-file-upload-button {
        border: none;
        border-radius: 999px;
        padding: 6px 14px;
        margin-right: 10px;
        background: linear-gradient(135deg, var(--primary), #0b3b80);
        color: #e5e7eb;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        font-weight: 600;
        cursor: pointer;
    }

    .text-danger {
        font-size: 0.75rem;
        margin-top: 3px;
        color: var(--danger) !important;
    }

    .btn-primary.modern {
        border-radius: 999px;
        border: 0;
        padding: 10px 30px;
        font-size: 0.88rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        background: linear-gradient(135deg, var(--primary), #0b3b80);
        color: #f9fafb;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 14px 32px rgba(11, 94, 215, 0.65);
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .btn-primary.modern:hover {
        box-shadow: 0 18px 40px rgba(11, 94, 215, 0.75);
        transform: translateY(-2px);
    }

    .btn-outline-secondary {
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, 0.6);
        color: var(--text-main);
        background: transparent;
        padding: 8px 24px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .btn-outline-secondary:hover {
        background: rgba(11, 94, 215, 0.15);
        border-color: var(--primary);
        color: var(--text-main);
    }

    .badge {
        font-size: 0.7rem;
        padding: 4px 8px;
    }

    .form-footer-note {
        margin-top: 10px;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-align: center;
    }

    .declaration-block {
        background: rgba(15, 23, 42, 0.95);
        border-radius: var(--radius-md);
        border: 1px solid var(--glass-border);
        color: #e5e7eb;
    }

    /* DataTables tweaks */
    table.dataTable thead th {
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.96));
        color: #e5e7eb;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button {
        color: #f9fafb !important;
    }

    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background: var(--primary) !important;
        color: #ffffff !important;
    }

    /* Saved data DataTable: black text, white course name */
    #savedIntakesTable,
    #savedIntakesTable th,
    #savedIntakesTable td {
        color: #000000 !important;
    }

    /* HEADER BACKGROUND COLOR ONLY FOR SAVED TABLE */
    #savedIntakesTable thead th {
        background: linear-gradient(135deg, var(--primary), #0b3b80);
        color: #ffffff !important;
        text-align: center;
    }

    #savedIntakesTable .course-name-cell .course-title {
        color: #ffffff !important;
    }

    #savedIntakesTable .total-intake-cell {
        background-color: #f3f4f6 !important;
        color: #000000 !important;
    }

    @@media (max-width: 768px) {
        .add-course-btn-container {
            bottom: 20px;
            right: 20px;
        }

        .add-course-btn {
            width: 56px;
            height: 56px;
            font-size: 1.4rem;
        }

        .add-course-tooltip {
            font-size: 0.75rem;
            padding: 8px 12px;
            bottom: 64px;
        }

        .institution-form-shell {
            padding-bottom: 120px;
        }

        .course-name-cell {
            min-width: 220px !important;
            font-size: 0.9rem !important;
        }
    }
</style>

<script>
    function recalcTotal(row) {
        var existingInput = row.querySelector('.existing-intake');
        var additionalInput = row.querySelector('.additional-intake');
        var totalSpan = row.querySelector('.total-intake');

        var existing = parseInt(existingInput.value || "0");
        var additional = parseInt(additionalInput.value || "0");
        totalSpan.textContent = existing + additional;
    }

    function wireTotals(sectionId) {
        var section = document.getElementById(sectionId);
        if (!section) return;

        section.querySelectorAll('tbody tr').forEach(function (row) {
            var existing = row.querySelector('.existing-intake');
            var additional = row.querySelector('.additional-intake');
            if (existing) existing.addEventListener('input', function () { recalcTotal(row); });
            if (additional) additional.addEventListener('input', function () { recalcTotal(row); });
            recalcTotal(row);
        });
    }

    function openCourseModal() {
        window.location.href = '@Url.Action("AddCourse", "LatestMedicalAffiliation")';
    }

    $(document).ready(function () {
        wireTotals('ug-section');
        wireTotals('pg-section');
        wireTotals('ss-section');

        // DataTable for saved data with horizontal scroll and fixed widths
        $('#savedIntakesTable').DataTable({
            pageLength: 10,
            lengthChange: false,
            order: [],        // keep UG -> PG -> SS order from server
            scrollX: true,
            autoWidth: false,
            columnDefs: [
                { width: "8%",  targets: 0 }, // Level
                { width: "32%", targets: 1 }, // Course Name
                { width: "20%", targets: 2 }, // Existing Intake
                { width: "20%", targets: 3 }, // Additional Intake
                { width: "20%", targets: 4 }  // Total Intake
            ]
        });
    });
</script>

